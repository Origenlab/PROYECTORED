---
// ─────────────────────────────────────────────────────────────────────────────
// Base.astro — Layout raíz unificado del sitio
// Usado directamente por L1/L2/L3/L4 y por CategoryLayout (vía BaseLayout).
// Responsabilidades:
//   · HTML shell (head, meta, hreflang, canonical, Open Graph, Twitter)
//   · Preload tipografía Inter (sin bloquear render)
//   · Preconnect CDN ExactDN
//   · JSON-LD LocalBusiness global (desde src/lib/seo.ts)
//   · Slot nombrado "head" para schemas/meta por página
//   · Soporte noindex (para 404, gracias, drafts)
// ─────────────────────────────────────────────────────────────────────────────

import '../styles/global.css'
import '../styles/components.css' // complemento titulo-duo + section-header
import TopBar         from '../components/global/TopBar.astro'
import Header         from '../components/global/Header.astro'
import Footer         from '../components/global/Footer.astro'
import WhatsAppButton from '../components/global/WhatsAppButton.astro'
import { SITE }       from '../config/site'
import { localBusinessLd } from '../lib/seo'

interface Props {
  title: string
  description: string
  canonical?: string
  ogImage?: string
  noindex?: boolean
}

const {
  title,
  description,
  canonical,
  ogImage,
  noindex = false,
} = Astro.props

const canonicalURL = canonical || new URL(Astro.url.pathname, SITE.url).href
const ogImageAbs = ogImage
  ? (ogImage.startsWith('http') ? ogImage : new URL(ogImage, SITE.url).href)
  : new URL('/imagenes/og/proyectored-og.jpg', SITE.url).href
---
<!doctype html>
<html lang="es-MX">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light only" />
  <meta name="generator" content={Astro.generator} />

  <!-- SEO primario -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  {noindex
    ? <meta name="robots" content="noindex,nofollow" />
    : <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
  }

  <!-- hreflang (sitio único es-MX) -->
  <link rel="alternate" hreflang="es-mx" href={canonicalURL} />
  <link rel="alternate" hreflang="x-default" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={SITE.name} />
  <meta property="og:locale" content={SITE.locale} />
  <meta property="og:image" content={ogImageAbs} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageAbs} />

  <!-- Favicons (fuente única: SVG moderno + ICO/PNG fallback) -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate icon" type="image/png" href="/favicon.png" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Preconnect CDN de imágenes (ExactDN / EWWW.io) -->
  <link rel="preconnect" href="https://ewvydcs5uyw.exactdn.com" crossorigin />
  <link rel="dns-prefetch" href="https://ewvydcs5uyw.exactdn.com" />

  <!-- Tipografía Inter — preload no-bloqueante con fallback noscript -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
  />
  <noscript>
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </noscript>

  <!-- JSON-LD: LocalBusiness (global, todas las páginas) -->
  <script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessLd)} />

  <!-- Slot para JSON-LD adicional (FAQ, Breadcrumb, Product, Article, etc.) -->
  <slot name="head" />

  <!-- TruConversion — heatmaps/session recording -->
  <script type="text/javascript" is:inline>
    var _tip = _tip || [];
    (function(d,s,id){
        var js, tjs = d.getElementsByTagName(s)[0];
        if(d.getElementById(id)) { return; }
        js = d.createElement(s); js.id = id;
        js.async = true;
        js.src = d.location.protocol + '//app.truconversion.com/ti-js/62910/efa5e.js';
        tjs.parentNode.insertBefore(js, tjs);
    }(document, 'script', 'ti-js'));
  </script>
</head>
<body>
  <TopBar />
  <Header />
  <main id="main-content">
    <!--
      REGLA DE LAYOUT — válida para todas las páginas del sitio:
      ─────────────────────────────────────────────────────────
      Entre el componente Hero y el CtaBar NO va ninguna sección.
      El orden siempre es:  breadcrumb-bar → <Hero> → <CtaBar> → resto de secciones.
    -->
    <slot />
  </main>
  <Footer />
  <WhatsAppButton />
</body>
</html>

<style is:global>
  :root {
    color-scheme: light only;
    /* Colores principales */
    --c-primary:       #C41E24;
    --c-primary-dark:  #A01820;
    --c-primary-light: #F9E8E8;
    --c-primary-rgb:   196, 30, 36;

    /* Negros y grises (Zinc) */
    --c-ink:    #111111;
    --c-ink-2:  #27272A;
    --c-muted:  #71717A;
    --c-border: #E4E4E7;
    --c-surface:#F4F4F5;
    --c-white:  #FFFFFF;

    /* Tipografía — Inter como estándar del sitio */
    --font-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;

    /* Spacing */
    --topbar-height: 36px;
    --header-height: 88px;
    --stack-height: calc(var(--topbar-height) + var(--header-height));
    --max-w: 1400px;
    --section-py: 5rem;

    /* Sombras tintadas */
    --shadow-sm:  0 1px 3px rgba(var(--c-primary-rgb), 0.08);
    --shadow-md:  0 4px 16px rgba(var(--c-primary-rgb), 0.12);
    --shadow-lg:  0 8px 32px rgba(var(--c-primary-rgb), 0.16);
    --shadow-ink: 0 4px 16px rgba(17, 17, 17, 0.1);
  }

  *, *::before, *::after {
    margin: 0; padding: 0;
    box-sizing: border-box;
  }

  html, body { overflow-x: hidden; }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }

  body {
    font-family: var(--font-sans);
    color: var(--c-ink);
    background: var(--c-white);
    line-height: 1.6;
  }

  img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  a {
    color: var(--c-primary);
    text-decoration: none;
  }

  a:hover { color: var(--c-primary-dark); }

  @media (max-width: 640px) {
    :root {
      --topbar-height: 32px;
      --stack-height: calc(32px + var(--header-height));
    }
  }

  .container {
    width: 100%;
    max-width: var(--max-w);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Botones globales */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--c-primary);
    color: #fff;
    padding: 0.875rem 1.75rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.9375rem;
    font-family: var(--font-sans);
    transition: background-color 0.2s;
    border: none;
    cursor: pointer;
    white-space: nowrap;
  }
  .btn-primary:hover { background: var(--c-primary-dark); color: #fff; }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 2px solid rgba(255,255,255,0.35);
    color: #fff;
    padding: 0.8125rem 1.75rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.9375rem;
    font-family: var(--font-sans);
    cursor: pointer;
    white-space: nowrap;
  }
  .btn-secondary:hover { border-color: #fff; background: rgba(255,255,255,0.08); color: #fff; }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 2px solid var(--c-primary);
    color: var(--c-primary);
    padding: 0.8125rem 1.75rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.9375rem;
    font-family: var(--font-sans);
    cursor: pointer;
    white-space: nowrap;
  }
  .btn-outline:hover { background: var(--c-primary); color: #fff; }

  /* Focus visible — accesibilidad teclado */
  .btn-primary:focus-visible,
  .btn-secondary:focus-visible,
  .btn-outline:focus-visible {
    outline: 2px solid var(--c-primary);
    outline-offset: 2px;
  }

  a:focus-visible {
    outline: 2px solid var(--c-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Skip link — accesibilidad teclado */
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 9999;
    background: var(--c-primary);
    color: #fff;
    padding: 0.75rem 1rem;
    font-weight: 600;
  }
  .skip-link:focus { left: 0; }

  /* ══════════════════════════════════════════════════
     Estilos de páginas → src/styles/pages.css
     Estilos de componentes → src/styles/components.css
     NO duplicar aquí. Solo tokens, resets y utilidades.
  ══════════════════════════════════════════════════ */
</style>
