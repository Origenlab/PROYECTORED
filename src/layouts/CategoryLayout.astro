---
// CategoryLayout.astro
// Layout para todas las páginas de Nivel 2
// Incluye: Hero + QuickLinks + StatsBar + slot(contenido único) + CotizacionForm + FAQ + CTAFinal

import BaseLayout from './BaseLayout.astro'
import Hero from '../components/sections/Hero.astro'
import QuickLinks from '../components/sections/QuickLinks.astro'
import StatsBar from '../components/sections/StatsBar.astro'
import CotizacionForm from '../components/sections/CotizacionForm.astro'
import FAQ from '../components/sections/FAQ.astro'
import CTAFinal from '../components/sections/CTAFinal.astro'

// Tipos reutilizables
export interface BreadcrumbItem {
  label: string
  href?: string
}

export interface Stat {
  value: string
  label: string
}

export interface FAQItem {
  question: string
  answer: string
}

export interface HeroCTA {
  text: string
  href: string
  variant?: 'primary' | 'outline'
}

interface Props {
  // SEO
  title: string
  description?: string
  canonical?: string

  // Hero
  badge: string
  heroTitle: string
  heroAccent: string
  heroSubtitle: string
  heroDescRight: string[]
  cta1: HeroCTA
  cta2: HeroCTA
  breadcrumb: BreadcrumbItem[]

  // Stats
  stats: Stat[]

  // Secciones opcionales
  showForm?: boolean
  faqItems?: FAQItem[]
  faqTitle?: string

  // CTA Final
  ctaTitle?: string
  ctaBody?: string
  ctaCTA1Text?: string
  ctaCTA1Href?: string
  ctaCTA2Text?: string
  ctaCTA2Href?: string
}

import { SITE } from '../config/site'

const {
  title,
  description,
  canonical,
  badge,
  heroTitle,
  heroAccent,
  heroSubtitle,
  heroDescRight,
  cta1,
  cta2,
  breadcrumb,
  stats,
  showForm = true,
  faqItems,
  faqTitle,
  ctaTitle = '¿Necesitas equipo contra incendios en CDMX?',
  ctaBody = 'Mándanos un WhatsApp con lo que necesitas. Te respondemos con precios, disponibilidad y tiempos de entrega.',
  ctaCTA1Text = 'Cotizar por WhatsApp',
  ctaCTA1Href,
  ctaCTA2Text = 'Ver catálogo completo',
  ctaCTA2Href = '/productos/',
} = Astro.props

// ── JSON-LD: BreadcrumbList ───────────────────────────────────────────────────
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumb.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.label,
    ...(item.href ? { item: `${SITE.url}${item.href}` } : {}),
  })),
}

// ── JSON-LD: FAQPage (solo si hay preguntas) ──────────────────────────────────
const faqLd = faqItems && faqItems.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqItems.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    }
  : null
---

<BaseLayout {title} {description} {canonical}>
  <!-- JSON-LD adicional (BreadcrumbList + FAQPage) en <head> -->
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    {faqLd && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(faqLd)} />
    )}
  </Fragment>

  <!-- Hero de página -->
  <Hero
    {badge}
    title={heroTitle}
    accent={heroAccent}
    subtitle={heroSubtitle}
    descRight={heroDescRight}
    {cta1}
    {cta2}
    {breadcrumb}
  />

  <!-- Accesos rápidos (idéntico en todas las páginas) -->
  <QuickLinks />

  <!-- Barra de métricas -->
  <StatsBar {stats} />

  <!-- Contenido único de cada página -->
  <slot />

  <!-- Formulario de cotización (opcional) -->
  {showForm && <CotizacionForm />}

  <!-- FAQ (opcional, si se pasan items) -->
  {faqItems && faqItems.length > 0 && (
    <FAQ items={faqItems} title={faqTitle} />
  )}

  <!-- CTA de cierre -->
  <CTAFinal
    title={ctaTitle}
    body={ctaBody}
    cta1Text={ctaCTA1Text}
    cta1Href={ctaCTA1Href ?? cta1.href}
    cta2Text={ctaCTA2Text}
    cta2Href={ctaCTA2Href}
  />
</BaseLayout>
