---
// ─────────────────────────────────────────────────────────────────────────────
// BaseLayout.astro
// Alias semántico de Base.astro — mantenido por compatibilidad con páginas que
// lo importan explícitamente (404.astro, CategoryLayout.astro).
// Toda la lógica real vive en Base.astro para tener una sola fuente de verdad.
// ─────────────────────────────────────────────────────────────────────────────

import Base from './Base.astro'
import { SITE } from '../config/site'

interface Props {
  title: string
  description?: string
  canonical?: string
  ogImage?: string
  noindex?: boolean
}

const {
  title,
  description = SITE.description,
  canonical,
  ogImage,
  noindex = false,
} = Astro.props

// Comportamiento legacy: si el title no incluye "Proyecto Red" lo sufijamos
const pageTitle = title.includes(SITE.name) ? title : `${title} | ${SITE.name}`
---

<Base
  title={pageTitle}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  noindex={noindex}
>
  <Fragment slot="head">
    <slot name="head" />
  </Fragment>
  <slot />
</Base>
