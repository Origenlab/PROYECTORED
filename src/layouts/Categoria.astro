---
import Base from './Base.astro';
import Hero from '../components/Hero.astro';

interface Props {
  title: string;
  description: string;
  heroTitle: string;
  heroSubtitle?: string;
}

const { title, description, heroTitle, heroSubtitle } = Astro.props;
---
<Base title={title} description={description}>
  <Hero title={heroTitle} subtitle={heroSubtitle || "Protegiendo tu seguridad, defendiendo tu futuro."} cta="Cotizar por WhatsApp" ctaLink="https://wa.me/525537238544?text=Hola%2C%20quiero%20información%20sobre%20sus%20productos" />
  <section class="categoria-content">
    <div class="container">
      <slot />
    </div>
  </section>
  <section class="cta-final">
    <div class="container">
      <h2>¿Necesitas asesoría personalizada?</h2>
      <p>Contáctanos por WhatsApp y uno de nuestros especialistas te atenderá de inmediato.</p>
      <a href="https://wa.me/525537238544?text=Hola%2C%20quiero%20información" class="btn-cta">Contactar por WhatsApp</a>
    </div>
  </section>
</Base>

<style>
  .categoria-content {
    padding: 3rem 0;
  }

  .cta-final {
    background-color: var(--color-black);
    color: var(--color-white);
    text-align: center;
    padding: 4rem 0;
  }

  .cta-final h2 {
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .cta-final p {
    margin-bottom: 2rem;
    color: var(--color-gray-light);
  }

  .btn-cta {
    display: inline-block;
    background-color: #25D366;
    color: #fff;
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1.1rem;
    transition: background-color 0.2s;
  }

  .btn-cta:hover {
    background-color: #1da851;
    color: #fff;
  }
</style>
