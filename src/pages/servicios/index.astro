---
/**
 * servicios.astro — Página de servicios de Proyecto Red
 * ─────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO.
 * Mismo patrón que productos.astro — cada sección es un componente autónomo.
 */

import Base                from '../../layouts/Base.astro'
import Breadcrumb          from '../../components/ui/Breadcrumb.astro'
import CtaBar              from '../../components/CtaBar.astro'

// ── Secciones de Servicios ──────────────────────────
import HeroServicios       from '../../components/sections/HeroServicios.astro'
import CatalogoServicios   from '../../components/sections/CatalogoServicios.astro'
import SeleccionIndex      from '../../components/sections/SeleccionIndex.astro'
import NormasIndex         from '../../components/sections/NormasIndex.astro'
import ProcesoIndex        from '../../components/sections/ProcesoIndex.astro'
import FaqCotizacionIndex  from '../../components/sections/FaqCotizacionIndex.astro'
import CTAFinalIndex       from '../../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ──────────────────────────────
import { SITE, CONTACT } from '../../config/site'

const siteUrl   = SITE.url
const pageUrl   = `${siteUrl}/servicios/`
const ogImage   = `${siteUrl}/imagenes/og/proyectored-og.jpg`

// ── Schema: BreadcrumbList ──────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Servicios",
      "item": pageUrl
    }
  ]
}

// ── Schema: OfferCatalog ────────────────────────────
const schemaOfferCatalog = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "Servicios de Protección Contra Incendios — Proyecto Red",
  "description": "Servicios profesionales de protección contra incendios: venta de equipos, recarga de extintores, mantenimiento preventivo, instalación de sistemas CI, prueba hidrostática, asesoría técnica, capacitación DC-3 y señalización NOM en CDMX y Estado de México.",
  "url": pageUrl,
  "numberOfItems": 8,
  "itemListElement": [
    { "@type": "OfferCatalog", "name": "Venta de Equipos Contra Incendios certificados NOM y NFPA", "url": `${siteUrl}/servicios/venta-equipos/` },
    { "@type": "OfferCatalog", "name": "Recarga de Extintores NOM-154-SCFI",                       "url": `${siteUrl}/servicios/recarga-extintores/` },
    { "@type": "OfferCatalog", "name": "Mantenimiento Preventivo con póliza anual",                "url": `${siteUrl}/servicios/mantenimiento-preventivo/` },
    { "@type": "OfferCatalog", "name": "Instalación de Sistemas Contra Incendio NFPA 13/72",       "url": `${siteUrl}/servicios/instalacion-sistemas/` },
    { "@type": "OfferCatalog", "name": "Prueba Hidrostática NOM-154-SCFI",                         "url": `${siteUrl}/servicios/prueba-hidrostatica/` },
    { "@type": "OfferCatalog", "name": "Asesoría Técnica y Dictamen sin costo",                    "url": `${siteUrl}/servicios/asesoria-tecnica/` },
    { "@type": "OfferCatalog", "name": "Capacitación y Formación de Brigadas DC-3 STPS",           "url": `${siteUrl}/servicios/capacitacion/` },
    { "@type": "OfferCatalog", "name": "Señalización e Instalación NOM-003-SEGOB",                 "url": `${siteUrl}/servicios/senalizacion/` },
  ]
}

// ── Schema: FAQPage ─────────────────────────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cada cuánto tiempo se deben recargar los extintores?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La NOM-154-SCFI indica que los extintores deben recargarse cada año o después de cada uso parcial o total. Además, cada 5 años es obligatoria la prueba hidrostática para verificar la integridad del cilindro. En Proyecto Red te recordamos las fechas de vencimiento y programamos el servicio para que nunca tengas equipo fuera de norma."
      }
    },
    {
      "@type": "Question",
      "name": "¿La recarga incluye certificado NOM para Protección Civil?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Cada recarga incluye collar de garantía, etiqueta de servicio actualizada y ficha técnica para tu expediente de Protección Civil. La documentación cumple con la NOM-154-SCFI y es aceptada en inspecciones de STPS y Protección Civil sin observaciones."
      }
    },
    {
      "@type": "Question",
      "name": "¿Ofrecen mantenimiento preventivo con póliza anual?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Ofrecemos pólizas anuales de mantenimiento que incluyen inspecciones programadas, reporte técnico documentado, actualización de etiquetas y bitácoras. Las pólizas tienen precio preferencial comparado con servicio por evento y garantizan que siempre estés preparado para una auditoría."
      }
    },
    {
      "@type": "Question",
      "name": "¿Las capacitaciones incluyen constancias con validez oficial?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Todas nuestras capacitaciones incluyen constancias DC-3 válidas ante la STPS. Los cursos cubren uso de extintores, formación de brigadas, evacuación y primeros auxilios. Se imparten en tus instalaciones con equipo real y escenarios prácticos."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta una asesoría técnica para saber qué equipo necesito?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La asesoría técnica es completamente gratuita y sin compromiso. Evaluamos tu instalación, tipo de riesgo, superficie y normativas aplicables. Te entregamos un plan de equipamiento con prioridades y presupuesto por etapas para que puedas ir cumpliendo a tu ritmo."
      }
    },
    {
      "@type": "Question",
      "name": "¿Atienden empresas fuera de CDMX y Estado de México?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nuestra cobertura principal es la Ciudad de México y el Estado de México. Para empresas fuera de esta zona podemos coordinar envíos de productos por paquetería y, en proyectos de cierto volumen, desplazar equipos de instalación y capacitación."
      }
    }
  ]
}
---

<Base
  title="Servicios de Equipos Contra Incendios en CDMX | Proyecto Red"
  description="Servicios profesionales de protección contra incendios: venta de equipos, recarga de extintores, mantenimiento preventivo, instalación de sistemas CI, prueba hidrostática, capacitación DC-3 y señalización NOM. CDMX y Estado de México."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <!-- ── Barra de migas de pan ────────────────────────────── -->
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Servicios' }
  ]} />

  <!-- ── Secciones ──────────────────────────────────────── -->
  <HeroServicios />
  <CtaBar />
  <CatalogoServicios />
  <SeleccionIndex />
  <NormasIndex />
  <ProcesoIndex />
  <FaqCotizacionIndex />
  <CTAFinalIndex />

  <!-- ── Datos estructurados JSON-LD ──────────────────────
       Inyectados al final del <body> para no bloquear render
  ─────────────────────────────────────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaOfferCatalog)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

</Base>
