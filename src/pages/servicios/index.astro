---
// /servicios/ — Servicios de protección contra incendios
import CategoryLayout from '../../layouts/CategoryLayout.astro'
import SectionHeader from '../../components/ui/SectionHeader.astro'
import { SERVICES, waUrl } from '../../config/site'

const PAGE_WA = waUrl('Hola, necesito información sobre sus servicios')

const stats = [
  { value: '8',    label: 'Servicios especializados' },
  { value: 'NOM',  label: 'Normativa certificada'    },
  { value: '<24h', label: 'Tiempo de respuesta'      },
  { value: 'DC-3', label: 'Constancias STPS'         },
]

const faqItems = [
  {
    question: '¿Con qué frecuencia debo recargar un extintor?',
    answer: 'La NOM-154-SCFI establece mantenimiento anual obligatorio para todos los extintores. La prueba hidrostática se realiza cada 5 años. Te ayudamos a llevar el control con pólizas de mantenimiento preventivo y reportes para tu expediente.',
  },
  {
    question: '¿Qué incluye el servicio de mantenimiento preventivo?',
    answer: 'Revisión del agente extintor, verificación de presión, inspección de manguera y boquilla, revisión del seguro y pin, actualización de etiqueta de inspección y emisión de reporte para tu expediente de Protección Civil.',
  },
  {
    question: '¿Cuánto tiempo tarda la instalación de un sistema contra incendio?',
    answer: 'Depende del alcance. Detectores y alarmas para una oficina mediana: 1-2 días hábiles. Sistema de rociadores NFPA 13 para planta industrial: 1-3 semanas. Te damos un cronograma exacto en la cotización.',
  },
  {
    question: '¿Las constancias de capacitación son válidas ante la STPS?',
    answer: 'Sí. Generamos constancias DC-3 que son el documento oficial reconocido por la STPS para acreditar la capacitación de brigadas de emergencia ante cualquier auditoría laboral.',
  },
  {
    question: '¿La asesoría técnica tiene costo?',
    answer: 'No, el diagnóstico inicial es completamente gratuito. Evaluamos tu instalación, te decimos exactamente qué equipo necesitas según la normativa aplicable y te entregamos una cotización detallada sin compromiso.',
  },
]
---

<CategoryLayout
  title="Servicios de Equipos Contra Incendios en CDMX | Proyecto Red"
  description="Recarga, mantenimiento, instalación de sistemas CI, prueba hidrostática, capacitación y señalización NOM. Todo en un solo proveedor en CDMX."
  badge="Servicios profesionales certificados"
  heroTitle="Servicios de Protección Contra"
  heroAccent="Incendios"
  heroSubtitle="Venta, recarga, mantenimiento, instalación, capacitación y señalización. Todo lo que tu empresa necesita para cumplir con Protección Civil y STPS en CDMX y Estado de México."
  heroDescRight={[
    'En Proyecto Red no solo vendemos equipos — ofrecemos protección integral contra incendios. Desde la asesoría técnica inicial hasta la capacitación de tu personal, nos encargamos de que tu empresa tenga el equipo correcto, funcionando y documentado para cualquier inspección.',
    'Todos nuestros servicios cumplen con la normativa mexicana vigente: NOM-002-STPS, NOM-154-SCFI, NOM-003-SEGOB y estándares NFPA. Un solo proveedor para todo — sin buscar entre cinco empresas diferentes.',
  ]}
  cta1={{ text: 'Solicitar cotización', href: PAGE_WA }}
  cta2={{ text: 'Ver todos los servicios', href: '#servicios' }}
  breadcrumb={[{ label: 'Inicio', href: '/' }, { label: 'Servicios' }]}
  {stats}
  faqItems={faqItems}
  ctaTitle="¿Necesitas alguno de nuestros servicios?"
  ctaBody="Mándanos un WhatsApp con lo que necesitas. Te respondemos con precio, disponibilidad y tiempo de ejecución en menos de 24 horas."
  ctaCTA1Text="Cotizar por WhatsApp"
  ctaCTA1Href={PAGE_WA}
  ctaCTA2Text="Ver catálogo de productos"
  ctaCTA2Href="/productos/"
>

  <!-- =====================================================
       CONTENIDO ÚNICO: 8 tarjetas de servicio
       ===================================================== -->
  <section id="servicios" class="servicios section">
    <div class="container">
      <SectionHeader
        eyebrow="Servicios profesionales"
        titleLine1="Más que productos:"
        titleLine2="protección integral"
        desc="Venta, recarga, mantenimiento, instalación, capacitación y asesoría. Todo desde un solo proveedor para que tu empresa siempre esté protegida y en norma."
      />

      <div class="servicios__grid">
        {SERVICES.map((svc) => (
          <div class="servicio-card" id={svc.id}>
            <div class="servicio-card__body">
              <h3 class="servicio-card__title">{svc.label}</h3>
              <p class="servicio-card__desc">{svc.desc}</p>
            </div>
            <a
              href={waUrl(`Hola, necesito información sobre: ${svc.label}`)}
              class="servicio-card__cta"
              target="_blank"
              rel="noopener noreferrer"
            >
              Cotizar →
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

</CategoryLayout>

<style>
  .servicios__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--sp-5);
  }

  .servicio-card {
    background: var(--color-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  }

  .servicio-card:hover {
    border-color: var(--color-red);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .servicio-card__body { flex: 1; }

  .servicio-card__title {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-gray-900);
    margin-bottom: var(--sp-2);
    line-height: var(--leading-snug);
  }

  .servicio-card__desc {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    line-height: var(--leading-relaxed);
  }

  .servicio-card__cta {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-red);
    transition: opacity var(--transition);
  }

  .servicio-card__cta:hover { opacity: 0.7; }
</style>
