---
// src/pages/equipo-seguridad/[producto].astro
// Páginas de Nivel 4 — Equipo de Seguridad Industrial (EPP)
// Genera: /equipo-seguridad/proteccion-craneal/,
//         /equipo-seguridad/proteccion-visual/,
//         /equipo-seguridad/proteccion-respiratoria/,
//         /equipo-seguridad/proteccion-manos/,
//         /equipo-seguridad/trabajo-alturas/,
//         /equipo-seguridad/proteccion-auditiva/

import CategoryLayout from '../../layouts/CategoryLayout.astro'
import SectionHeader from '../../components/ui/SectionHeader.astro'
import SectionHeaderDuo from '../../components/ui/SectionHeaderDuo.astro'
import { waUrl, SERVICES } from '../../config/site'
import { EQUIPO_SEGURIDAD_PAGES, EQUIPO_SEGURIDAD_PRODUCTS } from '../../data/equipo-seguridad-productos'
import '../../styles/product-page.css'

// Servicios más relevantes para esta categoría
const RELATED_SERVICES = SERVICES.filter((s) =>
  ['capacitacion', 'asesoria-tecnica', 'venta-equipos'].includes(s.id)
)

// ── Rutas estáticas ──────────────────────────────────────────
export function getStaticPaths() {
  return EQUIPO_SEGURIDAD_PRODUCTS.map((p) => ({
    params: { producto: p.slug },
    props: { slug: p.slug },
  }))
}

const { producto } = Astro.params
const data = EQUIPO_SEGURIDAD_PAGES[producto]

if (!data) {
  return Astro.redirect('/equipo-seguridad/')
}

// Productos relacionados (los demás, excluyendo el actual)
const related = EQUIPO_SEGURIDAD_PRODUCTS.filter((p) => p.slug !== producto)

const PAGE_WA = waUrl(data.waMessage)

// ── Helper: ¿tiene variantes este producto? ──────────────────
const hasVariantes = Boolean(data.variantes && data.variantes.length > 0)

// ── Helper: desc corta para la sección de variantes ──────────
const getVariantesDesc = (): string => {
  const n = data.variantes?.length ?? 0
  return `${n} opciones disponibles de ${data.heroAccent} con certificación NOM y stock permanente en CDMX.`
}
---

<CategoryLayout
  title={data.metaTitle}
  description={data.metaDesc}
  badge={data.badge}
  heroTitle={data.heroTitle}
  heroAccent={data.heroAccent}
  heroSubtitle={data.heroSubtitle}
  heroDescRight={data.heroDescRight}
  cta1={{ text: 'Cotizar por WhatsApp', href: PAGE_WA }}
  cta2={{ text: 'Ver todo el equipo de seguridad', href: '/equipo-seguridad/' }}
  breadcrumb={[
    { label: 'Inicio',                       href: '/'                   },
    { label: 'Productos',                    href: '/productos/'          },
    { label: 'Equipo de Seguridad Industrial', href: '/equipo-seguridad/' },
    { label: data.heroAccent },
  ]}
  showForm={true}
  faqItems={data.faqItems}
  ctaTitle={data.ctaTitle}
  ctaBody={data.ctaBody}
  ctaCTA1Text="Cotizar por WhatsApp"
  ctaCTA1Href={PAGE_WA}
  ctaCTA2Text="Ver todo el equipo de seguridad"
  ctaCTA2Href="/equipo-seguridad/"
>

  <!-- ===========================================================
       SECCIÓN 0 — Variantes / Modelos disponibles (opcional)
       Solo se renderiza si el producto tiene variantes definidas.
       =========================================================== -->
  {hasVariantes && (
    <section class="cat-section cat-section--white" id="variantes">
      <div class="container">
        <SectionHeaderDuo
          eyebrow={data.variantesEyebrow ?? 'Opciones disponibles'}
          titleLine1={data.variantesTitleLine1 ?? 'Modelos disponibles'}
          titleLine2={data.variantesTitleLine2}
          desc={getVariantesDesc()}
          bodyPara1={data.variantesBodyPara ?? 'Todos los equipos cumplen con la NOM-017-STPS y están disponibles con documentación técnica completa para tu expediente de seguridad.'}
        />
        <div class="catidx-grid" role="list" aria-label={`Opciones de ${data.heroAccent}`}>
          {data.variantes?.map((v, i) => (
            <article class="ccard ccard--tipo" role="listitem" aria-label={v.nombre}>
              <div class="ccard__content">
                {v.badge && <span class="ccard__badge ccard__badge--top">{v.badge}</span>}
                <h3 class="ccard__title">{v.nombre}</h3>
                <p class="ccard__desc">{v.desc}</p>
                {v.specs && <p class="ccard__specs">{v.specs}</p>}
                <a href={waUrl(v.waText)} class="ccard__cta" target="_blank" rel="noopener noreferrer">
                  Cotizar este equipo
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>
            </article>
          ))}
          <article class="ccard ccard--cta-wa" aria-label="Asesoría para elegir equipo">
            <a href={PAGE_WA} class="ccard--cta-wa__inner" target="_blank" rel="noopener noreferrer">
              <div class="ccard--cta-wa__icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <p class="ccard--cta-wa__title">¿No encuentras lo que necesitas?</p>
              <p class="ccard--cta-wa__sub">Cotiza directo por WhatsApp — te asesoramos sin costo.</p>
              <span class="ccard--cta-wa__btn">Enviar mensaje →</span>
            </a>
          </article>
        </div>
      </div>
    </section>
  )}

  <!-- ===========================================================
       BLOQUE 1 — Características técnicas
       Fondo: --gray si hay variantes (S0=white antes), --white si no.
       =========================================================== -->
  <section class={`prod-section section ${hasVariantes ? 'prod-section--light' : ''}`} id="caracteristicas">
    <div class="container">

      <SectionHeader
        eyebrow={data.caracteristicas.eyebrow}
        titleLine1={data.caracteristicas.titleLine1}
        titleLine2={data.caracteristicas.titleLine2}
        desc={data.caracteristicas.desc}
      />

      <div class="features-grid">
        {data.caracteristicas.items.map((item) => (
          <div class="feature-card">
            <div class="feature-card__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div class="feature-card__body">
              <h3 class="feature-card__title">{item.title}</h3>
              <p class="feature-card__desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA inline -->
      <div class="inline-cta">
        <p class="inline-cta__text">¿Necesitas dotar a tu personal con EPP correcto? Te asesoramos en la selección según la NOM-017-STPS.</p>
        <a
          href={PAGE_WA}
          class="btn btn--red"
          target="_blank"
          rel="noopener noreferrer"
        >
          Solicitar asesoría EPP
        </a>
      </div>

    </div>
  </section>

  <!-- ===========================================================
       BLOQUE 2 — ¿Cuándo usar?
       =========================================================== -->
  <section class="prod-section prod-section--light section--sm" id="cuando-usar">
    <div class="container">

      <SectionHeader
        eyebrow={data.cuandoUsar.eyebrow}
        titleLine1={data.cuandoUsar.titleLine1}
        titleLine2={data.cuandoUsar.titleLine2}
        desc={data.cuandoUsar.desc}
      />

      <div class="usos-grid">
        {data.cuandoUsar.usos.map((uso) => (
          <div class="uso-item">
            <div class="uso-item__dot" aria-hidden="true"></div>
            <div class="uso-item__body">
              <h3 class="uso-item__label">{uso.label}</h3>
              <p class="uso-item__desc">{uso.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ===========================================================
       BLOQUE 3 — Servicios relacionados
       =========================================================== -->
  <section class="prod-section section--sm" id="servicios-epp">
    <div class="container">
      <div class="svc-header">
        <p class="svc-header__label">Servicios disponibles para tu programa de seguridad</p>
        <a href="/servicios/" class="svc-header__link">Ver todos los servicios →</a>
      </div>
      <div class="svc-grid">
        {RELATED_SERVICES.map((svc) => (
          <a href={`/servicios/#${svc.id}`} class="svc-card">
            <span class="svc-card__name">{svc.label}</span>
            <span class="svc-card__desc">{svc.desc}</span>
            <span class="svc-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===========================================================
       BLOQUE 4 — Otros EPP del catálogo
       =========================================================== -->
  <section class="prod-section section--sm">
    <div class="container">

      <div class="related-header">
        <p class="related-header__label">{data.relatedTitle}:</p>
        <a href="/equipo-seguridad/" class="related-header__link">Ver todo el equipo →</a>
      </div>

      <div class="related-grid">
        {related.map((r) => (
          <a href={`/equipo-seguridad/${r.slug}/`} class="related-card">
            <span class="related-card__label">{r.label}</span>
            <span class="related-card__badge">{r.badge}</span>
          </a>
        ))}
      </div>

    </div>
  </section>

</CategoryLayout>

<!-- Estilos compartidos en src/styles/product-page.css (importado en frontmatter) -->
