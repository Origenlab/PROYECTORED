---
/**
 * equipo-seguridad/index.astro — L3 Equipo de Seguridad Industrial
 * ─────────────────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO + JSON-LD de nivel técnico.
 * Estructura 100% homologada con extintores/index.astro (L3 template autorizado).
 * Cada sección vive en src/components/sections/ con sus propios estilos.
 */

import Base                    from '../../layouts/Base.astro'
import CtaBar                  from '../../components/CtaBar.astro'
import Breadcrumb              from '../../components/ui/Breadcrumb.astro'

// ── Secciones específicas de equipo seguridad ─────────────
import HeroEquipoSeguridad     from '../../components/sections/HeroEquipoSeguridad.astro'
import CatalogoEquipoSeguridad from '../../components/sections/CatalogoEquipoSeguridad.astro'
import GuiaEquipoSeguridad     from '../../components/sections/GuiaEquipoSeguridad.astro'
import NormasEquipoSeguridad   from '../../components/sections/NormasEquipoSeguridad.astro'
import FaqEquipoSeguridad      from '../../components/sections/FaqEquipoSeguridad.astro'

// ── Secciones genéricas reutilizadas ───────────────────────
import TrustIndex              from '../../components/sections/TrustIndex.astro'
import CategoriasRelacionadas  from '../../components/sections/CategoriasRelacionadas.astro'
import CTAFinalIndex           from '../../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ─────────────────────────────────────
import { SITE, CONTACT } from '../../config/site'

const siteUrl = SITE.url
const pageUrl = `${siteUrl}/equipo-seguridad/`
const ogImage = `${siteUrl}/imagenes/og/equipo-seguridad-og.jpg`

// ── Schema: ItemList — 8 productos ────────────────────────
const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Equipo de seguridad industrial y EPP — Proyecto Red",
  "description": "Catálogo de equipo de protección personal: cascos NOM-017-STPS, protección visual ANSI Z87.1, auditiva NOM-011-STPS, respiratoria NIOSH, guantes, calzado, arneses y ropa de protección.",
  "url": pageUrl,
  "numberOfItems": 8,
  "itemListElement": [
    {
      "@type": "ListItem", "position": 1,
      "name": "Protección Craneal",
      "description": "Cascos clase E, G y C. Suspensión 4 y 6 puntos. NOM-017-STPS certificado. Para construcción, plantas industriales y trabajo eléctrico.",
      "url": `${siteUrl}/equipo-seguridad/cascos/`
    },
    {
      "@type": "ListItem", "position": 2,
      "name": "Protección Visual",
      "description": "Lentes ANSI Z87.1, goggles de sello, caretas faciales y visores de soldadura. Policarbonato antiimpacto, antiempañante y UV400.",
      "url": `${siteUrl}/equipo-seguridad/lentes/`
    },
    {
      "@type": "ListItem", "position": 3,
      "name": "Protección Auditiva",
      "description": "Tapones NRR 29–33 dB y orejeras NRR 25–31 dB. NOM-011-STPS. Para ambientes con ruido superior a 85 dB.",
      "url": `${siteUrl}/equipo-seguridad/auditiva/`
    },
    {
      "@type": "ListItem", "position": 4,
      "name": "Protección Respiratoria",
      "description": "N95 desechable, media cara con filtros OV y P100, cara completa. NIOSH certificado. Para polvos, vapores orgánicos y gases.",
      "url": `${siteUrl}/equipo-seguridad/respiratoria/`
    },
    {
      "@type": "ListItem", "position": 5,
      "name": "Protección de Manos",
      "description": "Guantes anticorte EN 388, químicos EN 374, soldador, dieléctricos y resistentes al calor EN 407.",
      "url": `${siteUrl}/equipo-seguridad/guantes/`
    },
    {
      "@type": "ListItem", "position": 6,
      "name": "Calzado de Seguridad",
      "description": "Zapatos y botas con casquillo acero y composite. NOM-113-STPS. Clasificación EH para riesgo eléctrico. Antiperforación y antideslizante.",
      "url": `${siteUrl}/equipo-seguridad/calzado/`
    },
    {
      "@type": "ListItem", "position": 7,
      "name": "Arneses y Protección contra Caídas",
      "description": "Arneses tipo I, II y III. Líneas de vida retráctiles 3–30 m y dobles. Anclajes portátiles. NOM-009-STPS.",
      "url": `${siteUrl}/equipo-seguridad/arneses/`
    },
    {
      "@type": "ListItem", "position": 8,
      "name": "Ropa de Protección",
      "description": "Overall FR, chaleco alta visibilidad clase 2 y 3, trajes para químicos tipo 3 y 4, overall antiestático ATEX. EN 11612 · ANSI 107.",
      "url": `${siteUrl}/equipo-seguridad/ropa/`
    }
  ]
}

// ── Schema: FAQPage ────────────────────────────────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué diferencia hay entre EPP certificado NOM y el que no lo tiene?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El EPP certificado NOM ha pasado pruebas de desempeño estandarizadas. Uno sin certificación puede verse igual pero su desempeño ante el riesgo real es desconocido. La STPS en inspección puede pedir la hoja técnica y certificación — si el producto no la tiene, hay observación aunque el equipo esté siendo usado."
      }
    },
    {
      "@type": "Question",
      "name": "¿El respirador N95 protege contra vapores orgánicos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. El N95 filtra partículas pero NO filtra vapores ni gases. Para vapores orgánicos se requiere un respirador de media cara con cartucho OV. Para ambos, el cartucho OV/P100 combinado. El respirador incorrecto da falsa sensación de protección mientras el trabajador inhala el vapor."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cada cuánto hay que reemplazar el EPP?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cascos: máximo 5 años desde manufactura, 2-3 si hubo impacto. Arneses: máximo 10 años, retirar si absorbió una caída. Guantes dieléctricos: prueba cada 6 meses. Tapones desechables: un solo uso. Respiradores: cambiar cartuchos cada 40 horas o al percibir olor."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta equipar a un trabajador con EPP completo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "EPP básico para construcción (casco + lentes + tapones + guantes + calzado): $800 a $1,800 MXN por trabajador. EPP completo para mantenimiento eléctrico (añadiendo casco clase E, guante dieléctrico, calzado EH y ropa FR): $3,500 a $8,000 MXN por persona."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué es el programa de EPP que exige NOM-017-STPS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La NOM-017-STPS exige análisis de riesgo por puesto de trabajo, selección del EPP correcto para cada riesgo, capacitación en uso correcto y registro de entrega firmado por cada trabajador. Sin este programa documentado no hay cumplimiento aunque el equipo exista en la empresa."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué pasa si un trabajador se lesiona sin usar el EPP asignado?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Si la empresa documentó la entrega del EPP y capacitó al trabajador, la responsabilidad puede trasladarse al trabajador. Sin evidencia documental, la empresa puede ser responsable aunque haya entregado el equipo verbalmente. El registro de entrega firmado es parte crítica del programa de EPP."
      }
    }
  ]
}

// ── Schema: BreadcrumbList ─────────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
    { "@type": "ListItem", "position": 3, "name": "Equipo de Seguridad Industrial", "item": pageUrl }
  ]
}

// ── Schema: CollectionPage ─────────────────────────────────
const schemaWebPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Equipo de Seguridad Industrial y EPP en CDMX | Proyecto Red",
  "description": "Venta de equipo de protección personal (EPP) certificado NOM-017-STPS: cascos, lentes, protección auditiva, respiradores, guantes, calzado, arneses y ropa de protección. Selección técnica por tipo de riesgo y documentación para programa de EPP.",
  "url": pageUrl,
  "image": ogImage,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "Proyecto Red", "url": siteUrl },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
      { "@type": "ListItem", "position": 3, "name": "Equipo de Seguridad", "item": pageUrl }
    ]
  },
  "mainEntity": {
    "@id": pageUrl + "#itemlist"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Proyecto Red",
    "url": siteUrl,
    "logo": `${siteUrl}/imagenes/logos/equipo-contra-incendios.jpg`,
    "telephone": `+52${CONTACT.phoneRaw}`,
    "email": CONTACT.email
  }
}
---

<Base
  title="Equipo de Seguridad Industrial y EPP en CDMX | Proyecto Red"
  description="Venta de equipo de protección personal (EPP) certificado NOM-017-STPS: cascos, lentes, protección auditiva, respiradores, guantes, calzado, arneses y ropa de protección. Selección técnica por tipo de riesgo."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Productos', href: '/productos/' },
    { label: 'Equipo de Seguridad Industrial' }
  ]} />

  <HeroEquipoSeguridad />
  <CtaBar />
  <CatalogoEquipoSeguridad />
  <GuiaEquipoSeguridad />
  <TrustIndex />
  <NormasEquipoSeguridad />
  <FaqEquipoSeguridad />
  <CategoriasRelacionadas current="equipo-seguridad" />
  <CTAFinalIndex />

  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebPage)} />

</Base>
