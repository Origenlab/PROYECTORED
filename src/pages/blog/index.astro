---
// /blog/ — Listado de artículos del blog
import CategoryLayout from '../../layouts/CategoryLayout.astro'
import { getCollection } from 'astro:content'
import { waUrl } from '../../config/site'

const PAGE_WA = waUrl('Hola, leí su blog y tengo una pregunta')

// Obtener todos los artículos del blog ordenados por fecha
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const stats = [
  { value: String(posts.length), label: 'Artículos publicados' },
  { value: 'NOM',   label: 'Normativa actualizada' },
  { value: 'STPS',  label: 'Regulación laboral'    },
  { value: 'Gratis',label: 'Contenido abierto'     },
]

// Categorías únicas
const categories = ['Todas', ...new Set(posts.map((p) => p.data.category).filter(Boolean))]
---

<CategoryLayout
  title="Blog — Guías de Seguridad Contra Incendios | Proyecto Red"
  description="Guías prácticas, normativas actualizadas y contenido técnico para que tu empresa cumpla con Protección Civil, STPS y NOM sin contratiempos."
  badge="Guías técnicas y normativas"
  heroTitle="Blog de Seguridad Contra"
  heroAccent="Incendios"
  heroSubtitle="Guías prácticas, normativas actualizadas y contenido técnico para que tu empresa cumpla con Protección Civil, STPS y NOM sin contratiempos."
  heroDescRight={[
    'En Proyecto Red creamos contenido técnico real — no relleno SEO genérico. Cada artículo responde preguntas que nuestros clientes nos hacen todos los días: qué extintor necesitan, qué exige Protección Civil, cómo pasar una auditoría STPS o qué norma aplica a su giro.',
    'Si después de leer tienes dudas, escríbenos por WhatsApp. Nuestro equipo técnico te asesora sin costo sobre el equipo y los servicios que tu empresa necesita.',
  ]}
  cta1={{ text: 'Ver todos los artículos', href: '#articulos' }}
  cta2={{ text: 'Ver catálogo de productos', href: '/productos/' }}
  breadcrumb={[{ label: 'Inicio', href: '/' }, { label: 'Blog' }]}
  {stats}
  showForm={false}
  ctaTitle="¿Tienes preguntas después de leer?"
  ctaBody="Nuestro equipo técnico resuelve tus dudas sin costo. Escríbenos por WhatsApp con tu pregunta y te respondemos en menos de 24 horas."
  ctaCTA1Text="Preguntar por WhatsApp"
  ctaCTA1Href={PAGE_WA}
  ctaCTA2Text="Ver catálogo completo"
  ctaCTA2Href="/productos/"
>

  <section id="articulos" class="blog section">
    <div class="container">

      <!-- Filtros por categoría -->
      {categories.length > 2 && (
        <div class="blog__filters" role="tablist" aria-label="Filtrar por categoría">
          {categories.map((cat) => (
            <button
              class:list={['filter-btn', { 'filter-btn--active': cat === 'Todas' }]}
              data-category={cat}
              role="tab"
            >
              {cat}
            </button>
          ))}
        </div>
      )}

      <!-- Grid de artículos -->
      {posts.length > 0 ? (
        <ul class="blog__grid" role="list">
          {posts.map((post) => (
            <li class="post-card" data-category={post.data.category ?? ''}>
              <a href={`/blog/${post.slug}/`} class="post-card__link">
                {post.data.image && (
                  <div class="post-card__image">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      width="400"
                      height="220"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="post-card__body">
                  {post.data.category && (
                    <span class="post-card__category">{post.data.category}</span>
                  )}
                  <h2 class="post-card__title">{post.data.title}</h2>
                  <p class="post-card__excerpt">{post.data.description}</p>
                  <div class="post-card__meta">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                    <span class="post-card__read">Leer artículo →</span>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="blog__empty">Próximamente publicaremos artículos técnicos. ¡Vuelve pronto!</p>
      )}

    </div>
  </section>

</CategoryLayout>

<style>
  .blog__filters {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-bottom: var(--sp-8);
  }

  .filter-btn {
    padding: var(--sp-2) var(--sp-4);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-gray-700);
    background: var(--color-gray-100);
    border-radius: var(--radius-full);
    transition: background var(--transition), color var(--transition);
  }

  .filter-btn:hover,
  .filter-btn--active {
    background: var(--color-red);
    color: var(--color-white);
  }

  .blog__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--sp-6);
  }

  .post-card {
    background: var(--color-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  }

  .post-card:hover {
    border-color: var(--color-red);
    box-shadow: var(--shadow-md);
    transform: translateY(-3px);
  }

  .post-card__link { display: flex; flex-direction: column; height: 100%; }

  .post-card__image img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    background: var(--color-gray-200);
  }

  .post-card__body {
    flex: 1;
    padding: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .post-card__category {
    display: inline-block;
    padding: 2px var(--sp-3);
    background: var(--color-red-faint);
    color: var(--color-red);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-full);
  }

  .post-card__title {
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-gray-900);
    line-height: var(--leading-snug);
  }

  .post-card__excerpt {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    line-height: var(--leading-relaxed);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--text-xs);
    color: var(--color-gray-400);
    margin-top: auto;
  }

  .post-card__read {
    font-weight: var(--weight-semibold);
    color: var(--color-red);
  }

  .blog__empty {
    text-align: center;
    color: var(--color-gray-500);
    padding: var(--sp-16) 0;
  }
</style>

<script>
  // Filtro de categorías por JS — sin framework
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn')
  const posts = document.querySelectorAll<HTMLElement>('.post-card')

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const cat = btn.dataset.category ?? 'Todas'

      filterBtns.forEach((b) => b.classList.remove('filter-btn--active'))
      btn.classList.add('filter-btn--active')

      posts.forEach((post) => {
        const show = cat === 'Todas' || post.dataset.category === cat
        post.style.display = show ? '' : 'none'
      })
    })
  })
</script>
