---
/**
 * blog/index.astro — Página del Blog de Proyecto Red (Nivel 2)
 * ─────────────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO.
 * Mismo patrón que productos.astro — cada sección es un componente autónomo.
 */

import Base              from '../../layouts/Base.astro'
import Breadcrumb        from '../../components/ui/Breadcrumb.astro'
import CtaBar            from '../../components/CtaBar.astro'

// ── Secciones de Blog ─────────────────────────────────
import HeroBlog            from '../../components/sections/HeroBlog.astro'
import CatalogoBlog        from '../../components/sections/CatalogoBlog.astro'
import FaqCotizacionIndex  from '../../components/sections/FaqCotizacionIndex.astro'
import CTAFinalIndex       from '../../components/sections/CTAFinalIndex.astro'

import '../../styles/pages.css'

// ── Datos para JSON-LD ──────────────────────────────────
import { SITE, CONTACT } from '../../config/site'
import { getCollection } from 'astro:content'

const siteUrl   = SITE.url
const pageUrl   = `${siteUrl}/blog/`
const ogImage   = `${siteUrl}/imagenes/og/proyectored-og.jpg`

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

// ── Schema: BreadcrumbList ──────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": pageUrl },
  ]
}

// ── Schema: Blog (CollectionPage) ───────────────────────
const schemaBlog = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Blog — Guías de Seguridad Contra Incendios",
  "description": "Artículos técnicos, guías prácticas y normativas sobre equipos contra incendios, prevención, Protección Civil, NOM y STPS.",
  "url": pageUrl,
  "numberOfItems": posts.length,
  "publisher": {
    "@type": "Organization",
    "name": SITE.name,
    "url": siteUrl,
  },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": Math.min(posts.length, 10),
    "itemListElement": posts.slice(0, 10).map((post, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `${siteUrl}/blog/${post.id}/`,
      "name": post.data.title,
    })),
  },
}

// ── Schema: FAQPage ─────────────────────────────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cada cuánto se debe recargar un extintor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un extintor debe recargarse cada 12 meses como máximo según la NOM-154-SCFI, incluso si no ha sido usado. Si se usó parcialmente, la recarga debe ser inmediata. En ambientes corrosivos o con temperaturas extremas, puede necesitarse cada 6 meses."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué extintor necesito para mi empresa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depende del tipo de riesgo. Para oficinas se recomienda el ABC multipropósito; para cocinas industriales, el Tipo K; para equipos electrónicos, el CO₂ o agente limpio. La NOM-002-STPS establece mínimo una unidad por cada 300 m². Nuestro equipo técnico te asesora sin costo."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué exige Protección Civil para una empresa en CDMX?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Protección Civil requiere un programa interno con análisis de riesgos, señalización conforme a NOM-003-SEGOB, extintores vigentes según NOM-154-SCFI, detectores de humo en áreas clave, capacitación de brigadas con constancias DC-3 y un expediente documentado actualizado."
      }
    },
    {
      "@type": "Question",
      "name": "¿Los artículos del blog son gratuitos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Todo nuestro contenido es abierto y gratuito. Publicamos guías técnicas, normativas actualizadas y contenido práctico para que tu empresa cumpla con las regulaciones de seguridad contra incendios sin contratiempos."
      }
    },
  ]
}
---

<Base
  title="Blog — Guías de Seguridad Contra Incendios | Proyecto Red"
  description="Artículos técnicos, guías prácticas y normativas sobre equipos contra incendios, prevención, Protección Civil, NOM y STPS. Contenido gratuito por especialistas."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <!-- ── Barra de migas de pan ────────────────────────────── -->
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Blog' }
  ]} />

  <!-- ── Secciones ──────────────────────────────────────── -->
  <HeroBlog />
  <CtaBar />
  <CatalogoBlog />
  <FaqCotizacionIndex />
  <CTAFinalIndex />

  <!-- ── Datos estructurados JSON-LD ────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBlog)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

</Base>
