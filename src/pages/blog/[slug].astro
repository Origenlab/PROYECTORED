<script>
  // ToC
  const headings = document.querySelectorAll('.blog-body h2');
  const tocEl = document.getElementById('blog-toc');
  const tocNav = document.getElementById('toc-nav');
  if (headings.length >= 2 && tocEl && tocNav) {
    tocEl.style.display = 'block';
    headings.forEach((h, i) => {
      const id = 'sec-' + i;
      h.id = id;
      const a = document.createElement('a');
      a.href = '#' + id;
      a.textContent = h.textContent || '';
      a.className = 'toc-link';
      tocNav.appendChild(a);
    });
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const link = tocNav.querySelector('a[href="#' + entry.target.id + '"]');
        if (link) link.classList.toggle('toc-link--active', entry.isIntersecting);
      });
    }, { rootMargin: '-10% 0px -80% 0px' });
    headings.forEach(h => observer.observe(h));
  }
</script>
