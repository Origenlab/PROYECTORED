---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<Base title={`${post.data.title} | PROYECTORED`} description={post.data.description}>
  <article class="blog-post">
    <div class="container">
      <div class="post-header">
        <span class="post-category">{post.data.category}</span>
        <h1>{post.data.title}</h1>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      </div>
      <div class="post-content">
        <Content />
      </div>
      <div class="post-cta">
        <p>¿Necesitas equipos contra incendios? <a href="https://wa.me/5255372385844?text=Hola%2C%20quiero%20información">Contáctanos por WhatsApp</a></p>
      </div>
    </div>
  </article>
</Base>

<style>
  .blog-post {
    padding: calc(var(--header-height, 80px) + 2rem) 0 3rem;
  }

  .post-header {
    max-width: 720px;
    margin-bottom: 2rem;
  }

  .post-category {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }

  .post-header h1 {
    font-size: 2rem;
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 0.75rem;
  }

  .post-header time {
    color: var(--color-gray);
    font-size: 0.9rem;
  }

  .post-content {
    max-width: 720px;
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
    font-weight: 700;
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    margin: 1.5rem 0 0.75rem;
    font-weight: 600;
  }

  .post-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-content :global(ul), .post-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin-bottom: 0.4rem;
  }

  .post-cta {
    max-width: 720px;
    margin-top: 3rem;
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 12px;
    text-align: center;
  }

  .post-cta a {
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 1.5rem;
    }
  }
</style>
