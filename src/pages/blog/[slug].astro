---
import Base from '../../layouts/Base.astro';
import CategoriesNav from '../../components/CategoriesNav.astro';
import { getCollection, render } from 'astro:content';
import '../../styles/pages.css';

function getImageForPost(post: any): string {
  if (post.data.image) return post.data.image;
  const category = post.data.category;
  const postId = post.id;
  const map: Record<string, string[]> = {
    'Extintores': [
      '/imagenes/extintores/extintores-contra-incendios.jpg',
      '/imagenes/extintores/extintores.jpg',
      '/imagenes/extintores/extintor.jpg',
      '/imagenes/extintores/extintores-mexico.jpg',
      '/imagenes/extintores/venta-de-extintores.jpg',
      '/imagenes/extintores/polvo-seco.jpg',
      '/imagenes/extintores/co2.jpg',
      '/imagenes/extintores/tipo-k.jpg',
      '/imagenes/extintores/afff.jpg',
      '/imagenes/extintores/agente-limpio.jpg',
      '/imagenes/extintores/abc.jpg',
      '/imagenes/extintores/automaticos.jpg',
      '/imagenes/extintores/agua-a-presion.jpg',
      '/imagenes/extintores/purpura-k.jpg',
      '/imagenes/extintores/extintores-de-agua.jpg',
      '/imagenes/extintores/venta-de-extintor.jpg',
      '/imagenes/extintores/extintores-para-incendios.jpg',
      '/imagenes/extintores/venta-de-extintores-economicos.jpg',
      '/imagenes/extintores/equipo-contra-incendios.jpg',
      '/img/blog-extintor-mantenimiento-certificado.avif',
      '/img/blog-extintor-tipo-k-cocina-restaurante.avif',
    ],
    'Señalización': [
      '/imagenes/senalamientos/senalamientos-hero.jpg',
      '/imagenes/senalamientos/salida-emergencia.jpg',
      '/imagenes/senalamientos/letrero-extintor.jpg',
      '/imagenes/senalamientos/punto-reunion.jpg',
      '/imagenes/senalamientos/escaleras-emergencia.jpg',
      '/imagenes/senalamientos/advertencia.jpg',
      '/imagenes/senalamientos/obligacion.jpg',
      '/imagenes/senalamientos/prohibicion.jpg',
      '/imagenes/senalamientos/senalamiento-alt.jpg',
      '/img/blog-senalizacion-ruta-evacuacion-nom.avif',
    ],
    'Sistemas': [
      '/imagenes/sistemas/alarmas.jpg',
      '/imagenes/sistemas/detectores.jpg',
      '/imagenes/sistemas/rociadores.jpg',
      '/imagenes/sistemas/tableros.jpg',
      '/imagenes/sistemas/redes-hidraulicas.jpg',
      '/imagenes/sistemas/tuberia-hidraulica.jpg',
      '/imagenes/sistemas/tablero-control.jpg',
      '/imagenes/sistemas/tablero-incendios.jpg',
      '/imagenes/sistemas/tableros-detectores.jpg',
      '/img/rociadores-automaticos-sprinklers.avif',
      '/img/red-hidraulica-contra-incendio.avif',
      '/img/tablero-control-alarma-incendio.avif',
      '/img/detectores-humo-instalacion-oficina.avif',
    ],
    'Detección': [
      '/imagenes/sistemas/detectores.jpg',
      '/imagenes/sistemas/alarmas.jpg',
      '/imagenes/sistemas/tableros-detectores.jpg',
      '/imagenes/sistemas/tablero-control.jpg',
    ],
    'Equipo Bomberos': [
      '/imagenes/equipo-bomberos/equipo-bomberos-hero.jpg',
      '/imagenes/equipo-bomberos/trajes-bombero.jpg',
      '/imagenes/equipo-bomberos/herramientas-bombero.jpg',
      '/imagenes/equipo-bomberos/respiracion-autonoma.jpg',
      '/imagenes/equipo-bomberos/arnes-bombero.jpg',
      '/imagenes/equipo-bomberos/complementos-traje.jpg',
    ],
    'Rescate': [
      '/imagenes/equipo-bomberos/herramientas-bombero.jpg',
      '/imagenes/equipo-bomberos/equipo-bomberos-hero.jpg',
      '/imagenes/equipo-bomberos/arnes-bombero.jpg',
    ],
    'Herramientas': [
      '/imagenes/equipo-bomberos/herramientas-bombero.jpg',
      '/imagenes/equipo-bomberos/equipo-bomberos-hero.jpg',
      '/imagenes/equipo-bomberos/complementos-traje.jpg',
    ],
    'Primeros Auxilios': [
      '/imagenes/primeros-auxilios/botiquines-hero.jpg',
      '/imagenes/primeros-auxilios/botiquin.jpg',
      '/imagenes/primeros-auxilios/camilla.jpg',
      '/imagenes/primeros-auxilios/camillas.jpg',
      '/imagenes/primeros-auxilios/collarin.jpg',
      '/img/botiquin-primeros-auxilios-stps.avif',
      '/img/camilla-emergencia-empresa.avif',
    ],
    'EPP': [
      '/imagenes/equipo-seguridad/equipos-seguridad-hero.jpg',
      '/imagenes/equipo-seguridad/cascos.jpg',
      '/imagenes/equipo-seguridad/lentes.jpg',
      '/imagenes/equipo-seguridad/chalecos.jpg',
      '/imagenes/equipo-seguridad/tapones-auditivos.jpg',
      '/imagenes/equipo-seguridad/conos.jpg',
    ],
    'Seguridad Industrial': [
      '/imagenes/equipo-seguridad/equipos-seguridad-hero.jpg',
      '/imagenes/equipo-seguridad/cascos.jpg',
      '/imagenes/equipo-seguridad/chalecos.jpg',
      '/imagenes/equipo-seguridad/conos.jpg',
    ],
    'Mangueras': [
      '/imagenes/mangueras/mangueras-hero.jpg',
      '/imagenes/mangueras/chiflon.jpg',
      '/imagenes/mangueras/valvulas.jpg',
      '/imagenes/mangueras/toma-siamesa.jpg',
      '/imagenes/mangueras/adaptadores.jpg',
      '/imagenes/mangueras/carrete-manguera.jpg',
      '/imagenes/mangueras/llaves.jpg',
    ],
    'Hidráulico': [
      '/imagenes/sistemas/redes-hidraulicas.jpg',
      '/imagenes/mangueras/mangueras-hero.jpg',
      '/imagenes/sistemas/tuberia-hidraulica.jpg',
      '/imagenes/sistemas/red-hidraulica-1.jpg',
      '/imagenes/sistemas/red-hidraulica-2.jpg',
    ],
    'Gabinetes': [
      '/imagenes/gabinetes/gabinetes-hero.jpg',
      '/imagenes/gabinetes/gabinetes-extintores.jpg',
      '/imagenes/gabinetes/gabinete-mangueras.jpg',
      '/imagenes/gabinetes/gabinete-bombero.jpg',
      '/imagenes/gabinetes/porta-extintor-cenicero.jpg',
    ],
    'Capacitación': [
      '/imagenes/extintores/equipo-contra-incendios.jpg',
      '/imagenes/equipo-bomberos/equipo-bomberos-hero.jpg',
      '/imagenes/extintores/extintores-contra-incendios.jpg',
      '/imagenes/primeros-auxilios/botiquines-hero.jpg',
    ],
    'Normativa': [
      '/imagenes/senalamientos/senalamientos-hero.jpg',
      '/imagenes/extintores/equipo-contra-incendios.jpg',
      '/imagenes/senalamientos/salida-emergencia.jpg',
      '/imagenes/extintores/extintores-contra-incendios.jpg',
    ],
  };
  const fallback = [
    '/imagenes/extintores/extintores-contra-incendios.jpg',
    '/imagenes/sistemas/alarmas.jpg',
    '/imagenes/senalamientos/senalamientos-hero.jpg',
    '/imagenes/equipo-bomberos/equipo-bomberos-hero.jpg',
    '/imagenes/mangueras/mangueras-hero.jpg',
    '/imagenes/gabinetes/gabinetes-hero.jpg',
  ];
  const pool = category ? (map[category] ?? fallback) : fallback;
  let hash = 0;
  for (let i = 0; i < postId.length; i++) hash = (hash * 31 + postId.charCodeAt(i)) & 0xffffffff;
  return pool[Math.abs(hash) % pool.length];
}


const WHATSAPP = "525537238544";

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Tiempo de lectura
const wordCount = post.body ? post.body.split(/\s+/).length : 500;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Artículos relacionados
const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p: any) => p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 3);

// Formatear fecha
const fecha = post.data.pubDate
  ? new Date(post.data.pubDate).toLocaleDateString('es-MX', {
      year: 'numeric', month: 'long', day: 'numeric'
    })
  : null;

// Schema JSON-LD para artículo
const schemaPage = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate
    ? new Date(post.data.pubDate).toISOString()
    : new Date().toISOString(),
  "publisher": {
    "@type": "Organization",
    "name": "Proyecto Red",
    "url": "https://proyectored.com.mx"
  },
  "author": {
    "@type": "Organization",
    "name": "Proyecto Red"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://proyectored.com.mx/blog/${post.id}/`
  }
});
---

<Base
  title={`${post.data.title} | Proyecto Red`}
  description={post.data.description}
  schema={schemaPage}
>

  <!-- ══════════════════════════════════════
       HEADER DEL ARTÍCULO
  ══════════════════════════════════════ -->
  <section class="blog-hero">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/" class="breadcrumb__link">Inicio</a>
        <span class="breadcrumb__sep">/</span>
        <a href="/blog/" class="breadcrumb__link">Blog</a>
        <span class="breadcrumb__sep">/</span>
        <span class="breadcrumb__current">{post.data.title}</span>
      </nav>

      <div class="blog-hero__meta">
        {post.data.category && (
          <span class="blog-cat-badge">{post.data.category}</span>
        )}
        {fecha && <time datetime={post.data.pubDate?.toString()}>{fecha}</time>}
        <span class="blog-reading-time">⏱ {readingTime} min lectura</span>
      </div>

      <h1 class="blog-hero__title">{post.data.title}</h1>
      <p class="blog-hero__desc">{post.data.description}</p>

      <!-- CTA inline en header -->
      <div class="blog-hero__cta">
        <a
          href={`https://wa.me/${WHATSAPP}?text=Hola%2C%20le%C3%AD%20el%20art%C3%ADculo%20sobre%20${encodeURIComponent(post.data.title)}%20y%20necesito%20asesor%C3%ADa`}
          class="btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Asesoría gratuita por WhatsApp
        </a>
        <a href="/productos/" class="btn-secondary">Ver catálogo</a>
      </div>

      <div class="blog-hero__img">
        <img 
          src={getImageForPost(post)} 
          alt={post.data.title}
          loading="eager"
          width="1200"
          height="630"
        />
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       CONTENIDO
  ══════════════════════════════════════ -->
  <div class="blog-layout">
    <div class="container blog-container">

      <!-- Contenido principal -->
      <article class="blog-content" itemscope itemtype="https://schema.org/Article">
        <div class="blog-body" itemprop="articleBody">
          <Content />
        </div>

        <!-- CTA en medio del contenido (sidebar sticky en desktop) -->
        <aside class="blog-sidebar">
          <div class="blog-toc" id="blog-toc" style="display:none">
            <div class="blog-toc__header">En este artículo</div>
            <nav class="blog-toc__nav" id="toc-nav"></nav>
          </div>
          <div class="blog-sidebar__card">
            <div class="blog-sidebar__header">
              <span class="blog-sidebar__badge">Proveedor directo</span>
              <h3>¿Necesitas este equipo?</h3>
              <p>Cotización gratuita con certificado NOM. Respuesta en menos de 24 horas.</p>
            </div>
            <div class="blog-sidebar__body">
              <a
                href={`https://wa.me/${WHATSAPP}?text=Hola%2C%20necesito%20informaci%C3%B3n%20sobre%20${encodeURIComponent(post.data.title)}`}
                class="blog-sidebar__wa"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                Cotizar por WhatsApp
              </a>
              <div class="blog-sidebar__links">
                <a href="/extintores/">→ Ver extintores</a>
                <a href="/senalamientos/">→ Ver señalamientos</a>
                <a href="/sistemas/">→ Ver sistemas CI</a>
                <a href="/equipo-seguridad/">→ Ver EPP</a>
                <a href="/productos/">→ Catálogo completo</a>
              </div>
              <div class="blog-sidebar__trust">
                <span>✓ Certificados NOM</span>
                <span>✓ Entrega CDMX mismo día</span>
                <span>✓ Factura incluida</span>
              </div>
            </div>
          </div>
        </aside>
      </article>

    </div>
  </div>

  <!-- ══════════════════════════════════════
       INTERLINKING
  ══════════════════════════════════════ -->
  {related.length > 0 && (
    <section class="related-posts">
      <div class="container">
        <div class="related-header">
          <p class="section-label-red">Artículos relacionados</p>
          <h2>Más sobre {post.data.category}</h2>
        </div>
        <div class="related-grid">
          {related.map((r: any) => (
            <a href={`/blog/${r.id}/`} class="related-card">
              <div class="related-card__img">
                <img src={getImageForPost(r)} alt={r.data.title} loading="lazy" width="600" height="338" />
              </div>
              <div class="related-card__body">
                <span class="related-cat">{r.data.category}</span>
                <h3>{r.data.title}</h3>
                <p>{r.data.description}</p>
                <span class="related-link">Leer artículo →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CategoriesNav />

  <!-- ══════════════════════════════════════
       CTA FINAL
  ══════════════════════════════════════ -->
  <section class="cta-final" aria-label="Cotización">
    <div class="container cta-final-inner">
      <div class="cta-text">
        <h2>¿Necesitas equipos contra incendios para tu empresa?</h2>
        <p>Mándanos un WhatsApp con lo que necesitas. Respondemos con precio, disponibilidad y tiempo de entrega ese mismo día.</p>
      </div>
      <div class="cta-btns">
        <a
          href={`https://wa.me/${WHATSAPP}?text=Hola%2C%20necesito%20cotizar%20equipos%20contra%20incendios`}
          class="btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Cotizar por WhatsApp
        </a>
        <a href="/productos/" class="btn-cta-ghost">Ver catálogo completo</a>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ── Hero del artículo ────────────────────────── */
  .blog-hero {
    padding-top: calc(var(--stack-height, 124px) + 3rem);
    padding-bottom: 3rem;
    background: linear-gradient(160deg, #0E0E0E 0%, #1A1010 55%, #0E0E0E 100%);
    color: #fff;
    position: relative;
    overflow: hidden;
  }
  .blog-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 60% at 70% 50%, rgba(196,30,36,0.1) 0%, transparent 70%);
    pointer-events: none;
  }
  .blog-hero .container { position: relative; z-index: 1; }

  .blog-hero__meta {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .blog-cat-badge {
    display: inline-block;
    background: var(--c-primary);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.225rem 0.625rem;
    border-radius: 3px;
  }

  .blog-hero__meta time {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.45);
    font-weight: 500;
  }

  .blog-hero__title {
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: #fff;
    margin-bottom: 1rem;
    max-width: 72ch;
  }

  .blog-hero__desc {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.65;
    max-width: 60ch;
    margin-bottom: 2rem;
  }

  .blog-hero__cta {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  /* ── Layout blog (contenido + sidebar) ───────── */
  .blog-layout {
    background: var(--c-white);
    padding: 4rem 0;
  }

  .blog-container {
    display: grid;
    grid-template-columns: 1fr;
  }

  /* El article usa grid interno para sidebar */
  .blog-content {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 4rem;
    align-items: start;
  }

  /* ── Cuerpo del artículo ─────────────────────── */
  .blog-body {
    min-width: 0;
  }

