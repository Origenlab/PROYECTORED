---
/**
 * productos.astro — Página de catálogo de Proyecto Red
 * ─────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO.
 * Mismo patrón que index.astro — cada sección es un componente autónomo.
 */

import Base              from '../layouts/Base.astro'
import Breadcrumb        from '../components/ui/Breadcrumb.astro'
import CtaBar            from '../components/CtaBar.astro'

// ── Secciones de Productos ─────────────────────────────
import HeroProductos       from '../components/sections/HeroProductos.astro'
import CatalogoProductos   from '../components/sections/CatalogoProductos.astro'
import SeleccionIndex      from '../components/sections/SeleccionIndex.astro'
import NormasIndex         from '../components/sections/NormasIndex.astro'
import ProcesoIndex        from '../components/sections/ProcesoIndex.astro'
import FaqCotizacionIndex  from '../components/sections/FaqCotizacionIndex.astro'
import CTAFinalIndex       from '../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ──────────────────────────────────
import { SITE, CONTACT } from '../config/site'

const siteUrl   = SITE.url
const pageUrl   = `${siteUrl}/productos/`
const ogImage   = `${siteUrl}/imagenes/og/proyectored-og.jpg`

// ── Schema: BreadcrumbList ──────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Productos",
      "item": pageUrl
    }
  ]
}

// ── Schema: OfferCatalog ────────────────────────────────
const schemaOfferCatalog = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "Catálogo de Equipos Contra Incendios — Proyecto Red",
  "description": "Catálogo completo de equipos contra incendios certificados NOM y NFPA: extintores, señalamientos, equipo para bomberos, gabinetes, mangueras, sistemas CI, primeros auxilios y EPP.",
  "url": pageUrl,
  "numberOfItems": 50,
  "itemListElement": [
    { "@type": "OfferCatalog", "name": "Extintores certificados NOM-154-SCFI", "url": `${siteUrl}/extintores/` },
    { "@type": "OfferCatalog", "name": "Equipo para Bomberos NFPA 1971", "url": `${siteUrl}/equipo-bomberos/` },
    { "@type": "OfferCatalog", "name": "Señalamientos de Emergencia NOM-003-SEGOB", "url": `${siteUrl}/senalamientos/` },
    { "@type": "OfferCatalog", "name": "Gabinetes y Porta Extintores", "url": `${siteUrl}/gabinetes/` },
    { "@type": "OfferCatalog", "name": "Mangueras y Herrajes contra incendio", "url": `${siteUrl}/mangueras/` },
    { "@type": "OfferCatalog", "name": "Sistemas Contra Incendio NFPA 13/72", "url": `${siteUrl}/sistemas/` },
    { "@type": "OfferCatalog", "name": "Primeros Auxilios NOM-005-STPS", "url": `${siteUrl}/primeros-auxilios/` },
    { "@type": "OfferCatalog", "name": "Equipo de Seguridad Industrial NOM-017-STPS", "url": `${siteUrl}/equipo-seguridad/` },
  ]
}

// ── Schema: FAQPage (producto-específicas) ──────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta un extintor certificado en la Ciudad de México?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depende del tipo de agente y la capacidad. Un extintor de polvo seco ABC de 4.5 kg parte desde $450 MXN aproximadamente. Los de CO₂ para equipos electrónicos y los Tipo K para cocinas industriales tienen otro rango de precio según la capacidad. Escríbenos por WhatsApp con lo que necesitas y te mandamos cotización el mismo día."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué extintores me pide Protección Civil para mi negocio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Eso lo define el tipo de riesgo y la superficie de tu local o planta. Como referencia general, la NOM-002-STPS pide al menos un extintor por cada 300 m², con mínimo uno por piso. Para oficinas conviene el ABC multipropósito, para cocinas el Tipo K, y para cuartos de servidores el CO₂ o agente limpio. Si quieres, hacemos un diagnóstico técnico sin costo para decirte exactamente qué te piden."
      }
    },
    {
      "@type": "Question",
      "name": "¿Entregan el mismo día en CDMX y Estado de México?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Si confirmas tu pedido antes de las 2 PM, lo entregamos ese mismo día en toda la zona metropolitana de la Ciudad de México y el Estado de México. Para pedidos grandes o envíos al interior de la república, coordinamos la logística directamente contigo en la cotización."
      }
    },
    {
      "@type": "Question",
      "name": "¿Los equipos traen certificado NOM para mi expediente?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Todos. Cada extintor que vendemos cumple con la NOM-154-SCFI y se entrega con etiqueta de inspección, ficha técnica del fabricante y garantía. Si necesitas documentación adicional para aseguradoras o auditorías internas, también te la proporcionamos sin costo extra."
      }
    },
    {
      "@type": "Question",
      "name": "¿También hacen recarga y mantenimiento de extintores?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Vamos a tus instalaciones a hacer la recarga, el mantenimiento preventivo y la verificación de todos tus cilindros. Revisamos agente extintor, presión, válvulas, manguera y actualizamos la etiqueta de inspección. También ofrecemos pólizas anuales con visitas programadas para que siempre estés al día."
      }
    },
    {
      "@type": "Question",
      "name": "¿Tienen precios especiales para empresas con varias sucursales?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Claro. Trabajamos con empresas que necesitan surtir varias ubicaciones, plantas o proyectos al mismo tiempo. Ofrecemos precios por volumen, facturación consolidada y entregas programadas. Cuéntanos tu necesidad y te armamos un esquema de suministro a la medida."
      }
    }
  ]
}
---

<Base
  title="Equipos Contra Incendios Certificados en CDMX | Catálogo Proyecto Red"
  description="Más de 50 equipos contra incendios certificados NOM y NFPA con entrega el mismo día en Ciudad de México y Estado de México. Extintores, señalamientos, sistemas CI, equipo para bomberos, gabinetes, mangueras, primeros auxilios y EPP. Proveedor directo con asesoría técnica gratuita."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <!-- ── Barra de migas de pan ────────────────────────────── -->
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Productos' }
  ]} />

  <!-- ── Secciones ──────────────────────────────────────── -->
  <HeroProductos />
  <CtaBar />
  <CatalogoProductos />
  <SeleccionIndex />
  <NormasIndex />
  <ProcesoIndex />
  <FaqCotizacionIndex />
  <CTAFinalIndex />

  <!-- ── Datos estructurados JSON-LD ──────────────────────
       Inyectados al final del <body> para no bloquear render
  ─────────────────────────────────────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaOfferCatalog)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

</Base>
