---
import Base from '../layouts/Base.astro';
import CtaBar from '../components/CtaBar.astro';
import FaqCotizacion from '../components/FaqCotizacion.astro';
import '../styles/pages.css';

const WHATSAPP = "525537238544";
const WA_URL = `https://wa.me/${WHATSAPP}`;

// ── SEO ─────────────────────────────────────────────
const title = "Catálogo de Productos Contra Incendios CDMX | Proyecto Red";
const description = "Catálogo de equipos contra incendios certificados NOM: extintores, señalamientos, sistemas CI, equipo bomberos y más. Proveedor directo en CDMX.";

// ── Breadcrumb ───────────────────────────────────────
const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Productos" },
];

// ── Métricas ─────────────────────────────────────────
const metricas = [
  { valor: "8+", label: "Categorías de equipo" },
  { valor: "50+", label: "Productos en catálogo" },
  { valor: "NOM", label: "Certificación incluida" },
  { valor: "24h", label: "Entrega en CDMX" },
];

// ── Categorías principales ────────────────────────────
const categorias = [
  {
    id: "extintores",
    titulo: "Extintores",
    badge: "NOM-154-SCFI",
    desc: "Primera línea de defensa para cualquier tipo de riesgo. Extintores certificados para todos los tipos de fuego: eléctrico, cocinas, áreas de oficina, industria y más.",
    href: "/extintores/",
    img: "/imagenes/extintores/extintores-contra-incendios.jpg",
    productos: [
      { nombre: "Polvo Seco ABC", sub: "Multiusos — oficinas, bodegas, vehículos", href: "/extintores/polvo-seco/", badge: "Más vendido" },
      { nombre: "CO₂ Dióxido de Carbono", sub: "Electrónica, servidores, laboratorios", href: "/extintores/co2/" },
      { nombre: "AFFF / Espuma", sub: "Líquidos inflamables, gasolineras, talleres", href: "/extintores/afff/" },
      { nombre: "Tipo K — Cocinas", sub: "Aceites vegetales, freidoras industriales", href: "/extintores/tipo-k/", badge: "Restaurantes" },
      { nombre: "Púrpura K", sub: "Grasas animales, cocinas de alto volumen", href: "/extintores/purpura-k/" },
      { nombre: "Agua a Presión", sub: "Materiales sólidos, papel, madera, textiles", href: "/extintores/agua-a-presion/" },
      { nombre: "Cold Fire", sub: "Supresión rápida con menor daño colateral", href: "/extintores/cold-fire/" },
      { nombre: "Automáticos", sub: "Activación autónoma sin intervención humana", href: "/extintores/automaticos/" },
      { nombre: "ABC Multiusos", sub: "Solución versátil para riesgos mixtos", href: "/extintores/abc/" },
      { nombre: "Agente Limpio", sub: "Centros de datos, archivos, equipos críticos", href: "/extintores/agente-limpio/", badge: "Premium" },
    ],
  },
  {
    id: "equipo-bomberos",
    titulo: "Equipo para Bomberos",
    badge: "NFPA 1971",
    desc: "Protección personal certificada NFPA para cuerpos de bomberos, brigadas industriales y equipos de respuesta a emergencias.",
    href: "/equipo-bomberos/",
    img: "/imagenes/equipo-bomberos/equipo-bomberos-hero.jpg",
    productos: [
      { nombre: "Trajes Estructurales", sub: "Protección térmica y química certificada NFPA", href: "/equipo-bomberos/trajes/", badge: "NFPA 1971" },
      { nombre: "Complementos de Uniforme", sub: "Casco, guantes, botas y capucha", href: "/equipo-bomberos/complementos/" },
      { nombre: "ERA — Respiración Autónoma", sub: "Equipos de aire autónomo para atmósferas peligrosas", href: "/equipo-bomberos/respiracion-autonoma/", badge: "Esencial" },
      { nombre: "Herramientas de Rescate", sub: "Quijadas de vida, hachas, palancas", href: "/equipo-bomberos/herramientas/" },
      { nombre: "Arneses de Rescate", sub: "Para trabajos en altura y rescate vertical", href: "/equipo-bomberos/arneses/" },
    ],
  },
  {
    id: "senalamientos",
    titulo: "Señalamientos de Emergencia",
    badge: "NOM-003-SEGOB",
    desc: "Señalética fotoluminiscente conforme a NOM-003-SEGOB y NOM-026-STPS. Visibles en cortes de luz — indispensables para pasar inspecciones de Protección Civil.",
    href: "/senalamientos/",
    img: "/imagenes/senalamientos/senalamientos-hero.jpg",
    productos: [
      { nombre: "Señales de Prohibición", sub: "No fumar, no paso, no usar en caso de incendio", href: "/senalamientos/prohibicion/" },
      { nombre: "Señales de Obligación", sub: "Uso de EPP, acceso autorizado, equipo obligatorio", href: "/senalamientos/obligacion/" },
      { nombre: "Señales de Advertencia", sub: "Riesgo eléctrico, material inflamable, piso resbaloso", href: "/senalamientos/advertencia/" },
      { nombre: "Señales de Salvación / Evacuación", sub: "Salidas de emergencia, rutas, punto de reunión", href: "/senalamientos/salvacion/", badge: "Obligatorio" },
    ],
  },
  {
    id: "gabinetes",
    titulo: "Gabinetes y Porta Extintores",
    badge: null,
    desc: "Resguardo y acceso inmediato para equipo contra incendios. Gabinetes metálicos para extintor, manguera y equipo de bombero, con o sin cerrojo de emergencia.",
    href: "/gabinetes/",
    img: "/imagenes/gabinetes/gabinetes-extintores.jpg",
    productos: [
      { nombre: "Gabinete para Extintor", sub: "Metálico, varios tamaños, con y sin visor", href: "/gabinetes/para-extintor/", badge: "Más popular" },
      { nombre: "Porta Extintor con Cenicero", sub: "Para áreas de fumadores y accesos", href: "/gabinetes/porta-extintor-cenicero/" },
      { nombre: "Gabinete para Bombero", sub: "Almacén completo de equipo de respuesta", href: "/gabinetes/para-bombero/" },
      { nombre: "Gabinete para Hidrante", sub: "Resguardo de manguera y herrajes en edificios", href: "/gabinetes/para-hidrante/" },
    ],
  },
  {
    id: "mangueras",
    titulo: "Mangueras y Herrajes",
    badge: null,
    desc: "Conducción de agua a alta presión para respuesta inmediata ante incendios. Todo lo necesario para sistemas hidrantes en edificios, plantas y espacios industriales.",
    href: "/mangueras/",
    img: "/imagenes/mangueras/mangueras-hero.jpg",
    productos: [
      { nombre: "Mangueras para Hidrante", sub: "Fibra sintética, alta presión, varios diámetros", href: "/mangueras/para-hidrante/", badge: "Indispensable" },
      { nombre: "Chiflones y Boquillas", sub: "Neblina, chorro directo y combinados", href: "/mangueras/chiflones/" },
      { nombre: "Válvulas de Control", sub: "Válvulas angulares, globo y de paso", href: "/mangueras/valvulas/" },
      { nombre: "Adaptadores y Uniones", sub: "Conexiones NST, Storz y tipo bombero", href: "/mangueras/adaptadores/" },
      { nombre: "Carretes Porta Manguera", sub: "Fijos y giratorios para edificios", href: "/mangueras/carretes/" },
      { nombre: "Toma Siamesa", sub: "Conexión exterior para bomberos", href: "/mangueras/toma-siamesa/" },
      { nombre: "Llaves de Herramienta", sub: "Para conexión y desconexión rápida de mangueras", href: "/mangueras/llaves/" },
      { nombre: "Monitores", sub: "Cañones de agua fijos y móviles para industria", href: "/mangueras/monitores/" },
    ],
  },
  {
    id: "sistemas",
    titulo: "Sistemas Contra Incendio",
    badge: "NFPA 13/72",
    desc: "Detección, supresión y control automático para protección total de instalaciones. Sistemas llave en mano con ingeniería, instalación y certificación incluidas.",
    href: "/sistemas/",
    img: "/imagenes/sistemas/alarmas.jpg",
    productos: [
      { nombre: "Alarmas contra Incendio", sub: "Convencionales y analógico-direccionables", href: "/sistemas/alarmas/", badge: "NFPA 72" },
      { nombre: "Detectores de Humo y Calor", sub: "Iónicos, fotoeléctricos y termovelocimétricos", href: "/sistemas/detectores/" },
      { nombre: "Rociadores Automáticos", sub: "Sistemas húmedos, secos y de diluvio", href: "/sistemas/rociadores/", badge: "NFPA 13" },
      { nombre: "Tableros de Control", sub: "Paneles convencionales y analógicos con monitoreo", href: "/sistemas/tableros/" },
      { nombre: "Redes Hidráulicas", sub: "Diseño e instalación de redes para rociadores", href: "/sistemas/redes-hidraulicas/" },
    ],
  },
  {
    id: "primeros-auxilios",
    titulo: "Primeros Auxilios",
    badge: "NOM-005-STPS",
    desc: "Kits de respuesta inmediata conforme a normativa STPS. Botiquines, camillas y material de curación para oficinas, plantas industriales y vehículos.",
    href: "/primeros-auxilios/",
    img: "/imagenes/primeros-auxilios/botiquines-hero.jpg",
    productos: [
      { nombre: "Botiquines STPS", sub: "Tipo A (oficinas), Tipo B (industria), Tipo C (vehículos)", href: "/primeros-auxilios/", badge: "NOM-005-STPS" },
      { nombre: "Camillas de Emergencia", sub: "Rígidas, plegables y de rescate vertical", href: "/primeros-auxilios/" },
      { nombre: "Collarines Cervicales", sub: "Tallas adulto y pediátrico, ajustables", href: "/primeros-auxilios/" },
      { nombre: "Material de Curación", sub: "Vendas, gasas, torniquetes, desinfectantes", href: "/primeros-auxilios/" },
    ],
  },
  {
    id: "equipo-seguridad",
    titulo: "Equipo de Seguridad Industrial",
    badge: "NOM-017-STPS",
    desc: "EPP certificado para entornos industriales, comerciales y de construcción. Protección para cabeza, ojos, manos, oídos y cuerpo conforme a normativa STPS.",
    href: "/equipo-seguridad/",
    img: "/imagenes/equipo-seguridad/equipos-seguridad-hero.jpg",
    productos: [
      { nombre: "Cascos de Seguridad", sub: "Tipo I y II, clases E y G, varios colores", href: "/equipo-seguridad/", badge: "NOM-115" },
      { nombre: "Lentes de Protección", sub: "Claros, oscuros, con ventilación lateral", href: "/equipo-seguridad/" },
      { nombre: "Guantes de Seguridad", sub: "Nitrilo, cuero, anticorte y dieléctricos", href: "/equipo-seguridad/" },
      { nombre: "Chalecos Reflectantes", sub: "Clase 2 y 3, naranja y amarillo", href: "/equipo-seguridad/" },
      { nombre: "Tapones y Orejeras Auditivas", sub: "SNR 27-33 dB para ruidos industriales", href: "/equipo-seguridad/" },
      { nombre: "Conos de Señalización", sub: "28\", 36\" y 42\" con y sin banda reflectiva", href: "/equipo-seguridad/" },
    ],
  },
];
---

<Base
  title={title}
  description={description}
>

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-left">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          {breadcrumbs.map((b, i) => (
            <>
              {i > 0 && <span class="breadcrumb__sep" aria-hidden="true">/</span>}
              {b.href
                ? <a href={b.href} class="breadcrumb__link">{b.label}</a>
                : <span class="breadcrumb__current" aria-current="page">{b.label}</span>
              }
            </>
          ))}
        </nav>
        <div class="hero-badge">
          <span class="badge-dot"></span>
          Catálogo certificado NOM y NFPA
        </div>
        <h1>Catálogo de Equipos<br>Contra <span class="h1-accent">Incendios</span></h1>
        <p class="hero-sub">
          Más de 50 productos en 8 categorías. Todo certificado NOM y NFPA. Entrega directa en CDMX y Estado de México con asesoría técnica incluida.
        </p>
        <div class="hero-ctas">
          <a
            href={`${WA_URL}?text=Hola%2C%20quiero%20cotizar%20equipos%20del%20cat%C3%A1logo`}
            class="btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Solicitar cotización
          </a>
          <a href="#catalogo" class="btn-secondary">Ver catálogo completo</a>
        </div>
      </div>

      <div class="hero-right">
        <p>En Proyecto Red somos proveedores directos de equipo contra incendios certificado para empresas, plantas industriales, restaurantes, edificios y cuerpos de bomberos en la Ciudad de México y el Estado de México.</p>
        <p>Cada producto de nuestro catálogo cumple con las normas NOM y NFPA vigentes. Entregamos con documentación completa: fichas técnicas, certificados de conformidad y etiqueta de inspección lista para tu expediente de Protección Civil y STPS.</p>
      </div>
    </div>
  </section>

  <CtaBar />

  <!-- ══════════════════════════════════════
       MÉTRICAS
  ══════════════════════════════════════ -->
  <section class="metricas-section" aria-label="Capacidades">
    <div class="container">
      <div class="metricas-grid">
        {metricas.map(m => (
          <div class="metrica-item">
            <span class="metrica-valor">{m.valor}</span>
            <span class="metrica-label">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       NAVEGACIÓN RÁPIDA — CATEGORÍAS
  ══════════════════════════════════════ -->
  <section class="nav-cats" aria-label="Navegación por categoría">
    <div class="container">
      <div class="nav-cats__inner">
        <span class="nav-cats__label">Ir a categoría:</span>
        <div class="nav-cats__links">
          {categorias.map(cat => (
            <a href={`#${cat.id}`} class="nav-cat-pill">{cat.titulo}</a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       CATÁLOGO COMPLETO
  ══════════════════════════════════════ -->
  <main id="catalogo">
    {categorias.map((cat, idx) => (
      <section
        id={cat.id}
        class={`cat-section ${idx % 2 === 0 ? 'cat-section--white' : 'cat-section--gray'}`}
        aria-labelledby={`cat-title-${cat.id}`}
      >
        <div class="container">

          {/* Header de categoría */}
          <div class="cat-header">
            <div class="cat-header__img-wrap">
              <img
                src={cat.img}
                alt={`${cat.titulo} — ${cat.desc.substring(0, 80)}`}
                loading={idx === 0 ? 'eager' : 'lazy'}
                width="640"
                height="400"
              />
              <div class="cat-header__img-overlay"></div>
              <div class="cat-header__img-content">
                {cat.badge && <span class="cat-norm-badge">{cat.badge}</span>}
                <h2 id={`cat-title-${cat.id}`}>{cat.titulo}</h2>
              </div>
            </div>

            <div class="cat-header__info">
              <div class="cat-header__meta">
                <span class="section-label">Categoría</span>
                {cat.badge && <span class="cat-badge-pill">{cat.badge}</span>}
              </div>
              <h2 class="cat-header__title">{cat.titulo}</h2>
              <p class="cat-header__desc">{cat.desc}</p>
              <div class="cat-header__ctas">
                <a href={cat.href} class="btn-outline">Ver categoría completa</a>
                <a
                  href={`${WA_URL}?text=Hola%2C%20necesito%20cotizar%20${encodeURIComponent(cat.titulo)}`}
                  class="cat-wa-link"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  Cotizar por WhatsApp
                </a>
              </div>
            </div>
          </div>

          {/* Grid de productos */}
          <div class="productos-grid">
            {cat.productos.map(p => (
              <a href={p.href} class="prod-card" aria-label={p.nombre}>
                <div class="prod-card__top">
                  {p.badge && <span class="prod-badge">{p.badge}</span>}
                  {!p.badge && <span class="prod-badge prod-badge--ghost">Disponible</span>}
                </div>
                <div class="prod-card__body">
                  <h3 class="prod-card__name">{p.nombre}</h3>
                  <p class="prod-card__sub">{p.sub}</p>
                </div>
                <div class="prod-card__footer">
                  <span class="prod-card__link">
                    Ver detalles
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </span>
                </div>
              </a>
            ))}

            {/* Card CTA de cotización */}
            <a
              href={`${WA_URL}?text=Hola%2C%20quiero%20cotizar%20${encodeURIComponent(cat.titulo)}`}
              class="prod-card prod-card--cta"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`Cotizar ${cat.titulo}`}
            >
              <div class="prod-card-cta__icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <p class="prod-card-cta__text">¿No encuentras lo que buscas?</p>
              <p class="prod-card-cta__sub">Cotiza por WhatsApp — respondemos en menos de 24 horas</p>
              <span class="prod-card-cta__btn">Escribir al WhatsApp →</span>
            </a>
          </div>

        </div>
      </section>
    ))}
  </main>

  <!-- ══════════════════════════════════════
       FAQ + COTIZACIÓN
  ══════════════════════════════════════ -->
  <FaqCotizacion
    titulo="Preguntas Frecuentes sobre Nuestros Productos"
    subtitulo="Todo lo que necesitas saber sobre equipos contra incendios certificados antes de hacer tu pedido"
    pageId="productos"
    bgGray={true}
  />

