---
/**
 * productos.astro — Página de catálogo de Proyecto Red
 * ─────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO.
 * Mismo patrón que index.astro — cada sección es un componente autónomo.
 */

import Base              from '../layouts/Base.astro'
import Breadcrumb        from '../components/ui/Breadcrumb.astro'
import CtaBar            from '../components/CtaBar.astro'

// ── Secciones de Productos ─────────────────────────────
import HeroProductos       from '../components/sections/HeroProductos.astro'
import CatalogoProductos   from '../components/sections/CatalogoProductos.astro'
import SeleccionIndex      from '../components/sections/SeleccionIndex.astro'
import NormasIndex         from '../components/sections/NormasIndex.astro'
import ProcesoIndex        from '../components/sections/ProcesoIndex.astro'
import FaqCotizacionIndex  from '../components/sections/FaqCotizacionIndex.astro'
import CTAFinalIndex       from '../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ──────────────────────────────────
import { SITE, CONTACT } from '../config/site'

const siteUrl   = SITE.url
const pageUrl   = `${siteUrl}/productos/`
const ogImage   = `${siteUrl}/imagenes/og/proyectored-og.jpg`

// ── Schema: BreadcrumbList ──────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Productos",
      "item": pageUrl
    }
  ]
}

// ── Schema: OfferCatalog ────────────────────────────────
const schemaOfferCatalog = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "Catálogo de Equipos Contra Incendios — Proyecto Red",
  "description": "Catálogo completo de equipos contra incendios certificados NOM y NFPA: extintores, señalamientos, equipo para bomberos, gabinetes, mangueras, sistemas CI, primeros auxilios y EPP.",
  "url": pageUrl,
  "numberOfItems": 50,
  "itemListElement": [
    { "@type": "OfferCatalog", "name": "Extintores certificados NOM-154-SCFI", "url": `${siteUrl}/extintores/` },
    { "@type": "OfferCatalog", "name": "Equipo para Bomberos NFPA 1971", "url": `${siteUrl}/equipo-bomberos/` },
    { "@type": "OfferCatalog", "name": "Señalamientos de Emergencia NOM-003-SEGOB", "url": `${siteUrl}/senalamientos/` },
    { "@type": "OfferCatalog", "name": "Gabinetes y Porta Extintores", "url": `${siteUrl}/gabinetes/` },
    { "@type": "OfferCatalog", "name": "Mangueras y Herrajes contra incendio", "url": `${siteUrl}/mangueras/` },
    { "@type": "OfferCatalog", "name": "Sistemas Contra Incendio NFPA 13/72", "url": `${siteUrl}/sistemas/` },
    { "@type": "OfferCatalog", "name": "Primeros Auxilios NOM-005-STPS", "url": `${siteUrl}/primeros-auxilios/` },
    { "@type": "OfferCatalog", "name": "Equipo de Seguridad Industrial NOM-017-STPS", "url": `${siteUrl}/equipo-seguridad/` },
  ]
}

// ── Schema: FAQPage (producto-específicas) ──────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta un extintor certificado en CDMX?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El precio varía según el tipo y capacidad. Un cilindro de polvo seco (PQS) de 4 kg para uso general parte desde $450 MXN. Los modelos de CO₂ para electrónica y los Tipo K para cocinas industriales tienen precios distintos. Contáctanos por WhatsApp para precio directo ese mismo día."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué extintores exige Protección Civil para mi empresa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depende del tipo de riesgo y superficie. La NOM-002-STPS establece una unidad por cada 300 m² de área, mínimo uno por piso. Para oficinas se recomienda el ABC multipropósito; para cocinas, el Tipo K; para servidores, el CO₂ o agente limpio. Realizamos diagnóstico técnico sin costo."
      }
    },
    {
      "@type": "Question",
      "name": "¿Hacen entrega a domicilio en CDMX y Estado de México?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Entregamos en toda la Ciudad de México y el Estado de México. Los pedidos confirmados antes de las 2 PM los entregamos el mismo día en la zona metropolitana. También coordinamos envíos al interior de la república para pedidos de volumen."
      }
    },
    {
      "@type": "Question",
      "name": "¿Los extintores incluyen certificado NOM?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Todos nuestros equipos cumplen con la NOM-154-SCFI y vienen con la documentación necesaria para tu expediente regulatorio: etiqueta de inspección, garantía y ficha técnica del fabricante."
      }
    },
    {
      "@type": "Question",
      "name": "¿También hacen mantenimiento y recarga de extintores?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Ofrecemos mantenimiento preventivo, recarga y verificación en tus instalaciones. El servicio incluye revisión del agente de extinción, presión, válvulas, manguera y etiqueta de inspección actualizada."
      }
    },
    {
      "@type": "Question",
      "name": "¿Manejan precios por volumen para empresas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Ofrecemos precios preferenciales, facturación consolidada y entregas programadas para empresas con múltiples sucursales, plantas o proyectos. Contáctanos para un esquema de suministro a tu medida."
      }
    }
  ]
}
---

<Base
  title="Catálogo de Productos Contra Incendios CDMX | Proyecto Red"
  description="Catálogo completo de equipos contra incendios certificados: extintores, señalamientos NOM, equipo para bomberos, gabinetes, mangueras, sistemas CI, primeros auxilios y EPP. Entrega en CDMX y Estado de México."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <!-- ── Barra de migas de pan ────────────────────────────── -->
  <div class="breadcrumb-bar">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Inicio', href: '/' },
        { label: 'Productos' }
      ]} />
    </div>
  </div>

  <!-- ── Secciones ──────────────────────────────────────── -->
  <HeroProductos />
  <CtaBar />
  <CatalogoProductos />
  <SeleccionIndex />
  <NormasIndex />
  <ProcesoIndex />
  <FaqCotizacionIndex />
  <CTAFinalIndex />

  <!-- ── Datos estructurados JSON-LD ──────────────────────
       Inyectados al final del <body> para no bloquear render
  ─────────────────────────────────────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaOfferCatalog)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

</Base>
