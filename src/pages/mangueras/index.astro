---
/**
 * mangueras/index.astro — L3 Mangueras y Herrajes Contra Incendio
 * ─────────────────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO + JSON-LD de nivel técnico.
 * Estructura 100% homologada con extintores/index.astro (L3 template autorizado).
 * Cada sección vive en src/components/sections/ con sus propios estilos.
 */

import Base              from '../../layouts/Base.astro'
import CtaBar            from '../../components/CtaBar.astro'
import Breadcrumb        from '../../components/ui/Breadcrumb.astro'

// ── Secciones específicas de mangueras ─────────────────────
import HeroMangueras     from '../../components/sections/HeroMangueras.astro'
import CatalogoMangueras from '../../components/sections/CatalogoMangueras.astro'
import GuiaMangueras     from '../../components/sections/GuiaMangueras.astro'
import NormasMangueras   from '../../components/sections/NormasMangueras.astro'
import FaqMangueras      from '../../components/sections/FaqMangueras.astro'

// ── Secciones genéricas reutilizadas ───────────────────────
import TrustIndex        from '../../components/sections/TrustIndex.astro'
import CategoriasRelacionadas from '../../components/sections/CategoriasRelacionadas.astro'
import CTAFinalIndex     from '../../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ─────────────────────────────────────
import { SITE, CONTACT } from '../../config/site'

const siteUrl = SITE.url
const pageUrl = `${siteUrl}/mangueras/`
const ogImage = `${siteUrl}/imagenes/og/mangueras-og.jpg`

// ── Schema: ItemList — 8 productos ────────────────────────
const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Mangueras y herrajes contra incendio — Proyecto Red",
  "description": "Catálogo de mangueras NFPA 1961 y herrajes para sistemas hidráulicos: mangueras de hidrante, chiflones, válvulas, adaptadores NST/Storz, carretes, toma siamesa, llaves y monitores.",
  "url": pageUrl,
  "numberOfItems": 8,
  "itemListElement": [
    {
      "@type": "ListItem", "position": 1,
      "name": "Mangueras para Hidrante",
      "description": "NFPA 1961. Diámetros 1.5\", 2.5\" y 4\". Longitudes 15, 20 y 30 m. Jacket doble, 300 PSI. Prueba hidrostática incluida.",
      "url": `${siteUrl}/mangueras/para-hidrante/`
    },
    {
      "@type": "ListItem", "position": 2,
      "name": "Chiflones y Boquillas",
      "description": "NFPA 1964. Chorro directo, niebla y combinado. Aluminio y bronce. Para 1.5\" y 2.5\". 95-250 GPM.",
      "url": `${siteUrl}/mangueras/chiflones/`
    },
    {
      "@type": "ListItem", "position": 3,
      "name": "Válvulas de Control",
      "description": "Angular 2½\" para gabinetes, compuerta para redes, check anti-retorno y alivio. Bronce e hierro dúctil.",
      "url": `${siteUrl}/mangueras/valvulas/`
    },
    {
      "@type": "ListItem", "position": 4,
      "name": "Adaptadores y Conexiones",
      "description": "NST, Storz, reducciones de diámetro. Aluminio, bronce y fundición. Compatibilidad entre sistemas de diferente rosca.",
      "url": `${siteUrl}/mangueras/adaptadores/`
    },
    {
      "@type": "ListItem", "position": 5,
      "name": "Carretes Porta Manguera",
      "description": "De pared, pivotante y con gabinete integrado. Capacidad para 30 m de manguera en 1.5\" y 2.5\".",
      "url": `${siteUrl}/mangueras/carretes/`
    },
    {
      "@type": "ListItem", "position": 6,
      "name": "Toma Siamesa",
      "description": "2×2½\" NST. Hierro fundido rojo. Válvulas check integradas. Tapones con cadena. Obligatoria en edificios con red de hidrantes.",
      "url": `${siteUrl}/mangueras/toma-siamesa/`
    },
    {
      "@type": "ListItem", "position": 7,
      "name": "Llaves Spanner",
      "description": "Universal para NST 1.5\" y 2.5\". Aluminio forjado. Para conectar y desconectar acoples rápidamente bajo presión.",
      "url": `${siteUrl}/mangueras/llaves/`
    },
    {
      "@type": "ListItem", "position": 8,
      "name": "Monitores Contra Incendio",
      "description": "500-2000 GPM. Fijo en estructura o portátil. Bronce o acero inoxidable. Distribuidor Elkhart Brass. Para patios industriales de alto riesgo.",
      "url": `${siteUrl}/mangueras/monitores/`
    }
  ]
}

// ── Schema: FAQPage ────────────────────────────────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué diámetro de manguera necesito para mi edificio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "1.5\" para residencial y brigadas no profesionales. 2.5\" para edificios comerciales e industriales con sistema standpipe. 4\" para bomberos profesionales y plantas industriales de alto caudal. Si ya hay red de hidrantes, el diámetro lo determina la tubería existente."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es la diferencia entre acoples NST y Storz?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "NST es rosca estándar en México — requiere varios giros para acoplar. Storz es acople simétrico de cuarto de giro sin rosca, más rápido pero menos común en instalaciones existentes. Vendemos adaptadores NST-Storz para compatibilidad entre ambos sistemas."
      }
    },
    {
      "@type": "Question",
      "name": "¿La toma siamesa es obligatoria en mi edificio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, si el edificio tiene sistema de rociadores automáticos o red de hidrantes. Se instala en fachada exterior a máximo 30 metros de donde se estaciona el camión de bomberos. Sin ella, Protección Civil hace observación al expediente."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cada cuánto se deben probar las mangueras contra incendio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "NFPA 1962 exige prueba hidrostática anual. Una manguera que falla se retira de servicio inmediatamente. Ofrecemos servicio de prueba hidrostática en instalaciones con certificado de conformidad."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta un sistema de manguera completo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gabinete con manguera 30 m, válvula y chiflón por piso desde $6,500 MXN. Toma siamesa desde $3,200 MXN. Carretes desde $2,800 MXN. Para edificios de 10 pisos el sistema completo puede ir de $75,000 a $150,000 MXN según configuración."
      }
    },
    {
      "@type": "Question",
      "name": "¿Puedo comprar solo los herrajes sin la manguera?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Vendemos todo por separado: chiflones, válvulas, adaptadores, llaves, carretes y tomas siamesas como piezas individuales. Para sistema nuevo completo cotizamos paquete con precio preferencial y verificamos compatibilidad de todos los componentes."
      }
    }
  ]
}

// ── Schema: BreadcrumbList ─────────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
    { "@type": "ListItem", "position": 3, "name": "Mangueras y Herrajes", "item": pageUrl }
  ]
}

// ── Schema: CollectionPage ─────────────────────────────────
const schemaWebPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Mangueras y Herrajes Contra Incendio NFPA en CDMX | Proyecto Red",
  "description": "Venta de mangueras NFPA 1961 y herrajes para sistemas hidráulicos: chiflones, válvulas, adaptadores NST/Storz, carretes, toma siamesa y monitores. Sistema completo por piso desde $6,500 MXN. Entrega en CDMX.",
  "url": pageUrl,
  "image": ogImage,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "Proyecto Red", "url": siteUrl },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
      { "@type": "ListItem", "position": 3, "name": "Mangueras", "item": pageUrl }
    ]
  },
  "mainEntity": {
    "@id": pageUrl + "#itemlist"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Proyecto Red",
    "url": siteUrl,
    "logo": `${siteUrl}/imagenes/logos/equipo-contra-incendios.jpg`,
    "telephone": `+52${CONTACT.phoneRaw}`,
    "email": CONTACT.email
  }
}
---

<Base
  title="Mangueras y Herrajes Contra Incendio NFPA en CDMX | Proyecto Red"
  description="Venta de mangueras NFPA 1961 y herrajes para sistemas hidráulicos: chiflones, válvulas, adaptadores NST/Storz, carretes, toma siamesa y monitores. Sistema completo por piso desde $6,500 MXN. Entrega directa en CDMX."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Productos', href: '/productos/' },
    { label: 'Mangueras y Herrajes' }
  ]} />

  <HeroMangueras />
  <CtaBar />
  <CatalogoMangueras />
  <GuiaMangueras />
  <TrustIndex />
  <NormasMangueras />
  <FaqMangueras />
  <CategoriasRelacionadas current="mangueras" />
  <CTAFinalIndex />

  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebPage)} />

</Base>
