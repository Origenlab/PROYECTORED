---
/**
 * sistemas/index.astro — L3 Sistemas Contra Incendio
 * ─────────────────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO + JSON-LD de nivel técnico.
 * Estructura 100% homologada con extintores/index.astro (L3 template autorizado).
 * Cada sección vive en src/components/sections/ con sus propios estilos.
 */

import Base              from '../../layouts/Base.astro'
import CtaBar            from '../../components/CtaBar.astro'
import Breadcrumb        from '../../components/ui/Breadcrumb.astro'

// ── Secciones específicas de sistemas ──────────────────────
import HeroSistemas      from '../../components/sections/HeroSistemas.astro'
import CatalogoSistemas  from '../../components/sections/CatalogoSistemas.astro'
import GuiaSistemas      from '../../components/sections/GuiaSistemas.astro'
import NormasSistemas    from '../../components/sections/NormasSistemas.astro'
import FaqSistemas       from '../../components/sections/FaqSistemas.astro'

// ── Secciones genéricas reutilizadas ───────────────────────
import TrustIndex        from '../../components/sections/TrustIndex.astro'
import CategoriasRelacionadas from '../../components/sections/CategoriasRelacionadas.astro'
import CTAFinalIndex     from '../../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ─────────────────────────────────────
import { SITE, CONTACT } from '../../config/site'

const siteUrl = SITE.url
const pageUrl = `${siteUrl}/sistemas/`
const ogImage = `${siteUrl}/imagenes/og/sistemas-og.jpg`

// ── Schema: ItemList — 5 subsistemas ──────────────────────
const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Sistemas contra incendio NFPA — Proyecto Red",
  "description": "Catálogo de sistemas contra incendio: alarmas NFPA 72, detectores, rociadores automáticos NFPA 13, tableros de control FACP y redes hidráulicas NFPA 14/20.",
  "url": pageUrl,
  "numberOfItems": 5,
  "itemListElement": [
    {
      "@type": "ListItem", "position": 1,
      "name": "Alarmas Contra Incendio",
      "description": "Paneles convencionales para espacios simples y sistemas direccionables para edificios complejos con identificación exacta de zona. Batería de respaldo 24h. UL Listed.",
      "url": `${siteUrl}/sistemas/alarmas/`
    },
    {
      "@type": "ListItem", "position": 2,
      "name": "Detectores de Humo e Incendio",
      "description": "Fotoeléctrico para fuegos lentos, iónico para combustión rápida, calor fijo para cocinas, VESDA para detección muy temprana. Direccionable IP42–IP55.",
      "url": `${siteUrl}/sistemas/detectores/`
    },
    {
      "@type": "ListItem", "position": 3,
      "name": "Rociadores Automáticos",
      "description": "Colgante, montante y lateral. Temperatura 57°C, 93°C y 141°C. Sistema tubo húmedo o seco. Diseño conforme a NFPA 13 con cálculo hidráulico incluido.",
      "url": `${siteUrl}/sistemas/rociadores/`
    },
    {
      "@type": "ListItem", "position": 4,
      "name": "Tableros de Control FACP",
      "description": "Convencional y analógico-direccionable. UL864 certificado life-safety. 2 a 2048 puntos de detección. Monitoreo remoto y notificación automática.",
      "url": `${siteUrl}/sistemas/tableros/`
    },
    {
      "@type": "ListItem", "position": 5,
      "name": "Redes Hidráulicas",
      "description": "Tubería CPVC para rociadores, acero negro Schedule 40 para redes principales. Bomba eléctrica + diésel conforme a NFPA 20. Cálculo hidráulico y planos incluidos.",
      "url": `${siteUrl}/sistemas/redes-hidraulicas/`
    }
  ]
}

// ── Schema: FAQPage ────────────────────────────────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta instalar un sistema contra incendio completo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depende del tipo de inmueble y los subsistemas requeridos. Un sistema básico de alarma para oficinas de 500 m² parte desde $45,000 MXN. Un sistema de rociadores para nave industrial de 1,000 m² puede ir de $180,000 a $350,000 MXN. Un sistema completo (alarma + rociadores + red hidráulica + bomba) para edificio de 10 pisos puede ir de $500,000 a $1,200,000 MXN. Hacemos cotización detallada sin compromiso después de diagnóstico del inmueble."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es la diferencia entre un sistema convencional y uno direccionable?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un sistema convencional divide el edificio en zonas — cuando hay alarma, sabes en qué zona está el fuego pero no cuál detector exacto la activó. Un sistema direccionable identifica exactamente qué detector se activó, en qué piso y en qué cuarto. Es obligatorio en edificios de más de 5 pisos o cuando hay más de 32 detectores."
      }
    },
    {
      "@type": "Question",
      "name": "¿Los rociadores automáticos son obligatorios en mi edificio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Son obligatorios conforme a NFPA 13 en bodegas de más de 300 m², centros comerciales, hoteles, hospitales, edificios de más de 23 metros de altura y áreas con carga de fuego alta. Hacemos diagnóstico gratuito para determinar si tu inmueble los requiere."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cada cuánto hay que darle mantenimiento al sistema?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mensual: prueba visual de detectores. Trimestral: prueba funcional. Semestral: prueba hidrostática de red y válvulas, prueba de bomba a plena carga (NFPA 25). Anual: inspección completa del sistema. Ofrecemos pólizas de mantenimiento anual con reportes válidos para expedientes de Protección Civil y STPS."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué pasa si la presión municipal no es suficiente para los rociadores?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Si la presión de la red no alcanza los mínimos de NFPA 13, la solución es una bomba contra incendio conforme a NFPA 20. Instalamos el conjunto completo: bomba eléctrica principal, bomba diésel de emergencia y bomba jockey de mantenimiento de presión."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto tiempo toma la instalación de un sistema completo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Una alarma convencional para oficina de 200 m² puede estar lista en 2-3 días. Un sistema direccionable para edificio de 5 pisos toma de 2 a 4 semanas. Un sistema completo (alarma + rociadores + red hidráulica + bomba) para nave industrial puede tomar de 6 a 12 semanas incluyendo cálculo hidráulico, planos, instalación y comisionamiento."
      }
    }
  ]
}

// ── Schema: BreadcrumbList ─────────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
    { "@type": "ListItem", "position": 3, "name": "Sistemas Contra Incendio", "item": pageUrl }
  ]
}

// ── Schema: CollectionPage ─────────────────────────────────
const schemaWebPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Sistemas Contra Incendio NFPA en CDMX | Proyecto Red",
  "description": "Diseño, instalación y mantenimiento de sistemas contra incendio en CDMX: alarmas NFPA 72, detectores, rociadores NFPA 13, tableros FACP y redes hidráulicas NFPA 20. Ingenieros certificados. Desde $45,000 MXN instalado.",
  "url": pageUrl,
  "image": ogImage,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "Proyecto Red", "url": siteUrl },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
      { "@type": "ListItem", "position": 3, "name": "Sistemas", "item": pageUrl }
    ]
  },
  "mainEntity": {
    "@id": pageUrl + "#itemlist"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Proyecto Red",
    "url": siteUrl,
    "logo": `${siteUrl}/imagenes/logos/equipo-contra-incendios.jpg`,
    "telephone": `+52${CONTACT.phoneRaw}`,
    "email": CONTACT.email
  }
}
---

<Base
  title="Sistemas Contra Incendio NFPA en CDMX | Proyecto Red"
  description="Diseño, instalación y mantenimiento de sistemas contra incendio en CDMX: alarmas NFPA 72, detectores, rociadores NFPA 13, tableros FACP y redes hidráulicas NFPA 20. Ingenieros certificados. Desde $45,000 MXN instalado."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Productos', href: '/productos/' },
    { label: 'Sistemas Contra Incendio' }
  ]} />

  <HeroSistemas />
  <CtaBar />
  <CatalogoSistemas />
  <GuiaSistemas />
  <TrustIndex />
  <NormasSistemas />
  <FaqSistemas />
  <CategoriasRelacionadas current="sistemas" />
  <CTAFinalIndex />

  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebPage)} />

</Base>
