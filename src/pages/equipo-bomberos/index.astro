---
/**
 * equipo-bomberos/index.astro — Categoría L3: equipo para bomberos — Proyecto Red
 * ─────────────────────────────────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO + JSON-LD técnico.
 * Estructura homologada con extintores/index.astro (L3 template aprobado).
 * Cada sección vive en src/components/sections/ con sus propios estilos.
 */

import Base                from '../../layouts/Base.astro'
import CtaBar              from '../../components/CtaBar.astro'
import Breadcrumb          from '../../components/ui/Breadcrumb.astro'

// ── Secciones específicas de equipo para bomberos ──────────
import HeroBomberos        from '../../components/sections/HeroBomberos.astro'
import CatalogoBomberos    from '../../components/sections/CatalogoBomberos.astro'
import GuiaBomberos        from '../../components/sections/GuiaBomberos.astro'
import NormasBomberos      from '../../components/sections/NormasBomberos.astro'
import FaqBomberos         from '../../components/sections/FaqBomberos.astro'

// ── Secciones genéricas reutilizadas del index ─────────────
import TrustIndex          from '../../components/sections/TrustIndex.astro'
import CategoriasRelacionadas from '../../components/sections/CategoriasRelacionadas.astro'
import CTAFinalIndex       from '../../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ─────────────────────────────────────
import { SITE, CONTACT } from '../../config/site'

const siteUrl = SITE.url
const pageUrl = `${siteUrl}/equipo-bomberos/`
const ogImage = `${siteUrl}/imagenes/og/equipo-bomberos-og.jpg`

// ── Schema: ItemList — 5 categorías de equipo ─────────────
const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Equipo profesional para bomberos certificado NFPA — Proyecto Red",
  "description": "Catálogo de equipo para bomberos y brigadas certificado NFPA: trajes estructurales NFPA 1971, ERA SCBA NIOSH, complementos de uniforme, herramientas de rescate y arneses NFPA 1983.",
  "url": pageUrl,
  "numberOfItems": 5,
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Trajes Estructurales NFPA 1971",
      "description": "Protección multicapa contra temperaturas extremas y llamas directas. Fabricados en Nomex, PBI y Kevlar. Chaquetón + pantalón con tirantes. Tallas S–4XL y sobre medida disponible.",
      "url": `${siteUrl}/equipo-bomberos/trajes/`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Complementos de Uniforme",
      "description": "Cascos NFPA 1971 con visor, guantes térmicos, botas certificadas, capuchas Nomex y gogles anti-flash. Cada pieza diseñada para el ensemble completo de protección estructural.",
      "url": `${siteUrl}/equipo-bomberos/complementos/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "ERA — Respiración Autónoma (SCBA)",
      "description": "Equipos SCBA certificados NIOSH con cilindros de 30, 45 y 60 minutos, máscaras panorámicas y alarma PASS integrada. Para atmósferas con humo, gases tóxicos o deficiencia de oxígeno.",
      "url": `${siteUrl}/equipo-bomberos/respiracion-autonoma/`
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "Herramientas de Rescate",
      "description": "Quijadas de vida, hachas, halligans, cortadores hidráulicos y herramientas manuales, neumáticas y eléctricas. Para rescate vehicular, estructural y en espacios confinados.",
      "url": `${siteUrl}/equipo-bomberos/herramientas/`
    },
    {
      "@type": "ListItem",
      "position": 5,
      "name": "Arneses de Rescate NFPA 1983",
      "description": "Arneses clase II y III certificados NFPA 1983 para trabajo en altura, rescate vertical y evacuación. Con puntos de anclaje dorsal y pectoral, hasta 140 kg en caída libre.",
      "url": `${siteUrl}/equipo-bomberos/arneses/`
    }
  ]
}

// ── Schema: FAQPage ────────────────────────────────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué certificaciones debe tener un traje de bombero?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un traje para combate estructural debe cumplir con la NFPA 1971, que exige tres capas: capa exterior resistente al fuego, barrera contra humedad y barrera térmica. Para bomberos forestales aplica la NFPA 1977. Para materiales peligrosos, la NFPA 1991 o 1992 según el nivel. Todos los trajes que vendemos incluyen certificación original del fabricante."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto dura un traje de bombero y cuándo hay que reemplazarlo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La NFPA 1851 establece una vida útil máxima de 10 años desde la fecha de fabricación. Requiere inspecciones visuales post-uso, limpiezas avanzadas semestrales e inspecciones técnicas anuales. Un traje que supera los 10 años debe retirarse del servicio independientemente de su estado aparente."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué es el ERA y por qué es obligatorio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "ERA (Equipo de Respiración Autónoma, SCBA en inglés) es un sistema portátil de aire comprimido con máscara panorámica y regulador NIOSH que permite respirar en atmósferas contaminadas. Es obligatorio en cualquier entrada a estructura en llamas — el humo de un incendio estructural contiene más de 100 compuestos tóxicos que incapacitan en segundos."
      }
    },
    {
      "@type": "Question",
      "name": "¿Venden equipo para brigadas industriales además de cuerpos de bomberos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Equipamos tanto cuerpos de bomberos profesionales como brigadas industriales de plantas petroleras, petroquímicas, farmacéuticas y de manufactura. Ayudamos a definir el equipo correcto según el análisis de riesgo y las normas STPS aplicables a cada sector."
      }
    },
    {
      "@type": "Question",
      "name": "¿Manejan trajes sobre medida y con bordado institucional?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Además de tallas estándar S a 4XL, gestionamos trajes sobre medida con el fabricante, incluyendo bordado institucional con nombre, número o escudo de la corporación, colores especiales y configuración de cintas reflectantes según los requerimientos de cada corporación."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta equipar a un bombero completo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El costo depende del nivel de equipo y las marcas seleccionadas. Un ensemble básico certificado (traje + casco + guantes + botas + capucha) tiene rangos que varían según marca y especificaciones. El ERA se cotiza aparte. Escríbenos con la cantidad de personal, el tipo de operación y el presupuesto disponible para opciones reales."
      }
    },
    {
      "@type": "Question",
      "name": "¿Hacen mantenimiento e inspección del equipo existente?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Realizamos inspecciones técnicas anuales conforme a NFPA 1851 para trajes y NFPA 1981 para ERA. El servicio incluye inspección de costuras, membranas y capas del traje, verificación de máscara y cilindro, y emitimos un reporte técnico útil para el expediente de la corporación."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cómo funciona la prueba hidrostática para los cilindros del ERA?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los cilindros ERA deben someterse a prueba hidrostática periódica: cada 5 años para cilindros de acero y aluminio, cada 3 años para fibra de carbono. La prueba verifica la integridad estructural bajo presión controlada. Un cilindro fuera de fecha no debe llenarse — representa riesgo de explosión."
      }
    }
  ]
}

// ── Schema: BreadcrumbList ─────────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": `${siteUrl}/`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Productos",
      "item": `${siteUrl}/productos/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Equipo para Bomberos",
      "item": pageUrl
    }
  ]
}

// ── Schema: CollectionPage (WebPage) ──────────────────────
const schemaWebPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Equipo para Bomberos Certificado NFPA en México — Trajes, ERA y Rescate | Proyecto Red",
  "description": "Catálogo de equipo profesional para bomberos y brigadas certificado NFPA: trajes estructurales NFPA 1971, ERA SCBA NIOSH, complementos de uniforme, herramientas de rescate y arneses NFPA 1983. Proveedor directo en CDMX.",
  "url": pageUrl,
  "image": ogImage,
  "inLanguage": "es-MX",
  "isPartOf": {
    "@type": "WebSite",
    "name": "Proyecto Red",
    "url": siteUrl
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
      { "@type": "ListItem", "position": 3, "name": "Equipo para Bomberos", "item": pageUrl }
    ]
  },
  "mainEntity": {
    "@id": pageUrl + "#itemlist"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Proyecto Red",
    "url": siteUrl,
    "logo": `${siteUrl}/imagenes/logos/equipo-contra-incendios.jpg`,
    "telephone": `+52${CONTACT.phoneRaw}`,
    "email": CONTACT.email
  }
}
---

<Base
  title="Equipo para Bomberos Certificado NFPA en México — Trajes, ERA y Rescate | Proyecto Red"
  description="Catálogo de equipo profesional para bomberos y brigadas certificado NFPA: trajes estructurales NFPA 1971, ERA SCBA NIOSH, complementos, herramientas de rescate y arneses. Proveedor directo en CDMX. Asesoría técnica gratuita."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <!-- ── Secciones ──────────────────────────────────────────── -->

  <!-- Barra de migas de pan -->
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Productos', href: '/productos/' },
    { label: 'Equipo para Bomberos' }
  ]} />

  <HeroBomberos />
  <CtaBar />
  <CatalogoBomberos />
  <GuiaBomberos />
  <TrustIndex />
  <NormasBomberos />
  <FaqBomberos />
  <CategoriasRelacionadas current="equipo-bomberos" />
  <CTAFinalIndex />

  <!-- ── Datos estructurados JSON-LD ────────────────────────
       Inyectados al final del <body> para no bloquear render
  ──────────────────────────────────────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebPage)} />

</Base>
