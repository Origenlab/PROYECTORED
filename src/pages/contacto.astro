---
/**
 * contacto.astro — Página de contacto y cotización de Proyecto Red
 * ─────────────────────────────────────────────────────────────────
 * Nivel L2: orquestador limpio de secciones modulares.
 * Mismo patrón que productos.astro — cada sección es un componente autónomo.
 *
 * Estructura:
 *   Breadcrumb → HeroContacto → CtaBar → CanalesContacto →
 *   DiferenciaContacto → CoberturaContacto → FaqCotizacionContacto →
 *   CTAFinalIndex
 *
 * SEO: JSON-LD (LocalBusiness, ContactPage, BreadcrumbList, FAQPage)
 */

import Base                    from '../layouts/Base.astro'
import Breadcrumb              from '../components/ui/Breadcrumb.astro'
import CtaBar                  from '../components/CtaBar.astro'

// ── Secciones de Contacto ─────────────────────────────
import HeroContacto            from '../components/sections/HeroContacto.astro'
import CanalesContacto         from '../components/sections/CanalesContacto.astro'
import DiferenciaContacto      from '../components/sections/DiferenciaContacto.astro'
import CoberturaContacto       from '../components/sections/CoberturaContacto.astro'
import FaqCotizacionContacto   from '../components/sections/FaqCotizacionContacto.astro'
import CTAFinalIndex           from '../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ──────────────────────────────────
import { SITE, CONTACT, SERVICES, COVERAGE_STATES } from '../config/site'

const siteUrl   = SITE.url
const pageUrl   = `${siteUrl}/contacto/`
const ogImage   = `${siteUrl}/imagenes/og/proyectored-og.jpg`

// ── Schema: BreadcrumbList ──────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Contacto",
      "item": pageUrl
    }
  ]
}

// ── Schema: LocalBusiness ───────────────────────────────
const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.name,
  "description": "Proveedor directo de equipos contra incendios certificados NOM y NFPA en la Ciudad de México y Estado de México. Venta, recarga, mantenimiento, instalación de sistemas CI, asesoría técnica y capacitación.",
  "url": siteUrl,
  "telephone": `+52${CONTACT.phoneRaw}`,
  "email": CONTACT.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Paseo de la Reforma 26",
    "addressLocality": "Cuauhtémoc",
    "addressRegion": "Ciudad de México",
    "postalCode": "06600",
    "addressCountry": "MX"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 19.4330,
    "longitude": -99.1515
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "08:00",
      "closes": "14:00"
    }
  ],
  "priceRange": "$$",
  "image": ogImage,
  "areaServed": COVERAGE_STATES.map(s => ({
    "@type": "State",
    "name": s.label
  })),
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Equipos contra incendios y seguridad industrial",
    "url": `${siteUrl}/productos/`
  }
}

// ── Schema: ContactPage ─────────────────────────────────
const schemaContactPage = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contacto — Proyecto Red",
  "description": "Página de contacto y cotización de equipos contra incendios en CDMX. WhatsApp, teléfono, email y formulario de cotización gratuita.",
  "url": pageUrl,
  "mainEntity": {
    "@type": "Organization",
    "name": SITE.name,
    "telephone": `+52${CONTACT.phoneRaw}`,
    "email": CONTACT.email,
    "contactPoint": [
      {
        "@type": "ContactPoint",
        "telephone": `+52${CONTACT.phoneRaw}`,
        "contactType": "sales",
        "availableLanguage": "Spanish",
        "areaServed": "MX"
      },
      {
        "@type": "ContactPoint",
        "email": CONTACT.email,
        "contactType": "customer support",
        "availableLanguage": "Spanish"
      }
    ]
  }
}

// ── Schema: FAQPage (contacto-específicas) ──────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuánto tardan en responder una cotización?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Por WhatsApp respondemos en minutos durante horario de atención (lunes a viernes 8:00–18:00, sábado 8:00–14:00). Las solicitudes por formulario y correo electrónico se responden en un máximo de 24 horas hábiles con precio, disponibilidad y tiempo de entrega."
      }
    },
    {
      "@type": "Question",
      "name": "¿La cotización tiene costo o compromiso?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Todas las cotizaciones son gratuitas y sin compromiso. Incluimos precios unitarios, cantidades recomendadas según tu instalación, tiempo de entrega y condiciones de facturación."
      }
    },
    {
      "@type": "Question",
      "name": "¿Puedo cotizar si no sé exactamente qué necesito?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Dinos qué tipo de inmueble tienes, la superficie aproximada y el giro de tu negocio. Nuestro equipo técnico te recomienda el equipamiento adecuado según la normativa aplicable. Si prefieres, agendamos una visita técnica sin costo."
      }
    },
    {
      "@type": "Question",
      "name": "¿Emiten factura electrónica?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Emitimos CFDI en cada operación. Para empresas con volumen recurrente, ofrecemos facturación consolidada y crédito a 30 días."
      }
    },
    {
      "@type": "Question",
      "name": "¿Atienden empresas fuera de CDMX?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Nuestra operación principal está en la Ciudad de México y Estado de México, pero damos servicio comercial en Querétaro, Puebla, Aguascalientes y Baja California. Para otros estados, coordinamos envíos y brindamos asesoría técnica remota."
      }
    },
    {
      "@type": "Question",
      "name": "¿Hacen entrega el mismo día?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, para pedidos de productos en stock confirmados antes de las 2 PM, entregamos el mismo día en la zona metropolitana de CDMX."
      }
    }
  ]
}
---

<Base
  title="Contacto y Cotización de Equipos Contra Incendios CDMX | Proyecto Red"
  description="Contáctanos para cotizaciones de equipos contra incendios certificados NOM en CDMX y Estado de México. WhatsApp, teléfono, email y formulario. Respuesta en menos de 24 horas — sin compromiso."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <!-- ── Barra de migas de pan ────────────────────────────── -->
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Contacto' }
  ]} />

  <!-- ── Secciones ──────────────────────────────────────── -->
  <HeroContacto />
  <CtaBar />
  <CanalesContacto />
  <DiferenciaContacto />
  <CoberturaContacto />
  <FaqCotizacionContacto />
  <CTAFinalIndex />

  <!-- ── Datos estructurados JSON-LD ──────────────────────
       Inyectados al final del <body> para no bloquear render
  ─────────────────────────────────────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaContactPage)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

</Base>
