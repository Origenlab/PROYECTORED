---
/**
 * gabinetes/index.astro — L3 Gabinetes Contra Incendio
 * ─────────────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO + JSON-LD de nivel técnico.
 * Estructura 100% homologada con extintores/index.astro (L3 template autorizado).
 * Cada sección vive en src/components/sections/ con sus propios estilos.
 */

import Base              from '../../layouts/Base.astro'
import CtaBar            from '../../components/CtaBar.astro'
import Breadcrumb        from '../../components/ui/Breadcrumb.astro'

// ── Secciones específicas de gabinetes ─────────────────────
import HeroGabinetes     from '../../components/sections/HeroGabinetes.astro'
import CatalogoGabinetes from '../../components/sections/CatalogoGabinetes.astro'
import GuiaGabinetes     from '../../components/sections/GuiaGabinetes.astro'
import NormasGabinetes   from '../../components/sections/NormasGabinetes.astro'
import FaqGabinetes      from '../../components/sections/FaqGabinetes.astro'

// ── Secciones genéricas reutilizadas ───────────────────────
import TrustIndex        from '../../components/sections/TrustIndex.astro'
import CTAFinalIndex     from '../../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ─────────────────────────────────────
import { SITE, CONTACT } from '../../config/site'

const siteUrl = SITE.url
const pageUrl = `${siteUrl}/gabinetes/`
const ogImage = `${siteUrl}/imagenes/og/gabinetes-og.jpg`

// ── Schema: ItemList — 4 tipos de gabinetes ────────────────
const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Gabinetes contra incendio — Proyecto Red",
  "description": "Catálogo de gabinetes contra incendio certificados NOM-002-STPS y NFPA 14: para extintor, porta extintor con cenicero, para bombero y para hidrante. Instalación incluida en CDMX.",
  "url": pageUrl,
  "numberOfItems": 4,
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Gabinete para Extintor",
      "description": "Lámina de acero calibre 20, pintura electrostática, vidrio templado 4 mm. Versión sobrepuesta o empotrada. Break-glass opcional. Para extintores de 4.5 a 12 kg.",
      "url": `${siteUrl}/gabinetes/para-extintor/`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Porta Extintor con Cenicero",
      "description": "Pedestal metálico con base contrapesada. Acabado cromado o rojo. Para lobbies, recepciones y accesos donde no se puede perforar el muro. Extintor visible y presentable.",
      "url": `${siteUrl}/gabinetes/porta-extintor-cenicero/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Gabinete para Bombero",
      "description": "90×60×25 cm. Espacio para manguera 30 m, extintor, hacha y llave de hidrante. Puerta abatible con break-glass opcional. Para edificios y plantas con brigada interna.",
      "url": `${siteUrl}/gabinetes/para-bombero/`
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "Gabinete para Hidrante",
      "description": "80×60×20 cm. Válvula angular 2½\", manguera 30 m pre-conectada. Listo para operar en segundos. Obligatorio en edificios con sistema hidráulico según NFPA 14.",
      "url": `${siteUrl}/gabinetes/para-hidrante/`
    }
  ]
}

// ── Schema: FAQPage ────────────────────────────────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Es obligatorio tener gabinete o basta con el soporte de pared?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depende del contexto. El soporte de pared es suficiente para oficinas pequeñas con extintores en área protegida de bajo tráfico. En pasillos de alto tráfico, plantas industriales, estacionamientos y exteriores, Protección Civil puede exigir gabinete. Para edificios con sistema de hidrantes, el gabinete con manguera es obligatorio según NFPA 14."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué medidas de gabinete necesito para mi extintor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Para PQS de 4.5 kg: gabinete de 60×35×20 cm. Para 6-9 kg: 70×35×25 cm. Para CO₂ de 4.5 kg (más alto): 80×35×25 cm. Los gabinetes para hidrante son distintos: 80×60×20 cm con espacio para manguera enrollada."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta un gabinete contra incendio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "El gabinete sobrepuesto para extintor 4.5-6 kg parte desde $650 MXN. El porta extintor con cenicero desde $850 MXN. Los gabinetes para bombero desde $2,800 MXN. Los de hidrante con manguera y válvula desde $4,500 MXN. Para 5+ gabinetes, precio por volumen."
      }
    },
    {
      "@type": "Question",
      "name": "¿Instalan los gabinetes o solo los venden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los dos. Vendemos sueltos y también ofrecemos servicio completo: suministro + instalación a la altura correcta según norma, con material de fijación adecuado para cada tipo de muro. La instalación incluye señalamiento del gabinete."
      }
    },
    {
      "@type": "Question",
      "name": "¿Los gabinetes incluyen el extintor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Se venden por separado para garantizar compatibilidad de medidas. Si compras extintor + gabinete juntos, garantizamos compatibilidad y damos precio de paquete. Los gabinetes para hidrante sí incluyen manguera y válvula porque funcionan como sistema completo."
      }
    },
    {
      "@type": "Question",
      "name": "¿Gabinete empotrado, sobrepuesto o pedestal — cuál elijo?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Empotrado: se mete dentro del muro, ideal para construcciones nuevas o remodelaciones. Sobrepuesto: se atornilla sobre el muro, el más práctico para inmuebles existentes. Pedestal: portátil con base contrapesada, para zonas donde no puedes perforar muros."
      }
    }
  ]
}

// ── Schema: BreadcrumbList ─────────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
    { "@type": "ListItem", "position": 3, "name": "Gabinetes Contra Incendio", "item": pageUrl }
  ]
}

// ── Schema: CollectionPage ─────────────────────────────────
const schemaWebPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Gabinetes Contra Incendio en CDMX — NOM-002-STPS y NFPA 14 | Proyecto Red",
  "description": "Venta e instalación de gabinetes contra incendio: para extintor, porta extintor, para bombero y para hidrante. Lámina acero cal. 20, vidrio templado. Desde $650 MXN. Entrega en CDMX.",
  "url": pageUrl,
  "image": ogImage,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "Proyecto Red", "url": siteUrl },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
      { "@type": "ListItem", "position": 3, "name": "Gabinetes", "item": pageUrl }
    ]
  },
  "mainEntity": {
    "@id": pageUrl + "#itemlist"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Proyecto Red",
    "url": siteUrl,
    "logo": `${siteUrl}/imagenes/logos/logo-proyectored-201x60.png`,
    "telephone": `+52${CONTACT.phoneRaw}`,
    "email": CONTACT.email
  }
}
---

<Base
  title="Gabinetes Contra Incendio en CDMX — NOM-002-STPS y NFPA 14 | Proyecto Red"
  description="Venta e instalación de gabinetes contra incendio: para extintor, porta extintor con cenicero, para bombero y para hidrante. Lámina de acero cal. 20, vidrio templado 4 mm. Desde $650 MXN. Entrega directa en CDMX."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Productos', href: '/productos/' },
    { label: 'Gabinetes Contra Incendio' }
  ]} />

  <HeroGabinetes />
  <CtaBar />
  <CatalogoGabinetes />
  <GuiaGabinetes />
  <TrustIndex />
  <NormasGabinetes />
  <FaqGabinetes />
  <CTAFinalIndex />

  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebPage)} />

</Base>
