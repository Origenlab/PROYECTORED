---
import Base from '../../layouts/Base.astro';
import CtaBar from '../../components/CtaBar.astro';
import FaqCotizacion from '../../components/FaqCotizacion.astro';
import '../../styles/pages.css';

const WHATSAPP = "525537238544";
const WA_URL = `https://wa.me/${WHATSAPP}`;

const title = "Gabinetes y Porta Extintores Contra Incendios CDMX | Proyecto Red";
const description = "Gabinetes contra incendio en CDMX: para extintor, hidrante y bombero. Acero calibre 20, vidrio templado, instalación empotrada o sobrepuesta. Cotiza.";

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Productos", href: "/productos/" },
  { label: "Gabinetes" },
];

// v4: métricas que cuentan una progresión, no datos aislados
const metricas = [
  { valor: "4", label: "Tipos de gabinete" },
  { valor: "Cal. 20", label: "Lámina de acero" },
  { valor: "3", label: "Instalaciones: empotrado, sobrepuesto, pedestal" },
  { valor: "24h", label: "Entrega zona metro" },
];

// ── Productos con specs técnicos reales ──────────────
const productos = [
  {
    nombre: "Gabinete para Extintor",
    desc: "Resguarda extintores de 4.5 a 12 kg contra polvo, humedad y vandalismo. Puerta con vidrio templado o acrílico que permite ver el estado del extintor sin abrirlo. Cerrojo de emergencia tipo break-glass disponible.",
    href: "/gabinetes/para-extintor/",
    badge: "Más vendido",
    // v4: specs técnicos compactos — lo que un comprador técnico necesita de un vistazo
    specs: "Lámina cal. 20 · Pintura electrostática roja/blanca · Vidrio templado 4mm",
  },
  {
    nombre: "Porta Extintor con Cenicero",
    desc: "Pedestal metálico que combina soporte para extintor con cenicero integrado. Para accesos de edificios, lobbies, áreas de fumadores y zonas de recepción donde el extintor debe estar visible pero presentable.",
    href: "/gabinetes/porta-extintor-cenicero/",
    badge: null,
    specs: "Acero al carbón · Base contrapesada · Acabado cromado o rojo",
  },
  {
    nombre: "Gabinete para Bombero",
    desc: "Espacio para manguera de 30 m, extintor, hacha y llave de hidrante en un solo gabinete. Para edificios, plantas industriales y naves que requieren equipo de respuesta rápida en cada piso o sector.",
    href: "/gabinetes/para-bombero/",
    badge: "Edificios",
    specs: "90×60×25 cm · Puerta abatible · Break-glass opcional · Señalamiento incluido",
  },
  {
    nombre: "Gabinete para Hidrante",
    desc: "Gabinete con manguera pre-conectada y válvula angular para conexión directa al sistema hidráulico contra incendio. Listo para operar en segundos. Para edificios con sistema de hidrantes según NFPA 14.",
    href: "/gabinetes/para-hidrante/",
    badge: "NFPA 14",
    specs: "80×60×20 cm · Válvula angular 2½\" · Manguera 30 m incluida",
  },
];

// v4: guía de decisión real — no diferenciadores genéricos, sino criterios
// que ayudan al comprador a ELEGIR entre las opciones
const guiaDecision = [
  {
    pregunta: "¿Tienes extintores expuestos?",
    respuesta: "Gabinete para extintor",
    detalle: "Si tu extintor está en un pasillo, bodega o área de alto tráfico sin protección, un gabinete con vidrio lo protege del polvo y el vandalismo sin sacrificar la visibilidad. Protección Civil puede observar extintores en mal estado por falta de resguardo.",
    href: "/gabinetes/para-extintor/",
  },
  {
    pregunta: "¿Tu edificio tiene hidrantes?",
    respuesta: "Gabinete para hidrante",
    detalle: "Si tu edificio cuenta con red hidráulica (tomas de agua para bomberos), cada toma necesita un gabinete con manguera pre-conectada y válvula. Es obligatorio en edificios de más de 5 pisos y naves industriales con sistema NFPA 14.",
    href: "/gabinetes/para-hidrante/",
  },
  {
    pregunta: "¿Necesitas equipo de respuesta en cada piso?",
    respuesta: "Gabinete para bombero",
    detalle: "Combina manguera, extintor, hacha y llave en un solo punto de acceso. Para edificios con brigada interna o que requieren equipo distribuido por planta. Protección Civil lo solicita en inmuebles de uso mixto y comercial de alto aforo.",
    href: "/gabinetes/para-bombero/",
  },
  {
    pregunta: "¿Tu lobby necesita extintor visible y presentable?",
    respuesta: "Porta extintor con cenicero",
    detalle: "En recepción, accesos principales o áreas comunes donde un gabinete empotrado no es viable, el porta extintor con cenicero mantiene el extintor accesible con un acabado profesional que no desentona con la estética del espacio.",
    href: "/gabinetes/porta-extintor-cenicero/",
  },
];

// v4: FAQ que resuelve objeciones reales del proceso de compra
const faqsGabinetes = [
  {
    pregunta: "¿Es obligatorio tener gabinetes o basta con el soporte de pared?",
    // v4: la pregunta que NADIE responde pero TODOS tienen
    respuesta: "Depende del contexto. El <strong>soporte de pared (bracket)</strong> es suficiente para oficinas pequeñas y comercios donde el extintor está en un área protegida. Pero en <strong>pasillos de alto tráfico, plantas industriales, estacionamientos y exteriores</strong>, Protección Civil puede exigir gabinete porque el extintor necesita protección contra polvo, humedad y vandalismo. En edificios con <strong>sistema de hidrantes</strong>, el gabinete con manguera es obligatorio. La regla práctica: si el extintor se ensucia, se golpea o alguien podría llevárselo — necesitas gabinete."
  },
  {
    pregunta: "¿Qué medidas de gabinete necesito para mi extintor?",
    respuesta: "Las medidas varían según la capacidad del extintor. Para un <strong>PQS de 4.5 kg</strong> (el más común): gabinete de 60×35×20 cm. Para <strong>6-9 kg</strong>: 70×35×25 cm. Para <strong>CO₂ de 4.5 kg</strong> (más largo): 80×35×25 cm. Los gabinetes para <strong>hidrante</strong> son más grandes: 80×60×20 cm con espacio para la manguera enrollada. Te recomendamos el gabinete correcto según el extintor que ya tienes o el que vas a comprar — lo cotizamos junto."
  },
  {
    pregunta: "¿Gabinete empotrado, sobrepuesto o pedestal — cuál elijo?",
    respuesta: "<strong>Empotrado:</strong> se mete dentro del muro. Limpio visualmente, ideal en construcciones nuevas o remodelaciones. Necesita muro con cavidad. <strong>Sobrepuesto:</strong> se atornilla sobre la superficie del muro. El más práctico para inmuebles existentes — no necesitas obra. <strong>Pedestal:</strong> portátil, con base contrapesada. Para áreas donde no puedes perforar muros o necesitas mover el extintor. Te asesoramos según tu tipo de muro y lo que permita el dictamen de tu inmueble."
  },
  {
    pregunta: "¿Los gabinetes incluyen el extintor o se venden vacíos?",
    respuesta: "Se venden <strong>por separado</strong>. Esto es deliberado: cada inmueble tiene extintores de distintos tipos y capacidades, y el gabinete debe ajustarse a lo que ya tienes. Pero si compras <strong>extintor + gabinete juntos</strong>, te aseguramos la compatibilidad de medidas y te damos <strong>precio de paquete</strong>. Los gabinetes para hidrante sí incluyen manguera y válvula porque vienen como sistema completo."
  },
  {
    pregunta: "¿Cuánto cuesta un gabinete contra incendio?",
    respuesta: "Un gabinete <strong>sobrepuesto para extintor de 4.5-6 kg</strong> parte desde $650 MXN. El <strong>porta extintor con cenicero</strong> desde $850 MXN. Los gabinetes <strong>para bombero</strong> (manguera + hacha + extintor) desde $2,800 MXN. Y los de <strong>hidrante con manguera y válvula</strong> desde $4,500 MXN. Precios directos de proveedor — sin intermediarios. Para pedidos de <strong>5+ gabinetes</strong> manejamos precio por volumen."
  },
  {
    // v4: la pregunta que cierra — resuelve el miedo a equivocarse
    pregunta: "¿Qué pasa si compro el gabinete equivocado para mi extintor?",
    respuesta: "Si nos compraste, <strong>no va a pasar</strong> — verificamos la compatibilidad antes de facturar. Pero si ya tienes un gabinete que no corresponde (demasiado grande, demasiado chico, instalación incorrecta), Protección Civil puede hacer observación. Mándanos una foto por WhatsApp del extintor que tienes y te decimos el gabinete exacto que necesitas. Si compraste con nosotros y algo no embona, <strong>lo cambiamos sin costo</strong>."
  },
];
---

<Base
  title={title}
  description={description}
>

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-left">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          {breadcrumbs.map((b, i) => (
            <>
              {i > 0 && <span class="breadcrumb__sep" aria-hidden="true">/</span>}
              {b.href
                ? <a href={b.href} class="breadcrumb__link">{b.label}</a>
                : <span class="breadcrumb__current" aria-current="page">{b.label}</span>
              }
            </>
          ))}
        </nav>
        <div class="hero-badge">
          <span class="badge-dot"></span>
          Acero cal. 20 · Vidrio templado · Instalación incluida
        </div>
        <h1>Gabinetes Contra<br><span class="h1-accent">Incendio</span></h1>
        <!-- v4: hero-sub con escenario del comprador, no feature list -->
        <p class="hero-sub">
          Tus extintores están expuestos al polvo, la humedad o al alcance de cualquiera. Un gabinete con vidrio templado los protege, los mantiene visibles y te evita observaciones en tu próxima inspección. Desde $650 MXN.
        </p>
        <div class="hero-ctas">
          <a
            href={`${WA_URL}?text=Hola%2C%20necesito%20cotizar%20gabinetes%20para%20extintores`}
            class="btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Cotizar gabinetes
          </a>
          <a href="#catalogo" class="btn-secondary">Ver los 4 tipos</a>
        </div>
      </div>

      <!-- v4: hero-right con escenario, no declaración.
           Habla DESDE la situación del lector, no SOBRE el producto -->
      <div class="hero-right">
        <p>Tienes 200 metros cuadrados de oficina con 3 extintores colgados de un bracket. Uno tiene polvo encima. Otro está en un pasillo donde el de limpieza lo golpea con el trapeador cada semana. El tercero está detrás de una puerta que siempre está abierta — nadie sabe que hay un extintor ahí. Cuando llegue Protección Civil, los tres van a ser observación.</p>
        <p>Un gabinete metálico con vidrio templado resuelve eso: el extintor se ve, está protegido y nadie lo mueve de su lugar. Si tu edificio tiene sistema de hidrantes, el gabinete con manguera pre-conectada es obligatorio. Si tu lobby necesita un extintor que no parezca decoración de bodega, el porta extintor con cenicero existe para eso. Cuatro soluciones, un solo proveedor.</p>
      </div>
    </div>
  </section>

  <CtaBar />

  <!-- ══════════════════════════════════════
       MÉTRICAS
  ══════════════════════════════════════ -->
  <section class="metricas-section" aria-label="Gabinetes">
    <div class="container">
      <div class="metricas-grid">
        {metricas.map(m => (
          <div class="metrica-item">
            <span class="metrica-valor">{m.valor}</span>
            <span class="metrica-label">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       CATÁLOGO
  ══════════════════════════════════════ -->
  <section class="cat-section cat-section--white" id="catalogo">
    <div class="container">

      <div class="cat-header">
        <div class="cat-header__img-wrap">
          <img src="/imagenes/gabinetes/gabinetes-extintores.jpg" alt="Gabinetes contra incendio para extintor e hidrante" loading="eager" width="640" height="400" />
          <div class="cat-header__img-overlay"></div>
          <div class="cat-header__img-content">
            <span class="cat-norm-badge">Acero cal. 20</span>
            <h2>Gabinetes Contra Incendio</h2>
          </div>
        </div>

        <div class="cat-header__info">
          <div class="cat-header__meta">
            <span class="section-label">Catálogo de gabinetes</span>
            <span class="cat-badge-pill">Lámina · Vidrio · Fibra</span>
          </div>
          <!-- v4: título como pregunta que el comprador tiene en la cabeza -->
          <h2 class="cat-header__title">¿Soporte de Pared o Gabinete? Depende de Dónde Está tu Extintor</h2>
          <!-- v4: desc con regla práctica, no solo features -->
          <p class="cat-header__desc">Regla rápida: si tu extintor se ensucia, se golpea o alguien podría llevárselo — necesitas gabinete. Fabricados en lámina de acero calibre 20 con pintura electrostática, puerta con vidrio templado de 4 mm. Empotrado, sobrepuesto o pedestal según tu inmueble. Desde $650 MXN.</p>
          <div class="normas-row">
            <span class="norma-tag">NOM-002-STPS</span>
            <span class="norma-tag">NFPA 10</span>
            <span class="norma-tag">NFPA 14</span>
          </div>
          <div class="cat-header__ctas">
            <!-- v4: CTA contextual — "cotiza extintor + gabinete junto" -->
            <a href={`${WA_URL}?text=Hola%2C%20necesito%20cotizar%20extintores%20con%20gabinete%20incluido`} class="btn-outline" target="_blank" rel="noopener noreferrer">Extintor + gabinete junto</a>
            <a
              href={`${WA_URL}?text=Hola%2C%20necesito%20gabinetes%20para%20mis%20extintores%20existentes`}
              class="cat-wa-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Solo gabinetes por WhatsApp
            </a>
          </div>
        </div>
      </div>

      <!-- v4: prod-cards con línea de specs técnicos -->
      <div class="productos-grid">
        {productos.map(p => (
          <a href={p.href} class="prod-card" aria-label={p.nombre}>
            <div class="prod-card__top">
              {p.badge && <span class="prod-badge">{p.badge}</span>}
              {!p.badge && <span class="prod-badge prod-badge--ghost">Disponible</span>}
            </div>
            <div class="prod-card__body">
              <h3 class="prod-card__name">{p.nombre}</h3>
              <p class="prod-card__sub">{p.desc}</p>
              <p class="prod-card__specs">{p.specs}</p>
            </div>
            <div class="prod-card__footer">
              <span class="prod-card__link">
                Ver medidas y cotizar
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}

        <!-- v4: 2 cards CTA contextualeas al flujo de compra -->
        <a
          href={`${WA_URL}?text=Hola%2C%20necesito%20cotizar%20extintores%20con%20gabinete%20incluido`}
          class="prod-card prod-card--cta"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Cotizar extintor + gabinete"
        >
          <div class="prod-card-cta__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <p class="prod-card-cta__text">¿Comprando extintores nuevos?</p>
          <p class="prod-card-cta__sub">Precio de paquete extintor + gabinete con compatibilidad garantizada</p>
          <span class="prod-card-cta__btn">Cotizar paquete →</span>
        </a>

        <a
          href={`${WA_URL}?text=Hola%2C%20tengo%20extintores%20y%20necesito%20gabinetes%20compatibles.%20Les%20mando%20fotos.`}
          class="prod-card prod-card--cta"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Enviar foto de extintor"
        >
          <div class="prod-card-cta__icon prod-card-cta__icon--muted">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
          <p class="prod-card-cta__text">¿Ya tienes extintores?</p>
          <p class="prod-card-cta__sub">Mándanos foto — te decimos el gabinete exacto que necesitas</p>
          <span class="prod-card-cta__btn">Enviar foto por WhatsApp →</span>
        </a>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       GUÍA DE DECISIÓN — v4: herramienta útil
       (no diferenciadores, no clientes, no servicios
       — una GUÍA que el visitante puede usar
       para tomar una decisión sin hablar con nadie)
  ══════════════════════════════════════ -->
  <section class="cat-section cat-section--gray">
    <div class="container">

      <div class="cat-header">
        <div class="cat-header__img-wrap">
          <img src="/imagenes/gabinetes/gabinete-bombero.jpg" alt="Gabinete para bombero con manguera y hacha instalado en edificio" loading="lazy" width="640" height="400" />
          <div class="cat-header__img-overlay"></div>
          <div class="cat-header__img-content">
            <span class="cat-norm-badge">Guía rápida</span>
            <h2>¿Cuál Necesitas?</h2>
          </div>
        </div>

        <div class="cat-header__info">
          <div class="cat-header__meta">
            <span class="section-label">Guía de selección</span>
            <span class="cat-badge-pill">4 escenarios</span>
          </div>
