---
// src/pages/[slug].astro
// Páginas de Nivel 3 — categorías de producto
// Genera: /extintores/, /equipo-bomberos/, /senalamientos/,
//         /gabinetes/, /mangueras/, /sistemas/,
//         /primeros-auxilios/, /equipo-seguridad/

import CategoryLayout from '../layouts/CategoryLayout.astro'
import SectionHeader from '../components/ui/SectionHeader.astro'
import { PRODUCT_CATEGORIES, waUrl } from '../config/site'
import { CATEGORY_PAGES } from '../data/categorias'

// Generar rutas estáticas a partir de PRODUCT_CATEGORIES (fuente de verdad)
export async function getStaticPaths() {
  return PRODUCT_CATEGORIES.map((cat) => ({
    params: { slug: cat.slug },
    props: { cat },
  }))
}

const { cat } = Astro.props
const data = CATEGORY_PAGES[cat.slug]

// Redirige al catálogo si no hay datos para ese slug
if (!data) {
  return Astro.redirect('/productos/')
}

const PAGE_WA = waUrl(data.waMessage)

// Categorías relacionadas (las otras 7, excluyendo la actual)
const relatedCategories = PRODUCT_CATEGORIES.filter((c) => c.slug !== cat.slug)
---

<CategoryLayout
  title={`${cat.label} | Proyecto Red — Equipos Contra Incendios CDMX`}
  description={`${data.heroSubtitle.slice(0, 155)}...`}
  badge={data.badge}
  heroTitle={data.heroTitle}
  heroAccent={data.heroAccent}
  heroSubtitle={data.heroSubtitle}
  heroDescRight={data.heroDescRight}
  cta1={{ text: 'Solicitar cotización', href: PAGE_WA }}
  cta2={{ text: 'Ver subcategorías', href: '#subcategorias' }}
  breadcrumb={[
    { label: 'Inicio',    href: '/'           },
    { label: 'Productos', href: '/productos/' },
    { label: cat.label },
  ]}
  stats={data.stats}
  showForm={true}
  faqItems={data.faqItems}
  ctaTitle={data.ctaTitle}
  ctaBody={data.ctaBody}
  ctaCTA1Text="Cotizar por WhatsApp"
  ctaCTA1Href={PAGE_WA}
  ctaCTA2Text="Ver catálogo completo"
  ctaCTA2Href="/productos/"
>

  <!-- =====================================================
       BLOQUE 1 — Subcategorías / Líneas de producto
       ===================================================== -->
  <section id="subcategorias" class="cat-section section">
    <div class="container">

      <SectionHeader
        eyebrow={cat.label}
        titleLine1="Líneas de"
        titleLine2="producto"
        desc={`Todo lo que manejamos dentro de la categoría ${cat.label}. Escríbenos si no encuentras lo que buscas.`}
      />

      <div class="subcats-grid">
        {data.subcategories.map((sub) => (
          <div class="subcat-card">
            <div class="subcat-card__icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div class="subcat-card__body">
              <h3 class="subcat-card__title">{sub.label}</h3>
              <p class="subcat-card__desc">{sub.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA inline para cotizar -->
      <div class="inline-cta">
        <p class="inline-cta__text">¿No encuentras lo que buscas? Escríbenos y lo conseguimos.</p>
        <a
          href={PAGE_WA}
          class="btn btn--red"
          target="_blank"
          rel="noopener noreferrer"
        >
          Preguntar por WhatsApp
        </a>
      </div>

    </div>
  </section>

  <!-- =====================================================
       BLOQUE 2 — Normas aplicables
       ===================================================== -->
  {data.norms.length > 0 && (
    <section class="cat-section cat-section--light section--sm">
      <div class="container">

        <SectionHeader
          eyebrow="Certificación y cumplimiento"
          titleLine1="Normas"
          titleLine2="aplicables"
          desc="Cada producto de esta categoría cumple con las normas vigentes en México y, donde aplica, con estándares internacionales NFPA, ANSI y EN."
        />

        <div class="norms-grid">
          {data.norms.map((norm) => (
            <div class="norm-card">
              <span class="norm-card__code">{norm.code}</span>
              <h3 class="norm-card__name">{norm.name}</h3>
              <p class="norm-card__desc">{norm.desc}</p>
            </div>
          ))}
        </div>

      </div>
    </section>
  )}

  <!-- =====================================================
       BLOQUE 3 — Para quién es
       ===================================================== -->
  <section class="cat-section section--sm">
    <div class="container">

      <SectionHeader
        eyebrow="Sectores que atendemos"
        titleLine1="¿Para quién es"
        titleLine2="este equipo?"
        desc="Atendemos empresas de todos los sectores con requerimientos específicos de norma, certificación y documentación."
      />

      <div class="targets-grid">
        {data.targets.map((target) => (
          <div class="target-item">
            <div class="target-item__dot" aria-hidden="true"></div>
            <div>
              <h3 class="target-item__title">{target.label}</h3>
              <p class="target-item__desc">{target.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- =====================================================
       BLOQUE 4 — Otras categorías del catálogo
       ===================================================== -->
  <section class="cat-section cat-section--light section--sm">
    <div class="container">

      <div class="related-header">
        <p class="related-header__label">Otras categorías del catálogo:</p>
        <a href="/productos/" class="related-header__link">Ver catálogo completo →</a>
      </div>

      <div class="related-grid">
        {relatedCategories.map((rc) => (
          <a href={rc.href} class="related-card">
            <span class="related-card__label">{rc.label}</span>
            {rc.badge && <span class="related-card__badge">{rc.badge}</span>}
          </a>
        ))}
      </div>

    </div>
  </section>

</CategoryLayout>

<style>
  /* ── Secciones ─────────────────────────────────────────── */
  .cat-section--light {
    background: var(--color-gray-50);
  }

  /* ── Subcategorías — grid de cards ────────────────────── */
  .subcats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--sp-5);
    margin-bottom: var(--sp-10);
  }

  .subcat-card {
    display: flex;
    gap: var(--sp-4);
    padding: var(--sp-5);
    background: var(--color-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    transition: border-color var(--transition), box-shadow var(--transition), transform var(--transition);
  }

  .subcat-card:hover {
    border-color: var(--color-red);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .subcat-card__icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    background: var(--color-red-faint);
    color: var(--color-red);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .subcat-card__title {
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-gray-900);
    margin-bottom: var(--sp-2);
    line-height: var(--leading-snug);
  }

  .subcat-card__desc {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    line-height: var(--leading-relaxed);
  }

  /* ── CTA inline ────────────────────────────────────────── */
  .inline-cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    padding: var(--sp-6);
    background: var(--color-gray-50);
    border-radius: var(--radius-xl);
    flex-wrap: wrap;
  }

  .inline-cta__text {
    font-size: var(--text-base);
    color: var(--color-gray-600);
    font-weight: var(--weight-medium);
  }

  /* ── Normas ────────────────────────────────────────────── */
  .norms-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--sp-5);
  }

  .norm-card {
    background: var(--color-white);
    border: 1px solid var(--border);
    border-top: 3px solid var(--color-red);
    border-radius: var(--radius-xl);
    padding: var(--sp-6);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .norm-card__code {
    font-size: var(--text-xs);
    font-weight: var(--weight-black);
    color: var(--color-red);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .norm-card__name {
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-gray-900);
    line-height: var(--leading-snug);
  }

  .norm-card__desc {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    line-height: var(--leading-relaxed);
    flex: 1;
  }

  /* ── Targets ───────────────────────────────────────────── */
  .targets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--sp-5);
  }

  .target-item {
    display: flex;
    gap: var(--sp-4);
    align-items: flex-start;
  }

  .target-item__dot {
    flex-shrink: 0;
    width: 10px;
    height: 10px;
    background: var(--color-red);
    border-radius: 50%;
    margin-top: 6px;
  }

  .target-item__title {
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-gray-900);
    margin-bottom: var(--sp-1);
    line-height: var(--leading-snug);
  }

  .target-item__desc {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    line-height: var(--leading-relaxed);
  }

  /* ── Categorías relacionadas ───────────────────────────── */
  .related-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    margin-bottom: var(--sp-6);
    flex-wrap: wrap;
  }

  .related-header__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-gray-500);
  }

  .related-header__link {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-red);
    transition: opacity var(--transition);
  }

  .related-header__link:hover { opacity: 0.75; }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--sp-3);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-4) var(--sp-5);
    background: var(--color-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    transition: border-color var(--transition), color var(--transition);
  }

  .related-card:hover {
    border-color: var(--color-red);
  }

  .related-card__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-gray-700);
    line-height: var(--leading-snug);
  }

  .related-card:hover .related-card__label {
    color: var(--color-red);
  }

  .related-card__badge {
    display: inline-block;
    font-size: 10px;
    font-weight: var(--weight-semibold);
    color: var(--color-red);
    background: var(--color-red-faint);
    padding: 2px var(--sp-2);
    border-radius: var(--radius-full);
    align-self: flex-start;
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 768px) {
    .subcats-grid {
      grid-template-columns: 1fr;
    }
    .inline-cta {
      flex-direction: column;
      align-items: flex-start;
    }
    .norms-grid {
      grid-template-columns: 1fr;
    }
    .targets-grid {
      grid-template-columns: 1fr;
    }
    .related-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
