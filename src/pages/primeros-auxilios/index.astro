---
/**
 * primeros-auxilios/index.astro — L3 Equipo de Primeros Auxilios
 * ─────────────────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO + JSON-LD de nivel técnico.
 * Estructura 100% homologada con extintores/index.astro (L3 template autorizado).
 * Cada sección vive en src/components/sections/ con sus propios estilos.
 */

import Base                    from '../../layouts/Base.astro'
import CtaBar                  from '../../components/CtaBar.astro'
import Breadcrumb              from '../../components/ui/Breadcrumb.astro'

// ── Secciones específicas de primeros auxilios ────────────
import HeroPrimerosAuxilios    from '../../components/sections/HeroPrimerosAuxilios.astro'
import CatalogoPrimerosAuxilios from '../../components/sections/CatalogoPrimerosAuxilios.astro'
import GuiaPrimerosAuxilios    from '../../components/sections/GuiaPrimerosAuxilios.astro'
import NormasPrimerosAuxilios  from '../../components/sections/NormasPrimerosAuxilios.astro'
import FaqPrimerosAuxilios     from '../../components/sections/FaqPrimerosAuxilios.astro'

// ── Secciones genéricas reutilizadas ───────────────────────
import TrustIndex              from '../../components/sections/TrustIndex.astro'
import CTAFinalIndex           from '../../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ─────────────────────────────────────
import { SITE, CONTACT } from '../../config/site'

const siteUrl = SITE.url
const pageUrl = `${siteUrl}/primeros-auxilios/`
const ogImage = `${siteUrl}/imagenes/og/primeros-auxilios-og.jpg`

// ── Schema: ItemList — 5 productos ────────────────────────
const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Equipo de primeros auxilios — Proyecto Red",
  "description": "Catálogo de equipo de primeros auxilios: botiquines NOM-030-STPS tipo A, B y C, desfibriladores DEA, camillas de emergencia, inmovilizadores y material de curación con resurtido.",
  "url": pageUrl,
  "numberOfItems": 5,
  "itemListElement": [
    {
      "@type": "ListItem", "position": 1,
      "name": "Botiquines de Primeros Auxilios",
      "description": "Tipo A (hasta 25 trabajadores), tipo B (26–100), tipo C (más de 100). Contenido certificado NOM-030-STPS. Resurtido periódico disponible.",
      "url": `${siteUrl}/primeros-auxilios/botiquines/`
    },
    {
      "@type": "ListItem", "position": 2,
      "name": "Desfibriladores Externos (DEA)",
      "description": "DEA automático y semiautomático. Instrucciones en español. IPX4. Electrodos adulto y pediátrico. Gabinete mural con alarma.",
      "url": `${siteUrl}/primeros-auxilios/desfibriladores/`
    },
    {
      "@type": "ListItem", "position": 3,
      "name": "Camillas de Emergencia",
      "description": "Camilla rígida tipo Miller, plegable de aluminio, tipo Stokes y de vacío. Hasta 180 kg. Para brigadas e instalaciones industriales.",
      "url": `${siteUrl}/primeros-auxilios/camillas/`
    },
    {
      "@type": "ListItem", "position": 4,
      "name": "Inmovilizadores y Collarines",
      "description": "Collarines cervicales tallas S, M, L, XL. Inmovilizador de cabeza. Férulas de extremidades superiores e inferiores.",
      "url": `${siteUrl}/primeros-auxilios/inmovilizadores/`
    },
    {
      "@type": "ListItem", "position": 5,
      "name": "Material de Curación y Resurtido",
      "description": "Gasas, vendas, antisépticos, guantes nitrilo, torniquetes CAT y SOFT-T. Resurtido periódico con revisión de caducidades e inventario.",
      "url": `${siteUrl}/primeros-auxilios/material-curacion/`
    }
  ]
}

// ── Schema: FAQPage ────────────────────────────────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué tipo de botiquín necesita mi empresa según la NOM-030-STPS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Tipo A para hasta 25 trabajadores, Tipo B para 26 a 100 trabajadores, Tipo C para más de 100 trabajadores. Cada tipo tiene el contenido mínimo especificado por NOM-030-STPS. La norma también establece que debe haber al menos un botiquín por piso y por área de riesgo diferenciada."
      }
    },
    {
      "@type": "Question",
      "name": "¿El desfibrilador DEA es obligatorio en mi empresa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La NOM-030-STPS no lo obliga explícitamente para todas las empresas, pero el riesgo de paro cardíaco existe en cualquier empresa. La tasa de supervivencia cae 10% por cada minuto sin desfibrilación. Para empresas medianas y grandes es una decisión de responsabilidad más que de normativa."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cada cuánto hay que resurtir el botiquín?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Se recomienda revisión mensual de inventario y resurtido semestral o anual según el uso. Ofrecemos servicio de resurtido con revisión de caducidades, reposición de lo usado y entrega de lista de inventario actualizada."
      }
    },
    {
      "@type": "Question",
      "name": "¿La capacitación de primeros auxilios es obligatoria?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. La NOM-030-STPS obliga a las empresas a tener brigadas de primeros auxilios con capacitación documentada mediante constancia DC-3 válida ante STPS. Ofrecemos cursos con constancia DC-3 coordinados el mismo día de la entrega del equipo."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué pasa si la STPS encuentra mi botiquín incompleto?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La STPS puede emitir acta de infracción con multa de 250 a 5000 veces el salario mínimo diario. Hacemos diagnóstico urgente del estado actual y plan de regularización para auditorías próximas."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta equipar una empresa con primeros auxilios?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Empresa hasta 25 personas: botiquín tipo A desde $1,800 MXN. Empresa 26–100 personas: botiquín tipo B + DEA + capacitación DC-3 desde $12,000 MXN. Empresa más de 100 personas: cotización a medida con múltiples botiquines tipo C, DEA por piso y camillas."
      }
    }
  ]
}

// ── Schema: BreadcrumbList ─────────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
    { "@type": "ListItem", "position": 3, "name": "Primeros Auxilios", "item": pageUrl }
  ]
}

// ── Schema: CollectionPage ─────────────────────────────────
const schemaWebPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Equipo de Primeros Auxilios NOM-030-STPS en CDMX | Proyecto Red",
  "description": "Venta de equipo de primeros auxilios para empresas en CDMX: botiquines NOM-030-STPS tipo A, B y C, desfibriladores DEA, camillas, collarines y material de curación. Resurtido periódico y capacitación DC-3.",
  "url": pageUrl,
  "image": ogImage,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "Proyecto Red", "url": siteUrl },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
      { "@type": "ListItem", "position": 3, "name": "Primeros Auxilios", "item": pageUrl }
    ]
  },
  "mainEntity": {
    "@id": pageUrl + "#itemlist"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Proyecto Red",
    "url": siteUrl,
    "logo": `${siteUrl}/imagenes/logos/logo-proyectored-201x60.png`,
    "telephone": `+52${CONTACT.phoneRaw}`,
    "email": CONTACT.email
  }
}
---

<Base
  title="Equipo de Primeros Auxilios NOM-030-STPS en CDMX | Proyecto Red"
  description="Venta de equipo de primeros auxilios para empresas en CDMX: botiquines NOM-030-STPS tipo A, B y C, desfibriladores DEA, camillas, collarines y material de curación. Resurtido periódico y capacitación DC-3."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Productos', href: '/productos/' },
    { label: 'Primeros Auxilios' }
  ]} />

  <HeroPrimerosAuxilios />
  <CtaBar />
  <CatalogoPrimerosAuxilios />
  <GuiaPrimerosAuxilios />
  <TrustIndex />
  <NormasPrimerosAuxilios />
  <FaqPrimerosAuxilios />
  <CTAFinalIndex />

  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebPage)} />

</Base>
