---
import Base from '../../layouts/Base.astro';
import CtaBar from '../../components/CtaBar.astro';
import FaqCotizacion from '../../components/FaqCotizacion.astro';
import '../../styles/pages.css';

const WHATSAPP = "525537238544";
const WA_URL = `https://wa.me/${WHATSAPP}`;

const title = "Equipo de Primeros Auxilios CDMX | Botiquines NOM, DEA y Camillas | Proyecto Red";
const description = "Venta de equipo de primeros auxilios para empresas en CDMX: botiquines NOM-030-STPS tipo A, B y C, desfibriladores DEA, camillas, material de curación e inmovilizadores. Resurtido periódico y capacitación DC-3.";

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Productos", href: "/productos/" },
  { label: "Primeros Auxilios" },
];

const productos = [
  {
    nombre: "Botiquines de Primeros Auxilios",
    desc: "Tipo A para hasta 25 trabajadores, tipo B para 26-100, tipo C para más de 100. Cada tipo tiene el contenido especificado por NOM-030-STPS. Resurtido periódico disponible para mantenerlos completos y vigentes.",
    href: "/primeros-auxilios/botiquines/",
    badge: "NOM-030-STPS",
    specs: "Tipo A · B · C · Portátil o mural · Contenido certificado NOM",
  },
  {
    nombre: "Desfibriladores Externos (DEA)",
    desc: "El paro cardíaco tiene tasa de supervivencia del 70% si se desfibrilá en los primeros 3 minutos. Cada minuto sin DEA reduce la supervivencia un 10%. Equipos con instrucciones en español y voz guía para uso por personal no médico.",
    href: "/primeros-auxilios/desfibriladores/",
    badge: "Esencial",
    specs: "Automático · Semiautomático · IPX4 · Electrodos adulto/pediátrico · Español",
  },
  {
    nombre: "Camillas de Emergencia",
    desc: "Camillas rígidas tipo Miller para inmovilización espinal, plegables de aluminio para traslado, tipo Stokes para rescate en altura y de vacío para inmovilización de trauma con sospecha de fractura.",
    href: "/primeros-auxilios/camillas/",
    badge: null,
    specs: "Rígida · Plegable · Stokes · Vacío · Aluminio reforzado · Hasta 180 kg",
  },
  {
    nombre: "Material de Curación",
    desc: "Gasas estériles, vendas de diferentes anchos, apósitos adhesivos, soluciones antisépticas, guantes de nitrilo, tijeras de trauma, torniquetes y todo el material de atención prehospitalaria básica para reponer o armar kit personalizado.",
    href: "/primeros-auxilios/material-curacion/",
    badge: null,
    specs: "Estéril · Gasas · Vendas 5–10 cm · Torniquete CAT · Guantes nitrilo",
  },
  {
    nombre: "Inmovilizadores y Collarines",
    desc: "Tablas espinales con correas, inmovilizadores de cabeza, collarines cervicales talla única y por tallas, férulas rígidas y neumáticas. Para traslado seguro de lesionados con sospecha de trauma de columna.",
    href: "/primeros-auxilios/inmovilizadores/",
    badge: null,
    specs: "Tabla espinal · Collarín Philadelphia · Férula SAM · 4 tallas · Poliuretano",
  },
];

const guiaEmpresa = [
  {
    tipo: "Oficina o comercio (hasta 50 trabajadores)",
    norma: "NOM-030-STPS",
    necesitas: "Botiquín tipo A + DEA en área común + collarín cervical + camilla plegable ligera + material de curación básico",
    porque: "NOM-030-STPS exige como mínimo un botiquín tipo A por centro de trabajo. El DEA es obligatorio en espacios con más de 50 personas concurrentes en CDMX según el Reglamento de Construcciones. Una silla de ruedas no sustituye a la camilla para traslado de emergencia.",
    href: "/primeros-auxilios/botiquines/",
  },
  {
    tipo: "Planta industrial (51-200 trabajadores)",
    norma: "NOM-030-STPS",
    necesitas: "Botiquín tipo B o C según número de trabajadores + DEA por área de producción + camilla rígida + tabla espinal + kit trauma avanzado",
    porque: "Las plantas con riesgo de accidentes de maquinaria o químicos requieren kit de atención de trauma más completo. La tabla espinal es indispensable cuando hay riesgo de caída desde altura o aplastamiento — el traslado incorrecto puede agravar una lesión de columna.",
    href: "/primeros-auxilios/camillas/",
  },
  {
    tipo: "Restaurante o cocina industrial",
    norma: "NOM-030-STPS",
    necesitas: "Botiquín tipo A + material específico para quemaduras (apósitos gelados, solución fisiológica) + guantes gruesos en kit + DEA accesible",
    porque: "El riesgo más frecuente en cocinas es la quemadura por aceite o vapor. Los apósitos gelados reducen la temperatura del tejido en los primeros minutos — crítico para la profundidad de la lesión. El agua fría está contraindicada para quemaduras extensas porque genera hipotermia.",
    href: "/primeros-auxilios/material-curacion/",
  },
  {
    tipo: "Obra de construcción o trabajo en exterior",
    norma: "NOM-030-STPS",
    necesitas: "Botiquín portátil tipo A por cuadrilla + camilla Stokes o plegable + collarín + torniquete CAT + vendaje compresivo hemostático",
    porque: "En obra el traslado al hospital puede tardar 20-40 minutos. El torniquete CAT y el vendaje hemostático controlaron hemorragias severas en ese tiempo. La camilla Stokes es la única que permite rescate desde niveles superiores con sistemas de cuerdas. El botiquín debe ser portátil para llevarse al punto de trabajo.",
    href: "/primeros-auxilios/inmovilizadores/",
  },
];

const faqsPrimeros = [
  {
    pregunta: "¿Qué tipo de botiquín me exige la NOM-030-STPS?",
    respuesta: "La <strong>NOM-030-STPS</strong> establece tres tipos según el número de trabajadores: <strong>Tipo A</strong> para centros de trabajo con hasta 25 trabajadores (el más básico). <strong>Tipo B</strong> para 26 a 100 trabajadores — incluye más material y equipo de mayor complejidad. <strong>Tipo C</strong> para más de 100 trabajadores — requiere equipo avanzado incluyendo camilla y collarín. El contenido de cada tipo está especificado en la norma. Si tienes varias áreas de trabajo dispersas, puedes necesitar un botiquín por área independientemente del número total de empleados."
  },
  {
    pregunta: "¿El DEA (desfibrilador) es obligatorio en mi empresa?",
    respuesta: "Depende del contexto. La <strong>NOM-030-STPS</strong> no lo exige explícitamente en todos los casos, pero el <strong>Reglamento de Construcciones del CDMX</strong> y normativas locales lo hacen obligatorio en espacios de uso público con aforo mayor a 50 personas. Más allá de la obligación legal: el paro cardíaco es la principal causa de muerte súbita y el DEA duplica la tasa de supervivencia si se usa en los primeros 3 minutos. El costo del equipo es considerablemente menor a la responsabilidad de no tenerlo. Te asesoramos si aplica en tu caso."
  },
  {
    pregunta: "¿Cada cuánto se debe resurtir el botiquín?",
    respuesta: "No hay una periodicidad fija en la norma, pero la regla es que el botiquín debe estar <strong>siempre completo</strong> — cualquier insumo usado debe reponerse inmediatamente. En la práctica, recomendamos revisión mensual para verificar fechas de vencimiento (soluciones antisépticas caducan, vendas se oxidan si se abren) y reposición trimestral de consumibles. Ofrecemos <strong>servicio de resurtido periódico</strong> con visita a tus instalaciones — tú no tienes que administrar inventario de insumos médicos."
  },
  {
    pregunta: "¿Cómo sé si mi camilla es la correcta para el tipo de emergencias en mi empresa?",
    respuesta: "Depende del riesgo y del acceso. <strong>Camilla plegable de aluminio:</strong> para traslado horizontal en espacios amplios sin obstáculos — la más común en oficinas y comercios. <strong>Camilla rígida tipo Miller:</strong> cuando hay sospecha de trauma de columna — el paciente va atado y no se dobla durante el traslado. <strong>Camilla Stokes o canasta:</strong> para rescate en altura, espacios confinados o lugares donde la camilla rígida no pasa. <strong>Tabla espinal:</strong> complementa a la camilla rígida para lesionados en el suelo. En plantas industriales con riesgo de caída es obligatorio tener tabla espinal y collarín."
  },
  {
    pregunta: "¿Cuánto cuesta armar la estación de primeros auxilios para una planta de 80 trabajadores?",
    respuesta: "Para una planta de 80 trabajadores necesitas mínimo botiquín <strong>tipo B</strong>. Un paquete básico completo incluye: botiquín tipo B ($2,800-$3,500 MXN) + camilla plegable ($1,200-$1,800 MXN) + collarín cervical ($350-$600 MXN) + DEA semiprofesional ($18,000-$28,000 MXN). El DEA es la inversión más significativa pero tiene vida útil de 8-10 años. El total sin DEA va de <strong>$4,500 a $6,000 MXN</strong>. Con DEA de <strong>$22,000 a $36,000 MXN</strong>. Cotizamos por paquete con precio preferencial."
  },
  {
    pregunta: "¿La capacitación en primeros auxilios es obligatoria?",
    respuesta: "Sí. La <strong>NOM-030-STPS</strong> exige que el personal designado como brigadista de primeros auxilios reciba capacitación específica. Las constancias <strong>DC-3</strong> deben registrarse ante STPS como evidencia de cumplimiento. El brigadista debe saber: evaluación primaria del lesionado, RCP básico, uso de DEA, control de hemorragias, inmovilización de fracturas y manejo de quemaduras. Ofrecemos cursos de primeros auxilios con práctica en vivo y constancias DC-3 válidas — puede combinarse con la compra del equipo."
  },
  {
    pregunta: "¿Puedo usar cualquier material de curación en el botiquín o debe ser de una marca específica?",
    respuesta: "No hay marca especificada en la norma, pero los insumos deben cumplir con los <strong>estándares de calidad correspondientes</strong> y estar dentro de fecha de vigencia. Lo crítico es que el contenido corresponda a lo que especifica la NOM para el tipo de botiquín (A, B o C). Materiales genéricos son aceptables en tanto cumplan la función — gasas estériles, vendas de 5 y 10 cm, solución isotónica, etc. Lo que no es aceptable es un botiquín incompleto, con insumos vencidos o que no correspondan al tipo requerido. Te vendemos el botiquín ya armado conforme a norma o te cotizamos el material por pieza."
  },
];
---

<Base
  title={title}
  description={description}
>

  <!-- ══════════════════════════════════════
       HERO
  ══════════════════════════════════════ -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-left">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          {breadcrumbs.map((b, i) => (
            <>
              {i > 0 && <span class="breadcrumb__sep" aria-hidden="true">/</span>}
              {b.href
                ? <a href={b.href} class="breadcrumb__link">{b.label}</a>
                : <span class="breadcrumb__current" aria-current="page">{b.label}</span>
              }
            </>
          ))}
        </nav>
        <div class="hero-badge">
          <span class="badge-dot"></span>
          NOM-030-STPS · DC-3 · Resurtido periódico
        </div>
        <h1>Equipo de <span class="h1-accent">Primeros</span><br>Auxilios</h1>
        <p class="hero-sub">
          Tu botiquín tiene gasas vencidas del año pasado, no tiene torniquete y el desfibrilador lleva 3 años sin cambio de electrodos. En una emergencia real, ese equipo no sirve. Botiquín tipo A conforme a NOM-030-STPS desde $850 MXN. DEA con capacitación incluida.
        </p>
        <div class="hero-ctas">
          <a
            href={`${WA_URL}?text=Hola%2C%20necesito%20cotizar%20equipo%20de%20primeros%20auxilios%20para%20mi%20empresa`}
            class="btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Cotizar equipo completo
          </a>
          <a href="#catalogo" class="btn-secondary">Ver los 5 productos</a>
        </div>
      </div>

      <div class="hero-right">
        <p>Tener equipo de primeros auxilios en el trabajo no es opcional. La NOM-030-STPS exige botiquín con contenido específico según el número de trabajadores, personal capacitado como brigadista y constancias DC-3 registradas ante STPS. Un botiquín incompleto o con insumos vencidos es observación en auditoría — y una emergencia real con equipo inútil es responsabilidad del patrón.</p>
        <p>En Proyecto Red vendemos botiquines ya armados conforme a norma, desfibriladores con instrucciones en español para personal no médico, camillas para cada tipo de traslado e inmovilizadores para sospecha de trauma de columna. Y si necesitas resurtido periódico para no administrar inventario de insumos médicos, también lo hacemos.</p>
      </div>
    </div>
  </section>

  <CtaBar />

  <!-- ══════════════════════════════════════
       CATÁLOGO
  ══════════════════════════════════════ -->
  <section class="cat-section cat-section--white" id="catalogo">
    <div class="container">

      <div class="cat-header">
        <div class="cat-header__img-wrap">
          <img src="/imagenes/primeros-auxilios/primeros-auxilios-hero.jpg" alt="Equipo de primeros auxilios certificado NOM-030-STPS para empresas" loading="eager" width="640" height="400" />
          <div class="cat-header__img-overlay"></div>
          <div class="cat-header__img-content">
            <span class="cat-norm-badge">NOM-030-STPS</span>
            <h2>Primeros Auxilios</h2>
          </div>
        </div>

        <div class="cat-header__info">
          <div class="cat-header__meta">
            <span class="section-label">5 categorías de equipo</span>
            <span class="cat-badge-pill">Resurtido periódico</span>
          </div>
          <h2 class="cat-header__title">Equipo que Funciona en los Primeros 10 Minutos — Que es Cuando Más Importa</h2>
          <p class="cat-header__desc">El tiempo de respuesta de una ambulancia en CDMX es de 8 a 20 minutos. En ese tiempo, el equipo de tu empresa es la única línea de atención. Botiquines tipo A, B y C conforme a NOM-030-STPS. DEA con electrodos activos. Camillas para cada tipo de traslado. Desde $850 MXN.</p>
          <div class="normas-row">
            <span class="norma-tag">NOM-030-STPS</span>
            <span class="norma-tag">NOM-028-STPS</span>
            <span class="norma-tag">NOM-006-STPS</span>
          </div>
          <div class="cat-header__ctas">
            <a href={`${WA_URL}?text=Hola%2C%20necesito%20armar%20la%20estaci%C3%B3n%20de%20primeros%20auxilios%20completa%20para%20mi%20empresa`} class="btn-outline" target="_blank" rel="noopener noreferrer">Estación completa por empresa</a>
            <a
              href={`${WA_URL}?text=Hola%2C%20necesito%20resurtir%20o%20completar%20mi%20botiquin%20de%20primeros%20auxilios`}
              class="cat-wa-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Resurtir botiquín
            </a>
          </div>
        </div>
      </div>

      <div class="productos-grid">
        {productos.map(p => (
          <a href={p.href} class="prod-card" aria-label={p.nombre}>
            <div class="prod-card__top">
              {p.badge && <span class="prod-badge">{p.badge}</span>}
              {!p.badge && <span class="prod-badge prod-badge--ghost">Disponible</span>}
            </div>
            <div class="prod-card__body">
              <h3 class="prod-card__name">{p.nombre}</h3>
              <p class="prod-card__sub">{p.desc}</p>
              <p class="prod-card__specs">{p.specs}</p>
            </div>
            <div class="prod-card__footer">
              <span class="prod-card__link">
                Ver specs y cotizar
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}

        <a
          href={`${WA_URL}?text=Hola%2C%20necesito%20armar%20la%20estaci%C3%B3n%20completa%20de%20primeros%20auxilios%20para%20mi%20empresa`}
          class="prod-card prod-card--cta"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Estación completa"
        >
          <div class="prod-card-cta__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </div>
          <p class="prod-card-cta__text">¿Estación completa desde cero?</p>
          <p class="prod-card-cta__sub">Botiquín + DEA + camilla + inmovilizadores + capacitación DC-3 en un solo paquete</p>
          <span class="prod-card-cta__btn">Cotizar paquete completo →</span>
        </a>

        <a
          href={`${WA_URL}?text=Hola%2C%20necesito%20resurtir%20mi%20botiquin%20o%20revisar%20el%20equipo%20de%20primeros%20auxilios%20que%20ya%20tengo`}
          class="prod-card prod-card--cta"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Resurtido de botiquín"
        >
          <div class="prod-card-cta__icon prod-card-cta__icon--muted">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          </div>
          <p class="prod-card-cta__text">¿Equipo existente que completar?</p>
          <p class="prod-card-cta__sub">Revisamos qué tienes, qué falta y qué está vencido — resurtido sin que tengas que gestionar inventario</p>
          <span class="prod-card-cta__btn">Solicitar resurtido →</span>
        </a>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════
       GUÍA POR TIPO DE EMPRESA
  ══════════════════════════════════════ -->
  <section class="cat-section cat-section--gray">
    <div class="container">

      <div class="cat-header">
        <div class="cat-header__img-wrap">
