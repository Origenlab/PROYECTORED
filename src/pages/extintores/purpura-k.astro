---
import Base from '../../layouts/Base.astro';
import CtaBar from '../../components/CtaBar.astro';
import FaqCotizacion from '../../components/FaqCotizacion.astro';
import '../../styles/pages.css';

const WHATSAPP = "525537238544";
const WA_URL = `https://wa.me/${WHATSAPP}`;

const title = "Extintor Púrpura K | Bicarbonato de Potasio | Clase B y C | Proyecto Red";
const description = "Extintores Púrpura K (bicarbonato de potasio) para clase B y C. 2x más efectivo que PQS en incendios clase B. Para refinerías, plantas petroquímicas, aeropuertos. De 4.5kg a 50kg rodante. NOM-154-SCFI. Entrega en CDMX.";

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Extintores", href: "/extintores/" },
  { label: "Púrpura K" },
];

const metricas = [
  { valor: "B · C", label: "Clases de fuego que combate" },
  { valor: "2x más potente", label: "vs polvo seco ABC en clase B" },
  { valor: "Púrpura", label: "Color distintivo del agente" },
  { valor: "4.5kg – 50kg", label: "Rango de capacidades" },
];

const variantes = [
  {
    nombre: "Púrpura K 4.5 kg",
    desc: "Capacity portátil para laboratorios químicos, zonas de almacenamiento de solventes medianas y pequeñas. Máxima efectividad en fuegos clase B intensos. Presión controlada para penetración en derrames de combustible o disolventes.",
    badge: "Compacto",
    specs: "Bicarbonato de potasio · 4.5kg · Presión 14 bar · 45-50s descarga · 5-6m alcance · No conductor",
    href: `${WA_URL}?text=Hola%2C%20quiero%20cotizar%20extintor%20P%C3%BArpura%20K%204.5kg`,
  },
  {
    nombre: "Púrpura K 9 kg Estándar",
    desc: "Capacidad intermedia para plantas petroquímicas pequeñas, laboratorios de alto riesgo y zonas de carga de combustibles. Mayor autonomía de descarga que 4.5kg — cubre áreas mayores con máxima potencia. Presión superior para alcance extendido.",
    badge: "Más vendido",
    specs: "Bicarbonato de potasio · 9kg · Presión 16 bar · 60-75s descarga · 6-8m alcance · No conductor",
    href: `${WA_URL}?text=Hola%2C%20quiero%20cotizar%20extintor%20P%C3%BArpura%20K%209kg`,
  },
  {
    nombre: "Púrpura K 25kg Rodante Industrial",
    desc: "Sistema rodante para plantas medianas de refinería, aeropuertos secundarios y depósitos de combustible. Concentración máxima de bicarbonato de potasio — máxima efectividad en fuegos clase B grandes. Movilidad completa con manguera de 3 metros.",
    badge: null,
    specs: "Bicarbonato de potasio · 25kg · Rodante · Presión 16 bar · Manguera 3m · 8-10m alcance · 70kg rodante",
    href: `${WA_URL}?text=Hola%2C%20quiero%20cotizar%20extintor%20P%C3%BArpura%20K%2025kg%20rodante`,
  },
  {
    nombre: "Púrpura K 50kg Rodante Industrial",
    desc: "Máxima capacidad para refinerías grandes, terminales de almacenamiento, plantas petroquímicas y hangares de aviación. Capacidad industrial para incendios clase B de gran escala. Cobertura de hasta 12 metros — protección de áreas extensas.",
    badge: "Industrial",
    specs: "Bicarbonato de potasio · 50kg · Rodante · Presión 18 bar · Manguera 5m · 10-12m alcance · 120kg rodante",
    href: `${WA_URL}?text=Hola%2C%20quiero%20cotizar%20extintor%20P%C3%BArpura%20K%2050kg%20rodante`,
  },
];

const guia = [
  {
    tipo: "Planta petroquímica / refinería",
    norma: "NFPA 10 · NOM-154-SCFI · PEMEX",
    necesitas: "Púrpura K 9kg mínimo por área crítica. Rodante 25-50kg distribuido cada 50-75 metros. Sistema automático en áreas de alto riesgo extremo.",
    porque: "En refinerías con almacenamiento masivo de hidrocarburos, el incendio clase B es exponencial en escala. El Púrpura K es 2x más efectivo que PQS en sofocación — la diferencia entre contener un fuego y verlo propagarse incontrolablemente.",
    href: `${WA_URL}?text=Hola%2C%20necesito%20extintores%20P%C3%BArpura%20K%20para%20refineria%20o%20petroquimica`,
  },
  {
    tipo: "Hangar aeronáutico",
    norma: "NFPA 10 · FAA Estándares · NOM-154-SCFI",
    necesitas: "Rodante Púrpura K 25kg — distribución: 1 cada 100 metros de perimetral. Ubicación próxima a fuentes potenciales (derrames de combustible de aviones).",
    porque: "Los hangares de aviación enfrentan riesgo clase B extremo — combustible de aviones (Jet A-1) en grandes volúmenes. NFPA especifica Púrpura K para estos espacios — es el estándar de la aviación porque apaga fuegos clase B mas rápido que alternativas.",
    href: `${WA_URL}?text=Hola%2C%20necesito%20extintores%20P%C3%BArpura%20K%20para%20hangar%20de%20aviaci%C3%B3n`,
  },
  {
    tipo: "Laboratorio químico / industrial",
    norma: "NOM-002-STPS · NOM-154-SCFI · Protocolos CIQUIME",
    necesitas: "Púrpura K 4.5-9kg según volumen de solventes y disolventes. Acceso rápido — menos de 15 metros de cualquier punto de almacenamiento.",
    porque: "En laboratorios con disolventes volátiles (acetona, tolueno, xileno), los incendios clase B son impredecibles y violentos. El Púrpura K sofoca rápido sin causar reacción secundaria — es el agente que los laboratorios exigen para compatibilidad química.",
    href: `${WA_URL}?text=Hola%2C%20necesito%20extintores%20P%C3%BArpura%20K%20para%20laboratorio%20qu%C3%ADmico`,
  },
  {
    tipo: "⚠ Cuándo NO usar Púrpura K",
    norma: "NFPA 10 · Alternativas: PQS, Agua, Espuma",
    necesitas: "No usar Púrpura K en: fuegos clase A (es ineficiente — usa PQS ABC), cocinas (usa Tipo K), oficinas sin riesgo B extremo (usa ABC multipropósito estándar). Púrpura K es especialista clase B puro.",
    porque: "El Púrpura K cuesta más que ABC estándar — solo se justifica en riesgo B alto. Si tu instalación es riesgo general (oficinas, comercios mixtos) el ABC 75% cumple normativa. El Púrpura K es para donde la escala del fuego clase B puede ser catastrófica — refinería, hangar, planta química.",
    href: `${WA_URL}?text=Hola%2C%20no%20estoy%20seguro%20si%20necesito%20P%C3%BArpura%20K%20o%20ABC%20tradicional`,
  },
];

const faqsPK = [
  {
    pregunta: "¿Por qué el Púrpura K es 2x más efectivo que polvo ABC tradicional?",
    respuesta: "El <strong>Púrpura K usa bicarbonato de potasio (KHCO₃)</strong>, el <strong>ABC usa fosfato monoamónico</strong>. En fuegos clase B, el bicarbonato de potasio <strong>sofoca más rápido y penetra mejor</strong> en combustibles líquidos — la molécuk es más reactiva químicamente. Comparación técnica: un extintor ABC de 9kg sofoca aprox. 20-30m² de derrame de gasolina. Un Púrpura K de 9kg sofoca ~40-50m² del mismo derrame. Es diferencia de efectividad matemática."
  },
  {
    pregunta: "¿Cuál es la diferencia entre color púrpura y color rojo en extintores de polvo?",
    respuesta: "En México el <strong>color del cuerpo del extintor es normalizador por NOM-154-SCFI</strong>: rojo universal. Pero el <strong>agente extintor tiene color intrínseco</strong>: <strong>blanco/gris = PQS (fosfato monoamónico)</strong>, <strong>púrpura/violeta = Púrpura K (bicarbonato de potasio)</strong>. El distintivo es el polvo que ves si se derrama o durante descarga. Púrpura K es identificable por el color único del polvo."
  },
  {
    pregunta: "¿Es seguro el Púrpura K en presencia de personas?",
    respuesta: "<strong>Sí, es seguro.</strong> El bicarbonato de potasio es <strong>no conductor de electricidad</strong> y <strong>no tóxico en concentraciones normales de uso</strong>. La inhalación de polvo fino puede causar irritación respiratoria temporal (como cualquier polvo fino), pero no es tóxico. Recomendación: usar en presencia de personas pero con ventilación adecuada después — abre ventanas para que el polvo se disipe."
  },
  {
    pregunta: "¿Puedo usar Púrpura K en equipos eléctricos energizados?",
    respuesta: "<strong>Sí, es no-conductor.</strong> El bicarbonato de potasio no conduce electricidad — es seguro en equipos energizados clase C. Sin embargo, Púrpura K es <strong>especialista clase B, NO clase C</strong> — si el riesgo es primariamente eléctrico, usa <a href='/extintores/abc/'>ABC multipropósito</a> o <a href='/extintores/co2/'>CO₂</a> que son diseñados para clase C. Púrpura K combate clase C secundariamente."
  },
  {
    pregunta: "¿Cuánto dura la carga de Púrpura K?",
    respuesta: "Un <strong>extintor Púrpura K bien mantenido puede durar indefinidamente</strong> si no fue descargado. El bicarbonato de potasio no se degrada. Lo que expire es la <strong>vigencia de mantenimiento: recarga anual obligatoria por NOM-154-SCFI</strong>. En servicio anual verificamos: (1) peso del polvo (si bajó >5%, recarga), (2) presión (debe estar en zona verde del manómetro), (3) integridad cilindro y válvula. Prueba hidrostática cada 5 años."
  },
  {
    pregunta: "¿Puedo usar Púrpura K como sustituto de ABC en cualquier instalación?",
    respuesta: "Técnicamente no. <strong>Púrpura K combate clase B y C únicamente</strong> — NO combate clase A (no es efectivo en sólidos). Si tu instalación tiene riesgo A (papeles, madera, cartón), Púrpura K dejaría que ardan porque su mecanismo no enfría ni sofoca clase A. Para riesgo mixto A+B, debes usar <a href='/extintores/abc/'>ABC multipropósito</a>. Púrpura K es puro clase B especialista."
  },
];
---

<Base
  title={title}
  description={description}
>

  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-left">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          {breadcrumbs.map((b, i) => (
            <>
              {i > 0 && <span class="breadcrumb__sep" aria-hidden="true">/</span>}
              {b.href
                ? <a href={b.href} class="breadcrumb__link">{b.label}</a>
                : <span class="breadcrumb__current" aria-current="page">{b.label}</span>
              }
            </>
          ))}
        </nav>
        <div class="hero-badge">
          <span class="badge-dot"></span>
          Púrpura K · Bicarbonato potasio · B y C · NOM-154-SCFI
        </div>
        <h1>Extintores<br><span class="h1-accent">Púrpura K Bicarbonato de Potasio</span></h1>
        <p class="hero-sub">
          En una refinería o hangar, el polvo ABC no es suficiente — necesitas la máxima potencia contra clase B. Púrpura K es 2x más efectivo que PQS. Desde $890 MXN. Entrega el mismo día en CDMX.
        </p>
        <div class="hero-ctas">
          <a
            href={`${WA_URL}?text=Hola%2C%20necesito%20cotizar%20extintores%20P%C3%BArpura%20K%20para%20instalaci%C3%B3n%20industrial`}
            class="btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Cotizar Púrpura K
          </a>
          <a href="#variantes" class="btn-secondary">Ver capacidades</a>
        </div>
      </div>

      <div class="hero-right">
        <p>El Púrpura K es la herramienta industrial especializada para fuegos clase B de altísima intensidad. Su agente — bicarbonato de potasio — es 2x más efectivo que el fosfato monoamónico (ABC) contra combustibles líquidos. En refinerías, plantas petroquímicas y hangares de aviación, donde un fuego clase B puede ser catastrófico, el Púrpura K es el estándar porque sofoca más rápido y con mayor cobertura.</p>
        <p>Es el extintor de las industrias de mayor riesgo: PEMEX, Aeroméxico, empresas de transporte de combustibles. No es universal como el ABC — es un especialista puro en clase B. Pero donde importa la clase B, no hay alternativa mejor. Es inversión en capacidad de extinción máxima.</p>
      </div>
    </div>
  </section>

  <CtaBar />

  <section class="metricas-section" aria-label="Datos técnicos del extintor Púrpura K">
    <div class="container">
      <div class="metricas-grid">
        {metricas.map(m => (
          <div class="metrica-item">
            <span class="metrica-valor">{m.valor}</span>
            <span class="metrica-label">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--white" id="variantes">
    <div class="container">

      <div class="cat-header">
        <div class="cat-header__img-wrap">
          <img src="/imagenes/extintores/purpura-k-hero.jpg" alt="Extintor Púrpura K para refinería y planta petroquímica" loading="eager" width="640" height="400" />
          <div class="cat-header__img-overlay"></div>
          <div class="cat-header__img-content">
            <span class="cat-norm-badge">NOM-154-SCFI</span>
            <h2>Púrpura K — Máxima Potencia</h2>
          </div>
        </div>

        <div class="cat-header__info">
          <div class="cat-header__meta">
            <span class="section-label">Variantes disponibles</span>
            <span class="cat-badge-pill">Clase B especialista</span>
          </div>
          <h2 class="cat-header__title">De 4.5kg a 50kg Rodante Industrial</h2>
          <p class="cat-header__desc">Cuatro capacidades de bicarbonato de potasio puro, desde laboratorios hasta refinerías de escala mayor. Máxima potencia en fuegos clase B — 2x más efectivo que polvo seco tradicional. Especificado en NFPA para industria petrolera.</p>
          <div class="normas-row">
            <span class="norma-tag">NFPA 10</span>
            <span class="norma-tag">NOM-154-SCFI</span>
            <span class="norma-tag">PEMEX</span>
            <span class="norma-tag">FAA Aviación</span>
          </div>
          <div class="cat-header__ctas">
            <a href={`${WA_URL}?text=Hola%2C%20necesito%20recarga%20de%20extintores%20P%C3%BArpura%20K`} class="btn-outline" target="_blank" rel="noopener noreferrer">Recarga y mantenimiento</a>
            <a
              href={`${WA_URL}?text=Hola%2C%20necesito%20cotizar%20extintores%20P%C3%BArpura%20K`}
              class="cat-wa-link"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Cotizar por WhatsApp
            </a>
          </div>
        </div>
      </div>

      <div class="productos-grid">
        {variantes.map(v => (
          <a href={v.href} class="prod-card" target="_blank" rel="noopener noreferrer" aria-label={v.nombre}>
            <div class="prod-card__top">
              {v.badge && <span class="prod-badge">{v.badge}</span>}
              {!v.badge && <span class="prod-badge prod-badge--ghost">Disponible</span>}
            </div>
            <div class="prod-card__body">
              <h3 class="prod-card__name">{v.nombre}</h3>
              <p class="prod-card__sub">{v.desc}</p>
              <p class="prod-card__specs">{v.specs}</p>
            </div>
            <div class="prod-card__footer">
              <span class="prod-card__link">
                Cotizar esta capacidad
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}

        <a
          href={`${WA_URL}?text=Hola%2C%20qu%C3%A9%20cantidad%20de%20P%C3%BArpura%20K%20necesito%20para%20mi%20refiner%C3%ADa%20o%20hangar`}
          class="prod-card prod-card--cta"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Asesoría para cantidad de Púrpura K"
        >
          <div class="prod-card-cta__icon prod-card-cta__icon--muted">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </div>
          <p class="prod-card-cta__text">¿Cuántos Púrpura K necesito?</p>
          <p class="prod-card-cta__sub">Dinos tamaño instalación y tipo (refinería, hangar, laboratorio) — calculamos distribución óptima</p>
          <span class="prod-card-cta__btn">Consultar por WhatsApp →</span>
        </a>
      </div>

    </div>
  </section>

  <section class="cat-section cat-section--gray">
    <div class="container">

      <div class="cat-header">
        <div class="cat-header__img-wrap">
          <img src="/imagenes/extintores/purpura-k-industrial.jpg" alt="Púrpura K en planta industrial y hangar de aviación" loading="lazy" width="640" height="400" />
          <div class="cat-header__img-overlay"></div>
          <div class="cat-header__img-content">
            <span class="cat-norm-badge">Especialista clase B</span>
            <h2>Por Tipo de Instalación</h2>
          </div>
        </div>

        <div class="cat-header__info">
          <div class="cat-header__meta">
            <span class="section-label">Guía de selección</span>
            <span class="cat-badge-pill">Alto riesgo industrial</span>
          </div>
          <h2 class="cat-header__title">Donde la Escala de Clase B Requiere Máxima Potencia</h2>
          <p class="cat-header__desc">Púrpura K no es para toda instalación — es para donde el fuego clase B puede causar pérdidas catastróficas. Refinería, hangar, laboratorio químico, planta petroquímica. Si tu riesgo B es grande, Púrpura K es obligatorio.</p>
          <div class="cat-header__ctas">
            <a href="/extintores/" class="btn-outline">Ver todos los extintores</a>
            <a
              href={`${WA_URL}?text=Hola%2C%20quiero%20asesor%C3%ADa%20sobre%20P%C3%BArpura%20K%20para%20mi%20instalaci%C3%B3n%20industrial`}
              class="cat-wa-link"
              target="_blank"
              rel="noopener noreferrer"
            >
