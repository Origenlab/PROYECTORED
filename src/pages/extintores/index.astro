---
/**
 * extintores/index.astro — Categoría de extintores de Proyecto Red
 * ─────────────────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO + JSON-LD de nivel técnico.
 * Cada sección vive en src/components/sections/ con sus propios estilos.
 * SectionHeader.astro es el complemento oficial de encabezado en todas las secciones.
 */

import Base              from '../../layouts/Base.astro'
import CtaBar            from '../../components/CtaBar.astro'
import Breadcrumb        from '../../components/ui/Breadcrumb.astro'

// ── Secciones específicas de extintores ───────────────────
import HeroExtintores    from '../../components/sections/HeroExtintores.astro'
import CatalogoExtintores from '../../components/sections/CatalogoExtintores.astro'
import GuiaExtintores    from '../../components/sections/GuiaExtintores.astro'
import NormasExtintores  from '../../components/sections/NormasExtintores.astro'
import FaqExtintores     from '../../components/sections/FaqExtintores.astro'

// ── Secciones genéricas reutilizadas del index ────────────
import TrustIndex        from '../../components/sections/TrustIndex.astro'
import ServiciosIndex    from '../../components/sections/ServiciosIndex.astro'
// ReviewsIndex removido de esta página
import CTAFinalIndex     from '../../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ────────────────────────────────────
import { SITE, CONTACT } from '../../config/site'

const siteUrl = SITE.url
const pageUrl = `${siteUrl}/extintores/`
const ogImage = `${siteUrl}/imagenes/og/extintores-og.jpg`

// ── Schema: ItemList — 10 tipos de extintores ─────────────
const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Tipos de extintores contra incendios — Proyecto Red",
  "description": "Catálogo de extintores certificados NOM-154-SCFI: polvo seco ABC, CO₂, AFFF espuma, Tipo K, Púrpura K, agua a presión, Cold Fire, automáticos, ABC multipropósito y agente limpio.",
  "url": pageUrl,
  "numberOfItems": 10,
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Extintor Polvo Seco ABC (PQS)",
      "description": "Combate fuegos clase A, B y C. Disponible de 1 kg a 50 kg. El más utilizado en México. Obligatorio según NOM-002-STPS.",
      "url": `${siteUrl}/extintores/polvo-seco/`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Extintor CO₂ — Dióxido de Carbono",
      "description": "Descarga limpia sin residuos. Ideal para equipos eléctricos, servidores y laboratorios. Disponible de 2.3 a 6.8 kg.",
      "url": `${siteUrl}/extintores/co2/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Extintor AFFF — Espuma Mecánica",
      "description": "Espuma formadora de película acuosa para líquidos inflamables. Para gasolineras, talleres y plantas químicas.",
      "url": `${siteUrl}/extintores/afff/`
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "Extintor Tipo K — Cocinas Industriales",
      "description": "Especializado en aceites vegetales y grasas animales. Obligatorio en restaurantes y cocinas industriales con freidoras.",
      "url": `${siteUrl}/extintores/tipo-k/`
    },
    {
      "@type": "ListItem",
      "position": 5,
      "name": "Extintor Púrpura K — Bicarbonato de Potasio",
      "description": "Mayor poder de extinción que el PQS en fuegos clase B y C de alta intensidad. Industria petroquímica y aeroportuaria.",
      "url": `${siteUrl}/extintores/purpura-k/`
    },
    {
      "@type": "ListItem",
      "position": 6,
      "name": "Extintor Agua a Presión",
      "description": "Solución ecológica para materiales sólidos combustibles: madera, papel, tela. Sin agentes químicos.",
      "url": `${siteUrl}/extintores/agua-a-presion/`
    },
    {
      "@type": "ListItem",
      "position": 7,
      "name": "Extintor Cold Fire",
      "description": "Tecnología de enfriamiento rápido. Biodegradable, no tóxico y recargable con agua. Clase A, B, D y K.",
      "url": `${siteUrl}/extintores/cold-fire/`
    },
    {
      "@type": "ListItem",
      "position": 8,
      "name": "Extintor Automático",
      "description": "Activación autónoma por temperatura a 68°C o 93°C. Para áreas desatendidas: cuartos de máquinas, servidores, bodegas.",
      "url": `${siteUrl}/extintores/automaticos/`
    },
    {
      "@type": "ListItem",
      "position": 9,
      "name": "Extintor ABC Multipropósito",
      "description": "El más versátil: cubre fuegos clase A, B y C. Requerido por norma en la mayoría de inmuebles comerciales e industriales.",
      "url": `${siteUrl}/extintores/abc/`
    },
    {
      "@type": "ListItem",
      "position": 10,
      "name": "Extintor Agente Limpio (FM-200 / Novec 1230)",
      "description": "Cero residuos, cero daño a equipos. Estándar premium para centros de datos y áreas con materiales sensibles. UL Listed.",
      "url": `${siteUrl}/extintores/agente-limpio/`
    }
  ]
}

// ── Schema: FAQPage ───────────────────────────────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué extintor necesito para mi oficina o negocio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Para la mayoría de oficinas y comercios, el extintor ABC multipropósito de 4.5 kg es el estándar. Si tienes equipos electrónicos (servidores, UPS), complementa con un CO₂ de 4.5 kg en ese espacio. Si hay cocina con freidoras, necesitas un Tipo K además del ABC. Ofrecemos diagnóstico por zona sin costo."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuántos extintores necesito según la NOM-002-STPS?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La norma establece un extintor por cada 300 m² de superficie, con un mínimo de uno por piso. La distancia máxima de recorrido hasta un extintor es de 15 metros para riesgo ordinario. Cada extintor debe ser del tipo correcto para el riesgo predominante de esa zona."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta un extintor certificado NOM en CDMX?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Un extintor PQS ABC de 4.5 kg (el más común) parte desde $450 MXN. Los de CO₂ arrancan desde $850 MXN y los de agente limpio son más costosos por el tipo de gas. El precio final depende del tipo, capacidad y cantidad solicitada."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es la diferencia entre PQS y ABC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "PQS (Polvo Químico Seco) y ABC son prácticamente lo mismo: ambos usan fosfato monoamónico como agente y cubren fuegos clase A, B y C. En el mercado mexicano se usan ambos nombres para el mismo producto."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cada cuánto tiempo se recarga un extintor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "La NOM-154-SCFI exige recarga anual o después de cualquier uso, parcial o total. Cada 5 años es obligatoria la prueba hidrostática para verificar la integridad del cilindro."
      }
    },
    {
      "@type": "Question",
      "name": "¿El extintor incluye soporte de pared y señalamiento?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Todos los extintores incluyen soporte de pared (bracket) para instalación. El señalamiento de ubicación se cotiza aparte, aunque lo ofrecemos junto con el equipo. La norma exige señalar cada extintor con un cartel fotoluminiscente."
      }
    },
    {
      "@type": "Question",
      "name": "¿Hacen mantenimiento y recarga a domicilio en CDMX?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Vamos a tus instalaciones para el mantenimiento preventivo, recarga y verificación del cilindro. El servicio incluye revisión del agente, presión, válvulas, manguera y actualización de la etiqueta de inspección. Ofrecemos pólizas anuales con reportes para auditorías."
      }
    },
    {
      "@type": "Question",
      "name": "¿Los extintores incluyen la documentación para Protección Civil?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Cada extintor sale con certificado de conformidad NOM-154-SCFI, ficha técnica del fabricante, etiqueta de inspección y garantía. Son los cuatro documentos que solicita la autoridad en una inspección."
      }
    }
  ]
}

// ── Schema: BreadcrumbList ────────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": `${siteUrl}/`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Productos",
      "item": `${siteUrl}/productos/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Extintores",
      "item": pageUrl
    }
  ]
}

// ── Schema: CollectionPage (WebPage) ─────────────────────
const schemaWebPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Venta de Extintores Contra Incendios en CDMX — Certificados NOM | Proyecto Red",
  "description": "Catálogo completo de extintores certificados NOM-154-SCFI: polvo seco ABC, CO₂, AFFF, Tipo K, agente limpio, Cold Fire y automáticos. Venta directa con entrega el mismo día en CDMX. Desde $450 MXN.",
  "url": pageUrl,
  "image": ogImage,
  "inLanguage": "es-MX",
  "isPartOf": {
    "@type": "WebSite",
    "name": "Proyecto Red",
    "url": siteUrl
  },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
      { "@type": "ListItem", "position": 3, "name": "Extintores", "item": pageUrl }
    ]
  },
  "mainEntity": {
    "@id": pageUrl + "#itemlist"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Proyecto Red",
    "url": siteUrl,
    "logo": `${siteUrl}/imagenes/logos/logo-proyectored-201x60.png`,
    "telephone": `+52${CONTACT.phoneRaw}`,
    "email": CONTACT.email
  }
}
---

<Base
  title="Venta de Extintores Contra Incendios en CDMX | Certificados NOM-154-SCFI | Proyecto Red"
  description="Catálogo completo de extintores certificados NOM: polvo seco ABC, CO₂, AFFF, Tipo K, agente limpio, Cold Fire y automáticos. Entrega el mismo día en CDMX y Estado de México. Asesoría técnica gratuita. Desde $450 MXN."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <!-- ── Secciones ────────────────────────────────────────── -->
  <!-- Barra de migas de pan -->
  <div class="breadcrumb-bar">
    <div class="container">
      <Breadcrumb items={[
        { label: 'Inicio', href: '/' },
        { label: 'Productos', href: '/productos/' },
        { label: 'Extintores' }
      ]} />
    </div>
  </div>

  <HeroExtintores />
  <CtaBar />
  <CatalogoExtintores />
  <GuiaExtintores />
  <TrustIndex />
  <ServiciosIndex />
  <NormasExtintores />
  <FaqExtintores />
  <CTAFinalIndex />

  <!-- ── Datos estructurados JSON-LD ──────────────────────
       Inyectados al final del <body> para no bloquear render
  ─────────────────────────────────────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebPage)} />

</Base>
