---
// src/pages/extintores/[producto].astro
// Páginas de Nivel 4 — productos individuales de la categoría Extintores
// Genera: /extintores/polvo-seco/, /extintores/co2/, /extintores/afff/,
//         /extintores/tipo-k/, /extintores/purpura-k/, /extintores/agua-a-presion/,
//         /extintores/cold-fire/, /extintores/automaticos/, /extintores/abc/,
//         /extintores/agente-limpio/

import CategoryLayout from '../../layouts/CategoryLayout.astro'
import SectionHeaderDuo from '../../components/ui/SectionHeaderDuo.astro'
import Img from '../../components/ui/Img.astro'
import TrustIndex from '../../components/sections/TrustIndex.astro'
import NormasExtintores from '../../components/sections/NormasExtintores.astro'
import { waUrl, SERVICES } from '../../config/site'
import { EXTINTOR_PAGES, EXTINTOR_PRODUCTS } from '../../data/extintores-productos'
import '../../styles/product-page.css'
import '../../styles/pages.css'

// Servicios más relevantes para esta categoría
const RELATED_SERVICES = SERVICES.filter((s) =>
  ['recarga-extintores', 'mantenimiento-preventivo', 'prueba-hidrostatica', 'asesoria-tecnica'].includes(s.id)
)

// ── Rutas estáticas ──────────────────────────────────────────
export function getStaticPaths() {
  return EXTINTOR_PRODUCTS.map((p) => ({
    params: { producto: p.slug },
    props: { slug: p.slug },
  }))
}

const { producto } = Astro.params
const data = EXTINTOR_PAGES[producto]

if (!data) {
  return Astro.redirect('/extintores/')
}

// Productos relacionados (los demás, excluyendo el actual)
const related = EXTINTOR_PRODUCTS.filter((p) => p.slug !== producto)

const PAGE_WA = waUrl(data.waMessage)

// Helpers para la sección de variantes
const hasVariantes = data.variantes && data.variantes.length > 0

const getVariantesDesc = () => {
  const productName = data.heroAccent || 'este extintor'
  return `Disponemos de ${data.variantes?.length || 0} capacidades de ${productName} con stock permanente y certificación NOM, lista para entrega inmediata en CDMX.`
}

const getVariantesBodyPara = () => {
  return 'Todas nuestras capacidades cumplen con las normas NOM-002-STPS y están disponibles con documentación técnica completa. Consulta stock y disponibilidad para tu zona.'
}
---

<CategoryLayout
  title={data.metaTitle}
  description={data.metaDesc}
  badge={data.badge}
  heroTitle={data.heroTitle}
  heroAccent={data.heroAccent}
  heroSubtitle={data.heroSubtitle}
  heroDescRight={data.heroDescRight}
  cta1={{ text: 'Cotizar por WhatsApp', href: PAGE_WA }}
  cta2={{ text: 'Ver todos los extintores', href: '/extintores/' }}
  breadcrumb={[
    { label: 'Inicio',     href: '/'            },
    { label: 'Productos',  href: '/productos/'  },
    { label: 'Extintores', href: '/extintores/' },
    { label: data.heroAccent },
  ]}
  showForm={true}
  faqItems={data.faqItems}
  ctaTitle={data.ctaTitle}
  ctaBody={data.ctaBody}
  ctaCTA1Text="Cotizar por WhatsApp"
  ctaCTA1Href={PAGE_WA}
  ctaCTA2Text="Ver todos los extintores"
  ctaCTA2Href="/extintores/"
>

  <!-- ===========================================================
       SECCIÓN 0 — Variantes / Capacidades disponibles
       =========================================================== -->
  {hasVariantes && (
    <section class="cat-section cat-section--white" id="variantes">
      <div class="container">

        <SectionHeaderDuo
          eyebrow="Capacidades disponibles"
          titleLine1="Selecciona la capacidad"
          titleLine2="que necesitas"
          desc={getVariantesDesc()}
          bodyPara1={getVariantesBodyPara()}
        />

        <div class="catidx-grid" role="list" aria-label={`Capacidades de ${data.heroAccent}`}>
          {data.variantes.map((v, i) => (
            <article class="ccard" role="listitem" aria-label={v.nombre}>
              {(() => {
                const imgSrc = v.img ?? data.img
                return (
                  <div class:list={['ccard__header', !imgSrc && 'ccard__header--placeholder']}>
                    {imgSrc ? (
                      <Img
                        src={imgSrc}
                        alt={v.nombre}
                        loading={i < 4 ? 'eager' : 'lazy'}
                        fetchpriority={i === 0 ? 'high' : undefined}
                        width={640}
                        height={360}
                        sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 320px"
                      />
                    ) : (
                      <div class="ccard__placeholder-icon" aria-hidden="true">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                          <circle cx="8.5" cy="8.5" r="1.5"/>
                          <polyline points="21 15 16 10 5 21"/>
                        </svg>
                        <span class="ccard__placeholder-label">Imagen próximamente</span>
                      </div>
                    )}
                    {imgSrc && <div class="ccard__header-overlay" aria-hidden="true"></div>}
                    {v.badge && <span class="ccard__badge">{v.badge}</span>}
                  </div>
                )
              })()}
              <div class="ccard__content">
                <h3 class="ccard__title">{v.nombre}</h3>
                <p class="ccard__desc">{v.desc}</p>
                {v.specs && <p class="ccard__specs">{v.specs}</p>}
                <a
                  href={waUrl(v.waText)}
                  class="ccard__cta"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Cotizar esta capacidad
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>
            </article>
          ))}

          <!-- CTA Card WhatsApp -->
          <article class="ccard ccard--cta-wa" aria-label="Asesoría para elegir capacidad">
            <a
              href={PAGE_WA}
              class="ccard--cta-wa__inner"
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="ccard--cta-wa__icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <p class="ccard--cta-wa__title">¿No encuentras tu capacidad?</p>
              <p class="ccard--cta-wa__sub">Cotiza directo por WhatsApp — te asesoramos sin costo.</p>
              <span class="ccard--cta-wa__btn">Enviar mensaje →</span>
            </a>
          </article>
        </div>

      </div>
    </section>
  )}

  <!-- ===========================================================
       SECCIÓN 1 — Características técnicas
       =========================================================== -->
  <section class={`cat-section ${hasVariantes ? 'cat-section--gray' : 'cat-section--white'}`} id="caracteristicas">
    <div class="container">

      <SectionHeaderDuo
        eyebrow={data.caracteristicas.eyebrow}
        titleLine1={data.caracteristicas.titleLine1}
        titleLine2={data.caracteristicas.titleLine2}
        desc={data.caracteristicas.desc}
        bodyPara1={data.caracteristicas.bodyPara}
      />

      <div class="l4-svc-grid" role="list" aria-label="Características técnicas">
        {data.caracteristicas.items.map((item, idx) => (
          <div class="srv-mini" role="listitem" aria-label={item.title}>
            <span class="srv-mini__num" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</span>
            <div class="srv-mini__body">
              <strong class="srv-mini__titulo">{item.title}</strong>
              <span class="srv-mini__sub">{item.desc}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA inline -->
      <div class="inline-cta">
        <p class="inline-cta__text">¿Tienes dudas sobre las especificaciones? Te asesoramos sin costo.</p>
        <a
          href={PAGE_WA}
          class="btn btn--red"
          target="_blank"
          rel="noopener noreferrer"
        >
          Preguntar por WhatsApp
        </a>
      </div>

    </div>
  </section>

  <!-- ===========================================================
       SECCIÓN 2 — ¿Cuándo usar?
       =========================================================== -->
  <section class="cat-section cat-section--white" id="cuando-usar">
    <div class="container">

      <SectionHeaderDuo
        eyebrow={data.cuandoUsar.eyebrow}
        titleLine1={data.cuandoUsar.titleLine1}
        titleLine2={data.cuandoUsar.titleLine2}
        desc={data.cuandoUsar.desc}
        bodyPara1={data.cuandoUsar.bodyPara}
      />

      <div class="l4-svc-grid" role="list" aria-label="Dónde usar este extintor">
        {data.cuandoUsar.usos.map((uso, idx) => (
          <div class="srv-mini" role="listitem" aria-label={uso.label}>
            <span class="srv-mini__num" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</span>
            <div class="srv-mini__body">
              <strong class="srv-mini__titulo">{uso.label}</strong>
              <span class="srv-mini__sub">{uso.desc}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA inline -->
      <div class="inline-cta">
        <p class="inline-cta__text">¿No estás seguro de qué extintor necesitas? Te hacemos el diagnóstico sin costo.</p>
        <a
          href={PAGE_WA}
          class="btn btn--red"
          target="_blank"
          rel="noopener noreferrer"
        >
          Solicitar diagnóstico
        </a>
      </div>

    </div>
  </section>

  <!-- ===========================================================
       SECCIÓN 3 — Servicios relacionados (patrón srv-mini de L1)
       =========================================================== -->
  <section class="cat-section cat-section--gray" id="servicios-extintor">
    <div class="container">

      <SectionHeaderDuo
        eyebrow="Servicios para tu extintor"
        titleLine1="Mantenimiento y soporte"
        titleLine2="profesional incluido"
        desc="No solo vendemos el equipo — lo recargamos, mantenemos y certificamos."
        bodyPara1="Cada extintor requiere mantenimiento anual, recarga periódica y prueba hidrostática cada 5 años conforme a la NOM-154-SCFI. Te ofrecemos el ciclo completo de servicio para que tu equipo siempre esté en norma."
      />

      <div class="l4-svc-grid" role="list" aria-label="Servicios disponibles para extintores">
        {RELATED_SERVICES.map((svc, idx) => (
          <a href={`/servicios/#${svc.id}`} class="srv-mini" role="listitem" aria-label={svc.label}>
            <span class="srv-mini__num" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</span>
            <div class="srv-mini__body">
              <strong class="srv-mini__titulo">{svc.label}</strong>
              <span class="srv-mini__sub">{svc.desc}</span>
            </div>
            <svg class="srv-mini__arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ===========================================================
       SECCIÓN 4 — Por qué Proyecto Red (homologado con L1/L3)
       =========================================================== -->
  <TrustIndex />

  <!-- ===========================================================
       SECCIÓN 5 — Normas aplicables (homologado con L3)
       =========================================================== -->
  <NormasExtintores />

  <!-- ===========================================================
       SECCIÓN 6 — Otros extintores del catálogo
       =========================================================== -->
  <section class="cat-section cat-section--white" id="otros-extintores">
    <div class="container">

      <SectionHeaderDuo
        eyebrow="Más opciones"
        titleLine1={data.relatedTitle}
        desc="Cada tipo de extintor está diseñado para un tipo de fuego distinto. Consulta las demás opciones para complementar tu protección."
        bodyPara1="La NOM-002-STPS exige que el extintor sea del tipo adecuado para el riesgo predominante de cada zona. Explora los demás tipos y asegúrate de cubrir todos los escenarios de tu instalación."
      />

      <div class="catidx-grid" role="list" aria-label="Otros tipos de extintor disponibles">
        {related.map((r, i) => (
          <article class="ccard" role="listitem" aria-label={r.label}>
            <div class="ccard__header">
              <Img
                src={r.img}
                alt={r.label}
                loading="lazy"
                width={640}
                height={360}
                sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 320px"
              />
              <div class="ccard__header-overlay" aria-hidden="true"></div>
              {r.badge && <span class="ccard__badge">{r.badge}</span>}
            </div>
            <div class="ccard__content">
              <h3 class="ccard__title">{r.label}</h3>
              <p class="ccard__desc">{r.desc}</p>
              <a href={`/extintores/${r.slug}/`} class="ccard__cta">
                Ver detalles
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            </div>
          </article>
        ))}

        <!-- CTA Card WhatsApp -->
        <article class="ccard ccard--cta-wa" aria-label="Asesoría para elegir extintor">
          <a
            href={PAGE_WA}
            class="ccard--cta-wa__inner"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="ccard--cta-wa__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <p class="ccard--cta-wa__title">¿No sabes qué extintor necesitas?</p>
            <p class="ccard--cta-wa__sub">Dinos tu tipo de instalación y riesgos — te recomendamos el equipo correcto por zona, gratis.</p>
            <span class="ccard--cta-wa__btn">Asesoría por WhatsApp →</span>
          </a>
        </article>
      </div>

    </div>
  </section>

</CategoryLayout>
