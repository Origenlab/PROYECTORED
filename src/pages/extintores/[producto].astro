---
// src/pages/extintores/[producto].astro
// Páginas de Nivel 4 — productos individuales de la categoría Extintores (L4 Homologation)
// Genera: /extintores/polvo-seco/, /extintores/co2/, /extintores/afff/,
//         /extintores/tipo-k/, /extintores/purpura-k/, /extintores/agua-a-presion/,
//         /extintores/cold-fire/, /extintores/automaticos/, /extintores/abc/,
//         /extintores/agente-limpio/

import CategoryLayout from '../../layouts/CategoryLayout.astro'
import SectionHeaderDuo from '../../components/ui/SectionHeaderDuo.astro'
import { waUrl, SERVICES } from '../../config/site'
import { EXTINTOR_PAGES, EXTINTOR_PRODUCTS } from '../../data/extintores-productos'
import '../../styles/product-page.css'
import '../../styles/pages.css'

// Servicios más relevantes para esta categoría
const RELATED_SERVICES = SERVICES.filter((s) =>
  ['recarga-extintores', 'mantenimiento-preventivo', 'prueba-hidrostatica', 'asesoria-tecnica'].includes(s.id)
)

// ── Rutas estáticas ──────────────────────────────────────────
export function getStaticPaths() {
  return EXTINTOR_PRODUCTS.map((p) => ({
    params: { producto: p.slug },
    props: { slug: p.slug },
  }))
}

const { producto } = Astro.params
const data = EXTINTOR_PAGES[producto]

if (!data) {
  return Astro.redirect('/extintores/')
}

// Productos relacionados (los demás, excluyendo el actual)
const related = EXTINTOR_PRODUCTS.filter((p) => p.slug !== producto)

const PAGE_WA = waUrl(data.waMessage)

// Helpers para la sección de variantes
const hasVariantes = data.variantes && data.variantes.length > 0

// Generar descripciones dinámicas basadas en el nombre del producto
const getVariantesDesc = () => {
  const productName = data.heroAccent || 'este extintor'
  return `Disponemos de ${data.variantes?.length || 0} capacidades de ${productName} con stock permanente y certificación NOM, lista para entrega inmediata en CDMX.`
}

const getVariantesBodyPara = () => {
  return 'Todas nuestras capacidades cumplen con las normas NOM-002-STPS y están disponibles con documentación técnica completa. Consulta stock y disponibilidad para tu zona.'
}
---

<CategoryLayout
  title={data.metaTitle}
  description={data.metaDesc}
  badge={data.badge}
  heroTitle={data.heroTitle}
  heroAccent={data.heroAccent}
  heroSubtitle={data.heroSubtitle}
  heroDescRight={data.heroDescRight}
  cta1={{ text: 'Cotizar por WhatsApp', href: PAGE_WA }}
  cta2={{ text: 'Ver todos los extintores', href: '/extintores/' }}
  breadcrumb={[
    { label: 'Inicio',     href: '/'            },
    { label: 'Productos',  href: '/productos/'  },
    { label: 'Extintores', href: '/extintores/' },
    { label: data.heroAccent },
  ]}
  stats={data.stats}
  showForm={true}
  faqItems={data.faqItems}
  ctaTitle={data.ctaTitle}
  ctaBody={data.ctaBody}
  ctaCTA1Text="Cotizar por WhatsApp"
  ctaCTA1Href={PAGE_WA}
  ctaCTA2Text="Ver todos los extintores"
  ctaCTA2Href="/extintores/"
>

  <!-- ===========================================================
       SECCIÓN 0 — Variantes (solo si existen)
       =========================================================== -->
  {hasVariantes && (
    <section class="cat-section cat-section--white" id="variantes">
      <div class="container">

        <SectionHeaderDuo
          eyebrow="Capacidades disponibles"
          titleLine1="Selecciona la capacidad"
          titleLine2="que necesitas"
          desc={getVariantesDesc()}
          bodyPara1={getVariantesBodyPara()}
        />

        <div class="catidx-grid">
          {data.variantes.map((v) => {
            const imgSrc = v.img || data.img
            return (
              <article class="ccard">
                <div class="ccard__header">
                  <img src={imgSrc} alt={v.nombre} loading="lazy" />
                  <div class="ccard__header-overlay"></div>
                  {v.badge && <span class="ccard__badge">{v.badge}</span>}
                </div>
                <div class="ccard__content">
                  <h3 class="ccard__title">{v.nombre}</h3>
                  <p class="ccard__desc">{v.desc}</p>
                  {v.specs && <p class="ccard__specs">{v.specs}</p>}
                  <a
                    href={waUrl(v.waText)}
                    class="ccard__cta"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Cotizar esta capacidad
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              </article>
            )
          })}

          <!-- CTA Card para WhatsApp -->
          <article class="ccard ccard--cta-wa">
            <div class="ccard__content" style="justify-content:center; text-align:center; padding:2rem;">
              <div style="margin-bottom:1rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="#25D366">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.148-.198.297-.766.967-.94 1.165-.173.198-.347.223-.645.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.52.149-.174.198-.298.297-.497.099-.198.05-.371-.025-.52-.075-.148-.67-1.616-.918-2.213-.242-.579-.487-.501-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.71.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004a8.06 8.06 0 0 0-8.062 8.062c0 1.42.369 2.8 1.07 4.015L3.707 21.98l4.244-1.111a8.007 8.007 0 0 0 3.826.972h.005c4.47 0 8.068-3.597 8.068-8.062 0-2.153-.841-4.181-2.369-5.703-1.529-1.523-3.556-2.364-5.704-2.364"/>
                </svg>
              </div>
              <h3 class="ccard__title" style="border:none; padding-left:0; color:#fff;">¿No encuentras tu capacidad?</h3>
              <p class="ccard__desc" style="color:rgba(255,255,255,.7);">Cotiza directo por WhatsApp — te asesoramos sin costo.</p>
              <a
                href={PAGE_WA}
                class="ccard__cta"
                style="color:#25D366;"
                target="_blank"
                rel="noopener noreferrer"
              >
                Enviar mensaje
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        </div>

      </div>
    </section>
  )}

  <!-- ===========================================================
       SECCIÓN 1 — Características técnicas
       =========================================================== -->
  <section class={`cat-section ${hasVariantes ? 'cat-section--gray' : 'cat-section--white'}`} id="caracteristicas">
    <div class="container">

      <SectionHeaderDuo
        eyebrow={data.caracteristicas.eyebrow}
        titleLine1={data.caracteristicas.titleLine1}
        titleLine2={data.caracteristicas.titleLine2}
        desc={data.caracteristicas.desc}
        bodyPara1={data.caracteristicas.bodyPara}
      />

      <div class="features-grid">
        {data.caracteristicas.items.map((item) => (
          <div class="feature-card">
            <div class="feature-card__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div class="feature-card__body">
              <h3 class="feature-card__title">{item.title}</h3>
              <p class="feature-card__desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA inline -->
      <div class="inline-cta">
        <p class="inline-cta__text">¿Tienes dudas sobre las especificaciones? Te asesoramos sin costo.</p>
        <a
          href={PAGE_WA}
          class="btn btn--red"
          target="_blank"
          rel="noopener noreferrer"
        >
          Preguntar por WhatsApp
        </a>
      </div>

    </div>
  </section>

  <!-- ===========================================================
       SECCIÓN 2 — ¿Cuándo usar?
       =========================================================== -->
  <section class="cat-section cat-section--white" id="cuando-usar">
    <div class="container">

      <SectionHeaderDuo
        eyebrow={data.cuandoUsar.eyebrow}
        titleLine1={data.cuandoUsar.titleLine1}
        titleLine2={data.cuandoUsar.titleLine2}
        desc={data.cuandoUsar.desc}
        bodyPara1={data.cuandoUsar.bodyPara}
      />

      <div class="usos-grid">
        {data.cuandoUsar.usos.map((uso) => (
          <div class="uso-item">
            <div class="uso-item__dot" aria-hidden="true"></div>
            <div class="uso-item__body">
              <h3 class="uso-item__label">{uso.label}</h3>
              <p class="uso-item__desc">{uso.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ===========================================================
       SECCIÓN 3 — Servicios relacionados
       =========================================================== -->
  <section class="cat-section cat-section--gray" id="servicios-extintor">
    <div class="container">
      <div class="svc-header">
        <p class="svc-header__label">Servicios disponibles para tu extintor</p>
        <a href="/servicios/" class="svc-header__link">Ver todos los servicios →</a>
      </div>
      <div class="svc-grid">
        {RELATED_SERVICES.map((svc) => (
          <a href={`/servicios/#${svc.id}`} class="svc-card">
            <span class="svc-card__name">{svc.label}</span>
            <span class="svc-card__desc">{svc.desc}</span>
            <span class="svc-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===========================================================
       SECCIÓN 4 — Otros extintores del catálogo
       =========================================================== -->
  <section class="cat-section cat-section--white" id="otros-extintores">
    <div class="container">

      <div class="related-header">
        <p class="related-header__label">{data.relatedTitle}:</p>
        <a href="/extintores/" class="related-header__link">Ver todos los extintores →</a>
      </div>

      <div class="related-grid">
        {related.map((r) => (
          <a href={`/extintores/${r.slug}/`} class="related-card">
            <span class="related-card__label">{r.label}</span>
            <span class="related-card__badge">{r.badge}</span>
          </a>
        ))}
      </div>

    </div>
  </section>

</CategoryLayout>

<!-- Estilos compartidos en src/styles/product-page.css y src/styles/pages.css (importados en frontmatter) -->
