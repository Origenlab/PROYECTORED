---
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import CtaBar from '../../../components/CtaBar.astro';
import FaqCotizacion from '../../../components/FaqCotizacion.astro';
import '../../../styles/pages.css';

const WHATSAPP = "525627596245";
const WA_URL = `https://wa.me/${WHATSAPP}`;

const seo = { title: "Extintor CO₂ 10 kg — Dióxido de Carbono Industrial para Cuartos Eléctricos | Proyecto Red", description: "Extintor de CO₂ 10 kg de alta capacidad para cuartos eléctricos, subestaciones y generadores. No deja residuo. Clase B y C. NOM-154-SCFI. CDMX y Estado de México." };

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Extintores", href: "/extintores/" },
  { label: "CO₂", href: "/extintores/co2/" },
  { label: "CO₂ 10 kg" },
];

const specs = [
  { label: "Agente extintor", value: "Dióxido de carbono (CO₂)" },
  { label: "Clases de fuego", value: "B · C" },
  { label: "Capacidad nominal", value: "10 kg" },
  { label: "Tiempo de descarga", value: "~12 segundos" },
  { label: "Alcance / descarga", value: "2.5–3 m" },
  { label: "Presión de trabajo", value: "~58 bar (≈850 PSI)" },
  { label: "Altura aprox.", value: "~95 cm" },
  { label: "Diámetro aprox.", value: "~17 cm" },
  { label: "Peso total cargado", value: "~28 kg" },
  { label: "Material", value: "Acero, pintura electrostática roja" },
  { label: "Certificación", value: "NOM-154-SCFI · NFPA 10" },
  { label: "Incluye", value: "Soporte/carretilla según modelo, etiqueta, collar de garantía" },
  { label: "Mantenimiento", value: "Anual obligatorio (NOM-154-SCFI) · Prueba hidrostática c/5 años" }
];
const caracteristicas = [
  "CO₂ gaseoso · 10 kg · ~12 s descarga · 2.5–3 m alcance · Carretilla o soporte reforzado",
  "Certificado NOM-154-SCFI con collar de garantía",
  "Recargable — servicio de recarga en CDMX",
  "Entrega el mismo día en zona metropolitana",
  "Documentación para Protección Civil incluida"
];
const aplicaciones = [
  "Cuartos eléctricos y subestaciones",
  "Generadores y plantas de emergencia",
  "Centros de carga y tableros grandes",
  "Salas de máquinas industriales",
  "Cuartos de UPS de gran capacidad",
  "Talleres con equipo eléctrico pesado"
];
const faqs = [
  {
    pregunta: "¿Qué clases de fuego apaga el CO₂ 10 kg?",
    respuesta: "Está certificado para fuegos <strong>B · C</strong>. El CO₂ de 10 kg entrega la <strong>mayor capacidad portátil</strong> de la línea de dióxido de carbono. Apaga sin residuo, protegiendo equipo eléctrico de gran valor sin daño secundario por polvo o humedad.",
  },
  {
    pregunta: "¿Por qué el CO₂ es ideal para cuartos eléctricos?",
    respuesta: "Porque <strong>no conduce electricidad y no deja residuo</strong>. Apaga desplazando el oxígeno, sin dañar tableros, generadores ni instalaciones. Tras la descarga, el equipo queda limpio y operable, a diferencia del polvo ABC.",
  },
  {
    pregunta: "¿Requiere montaje especial el de 10 kg?",
    respuesta: "Sí. Por su peso (~28 kg cargado) se entrega sobre <strong>carretilla o soporte reforzado</strong> para movilidad y acceso inmediato en el área protegida.",
  },
  {
    pregunta: "¿Cada cuánto requiere mantenimiento?",
    respuesta: "Conforme a <strong>NOM-154-SCFI</strong>, requiere mantenimiento anual y prueba hidrostática del cilindro cada 5 años. Ofrecemos pólizas de mantenimiento preventivo en CDMX y Estado de México.",
  },
  {
    pregunta: "¿Puedo recargarlo en CDMX?",
    respuesta: "Sí. Ofrecemos servicio de recarga con verificación, revisión y collar de garantía NOM-154-SCFI. Llámanos al <strong>56 2759 6245</strong> o escríbenos por WhatsApp.",
  }
];
---
<Base title={seo.title} description={seo.description}>
  <Breadcrumb items={breadcrumbs} />
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-left">
        <div class="hero-badge"><span class="badge-dot"></span>Clase B·C · Industrial · NOM-154-SCFI</div>
        <h1>Extintor CO₂<br><span class="h1-accent">10 kg — Industrial</span></h1>
        <p class="hero-sub">El extintor de CO₂ de 10 kg es la capacidad industrial para cuartos eléctricos, subestaciones, generadores y plantas de mayor envergadura. Mayor carga de agente para áreas con equipo eléctrico crítico de gran tamaño.</p>
        <div class="hero-ctas">
          <a href={`${WA_URL}?text=Hola%2C%20necesito%20cotizar%20el%20extintor%20CO%E2%82%82%2010%20kg`} class="btn-primary" target="_blank" rel="noopener noreferrer">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Solicitar Cotización
          </a>
          <a href="/extintores/co2/" class="btn-secondary">Ver Catálogo</a>
        </div>
      </div>
      <div class="hero-right"><p>El CO₂ de 10 kg entrega la <strong>mayor capacidad portátil</strong> de la línea de dióxido de carbono. Apaga sin residuo, protegiendo equipo eléctrico de gran valor sin daño secundario por polvo o humedad.</p><p>Por su peso, normalmente se monta en <strong>carretilla o soporte reforzado</strong>. Es el extintor de elección para subestaciones, cuartos de generadores y centros de carga industriales donde un conato eléctrico debe controlarse de inmediato.</p></div>
    </div>
  </section>
  <CtaBar />
  <div class="pp-layout container">
    <main class="pp-main">
      <div class="pp-gallery">
        <div class="pp-gallery__col">
          <img src="https://ewvydcs5uyw.exactdn.com/imagenes/extintores/co2/co2-10kg-extintor-industrial-alta-capacidad.avif?strip=all&lossy=1" alt="Extintor CO₂ 10 kg — Vista frontal" width="400" height="300" loading="eager" />
          <img src="https://ewvydcs5uyw.exactdn.com/imagenes/extintores/co2/galeria-2.avif?strip=all&lossy=1" alt="Extintor CO₂ 10 kg — Detalle válvula" width="400" height="300" loading="eager" />
        </div>
        <div class="pp-gallery__col">
          <img src="https://ewvydcs5uyw.exactdn.com/imagenes/extintores/co2/galeria-3.avif?strip=all&lossy=1" alt="Extintor CO₂ 10 kg — Aplicación profesional" width="400" height="300" loading="eager" />
          <img src="https://ewvydcs5uyw.exactdn.com/imagenes/extintores/co2/co2-10kg-extintor-industrial-alta-capacidad.avif?strip=all&lossy=1" alt="Extintor CO₂ 10 kg — Instalación CDMX" width="400" height="300" loading="lazy" />
        </div>
      </div>
      <div class="pp-desc">
        <p>El extintor de CO₂ de 10 kg es la mayor capacidad portátil de la línea de dióxido de carbono. Está diseñado para áreas industriales con equipo eléctrico crítico de gran tamaño, donde se requiere más agente para controlar un conato sin dañar la instalación.</p><p>Por su peso cargado (~28 kg) se entrega con carretilla o soporte reforzado para acceso inmediato. Es el equipo indicado para subestaciones, cuartos de generadores y centros de carga donde el riesgo eléctrico es alto.</p>
        <p><strong>Capacidad:</strong> 10 kg. <strong>Clases:</strong> B · C. <strong>Agente:</strong> Dióxido de carbono (CO₂). <strong>Certificación:</strong> NOM-154-SCFI, NFPA 10.</p>
      </div>
      <section class="pp-block"><h2>Especificaciones Técnicas</h2>
        <table class="pp-table"><tbody>{specs.map(s => (<tr><td class="pp-table__label">{s.label}</td><td class="pp-table__value">{s.value}</td></tr>))}</tbody></table>
      </section>
      <section class="pp-block"><h2>Aplicaciones</h2><ul class="pp-app-list">
          <li>Cuartos eléctricos y subestaciones</li>
          <li>Generadores y plantas de emergencia</li>
          <li>Centros de carga y tableros grandes</li>
          <li>Salas de máquinas industriales</li>
          <li>Cuartos de UPS de gran capacidad</li>
          <li>Talleres con equipo eléctrico pesado</li>
      </ul></section>
      <section class="pp-block"><h2>Comparativa rápida</h2>
        <table class="pp-table" style="margin-top:0.5rem;"><tbody>
          <tr><td class="pp-table__label">Residuo</td><td class="pp-table__value">CO₂: cero residuo · ABC: residuo corrosivo</td></tr>
          <tr><td class="pp-table__label">Equipo eléctrico grande</td><td class="pp-table__value">CO₂ 10 kg: ideal</td></tr>
          <tr><td class="pp-table__label">Montaje</td><td class="pp-table__value">Carretilla / soporte reforzado</td></tr>
          <tr><td class="pp-table__label">Mejor uso</td><td class="pp-table__value">Subestaciones, generadores, cuartos eléctricos</td></tr>
        </tbody></table>
      </section>
      <section class="pp-block"><h2>Cumplimiento Normativo</h2>
        <p>Este extintor cumple con la <strong>NOM-154-SCFI</strong> para mantenimiento y recarga y <strong>NFPA 10</strong> como referencia internacional. La <strong>NOM-002-STPS</strong> establece los requerimientos de protección contra incendios en centros de trabajo. Cada unidad se entrega con documentación para tu expediente de Protección Civil.</p>
      </section>
    </main>
    <aside class="sb">
      <div class="sb__widget sb__widget--cta">
        <h3>Cotización Rápida</h3>
        <p class="sb__cta-text">Respuesta en menos de 24 horas con precio y disponibilidad.</p>
        <a href="#cotizar" class="sb__btn sb__btn--solid">Solicitar Cotización</a>
        <a href={`${WA_URL}?text=Hola%2C%20necesito%20cotizar%20el%20extintor%20CO%E2%82%82%2010%20kg`} class="sb__btn sb__btn--outline" target="_blank" rel="noopener noreferrer">WhatsApp Directo</a>
        <p class="sb__tel">Tel: <a href="tel:+525627596245">56 2759 6245</a></p>
      </div>
      <div class="sb__widget"><div class="sb__header"><h3>Características Clave</h3></div>
        <ul class="sb__checks">{caracteristicas.map(c => (<li><span class="sb__check-icon">✓</span><span>{c}</span></li>))}</ul></div>
      <div class="sb__widget"><div class="sb__header"><h3>Aplicaciones</h3></div>
        <ul class="sb__app-list">{aplicaciones.map(a => (<li>{a}</li>))}</ul></div>
      <div class="sb__widget"><div class="sb__header"><h3>Otros Extintores</h3></div>
        <ul class="sb__products">
          <li><a href="/extintores/co2/">Ver todo Extintores CO₂</a></li>
          <li><a href="/extintores/polvo-seco/">Polvo Seco PQS</a></li>
          <li><a href="/extintores/co2/">CO₂</a></li>
          <li><a href="/extintores/tipo-k/">Tipo K — Cocinas</a></li>
          <li><a href="/extintores/afff/">AFFF — Espuma</a></li>
        </ul></div>
      <div class="sb__widget sb__widget--services"><div class="sb__header"><h3>Servicios Proyecto Red</h3></div>
        <ul class="sb__services">
          <li><a href="/servicios/recarga-extintores/">Recarga de extintores</a></li>
          <li><a href="/servicios/mantenimiento-preventivo/">Mantenimiento preventivo</a></li>
          <li><a href="/servicios/prueba-hidrostatica/">Prueba hidrostática</a></li>
          <li><a href="/servicios/capacitacion/">Capacitación DC-3</a></li>
        </ul>
        <a href="/servicios/" class="sb__services-link">Ver todos los servicios →</a></div>
    </aside>
  </div>
  <section class="pp-cotizar" id="cotizar">
    <div class="container pp-cotizar__inner">
      <div class="pp-cotizar__info"><h2>Cotiza CO₂ 10 kg</h2>
        <p class="pp-cotizar__sub">Precio y disponibilidad en menos de 24 horas</p>
        <ul class="pp-cotizar__perks"><li>Asesoría técnica sin costo</li><li>Entrega el mismo día en CDMX</li><li>Factura electrónica disponible</li></ul></div>
      <div class="pp-cotizar__form">
        <a href={`${WA_URL}?text=Hola%2C%20necesito%20cotizar%20el%20extintor%20CO%E2%82%82%2010%20kg`} class="btn-primary" style="background:#25D366;font-size:0.95rem;padding:0.85rem 1.8rem;" target="_blank" rel="noopener noreferrer">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Enviar por WhatsApp
        </a>
        <p class="pp-cotizar__note">Sin compromiso · Atención personalizada · Te respondemos al instante</p>
        <p class="pp-cotizar__alt">También puedes llamarnos: <a href="tel:+525627596245">56 2759 6245</a></p>
      </div>
    </div>
  </section>
  <FaqCotizacion titulo="Preguntas Frecuentes" subtitulo="Todo sobre el extintor CO₂ 10 kg" pageId="co2-10-kg" bgGray={false} faqs={faqs} />
</Base>
<style>
  .pp-layout { display: grid; grid-template-columns: 1fr 320px; gap: 2.5rem; padding-top: 2.5rem; padding-bottom: 3rem; align-items: start; }
  .pp-main { min-width: 0; }
  .pp-gallery { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 1.75rem; border-radius: 10px; overflow: hidden; }
  .pp-gallery__col { display: flex; flex-direction: column; gap: 0.5rem; }
  .pp-gallery img { width: 100%; height: 200px; object-fit: cover; display: block; background: #f5f5f5; border-radius: 6px; }
  .pp-desc { margin-bottom: 2rem; }
  .pp-desc p { font-size: 0.88rem; color: #444; line-height: 1.7; margin: 0 0 0.75rem; }
  .pp-desc strong { color: #111; }
  .pp-block { margin-bottom: 2.25rem; border-bottom: 1px solid #eee; padding-bottom: 2rem; }
  .pp-block:last-child { border-bottom: none; }
  .pp-block h2 { font-size: 1.15rem; font-weight: 800; color: #111; margin: 0 0 1rem; }
  .pp-block p { font-size: 0.85rem; color: #555; line-height: 1.65; margin: 0 0 0.5rem; }
  .pp-table { width: 100%; border-collapse: collapse; }
  .pp-table tr { border-bottom: 1px solid #f0f0f0; }
  .pp-table td { padding: 0.65rem 0; font-size: 0.82rem; vertical-align: top; }
  .pp-table__label { color: #888; font-weight: 600; width: 35%; padding-right: 1rem; }
  .pp-table__value { color: #222; font-weight: 500; }
  .pp-features { list-style: none; padding: 0; margin: 0; }
  .pp-features li { position: relative; padding: 0.6rem 0 0.6rem 1.5rem; font-size: 0.84rem; color: #444; line-height: 1.55; border-bottom: 1px solid #f5f5f5; }
  .pp-features li::before { content: "✓"; position: absolute; left: 0; color: var(--c-primary, #C41E24); font-weight: 800; }
  .pp-features li strong { color: #111; }
  .pp-app-list { list-style: none; padding: 0; margin: 0; }
  .pp-app-list li { padding: 0.45rem 0 0.45rem 1.3rem; position: relative; font-size: 0.84rem; color: #444; }
  .pp-app-list li::before { content: "•"; position: absolute; left: 0; color: var(--c-primary, #C41E24); font-weight: 800; font-size: 1.1rem; line-height: 1; top: 0.45rem; }
  .pp-specs-mini { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
  .pp-specs-mini__item { display: flex; justify-content: space-between; padding: 0.6rem 0; border-bottom: 1px solid #f0f0f0; font-size: 0.82rem; }
  .pp-specs-mini__item span:first-child { color: #888; font-weight: 600; }
  .pp-specs-mini__item span:last-child { color: #222; font-weight: 500; text-align: right; }
  .pp-specs-mini__item:nth-child(odd) { padding-right: 1rem; }
  .pp-specs-mini__item:nth-child(even) { padding-left: 1rem; border-left: 1px solid #f0f0f0; }
  .sb { position: sticky; top: 32px; display: flex; flex-direction: column; gap: 20px; }
  .sb__widget { background: #fff; border: 1px solid #ddd; border-radius: 8px; padding: 20px; }
  .sb__header { margin-bottom: 12px; }
  .sb__header h3 { font-size: 0.85rem; font-weight: 700; color: #111; margin: 0; }
  .sb__nav ul { list-style: none; padding: 0; margin: 0; }
  .sb__nav li { border-bottom: 1px solid #f3f3f3; }
  .sb__nav li:last-child { border-bottom: none; }
  .sb__nav a { display: flex; align-items: center; gap: 6px; padding: 8px 10px; font-size: 0.8rem; color: #555; text-decoration: none; border-radius: 6px; font-weight: 500; }
  .sb__nav a:hover { background: #f7f7f7; color: #111; }
  .sb__nav-active { background: #fef2f2 !important; color: var(--c-primary, #C41E24) !important; font-weight: 700 !important; }
  .sb__back { display: block; font-size: 0.75rem; color: var(--c-primary, #C41E24); text-decoration: none; font-weight: 600; margin-top: 10px; padding-top: 10px; border-top: 1px solid #f0f0f0; }
  .sb__widget--cta { background: linear-gradient(135deg, #1a1a2e 0%, #1a365d 100%); border: none; color: #fff; }
  .sb__widget--cta h3 { color: #fff; font-size: 0.9rem; font-weight: 700; margin: 0 0 6px; }
  .sb__cta-text { font-size: 0.78rem; color: rgba(255,255,255,0.65); margin: 0 0 14px; line-height: 1.5; }
  .sb__btn { display: flex; align-items: center; justify-content: center; width: 100%; padding: 8px 20px; font-size: 0.82rem; font-weight: 600; border-radius: 8px; text-decoration: none; text-align: center; cursor: pointer; }
  .sb__btn--solid { background: var(--c-primary, #C41E24); color: #fff; border: 2px solid var(--c-primary, #C41E24); margin-bottom: 8px; }
  .sb__btn--outline { background: transparent; color: var(--c-primary, #C41E24); border: 2px solid var(--c-primary, #C41E24); }
  .sb__tel { font-size: 0.75rem; color: rgba(255,255,255,0.5); margin: 10px 0 0; text-align: center; }
  .sb__tel a { color: #fff; font-weight: 600; text-decoration: none; }
  .sb__checks { list-style: none; padding: 0; margin: 0; }
  .sb__checks li { display: flex; align-items: flex-start; gap: 8px; padding: 6px 0; font-size: 0.78rem; color: #444; line-height: 1.45; }
  .sb__check-icon { color: #22c55e; font-weight: 800; font-size: 0.82rem; flex-shrink: 0; margin-top: 1px; }
  .sb__certs { display: flex; flex-direction: column; gap: 8px; }
  .sb__cert { display: flex; align-items: center; gap: 10px; }
  .sb__cert-badge { display: inline-flex; align-items: center; justify-content: center; width: 36px; height: 36px; background: #f5f5f5; border: 1px solid #e5e5e5; border-radius: 6px; font-size: 0.6rem; font-weight: 800; color: #555; flex-shrink: 0; }
  .sb__cert-name { font-size: 0.78rem; color: #333; font-weight: 500; }
  .sb__brands { list-style: none; padding: 0; margin: 0; }
  .sb__brands li { padding: 5px 0; font-size: 0.8rem; color: #333; font-weight: 600; border-bottom: 1px solid #f3f3f3; }
  .sb__brands li:last-child { border-bottom: none; }
  .sb__note { font-size: 0.72rem; color: #999; font-style: italic; margin: 8px 0 0; }
