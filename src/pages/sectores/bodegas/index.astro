---
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import CtaBar from '../../../components/CtaBar.astro';
import FaqCotizacion from '../../../components/FaqCotizacion.astro';
import '../../../styles/pages.css';

const WHATSAPP = "525537238544";
const WA_URL = `https://wa.me/${WHATSAPP}`;

const title = "Equipo Contra Incendios para Bodegas y Almacenes CDMX | Proyecto Red";
const description = "1 extintor por cada 300 m² según NOM-002-STPS. Extintores rodantes, rociadores y alarmas para bodegas y centros de distribución en CDMX. Diagnóstico gratuito.";

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Sectores", href: "/sectores/" },
  { label: "Bodegas y Almacenes" },
];

const metricas = [
  { valor: "NOM-002", label: "STPS obligatoria" },
  { valor: "1/300m²", label: "Extintor mínimo" },
  { valor: "Rodantes", label: "Para bodegas grandes" },
  { valor: "24h", label: "Entrega CDMX" },
];

const equipoObligatorio = [
  { nombre: "Extintores Polvo Seco ABC", desc: "1 por cada 300 m². Para bodegas de productos secos, cajas, textiles y materiales sólidos combustibles. Desde 6 kg hasta extintores rodantes de 50 kg.", href: "/extintores/polvo-seco/", badge: "Obligatorio NOM" },
  { nombre: "Extintores Rodantes 50 kg", desc: "Para bodegas grandes o con productos de alto riesgo. Mayor alcance y capacidad de extinción. Un rodante puede cubrir hasta 1,500 m² como refuerzo.", href: "/extintores/polvo-seco/", badge: "Bodegas grandes" },
  { nombre: "Extintores AFFF (Espuma)", desc: "Para bodegas con líquidos inflamables: aceites, solventes, pinturas, combustibles. La espuma sella la superficie del líquido y evita la reignición.", href: "/extintores/afff/", badge: "Líquidos inf." },
  { nombre: "Señalamientos NOM-003", desc: "Rutas de evacuación, señales de salida y punto de reunión. Obligatorio en bodegas con 5 o más trabajadores o con acceso de montacargas.", href: "/senalamientos/", badge: "NOM-003-SEGOB" },
  { nombre: "Sistemas de Rociadores", desc: "Para bodegas de más de 1,000 m² o con materiales de alto riesgo. Sistema automático que actúa sin intervención humana en caso de incendio.", href: "/sistemas/rociadores/", badge: "Bodegas +1000m²" },
  { nombre: "Alarmas de Detección", desc: "Detectores de humo o calor con sirena. Especialmente necesarios en bodegas sin presencia constante de personal durante el turno nocturno.", href: "/sistemas/alarmas/", badge: "Turno nocturno" },
];

const pasos = [
  { titulo: "Medición y clasificación del riesgo", desc: "Calculamos la superficie y analizamos qué materiales se almacenan. El tipo de mercancía define qué agente extintor es necesario: ABC para sólidos, AFFF para líquidos." },
  { titulo: "Distribución estratégica", desc: "Los extintores se ubican en puntos de fácil acceso: entradas, pasillos de circulación de montacargas y zonas de carga/descarga. Nunca detrás de racks o estanterías altas." },
  { titulo: "Señalización de rutas", desc: "Señalamientos de evacuación visibles desde cualquier punto de la bodega, incluyendo áreas de altura con operadores de montacargas." },
  { titulo: "Sistema automático si aplica", desc: "Para bodegas mayores a 1,000 m² o con materiales de clase A y B, instalamos rociadores automáticos conforme a NFPA 13." },
  { titulo: "Documentación y capacitación", desc: "Certificados NOM, factura fiscal y capacitación básica para el personal de almacén y vigilancia sobre uso de extintores y rutas de evacuación." },
];

const faqs = [
  { pregunta: "¿Cuántos extintores necesita mi bodega?", respuesta: "La <strong>NOM-002-STPS</strong> exige mínimo <strong>1 extintor por cada 300 m²</strong> de superficie techada, con al menos uno visible desde cualquier punto. Una bodega de 900 m² necesita mínimo 3 extintores. Si hay productos inflamables o el riesgo es alto, el número aumenta. El diagnóstico gratuito te da el plan exacto." },
  { pregunta: "¿Qué tipo de extintor necesita una bodega con líquidos inflamables?", respuesta: "Para bodegas con aceites, solventes, pinturas, combustibles o cualquier líquido inflamable se requiere un extintor <strong>AFFF (espuma) o CO₂</strong> en esas áreas específicas, además del polvo seco ABC para las zonas generales. El AFFF sella la superficie del líquido e impide la reignición, que es el mayor riesgo en estos casos." },
  { pregunta: "¿Cuándo es obligatorio el sistema de rociadores?", respuesta: "Según la NOM-002 y las normas NFPA, los rociadores automáticos son obligatorios en bodegas de más de <strong>1,000 m²</strong> con materiales combustibles de clase A y B, o en instalaciones con almacenamiento de más de 3 metros de altura. También los exigen muchas aseguradoras para dar cobertura de incendio." },
  { pregunta: "¿Los operadores de montacargas necesitan capacitación en uso de extintores?", respuesta: "Sí. La NOM-002 exige que todo el personal del centro de trabajo conozca la ubicación y uso básico de los extintores. Esto incluye a operadores de montacargas, recepcionistas de mercancía y vigilantes del turno nocturno. Proyecto Red incluye una sesión de capacitación básica con cada instalación." },
  { pregunta: "¿Qué pasa con el seguro de mercancía si no tengo extintores certificados?", respuesta: "La mayoría de las aseguradoras de carga y mercancía exigen extintores certificados NOM como condición para dar cobertura. Si hay un siniestro y los extintores no tienen certificación vigente, la aseguradora puede negar el pago de la reclamación. Los certificados NOM que entrega Proyecto Red son los que aceptan las aseguradoras en México." },
];
---

<Base title={title} description={description} canonical="https://proyectored.com.mx/sectores/bodegas/">

  <div class="breadcrumb-bar">
    <div class="container">
      <Breadcrumb items={breadcrumbs} />
    </div>
  </div>

  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-left">
          <span class="hero-badge"><span class="badge-dot"></span> NOM-002-STPS · 1 extintor por 300 m²</span>
          <h1>Equipo Contra Incendios<br><span class="h1-accent">para Bodegas y Almacenes</span></h1>
          <p class="hero-sub">Extintores portátiles y rodantes, rociadores automáticos y señalamientos NOM para bodegas y centros de distribución en CDMX. Diagnóstico gratuito.</p>
          <div class="hero-ctas">
            <a href={`${WA_URL}?text=Hola%2C%20necesito%20extintores%20para%20mi%20bodega%20en%20CDMX`} class="btn-primary" target="_blank" rel="noopener noreferrer">Diagnóstico gratuito</a>
            <a href="/sectores/" class="btn-ghost">← Todos los sectores</a>
          </div>
        </div>
        <div class="hero-right">
          <p>La <strong>NOM-002-STPS-2010</strong> exige mínimo 1 extintor por cada 300 m² en toda bodega o almacén. Para bodegas con líquidos inflamables o materiales de alto riesgo, el tipo de extintor cambia. El incumplimiento puede resultar en <strong>multas de hasta 500,000 MXN</strong> y en caso de siniestro, el seguro puede negarse a pagar.</p>
          <p>Proyecto Red suministra extintores portátiles desde 6 kg hasta rodantes de 50 kg, rociadores automáticos para bodegas grandes y señalamientos fotoluminiscentes. Diagnóstico gratuito, entrega en 24h, certificados NOM incluidos.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBar />

  <section class="metricas-section">
    <div class="container">
      <div class="metricas-grid">
        {metricas.map(m => (
          <div class="metrica-item">
            <span class="metrica-valor">{m.valor}</span>
            <span class="metrica-label">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--white">
    <div class="container">
      <div class="cat-header" style="margin-bottom:2.5rem">
        <div class="cat-header__info">
          <h2 class="cat-header__title">¿Qué equipo necesita tu bodega según la NOM?</h2>
          <p class="cat-header__desc">El tipo de mercancía almacenada define el agente extintor. Estos son los productos que Proyecto Red suministra para bodegas y centros de distribución en CDMX:</p>
        </div>
        <div style="background:var(--c-primary-light);border-radius:8px;display:flex;align-items:center;justify-content:center;min-height:200px">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--c-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
        </div>
      </div>
      <div class="productos-grid">
        {equipoObligatorio.map(p => (
          <a href={p.href} class="prod-card">
            <div class="prod-card__top">
              {p.badge && <span class="prod-badge">{p.badge}</span>}
            </div>
            <div class="prod-card__body">
              <h3>{p.nombre}</h3>
              <p>{p.desc}</p>
            </div>
            <div class="prod-card__footer">
              <span>Ver producto →</span>
            </div>
          </a>
        ))}
        <a href={`${WA_URL}?text=Hola%2C%20necesito%20cotizaci%C3%B3n%20de%20extintores%20para%20bodega`} class="prod-card prod-card--cta" target="_blank" rel="noopener noreferrer">
          <strong>¿Cuántos extintores necesita tu bodega?</strong>
          <p>Diagnóstico gratis según superficie y mercancía</p>
          <span>Cotizar por WhatsApp →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--gray">
    <div class="container">
      <h2 style="font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;margin-bottom:0.5rem">Plan de cumplimiento para bodegas</h2>
      <p style="color:var(--c-muted);margin-bottom:0">Del diagnóstico a la instalación certificada, paso a paso.</p>
      <div class="cumplimiento-steps">
        {pasos.map((paso, i) => (
          <div class="cumplimiento-step">
            <span class="step-num">{i + 1}</span>
            <div class="step-content">
              <h4>{paso.titulo}</h4>
              <p>{paso.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FaqCotizacion
    titulo="Preguntas frecuentes — Bodegas y Almacenes"
    subtitulo="Todo sobre extintores y sistemas contra incendios para almacenamiento"
    faqs={faqs}
    pageId="bodegas"
    bgGray={false}
  />

  <section class="cta-final">
    <div class="container">
      <div class="cta-final-inner">
        <h2>Protege tu mercancía y cumple la NOM.</h2>
        <p>Diagnóstico gratuito. Extintores portátiles y rodantes. Entrega 24h CDMX.</p>
        <a href={`${WA_URL}?text=Hola%2C%20quiero%20el%20diagn%C3%B3stico%20gratuito%20para%20mi%20bodega`} class="btn-primary btn-lg" target="_blank" rel="noopener noreferrer">Solicitar diagnóstico →</a>
      </div>
    </div>
  </section>

</Base>
