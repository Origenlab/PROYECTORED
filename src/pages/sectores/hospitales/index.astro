---
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import CtaBar from '../../../components/CtaBar.astro';
import FaqCotizacion from '../../../components/FaqCotizacion.astro';
import '../../../styles/pages.css';

const WHATSAPP = "525537238544";
const WA_URL = `https://wa.me/${WHATSAPP}`;

const title = "Equipo Contra Incendios para Hospitales y Clínicas CDMX | Proyecto Red";
const description = "CO₂ y Agente Limpio obligatorios en áreas con equipo médico. NOM-002-STPS y NOM-016-SSA3 para hospitales, clínicas y consultorios en CDMX. Diagnóstico gratuito.";

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Sectores", href: "/sectores/" },
  { label: "Hospitales y Clínicas" },
];

const metricas = [
  { valor: "NOM-002", label: "STPS + NOM-016-SSA3" },
  { valor: "CO₂", label: "Obligatorio en equipo médico" },
  { valor: "0", label: "Residuos en áreas críticas" },
  { valor: "24h", label: "Entrega CDMX" },
];

const equipoObligatorio = [
  { nombre: "Extintores CO₂", desc: "Obligatorio en quirófanos, UCI, salas de recuperación y áreas con equipo médico electrónico. No deja residuos y no contamina el ambiente estéril.", href: "/extintores/co2/", badge: "Áreas críticas" },
  { nombre: "Agente Limpio", desc: "Para centros de datos hospitalarios, farmacia y laboratorio. Extinción sin residuos, sin daño a equipos de diagnóstico ni a medicamentos almacenados.", href: "/extintores/agente-limpio/", badge: "Sin residuos" },
  { nombre: "Extintores Polvo Seco ABC", desc: "Para pasillos, accesos, estacionamiento, cocina hospitalaria y áreas de baja sensibilidad. La base de cualquier plan contra incendios.", href: "/extintores/polvo-seco/", badge: "Áreas generales" },
  { nombre: "Señalamientos NOM-003", desc: "Señalamientos fotoluminiscentes de evacuación en cada piso, incluyendo rutas especiales para pacientes en camillas y sillas de ruedas.", href: "/senalamientos/salvacion/", badge: "NOM-003-SEGOB" },
  { nombre: "Sistemas de Detección", desc: "Detectores de humo y calor con alarma centralizada. Exigidos en instalaciones de salud de más de 1 piso o con internamiento de pacientes.", href: "/sistemas/detectores/", badge: "Internamiento" },
  { nombre: "Gabinetes para Extintor", desc: "Instalación visible y accesible en pasillos clínicos. Altura y señalización conforme a norma para facilitar el acceso en emergencia.", href: "/gabinetes/para-extintor/", badge: "Accesibilidad" },
];

const pasos = [
  { titulo: "Mapeo de áreas críticas", desc: "Identificamos quirófanos, UCI, laboratorio, farmacia y centros de cómputo. Cada área tiene requerimientos distintos según el equipo presente." },
  { titulo: "Selección del agente correcto", desc: "CO₂ o Agente Limpio para áreas médicas sensibles. Polvo seco ABC para zonas generales. El agente incorrecto puede contaminar equipos o medicamentos." },
  { titulo: "Instalación especializada", desc: "Ubicación estratégica en pasillos clínicos a la altura correcta, sin obstruir el paso de camillas ni equipos de traslado." },
  { titulo: "Señalización de evacuación", desc: "Rutas de evacuación que contemplan la movilidad de pacientes con limitaciones físicas, conforme a NOM-003 y estándares de la Secretaría de Salud." },
  { titulo: "Documentación y capacitación", desc: "Certificados NOM, factura fiscal y sesión de uso básico para el personal administrativo. El personal médico requiere saber cómo actuar antes de usar el extintor." },
];

const faqs = [
  { pregunta: "¿Por qué no se usa polvo seco ABC en quirófanos?", respuesta: "El polvo del extintor ABC contamina el ambiente estéril del quirófano, daña los equipos de anestesia y monitoreo, y puede causar problemas respiratorios en pacientes intubados. La norma y los estándares de la <strong>Secretaría de Salud</strong> exigen extintores de CO₂ o Agente Limpio en todas las áreas con equipo médico electrónico o ambientes estériles." },
  { pregunta: "¿Qué normativas aplican a hospitales y clínicas?", respuesta: "Principalmente la <strong>NOM-002-STPS-2010</strong> (prevención y protección contra incendios en centros de trabajo) y la <strong>NOM-016-SSA3-2012</strong> (establecimientos de salud). Para instalaciones con internamiento también aplica la <strong>NOM-003-SEGOB-2011</strong> de señalamientos y las guías de la COFEPRIS para clínicas con manejo de medicamentos controlados." },
  { pregunta: "¿Las clínicas pequeñas y consultorios también necesitan este equipo?", respuesta: "Sí. Cualquier establecimiento de salud — desde un consultorio dental hasta un hospital de tercer nivel — está sujeto a las normas de prevención de incendios. La diferencia está en la cantidad y tipo de equipo. Un consultorio pequeño puede necesitar solo 1-2 extintores CO₂ y señalamientos básicos. El diagnóstico gratuito te dice exactamente qué aplica en tu caso." },
  { pregunta: "¿El Agente Limpio es seguro en ambientes con pacientes?", respuesta: "Sí, cuando se usa correctamente. El Agente Limpio (halon o sustitutos como FM-200) actúa rápido y se disipa sin dejar residuos. <strong>No es tóxico</strong> en concentraciones de extinción para personas fuera de la zona de descarga. Es la opción más adecuada para farmacia, laboratorio y centros de datos hospitalarios." },
  { pregunta: "¿Con qué frecuencia se revisa el equipo en instalaciones de salud?", respuesta: "La NOM-002 exige mantenimiento anual certificado. Sin embargo, para instalaciones de salud recomendamos revisión semestral del CO₂ y el Agente Limpio dado el uso continuo del inmueble. Proyecto Red ofrece contratos de mantenimiento preventivo con visitas programadas." },
];
---

<Base title={title} description={description} canonical="https://proyectored.com.mx/sectores/hospitales/">

  <div class="breadcrumb-bar">
    <div class="container">
      <Breadcrumb items={breadcrumbs} />
    </div>
  </div>

  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-left">
          <span class="hero-badge"><span class="badge-dot"></span> NOM-002-STPS · NOM-016-SSA3</span>
          <h1>Equipo Contra Incendios<br><span class="h1-accent">para Hospitales y Clínicas</span></h1>
          <p class="hero-sub">CO₂ y Agente Limpio para áreas con equipo médico. Extintores sin residuos que no contaminan ambientes estériles ni dañan equipos de diagnóstico.</p>
          <div class="hero-ctas">
            <a href={`${WA_URL}?text=Hola%2C%20necesito%20extintores%20CO2%20y%20equipo%20para%20instalaci%C3%B3n%20de%20salud%20en%20CDMX`} class="btn-primary" target="_blank" rel="noopener noreferrer">Diagnóstico gratuito</a>
            <a href="/sectores/" class="btn-ghost">← Todos los sectores</a>
          </div>
        </div>
        <div class="hero-right">
          <p>Las instalaciones de salud tienen requerimientos especiales: el extintor de <strong>polvo seco ABC contamina equipos médicos</strong> y ambientes estériles. La <strong>NOM-002-STPS</strong> y los estándares de la Secretaría de Salud exigen CO₂ o Agente Limpio en quirófanos, UCI, laboratorio y farmacia.</p>
          <p>Proyecto Red suministra el agente correcto para cada área de tu instalación: CO₂ para cuartos de máquinas y equipo eléctrico, Agente Limpio para ambientes sensibles, y ABC para pasillos y áreas generales. Diagnóstico gratuito, entrega en 24h en CDMX.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBar />

  <section class="metricas-section">
    <div class="container">
      <div class="metricas-grid">
        {metricas.map(m => (
          <div class="metrica-item">
            <span class="metrica-valor">{m.valor}</span>
            <span class="metrica-label">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--white">
    <div class="container">
      <div class="cat-header" style="margin-bottom:2.5rem">
        <div class="cat-header__info">
          <h2 class="cat-header__title">¿Qué equipo contra incendios requiere una instalación de salud?</h2>
          <p class="cat-header__desc">El tipo de extintor depende del área. En zonas con equipo médico electrónico o ambientes estériles, el agente correcto es CO₂ o Agente Limpio — nunca polvo seco.</p>
        </div>
        <div style="background:var(--c-primary-light);border-radius:8px;display:flex;align-items:center;justify-content:center;min-height:200px">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--c-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
      </div>
      <div class="productos-grid">
        {equipoObligatorio.map(p => (
          <a href={p.href} class="prod-card">
            <div class="prod-card__top">
              {p.badge && <span class="prod-badge">{p.badge}</span>}
            </div>
            <div class="prod-card__body">
              <h3>{p.nombre}</h3>
              <p>{p.desc}</p>
            </div>
            <div class="prod-card__footer">
              <span>Ver producto →</span>
            </div>
          </a>
        ))}
        <a href={`${WA_URL}?text=Hola%2C%20necesito%20cotizaci%C3%B3n%20de%20extintores%20para%20instalaci%C3%B3n%20de%20salud`} class="prod-card prod-card--cta" target="_blank" rel="noopener noreferrer">
          <strong>¿Qué equipo necesita tu clínica u hospital?</strong>
          <p>Diagnóstico gratuito según área y equipo médico</p>
          <span>Cotizar por WhatsApp →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--gray">
    <div class="container">
      <h2 style="font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;margin-bottom:0.5rem">¿Cómo cumplir la NOM en instalaciones de salud?</h2>
      <p style="color:var(--c-muted);margin-bottom:0">Cada área requiere el agente y la instalación correcta.</p>
      <div class="cumplimiento-steps">
        {pasos.map((paso, i) => (
          <div class="cumplimiento-step">
            <span class="step-num">{i + 1}</span>
            <div class="step-content">
              <h4>{paso.titulo}</h4>
              <p>{paso.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FaqCotizacion
    titulo="Preguntas frecuentes — Hospitales y Clínicas"
    subtitulo="Extintores sin residuos para ambientes médicos sensibles"
    faqs={faqs}
    pageId="hospitales"
    bgGray={false}
  />

  <section class="cta-final">
    <div class="container">
      <div class="cta-final-inner">
        <h2>Protege tus equipos médicos y tu personal.</h2>
        <p>Diagnóstico gratuito. CO₂ y Agente Limpio para cada área. Entrega 24h.</p>
        <a href={`${WA_URL}?text=Hola%2C%20quiero%20el%20diagn%C3%B3stico%20para%20mi%20instalaci%C3%B3n%20de%20salud`} class="btn-primary btn-lg" target="_blank" rel="noopener noreferrer">Solicitar diagnóstico →</a>
      </div>
    </div>
  </section>

</Base>
