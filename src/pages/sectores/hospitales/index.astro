---
import Base from '../../../layouts/Base.astro';
import CtaBar from '../../../components/CtaBar.astro';
import FaqCotizacion from '../../../components/FaqCotizacion.astro';
import '../../../styles/pages.css';

const WHATSAPP = "525537238544";
const WA_URL = `https://wa.me/${WHATSAPP}`;

const title = "Extintores CO₂ y Agente Limpio para Hospitales CDMX — Sin residuos | Proyecto Red";
const description = "CO₂ desde $1,100 y Agente Limpio para hospitales y clínicas. Sin residuos en equipos médicos ni ambientes estériles. NOM-002-STPS y NOM-016-SSA3. Diagnóstico gratuito CDMX.";

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Sectores", href: "/sectores/" },
  { label: "Hospitales y Clínicas" },
];

const metricas = [
  { valor: "Desde $1,100", label: "Extintor CO₂ para equipo médico" },
  { valor: "0 residuos", label: "CO₂ y Agente Limpio" },
  { valor: "NOM-002", label: "STPS + NOM-016-SSA3" },
  { valor: "24h", label: "Entrega en CDMX" },
];

const heroImg = "/img/sector-hospitales-sistema-contra-incendio.avif";

const equipoObligatorio = [
  {
    nombre: "Extintores CO₂",
    desc: "Para quirófanos, UCI, laboratorios y cuartos de equipo electrónico. Descarga sin residuos que contaminen ambientes estériles o dañen monitores y equipos de diagnóstico.",
    href: "/extintores/co2/",
    badge: "Áreas críticas",
  },
  {
    nombre: "Agente Limpio (FM-200)",
    desc: "Para farmacias, laboratorios de análisis clínico y centros de datos hospitalarios. Se evapora sin residuos — cero contaminación de muestras o medicamentos almacenados.",
    href: "/extintores/agente-limpio/",
    badge: "Sin residuos",
  },
  {
    nombre: "Extintores Polvo Seco ABC",
    desc: "Para pasillos generales, estacionamiento, cocina hospitalaria y cuartos de limpieza. Solo donde no hay equipo médico sensible ni ambientes estériles.",
    href: "/extintores/polvo-seco/",
    badge: "Áreas generales",
  },
  {
    nombre: "Señalamientos NOM-003",
    desc: "Rutas de evacuación que contemplan pacientes con movilidad reducida. Fotoluminiscentes en cada piso y área crítica. Obligatorio por NOM-003-SEGOB en instalaciones de salud.",
    href: "/senalamientos/",
    badge: "NOM-003-SEGOB",
  },
  {
    nombre: "Sistemas de Detección",
    desc: "Detectores de humo con alarma centralizada. Obligatorios en hospitales de 2+ pisos o con internamiento. Acción temprana sin depender de personal de guardia.",
    href: "/sistemas/detectores/",
    badge: "Internamiento",
  },
  {
    nombre: "Botiquines NOM Hospitalarios",
    desc: "Botiquines certificados para el personal administrativo y de mantenimiento. Complemento del equipo médico interno. Exigidos por la NOM-002 en centros de trabajo.",
    href: "/primeros-auxilios/",
    badge: "Personal",
  },
];

const faqs = [
  {
    pregunta: "¿Por qué no usar polvo seco ABC en un quirófano?",
    respuesta: "El polvo ABC contamina el ambiente estéril del quirófano, daña equipos de anestesia y monitoreo, y puede causar problemas respiratorios en pacientes intubados. La <strong>Secretaría de Salud y la NOM-002-STPS</strong> exigen extintores de CO₂ o Agente Limpio en áreas con equipo médico. El polvo solo va en áreas generales donde no hay equipo sensible ni pacientes.",
  },
  {
    pregunta: "¿Las clínicas pequeñas y consultorios también necesitan CO₂?",
    respuesta: "Depende del equipo presente. Un consultorio con solo silla dental y luz puede usar ABC. Una clínica con equipo de rayos X, ultrasonido o laboratorio de análisis necesita CO₂ o Agente Limpio en esas áreas. El diagnóstico gratuito evalúa el equipo específico de tu instalación.",
  },
  {
    pregunta: "¿Qué normativas aplican a hospitales y clínicas?",
    respuesta: "La <strong>NOM-002-STPS-2010</strong> (extintores en centros de trabajo) y la <strong>NOM-016-SSA3-2012</strong> (establecimientos de atención médica). Para farmacias también aplica COFEPRIS. Hospitales con internamiento tienen requisitos adicionales de Protección Civil y la Secretaría de Salud CDMX.",
  },
  {
    pregunta: "¿Con qué frecuencia se revisa el equipo en instalaciones de salud?",
    respuesta: "La NOM-002 exige mantenimiento anual. Para hospitales recomendamos <strong>revisión semestral</strong> del CO₂ y Agente Limpio dado el uso continuo del inmueble. Los certificados vigentes son necesarios para auditorías de COFEPRIS y acreditaciones hospitalarias.",
  },
  {
    pregunta: "¿El Agente Limpio es seguro con pacientes presentes?",
    respuesta: "Sí, en concentraciones de extinción. El Agente Limpio (FM-200) actúa en segundos y se disipa sin residuos. No es tóxico para personas fuera de la zona directa de descarga. Es la opción más usada en farmacia, laboratorio y centros de datos hospitalarios precisamente por su seguridad.",
  },
  {
    pregunta: "¿Qué pasa si compro el extintor incorrecto para un área médica?",
    respuesta: "Si compraste con base en nuestro diagnóstico y hay una observación de Protección Civil o COFEPRIS, lo resolvemos sin costo adicional. Por eso el diagnóstico previo es clave en instalaciones de salud — el equipo incorrecto puede ser peor que no tener nada en áreas con muestras o equipos de precisión.",
  },
];
---

<Base title={title} description={description} canonical="https://proyectored.com.mx/sectores/hospitales/">

  <nav class="breadcrumb container" aria-label="Ruta de navegación">
    {breadcrumbs.map((item, i) => (
      <>
        {i > 0 && <span class="breadcrumb__sep">›</span>}
        {item.href
          ? <a href={item.href} class="breadcrumb__link">{item.label}</a>
          : <span class="breadcrumb__current">{item.label}</span>
        }
      </>
    ))}
  </nav>

  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-left">
          <span class="hero-badge"><span class="badge-dot"></span> CO₂ y Agente Limpio · Sin residuos</span>
          <h1>Extintores sin Residuos<br><span class="h1-accent">para Hospitales y Clínicas</span></h1>
          <p class="hero-sub">Un extintor ABC en quirófano o laboratorio no solo incumple la norma — contamina el ambiente estéril y puede dañar equipos que valen millones. CO₂ desde $1,100, Agente Limpio para áreas de mayor sensibilidad. Diagnóstico gratuito sin interrumpir operaciones.</p>
          <div class="hero-ctas">
            <a href={`${WA_URL}?text=Hola%2C%20necesito%20extintores%20CO2%20o%20Agente%20Limpio%20para%20instalaci%C3%B3n%20de%20salud%20en%20CDMX`} class="btn-primary" target="_blank" rel="noopener noreferrer">Diagnóstico gratuito</a>
            <a href="/sectores/" class="btn-ghost">← Todos los sectores</a>
          </div>
        </div>
        <div class="hero-right">
          <img src={heroImg} alt="Sistema contra incendio en pasillo de hospital" width="1200" height="675" loading="eager" style="border-radius: 12px; width: 100%; height: auto; margin-bottom: 1.5rem;" />
          <p>El polvo de un extintor ABC arruina el ambiente estéril del quirófano, daña los contactos de equipos de monitoreo y puede quedar impregnado en superficies que tardas semanas en limpiar. La <strong>NOM-002-STPS</strong> y los estándares de la Secretaría de Salud exigen <strong>CO₂ o Agente Limpio</strong> en áreas con equipo médico electrónico o ambientes estériles.</p>
          <p>Proyecto Red identifica cada área de tu instalación — quirófano, laboratorio, farmacia, cuartos técnicos, pasillos generales — y asigna el agente correcto a cada espacio. Cero riesgo de contaminar lo que estás protegiendo. Diagnóstico sin costo, instalación coordinada con tu equipo de mantenimiento.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBar />

  <section class="metricas-section">
    <div class="container">
      <div class="metricas-grid">
        {metricas.map(m => (
          <div class="metrica-item">
            <span class="metrica-valor">{m.valor}</span>
            <span class="metrica-label">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--white">
    <div class="container">
      <div class="cat-header" style="margin-bottom:2.5rem">
        <div class="cat-header__info">
          <h2 class="cat-header__title">¿Qué agente extintor va en cada área de tu instalación?</h2>
          <p class="cat-header__desc">La regla es simple: donde hay equipo médico o ambiente estéril → CO₂ o Agente Limpio. Donde solo hay material de construcción o personas → ABC. El diagnóstico gratuito mapea tu instalación área por área.</p>
        </div>
        <div style="background:var(--c-primary-light);border-radius:8px;display:flex;align-items:center;justify-content:center;min-height:200px">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--c-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
      </div>
      <div class="productos-grid">
        {equipoObligatorio.map(p => (
          <a href={p.href} class="prod-card">
            <div class="prod-card__top">
              {p.badge && <span class="prod-badge">{p.badge}</span>}
            </div>
            <div class="prod-card__body">
              <h3>{p.nombre}</h3>
              <p>{p.desc}</p>
            </div>
            <div class="prod-card__footer">
              <span>Ver producto →</span>
            </div>
          </a>
        ))}
        <a href={`${WA_URL}?text=Hola%2C%20ya%20s%C3%A9%20qu%C3%A9%20necesito%3A%20quiero%20cotizaci%C3%B3n%20CO2%20o%20Agente%20Limpio%20para%20mi%20cl%C3%ADnica`} class="prod-card prod-card--cta" target="_blank" rel="noopener noreferrer">
          <strong>Ya sé qué agente necesito — cotizar ahora</strong>
          <p>CO₂ o Agente Limpio. Entrega en 24h CDMX.</p>
          <span>Cotizar por WhatsApp →</span>
        </a>
        <a href={`${WA_URL}?text=Hola%2C%20no%20s%C3%A9%20qu%C3%A9%20extintor%20va%20en%20cada%20%C3%A1rea%20de%20mi%20instalaci%C3%B3n%20de%20salud%20%E2%80%94%20quiero%20el%20diagn%C3%B3stico`} class="prod-card prod-card--cta" style="background:var(--c-ink);" target="_blank" rel="noopener noreferrer">
          <strong>No sé qué va en cada área — diagnóstico gratis</strong>
          <p>Mapeamos tu instalación sin interrumpir operaciones.</p>
          <span>Agendar diagnóstico →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--gray">
    <div class="container">
      <h2 style="font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;margin-bottom:0.5rem">¿Qué extintor va en cada área de tu instalación?</h2>
      <p style="color:var(--c-muted);margin-bottom:1.5rem">La elección del agente depende de lo que hay en el área, no del tamaño:</p>
      <div class="sector-escenarios-grid">
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Quirófano / UCI</p>
          <p class="sector-escenario__titulo">Ambiente estéril con equipo crítico</p>
          <ul class="sector-escenario__items">
            <li>CO₂ o Agente Limpio — nunca ABC</li>
            <li>1 por cuarto, accesible en 10 segundos</li>
            <li>Sin residuos que contaminen ambiente o paciente</li>
            <li>Personal capacitado para uso en emergencia</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Laboratorio / Farmacia</p>
          <p class="sector-escenario__titulo">Muestras, reactivos y medicamentos</p>
          <ul class="sector-escenario__items">
            <li>Agente Limpio ideal (cero residuos en muestras)</li>
            <li>CO₂ como alternativa si no hay muestras abiertas</li>
            <li>Señal de advertencia de reactivos en puerta</li>
            <li>Detector de humo conectado a alarma central</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Cuartos técnicos / Servidores</p>
          <p class="sector-escenario__titulo">Tableros, UPS, equipos electrónicos</p>
          <ul class="sector-escenario__items">
            <li>CO₂ — sin residuos en componentes</li>
            <li>1 por cuarto técnico, señalizado en puerta</li>
            <li>Detector de calor (no solo humo) en cuartos cerrados</li>
            <li>Plan de apagado coordinado con el extintor</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Pasillos / Cocina / Estacionamiento</p>
          <p class="sector-escenario__titulo">Áreas generales sin equipo sensible</p>
          <ul class="sector-escenario__items">
            <li>ABC estándar: 1 por cada 300 m²</li>
            <li>Tipo K en cocina si hay freidoras industriales</li>
            <li>Señalamientos NOM-003 en cada piso</li>
            <li>Punto de reunión exterior para personal y visitantes</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqCotizacion
    titulo="Preguntas frecuentes — Hospitales y Clínicas"
    subtitulo="Extintores sin residuos para instalaciones de salud en CDMX"
    faqs={faqs}
    pageId="hospitales"
    bgGray={false}
  />

  <section class="cta-final">
    <div class="container">
      <div class="cta-final-inner">
        <h2>El agente incorrecto puede contaminar lo que estás protegiendo.</h2>
        <p>Diagnóstico área por área sin costo. CO₂ desde $1,100. Agente Limpio sin interrumpir operaciones.</p>
        <a href={`${WA_URL}?text=Hola%2C%20quiero%20el%20diagn%C3%B3stico%20de%20extintores%20para%20mi%20instalaci%C3%B3n%20de%20salud`} class="btn-primary btn-lg" target="_blank" rel="noopener noreferrer">Solicitar diagnóstico →</a>
      </div>
    </div>
  </section>

</Base>
