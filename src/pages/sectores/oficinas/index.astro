---
import Base from '../../../layouts/Base.astro';
import CtaBar from '../../../components/CtaBar.astro';
import FaqCotizacion from '../../../components/FaqCotizacion.astro';
import '../../../styles/pages.css';

const WHATSAPP = "525537238544";
const WA_URL = `https://wa.me/${WHATSAPP}`;

const title = "Extintores para Oficinas y Corporativos CDMX — NOM-002 | Proyecto Red";
const description = "ABC desde $450 y CO₂ desde $1,100 para servidores. NOM-002-STPS para oficinas, corporativos y coworkings en CDMX. Instalación sin interrumpir operaciones. Diagnóstico gratuito.";

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Sectores", href: "/sectores/" },
  { label: "Oficinas y Corporativos" },
];

const metricas = [
  { valor: "Desde $450", label: "Extintor ABC certificado NOM" },
  { valor: "1/300 m²", label: "Mínimo por piso según NOM" },
  { valor: "CO₂", label: "Obligatorio para servidores" },
  { valor: "Sin parar", label: "Instalación sin interrumpir operaciones" },
];

const heroImg = "/img/sector-oficinas-extintor-co2.avif";

const equipoObligatorio = [
  {
    nombre: "Extintores Polvo Seco ABC",
    desc: "1 por cada 300 m², mínimo 1 por planta. Oficina de 400 m²: 2 extintores mínimo. Para áreas de trabajo general, salas de juntas, recepción y archivo.",
    href: "/extintores/polvo-seco/",
    badge: "Obligatorio NOM",
  },
  {
    nombre: "Extintores CO₂",
    desc: "Para cuartos de servidores, data center y centros de cómputo. No deja residuos que dañen discos, tarjetas o equipos. 1 por cuarto de servidores mínimo.",
    href: "/extintores/co2/",
    badge: "Servidores",
  },
  {
    nombre: "Agente Limpio",
    desc: "Para data centers críticos donde el CO₂ no es suficiente. Extinción instantánea sin residuos ni daño a la infraestructura de TI de mayor valor.",
    href: "/extintores/agente-limpio/",
    badge: "Data center",
  },
  {
    nombre: "Señalamientos NOM-003",
    desc: "Señales de evacuación, salidas de emergencia y punto de reunión exterior. Obligatorio en oficinas con 5 o más trabajadores. Fotoluminiscentes para cortes de luz.",
    href: "/senalamientos/",
    badge: "NOM-003-SEGOB",
  },
  {
    nombre: "Detectores de Humo",
    desc: "Para oficinas en edificios de varios pisos o con áreas sin presencia constante. Detección temprana antes de que el incendio se propague entre plantas.",
    href: "/sistemas/detectores/",
    badge: "Detección",
  },
  {
    nombre: "Gabinetes para Extintor",
    desc: "Instalación discreta y profesional en pasillos de oficinas corporativas. El extintor accesible y visible sin afectar la estética del espacio de trabajo.",
    href: "/gabinetes/para-extintor/",
    badge: "Presentación",
  },
];

const faqs = [
  {
    pregunta: "¿Cuántos extintores necesita mi oficina?",
    respuesta: "La <strong>NOM-002-STPS</strong> establece mínimo 1 extintor por planta y 1 por cada 300 m² de área de trabajo. Una oficina de 600 m² en un piso necesita mínimo 2 extintores. Si hay cuarto de servidores, ese espacio requiere un CO₂ adicional. El diagnóstico gratuito te da el número exacto.",
  },
  {
    pregunta: "¿Por qué el CO₂ para el cuarto de servidores y no el ABC?",
    respuesta: "El polvo del extintor ABC se introduce en los componentes electrónicos, provoca cortocircuitos y puede arruinar irreparablemente servidores y almacenamiento. El <strong>CO₂</strong> actúa por desplazamiento de oxígeno sin dejar residuos, protegiendo el equipo. Para data centers de mayor valor, el Agente Limpio es la mejor opción.",
  },
  {
    pregunta: "¿Las oficinas en edificios compartidos necesitan sus propios extintores?",
    respuesta: "Sí. Cada empresa inquilina es responsable del cumplimiento de la NOM-002 dentro de su espacio. El extintor en el pasillo del edificio es responsabilidad del administrador, pero no exime al inquilino. Ambos deben tener su propio equipo certificado.",
  },
  {
    pregunta: "¿La instalación puede hacerse en horario que no interrumpa operaciones?",
    respuesta: "Sí. Proyecto Red instala en el horario que mejor le funcione a tu empresa: antes de que llegue el personal, durante la hora de comida o en fin de semana. La instalación de extintores portátiles toma menos de 2 horas en una oficina estándar.",
  },
  {
    pregunta: "¿Los coworkings y espacios flex necesitan extintores propios?",
    respuesta: "Sí. Los coworkings son centros de trabajo sujetos a la misma NOM-002-STPS. El operador del espacio es responsable del equipo en áreas comunes. Si rentas un espacio privado dentro de un coworking, el operador debe mostrar los certificados vigentes de todo el inmueble.",
  },
  {
    pregunta: "¿Qué pasa si compro el equipo equivocado para mi oficina?",
    respuesta: "Si compraste con base en nuestro diagnóstico y hay una observación, lo resolvemos sin costo adicional. El caso más común en oficinas es poner ABC donde debía ir CO₂ en el cuarto de servidores — el diagnóstico previo existe para prevenir exactamente eso.",
  },
];
---

<Base title={title} description={description} canonical="https://proyectored.com.mx/sectores/oficinas/">

  <nav class="breadcrumb container" aria-label="Ruta de navegación">
    {breadcrumbs.map((item, i) => (
      <>
        {i > 0 && <span class="breadcrumb__sep">›</span>}
        {item.href
          ? <a href={item.href} class="breadcrumb__link">{item.label}</a>
          : <span class="breadcrumb__current">{item.label}</span>
        }
      </>
    ))}
  </nav>

  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-left">
          <span class="hero-badge"><span class="badge-dot"></span> NOM-002-STPS · Oficinas y Corporativos</span>
          <h1>Extintores para Oficinas<br><span class="h1-accent">y Corporativos en CDMX</span></h1>
          <p class="hero-sub">El extintor ABC en el cuarto de servidores puede destruir el equipo que intentas proteger. ABC desde $450 para áreas generales, CO₂ desde $1,100 para servidores. Instalación sin interrumpir operaciones, certificado NOM incluido.</p>
          <div class="hero-ctas">
            <a href={`${WA_URL}?text=Hola%2C%20necesito%20extintores%20para%20mis%20oficinas%20en%20CDMX`} class="btn-primary" target="_blank" rel="noopener noreferrer">Diagnóstico gratuito</a>
            <a href="/sectores/" class="btn-ghost">← Todos los sectores</a>
          </div>
        </div>
        <div class="hero-right">
          <img src={heroImg} alt="Extintor CO₂ junto a cuarto de servidores en oficina" width="1200" height="675" loading="eager" style="border-radius: 12px; width: 100%; height: auto; margin-bottom: 1.5rem;" />
          <p>Toda empresa con 5 o más trabajadores está sujeta a la <strong>NOM-002-STPS-2010</strong>. El requerimiento básico es simple: 1 extintor por cada 300 m². Pero si hay servidores, el agente correcto es <strong>CO₂ o Agente Limpio</strong> — el polvo del ABC puede arruinar discos duros y tarjetas irreparablemente.</p>
          <p>Proyecto Red instala el equipo correcto para cada área de tu oficina en el horario que tú elijas. Certificado NOM incluido para tus auditorías internas y verificaciones de Protección Civil. Sin cortar servicios, sin interrumpir al equipo de trabajo.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBar />

  <section class="metricas-section">
    <div class="container">
      <div class="metricas-grid">
        {metricas.map(m => (
          <div class="metrica-item">
            <span class="metrica-valor">{m.valor}</span>
            <span class="metrica-label">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--white">
    <div class="container">
      <div class="cat-header" style="margin-bottom:2.5rem">
        <div class="cat-header__info">
          <h2 class="cat-header__title">¿Qué extintor va en cada área de tu oficina?</h2>
          <p class="cat-header__desc">ABC para trabajo general. CO₂ para servidores. La distribución exacta depende de tu planta. El diagnóstico gratuito te da el mapa completo en menos de 1 hora.</p>
        </div>
        <div style="background:var(--c-primary-light);border-radius:8px;display:flex;align-items:center;justify-content:center;min-height:200px">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--c-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
      </div>
      <div class="productos-grid">
        {equipoObligatorio.map(p => (
          <a href={p.href} class="prod-card">
            <div class="prod-card__top">
              {p.badge && <span class="prod-badge">{p.badge}</span>}
            </div>
            <div class="prod-card__body">
              <h3>{p.nombre}</h3>
              <p>{p.desc}</p>
            </div>
            <div class="prod-card__footer">
              <span>Ver producto →</span>
            </div>
          </a>
        ))}
        <a href={`${WA_URL}?text=Hola%2C%20ya%20s%C3%A9%20qu%C3%A9%20necesito%3A%20quiero%20cotizaci%C3%B3n%20de%20extintores%20para%20oficinas`} class="prod-card prod-card--cta" target="_blank" rel="noopener noreferrer">
          <strong>Ya sé qué necesito — cotizar ahora</strong>
          <p>Instalación en el horario que tú elijas.</p>
          <span>Cotizar por WhatsApp →</span>
        </a>
        <a href={`${WA_URL}?text=Hola%2C%20no%20s%C3%A9%20cu%C3%A1ntos%20extintores%20necesitan%20mis%20oficinas%20%E2%80%94%20quiero%20el%20diagn%C3%B3stico%20gratuito`} class="prod-card prod-card--cta" style="background:var(--c-ink);" target="_blank" rel="noopener noreferrer">
          <strong>No sé cuántos necesito — diagnóstico gratis</strong>
          <p>Visitamos sin interrumpir operaciones.</p>
          <span>Agendar diagnóstico →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--gray">
    <div class="container">
      <h2 style="font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;margin-bottom:0.5rem">¿Qué extintor va en cada área de tu empresa?</h2>
      <p style="color:var(--c-muted);margin-bottom:1.5rem">Identifica las áreas de tu oficina y el agente correcto para cada una:</p>
      <div class="sector-escenarios-grid">
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Área de trabajo general</p>
          <p class="sector-escenario__titulo">Escritorios, salas de juntas, recepción</p>
          <ul class="sector-escenario__items">
            <li>ABC estándar: 1 por cada 300 m²</li>
            <li>Mínimo 1 por planta aunque sea pequeña</li>
            <li>Señalamientos de evacuación visibles</li>
            <li>Gabinete discreto en pasillo principal</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Cuarto de servidores</p>
          <p class="sector-escenario__titulo">Servidores, switches, UPS, almacenamiento</p>
          <ul class="sector-escenario__items">
            <li>CO₂ (no ABC — el polvo destruye el equipo)</li>
            <li>1 extintor CO₂ por cuarto, señalizado en puerta</li>
            <li>Detector de temperatura además de humo</li>
            <li>Para data centers de alto valor: Agente Limpio</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Cocina o área de comedor</p>
          <p class="sector-escenario__titulo">Microondas, cafetera, refrigerador</p>
          <ul class="sector-escenario__items">
            <li>ABC en área de cocina de uso de oficina</li>
            <li>Si hay freidoras o parrilla: Tipo K adicional</li>
            <li>Señalamiento de extintor visible desde el área</li>
            <li>A no más de 10 metros del punto de riesgo</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Oficinas en edificio compartido</p>
          <p class="sector-escenario__titulo">Inquilino en piso de edificio multi-tenant</p>
          <ul class="sector-escenario__items">
            <li>Cada inquilino es responsable de su espacio</li>
            <li>El extintor del pasillo no sustituye el tuyo</li>
            <li>Pedir certificados del edificio al administrador</li>
            <li>Señalamientos propios en tu área arrendada</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqCotizacion
    titulo="Preguntas frecuentes — Oficinas y Corporativos"
    subtitulo="Extintores correctos para cada área de tu empresa"
    faqs={faqs}
    pageId="oficinas"
    bgGray={false}
  />

  <section class="cta-final">
    <div class="container">
      <div class="cta-final-inner">
        <h2>Cumple la NOM sin interrumpir tu operación.</h2>
        <p>Desde $450. Instalación en el horario que tú elijas. Certificado NOM incluido.</p>
        <a href={`${WA_URL}?text=Hola%2C%20quiero%20extintores%20para%20mis%20oficinas%20en%20CDMX`} class="btn-primary btn-lg" target="_blank" rel="noopener noreferrer">Solicitar cotización →</a>
      </div>
    </div>
  </section>

</Base>
