---
import Base from '../../../layouts/Base.astro';
import CtaBar from '../../../components/CtaBar.astro';
import FaqCotizacion from '../../../components/FaqCotizacion.astro';
import '../../../styles/pages.css';

const WHATSAPP = "525537238544";
const WA_URL = `https://wa.me/${WHATSAPP}`;

const title = "Extintores AFFF para Gasolineras CDMX — CRE y NOM-005 | Proyecto Red";
const description = "AFFF obligatorio en cada isla de despacho según CRE y NOM-005-STPS. Desde $1,200. Sin AFFF la CRE puede suspender tu permiso de operación. Entrega sin interrumpir operaciones.";

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Sectores", href: "/sectores/" },
  { label: "Gasolineras y Estaciones" },
];

const metricas = [
  { valor: "Desde $1,200", label: "Extintor AFFF certificado" },
  { valor: "CRE + NOM-005", label: "Normativa obligatoria" },
  { valor: "1/isla", label: "AFFF mínimo por isla de despacho" },
  { valor: "Sin parar", label: "Instalación sin cerrar la estación" },
];

const heroImg = "/img/sector-gasolineras-extintores-afff.avif";

const equipoObligatorio = [
  {
    nombre: "Extintores AFFF (Espuma)",
    desc: "1 por cada isla de despacho, a no más de 15 m del punto de riesgo. La CRE lo exige. El ABC no previene la reignición de gasolina — solo el AFFF sella el vapor del combustible.",
    href: "/extintores/afff/",
    badge: "Obligatorio CRE",
  },
  {
    nombre: "Extintores Polvo Seco ABC",
    desc: "Para tienda de conveniencia, oficina, baños y área de espera. 1 por cada 300 m² de área no relacionada con combustibles.",
    href: "/extintores/polvo-seco/",
    badge: "Áreas generales",
  },
  {
    nombre: "Extintores CO₂",
    desc: "Para tableros eléctricos, compresor de aire y área de cómputo de la estación. Sin residuos que contaminen los equipos de medición de despacho.",
    href: "/extintores/co2/",
    badge: "Área eléctrica",
  },
  {
    nombre: "Señalamientos de Prohibición",
    desc: "No fumar, no encender motor, prohibido el paso no autorizado — en cada isla y entrada de la zona de despacho. Obligatorios por NOM-003 y reglamento CRE.",
    href: "/senalamientos/prohibicion/",
    badge: "Zona peligrosa",
  },
  {
    nombre: "Señalamientos de Advertencia",
    desc: "Materiales inflamables, zona de carga de tanques y riesgo de explosión. Visibles desde accesos vehiculares y peatonales según NOM-003-SEGOB.",
    href: "/senalamientos/advertencia/",
    badge: "NOM-003-SEGOB",
  },
  {
    nombre: "Señalamientos de Evacuación",
    desc: "Ruta de evacuación y punto de reunión exterior a distancia segura de las islas. En gasolineras el punto de reunión debe estar fuera de la zona de riesgo.",
    href: "/senalamientos/salvacion/",
    badge: "Evacuación",
  },
];

const faqs = [
  {
    pregunta: "¿Por qué el AFFF y no el polvo seco en gasolineras?",
    respuesta: "El polvo ABC puede apagar temporalmente el fuego de gasolina, pero <strong>el combustible líquido sigue caliente y se reignita</strong>. El AFFF forma una película acuosa sobre la superficie del líquido que sella el vapor inflamable e impide que vuelva a encenderse. La CRE y la NOM-005-STPS lo exigen específicamente en zonas de despacho porque el ABC solo es insuficiente para combustibles líquidos.",
  },
  {
    pregunta: "¿Cuántos AFFF necesita mi gasolinera?",
    respuesta: "La norma exige <strong>mínimo 1 AFFF por isla de despacho</strong>, ubicado a no más de 15 metros del punto de mayor riesgo y accesible sin cruzar la zona de peligro. Una estación con 4 islas necesita mínimo 4 AFFF. Además, el área de tanques de almacenamiento puede requerir un AFFF adicional de mayor capacidad.",
  },
  {
    pregunta: "¿La CRE puede suspender el permiso de operación por incumplimiento?",
    respuesta: "Sí. La CRE realiza verificaciones periódicas de seguridad en estaciones de servicio. El incumplimiento con la normativa de equipos contra incendios puede resultar en <strong>suspensión temporal del permiso de operación</strong> hasta que se demuestren las correcciones. Proyecto Red puede regularizarte sin interrumpir operaciones.",
  },
  {
    pregunta: "¿Se puede instalar el AFFF sin cerrar la gasolinera?",
    respuesta: "Sí. Proyecto Red instala los extintores en soportes murales o pedestales sin interrumpir el flujo de despacho. La instalación se coordina en el horario de menor afluencia y se completa típicamente en 1-2 horas. Los clientes no notan la instalación.",
  },
  {
    pregunta: "¿Cada cuánto se revisa el AFFF en gasolineras?",
    respuesta: "La NOM-002 exige mantenimiento anual certificado. En gasolineras recomendamos revisión <strong>semestral</strong> del AFFF por el ambiente corrosivo de vapores de hidrocarburos — el agente espumante se degrada más rápido. Proyecto Red programa visitas de mantenimiento preventivo.",
  },
  {
    pregunta: "¿Qué pasa si compro el equipo equivocado para mi gasolinera?",
    respuesta: "Si compraste con base en nuestro diagnóstico y hay una observación de la CRE o PC, lo resolvemos sin costo adicional. El diagnóstico previo existe para asegurar que el equipo sea el correcto según la configuración exacta de tu estación — número de islas, tipo de combustible y áreas complementarias.",
  },
];
---

<Base title={title} description={description} canonical="https://proyectored.com.mx/sectores/gasolineras/">

  <nav class="breadcrumb container" aria-label="Ruta de navegación">
    {breadcrumbs.map((item, i) => (
      <>
        {i > 0 && <span class="breadcrumb__sep">›</span>}
        {item.href
          ? <a href={item.href} class="breadcrumb__link">{item.label}</a>
          : <span class="breadcrumb__current">{item.label}</span>
        }
      </>
    ))}
  </nav>

  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-left">
          <span class="hero-badge"><span class="badge-dot"></span> AFFF obligatorio · CRE · NOM-005-STPS</span>
          <h1>Extintores AFFF para<br><span class="h1-accent">Gasolineras en CDMX</span></h1>
          <p class="hero-sub">El ABC no previene la reignición de gasolina. La CRE exige AFFF en cada isla de despacho. Sin él, una verificación puede suspender tu permiso de operación. Desde $1,200, instalación sin cerrar la estación.</p>
          <div class="hero-ctas">
            <a href={`${WA_URL}?text=Hola%2C%20necesito%20extintores%20AFFF%20para%20mi%20gasolinera%20en%20CDMX`} class="btn-primary" target="_blank" rel="noopener noreferrer">Cotizar AFFF ahora</a>
            <a href="/sectores/" class="btn-ghost">← Todos los sectores</a>
          </div>
        </div>
        <div class="hero-right">
          <img src={heroImg} alt="Extintores AFFF instalados en gasolinera PEMEX" width="1200" height="675" loading="eager" style="border-radius: 12px; width: 100%; height: auto; margin-bottom: 1.5rem;" />
          <p>La gasolina es un líquido inflamable: el fuego apagado con polvo seco puede reignitarse cuando el combustible sigue caliente. El <strong>AFFF (espuma)</strong> forma una película que sella el vapor inflamable e impide que vuelva a arder. Por eso la <strong>CRE y la NOM-005-STPS</strong> lo exigen específicamente en islas de despacho — no es equivalente al ABC.</p>
          <p>Proyecto Red entrega AFFF certificado e instala sin interrumpir operaciones. 1 extintor por isla de despacho como mínimo, señalamientos de zona peligrosa y el paquete completo para la próxima verificación de la CRE o Protección Civil. Factura y certificados NOM incluidos.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBar />

  <section class="metricas-section">
    <div class="container">
      <div class="metricas-grid">
        {metricas.map(m => (
          <div class="metrica-item">
            <span class="metrica-valor">{m.valor}</span>
            <span class="metrica-label">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--white">
    <div class="container">
      <div class="cat-header" style="margin-bottom:2.5rem">
        <div class="cat-header__info">
          <h2 class="cat-header__title">¿Cuánto AFFF necesita tu estación para cumplir con la CRE?</h2>
          <p class="cat-header__desc">Regla base: 1 AFFF por isla de despacho. Una estación con 4 islas: mínimo 4 AFFF + señalamientos de zona peligrosa en toda el área de combustibles + ABC en tienda y oficina.</p>
        </div>
        <div style="background:var(--c-primary-light);border-radius:8px;display:flex;align-items:center;justify-content:center;min-height:200px">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--c-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 22V6a2 2 0 012-2h7a2 2 0 012 2v16"/><path d="M14 11h4a2 2 0 012 2v4a1 1 0 001 1 1 1 0 001-1V9l-3-4"/><line x1="3" y1="22" x2="22" y2="22"/><rect x="5" y="9" width="8" height="5" rx="1"/></svg>
        </div>
      </div>
      <div class="productos-grid">
        {equipoObligatorio.map(p => (
          <a href={p.href} class="prod-card">
            <div class="prod-card__top">
              {p.badge && <span class="prod-badge">{p.badge}</span>}
            </div>
            <div class="prod-card__body">
              <h3>{p.nombre}</h3>
              <p>{p.desc}</p>
            </div>
            <div class="prod-card__footer">
              <span>Ver producto →</span>
            </div>
          </a>
        ))}
        <a href={`${WA_URL}?text=Hola%2C%20necesito%20AFFF%20y%20equipo%20completo%20para%20mi%20gasolinera%2C%20quiero%20cotizaci%C3%B3n`} class="prod-card prod-card--cta" target="_blank" rel="noopener noreferrer">
          <strong>Paquete completo — AFFF + señalamientos</strong>
          <p>Instalación sin cerrar la estación. Factura NOM.</p>
          <span>Cotizar por WhatsApp →</span>
        </a>
        <a href={`${WA_URL}?text=Hola%2C%20tengo%20una%20verificaci%C3%B3n%20de%20CRE%20pendiente%20%E2%80%94%20necesito%20que%20me%20revisen%20la%20gasolinera`} class="prod-card prod-card--cta" style="background:var(--c-ink);" target="_blank" rel="noopener noreferrer">
          <strong>Verificación CRE pendiente — urgente</strong>
          <p>Regularización antes de tu fecha de inspección.</p>
          <span>Contactar ahora →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--gray">
    <div class="container">
      <h2 style="font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;margin-bottom:0.5rem">¿Qué necesita tu estación según su configuración?</h2>
      <p style="color:var(--c-muted);margin-bottom:1.5rem">No todas las gasolineras tienen el mismo layout. Identifica la tuya:</p>
      <div class="sector-escenarios-grid">
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Estación pequeña</p>
          <p class="sector-escenario__titulo">2-3 islas de despacho</p>
          <ul class="sector-escenario__items">
            <li>2-3 AFFF (1 por isla, accesible a 15m máx)</li>
            <li>1-2 ABC para tienda y oficina</li>
            <li>Señalamientos de prohibición en islas</li>
            <li>Punto de reunión a distancia segura</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Estación mediana</p>
          <p class="sector-escenario__titulo">4-6 islas + tienda de conveniencia</p>
          <ul class="sector-escenario__items">
            <li>4-6 AFFF distribuidos por isla</li>
            <li>2-3 ABC en tienda, baños y oficina</li>
            <li>1 CO₂ en compresor y tablero eléctrico</li>
            <li>Señalamientos de advertencia en zona de tanques</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Estación con servicio adicional</p>
          <p class="sector-escenario__titulo">Lavado, lubricentro o taller</p>
          <ul class="sector-escenario__items">
            <li>AFFF en islas + AFFF adicional en área de lubricantes</li>
            <li>ABC para cada área de servicio</li>
            <li>Señalamientos específicos por zona de riesgo</li>
            <li>Plan de evacuación con zonas separadas</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Estación con renovación CRE</p>
          <p class="sector-escenario__titulo">Permiso por renovar o verificación próxima</p>
          <ul class="sector-escenario__items">
            <li>Auditoría completa de todo el equipo existente</li>
            <li>Reemplazo de extintores vencidos o descargados</li>
            <li>Actualización de señalamientos deteriorados</li>
            <li>Certificados NOM vigentes para expediente CRE</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqCotizacion
    titulo="Preguntas frecuentes — Gasolineras y Estaciones"
    subtitulo="AFFF, CRE y NOM-005 para estaciones de servicio en CDMX"
    faqs={faqs}
    pageId="gasolineras"
    bgGray={false}
  />

  <section class="cta-final">
    <div class="container">
      <div class="cta-final-inner">
        <h2>Sin AFFF, el permiso de la CRE está en riesgo.</h2>
        <p>Desde $1,200. Instalación sin cerrar. Certificados CRE-NOM incluidos.</p>
        <a href={`${WA_URL}?text=Hola%2C%20quiero%20AFFF%20certificado%20para%20mi%20gasolinera%20en%20CDMX`} class="btn-primary btn-lg" target="_blank" rel="noopener noreferrer">Cotizar AFFF →</a>
      </div>
    </div>
  </section>

</Base>
