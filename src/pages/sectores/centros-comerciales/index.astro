---
import Base from '../../../layouts/Base.astro';
import CtaBar from '../../../components/CtaBar.astro';
import FaqCotizacion from '../../../components/FaqCotizacion.astro';
import '../../../styles/pages.css';

const WHATSAPP = "525537238544";
const WA_URL = `https://wa.me/${WHATSAPP}`;

const title = "Equipo Contra Incendios para Centros Comerciales CDMX | Proyecto Red";
const description = "Rociadores NFPA 13, alarma centralizada y señalamientos masivos para plazas comerciales en CDMX. Cumplimiento para administradores e inquilinos. Diagnóstico gratuito.";

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Sectores", href: "/sectores/" },
  { label: "Centros Comerciales" },
];

const metricas = [
  { valor: "Desde $450", label: "Extintor ABC por local" },
  { valor: "NFPA 13", label: "Rociadores obligatorios +1,000m²" },
  { valor: "Clausura", label: "Riesgo para alta afluencia" },
  { valor: "Locatario", label: "Atendemos inquilinos y admins" },
];

const equipoObligatorio = [
  {
    nombre: "Rociadores Automáticos NFPA 13",
    desc: "Obligatorios en plazas de más de 1,000 m². Actúan automáticamente sin intervención humana. Las aseguradoras de inmuebles los exigen para dar cobertura.",
    href: "/sistemas/rociadores/",
    badge: "NFPA 13",
  },
  {
    nombre: "Alarma Centralizada",
    desc: "Panel de detección que cubre todos los locales y pasillos. Evacuación coordinada del inmueble completo ante cualquier incidente. Obligatorio en plazas de más de 1 nivel.",
    href: "/sistemas/alarmas/",
    badge: "Obligatorio",
  },
  {
    nombre: "Extintores ABC — por local",
    desc: "Cada local inquilino necesita su propio extintor. El del pasillo no sustituye. 1 ABC por cada 300 m² de área arrendada, más 1 CO₂ si hay equipo electrónico.",
    href: "/extintores/polvo-seco/",
    badge: "Por inquilino",
  },
  {
    nombre: "Señalamientos Masivos NOM-003",
    desc: "Flechas de evacuación en todos los pasillos, señales de salida sobre cada acceso, punto de reunión exterior claramente marcado. Fotoluminiscentes para cortes de luz.",
    href: "/senalamientos/",
    badge: "NOM-003-SEGOB",
  },
  {
    nombre: "Detectores de Humo",
    desc: "En cada local, pasillo techado y estacionamiento interior. Conectados al panel centralizado para respuesta inmediata en cualquier punto del inmueble.",
    href: "/sistemas/detectores/",
    badge: "Por zona",
  },
  {
    nombre: "Extintores CO₂",
    desc: "Para kioscos tecnológicos, cajeros automáticos, cuartos de servidores del inmueble y subestaciones eléctricas de la plaza.",
    href: "/extintores/co2/",
    badge: "Áreas eléctricas",
  },
];

const faqs = [
  {
    pregunta: "¿El administrador o el inquilino es responsable del equipo?",
    respuesta: "Los dos, en áreas distintas. El <strong>administrador</strong> es responsable de áreas comunes: pasillos, estacionamiento, rociadores generales y alarma central. El <strong>inquilino</strong> es responsable del equipo dentro de su local arrendado. Un fallo en cualquiera puede resultar en clausura del inmueble completo.",
  },
  {
    pregunta: "¿Mi local en la plaza necesita su propio extintor?",
    respuesta: "Sí. El extintor del pasillo de la plaza no cumple para tu local. La NOM-002 exige que cada centro de trabajo tenga su propio extintor dentro del área que ocupa. Un local de 80 m²: mínimo 1 ABC. Un local con equipo electrónico: 1 ABC + 1 CO₂.",
  },
  {
    pregunta: "¿Cuándo son obligatorios los rociadores en plazas?",
    respuesta: "En centros comerciales de más de <strong>1,000 m²</strong> de área construida con alta afluencia de público. Bajo las normas NFPA 13 adoptadas por Protección Civil CDMX, también se exigen cuando hay más de un nivel de área comercial techada. Las aseguradoras del inmueble también los requieren.",
  },
  {
    pregunta: "¿Qué pasa si PC detecta incumplimiento en la plaza?",
    respuesta: "Para inmuebles con alta afluencia pública, Protección Civil puede decretar clausura preventiva inmediata si detecta riesgo inminente. No aplica multa primero — cierra directo. La reapertura requiere demostrar cumplimiento completo, lo que puede tardar días.",
  },
  {
    pregunta: "¿El estacionamiento también necesita equipo?",
    respuesta: "Sí. Los estacionamientos cubiertos requieren extintores ABC o CO₂ cada 300 m², detectores de CO y humo, y señalamientos de evacuación con punto de reunión exterior. Es una de las áreas más olvidadas y de las primeras que revisa Protección Civil.",
  },
  {
    pregunta: "¿Qué pasa si compro el equipo equivocado para mi local en la plaza?",
    respuesta: "Si compraste con base en nuestro diagnóstico y hay una observación de PC, lo resolvemos sin costo. Para locatarios en plazas, el diagnóstico previo también verifica que el equipo sea compatible con el sistema centralizado del inmueble — para que no haya conflictos en una emergencia.",
  },
];
---

<Base title={title} description={description} canonical="https://proyectored.com.mx/sectores/centros-comerciales/">

  <nav class="breadcrumb container" aria-label="Ruta de navegación">
    {breadcrumbs.map((item, i) => (
      <>
        {i > 0 && <span class="breadcrumb__sep">›</span>}
        {item.href
          ? <a href={item.href} class="breadcrumb__link">{item.label}</a>
          : <span class="breadcrumb__current">{item.label}</span>
        }
      </>
    ))}
  </nav>

  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-left">
          <span class="hero-badge"><span class="badge-dot"></span> NOM-002 · NOM-003 · NFPA 13</span>
          <h1>Protección Contra Incendios<br><span class="h1-accent">para Centros Comerciales</span></h1>
          <p class="hero-sub">La falla en una sola área del inmueble puede clausurar la plaza completa. Administradores e inquilinos tienen responsabilidades distintas — ambos deben cumplir. Diagnóstico gratuito para cada caso.</p>
          <div class="hero-ctas">
            <a href={`${WA_URL}?text=Hola%2C%20necesito%20asesor%C3%ADa%20sobre%20equipo%20contra%20incendios%20para%20centro%20comercial%20en%20CDMX`} class="btn-primary" target="_blank" rel="noopener noreferrer">Diagnóstico gratuito</a>
            <a href="/sectores/" class="btn-ghost">← Todos los sectores</a>
          </div>
        </div>
        <div class="hero-right">
          <p>Un centro comercial tiene dos responsables: el <strong>administrador</strong> responde por pasillos, estacionamiento, rociadores generales y alarma central. El <strong>inquilino</strong> responde por el equipo dentro de su local. Un fallo en cualquiera puede resultar en clausura del inmueble completo — afectando a todos los locatarios aunque el resto esté en regla.</p>
          <p>Proyecto Red asesora a administradores de plazas e inquilinos de locales. Para cada caso hay requerimientos distintos: Proyecto Red los conoce y entrega el equipo correcto con certificados NOM para el expediente de Protección Civil.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBar />

  <section class="metricas-section">
    <div class="container">
      <div class="metricas-grid">
        {metricas.map(m => (
          <div class="metrica-item">
            <span class="metrica-valor">{m.valor}</span>
            <span class="metrica-label">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--white">
    <div class="container">
      <div class="cat-header" style="margin-bottom:2.5rem">
        <div class="cat-header__info">
          <h2 class="cat-header__title">¿Eres administrador de la plaza o locatario?</h2>
          <p class="cat-header__desc">Los requerimientos son distintos para cada rol. El administrador responde por el inmueble. El inquilino responde por su local. Los dos necesitan equipo propio con certificado NOM.</p>
        </div>
        <div style="background:var(--c-primary-light);border-radius:8px;display:flex;align-items:center;justify-content:center;min-height:200px">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--c-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        </div>
      </div>
      <div class="productos-grid">
        {equipoObligatorio.map(p => (
          <a href={p.href} class="prod-card">
            <div class="prod-card__top">
              {p.badge && <span class="prod-badge">{p.badge}</span>}
            </div>
            <div class="prod-card__body">
              <h3>{p.nombre}</h3>
              <p>{p.desc}</p>
            </div>
            <div class="prod-card__footer">
              <span>Ver producto →</span>
            </div>
          </a>
        ))}
        <a href={`${WA_URL}?text=Hola%2C%20soy%20locatario%20en%20plaza%20comercial%20y%20necesito%20extintor%20para%20mi%20local`} class="prod-card prod-card--cta" target="_blank" rel="noopener noreferrer">
          <strong>Soy locatario — necesito extintor para mi local</strong>
          <p>Desde $450 ABC. Entrega hoy en CDMX.</p>
          <span>Cotizar ahora →</span>
        </a>
        <a href={`${WA_URL}?text=Hola%2C%20administro%20una%20plaza%20comercial%20y%20necesito%20asesor%C3%ADa%20sobre%20cumplimiento%20NOM`} class="prod-card prod-card--cta" style="background:var(--c-ink);" target="_blank" rel="noopener noreferrer">
          <strong>Administro la plaza — asesoría completa</strong>
          <p>Rociadores, alarma central, señalización masiva.</p>
          <span>Consultar →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--gray">
    <div class="container">
      <h2 style="font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;margin-bottom:0.5rem">¿Qué necesita tu plaza según su tamaño?</h2>
      <p style="color:var(--c-muted);margin-bottom:1.5rem">El tamaño y la afluencia determinan los sistemas obligatorios:</p>
      <div class="sector-escenarios-grid">
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Local inquilino</p>
          <p class="sector-escenario__titulo">Cualquier tamaño de local comercial</p>
          <ul class="sector-escenario__items">
            <li>1 ABC por cada 300 m² del local</li>
            <li>1 CO₂ si hay equipo electrónico o caja registradora</li>
            <li>Señal de extintor visible en el local</li>
            <li>Certificado NOM para el expediente del inmueble</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Plaza pequeña</p>
          <p class="sector-escenario__titulo">Hasta 1,000 m², 1 nivel</p>
          <ul class="sector-escenario__items">
            <li>ABC en cada local y áreas comunes</li>
            <li>Señalamientos NOM-003 en pasillo principal</li>
            <li>Detector de humo en áreas cerradas</li>
            <li>Punto de reunión exterior señalizado</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Plaza mediana</p>
          <p class="sector-escenario__titulo">+1,000 m² o 2+ niveles</p>
          <ul class="sector-escenario__items">
            <li>Rociadores NFPA 13 obligatorios</li>
            <li>Alarma centralizada para todo el inmueble</li>
            <li>Señalamientos en cada pasillo y nivel</li>
            <li>Plan de evacuación con rutas por piso</li>
          </ul>
        </div>
        <div class="sector-escenario">
          <p class="sector-escenario__tipo">Plaza grande / anchor store</p>
          <p class="sector-escenario__titulo">Tienda departamental, megaplaza</p>
          <ul class="sector-escenario__items">
            <li>Sistema completo: rociadores + detección + alarma</li>
            <li>Señalización masiva en todos los pisos</li>
            <li>Estacionamiento con detectores de CO</li>
            <li>Mantenimiento anual del sistema completo</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FaqCotizacion
    titulo="Preguntas frecuentes — Centros Comerciales"
    subtitulo="Cumplimiento NOM para plazas, locales y tiendas departamentales"
    faqs={faqs}
    pageId="centros-comerciales"
    bgGray={false}
  />

  <section class="cta-final">
    <div class="container">
      <div class="cta-final-inner">
        <h2>Administradores e inquilinos: los dos necesitan cumplir.</h2>
        <p>Diagnóstico gratuito para cada rol. Equipo correcto con certificado NOM.</p>
        <a href={`${WA_URL}?text=Hola%2C%20necesito%20asesor%C3%ADa%20de%20equipo%20contra%20incendios%20para%20centro%20comercial`} class="btn-primary btn-lg" target="_blank" rel="noopener noreferrer">Solicitar asesoría →</a>
      </div>
    </div>
  </section>

</Base>
