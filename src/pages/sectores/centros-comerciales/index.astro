---
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import CtaBar from '../../../components/CtaBar.astro';
import FaqCotizacion from '../../../components/FaqCotizacion.astro';
import '../../../styles/pages.css';

const WHATSAPP = "525537238544";
const WA_URL = `https://wa.me/${WHATSAPP}`;

const title = "Equipo Contra Incendios para Centros Comerciales CDMX | Proyecto Red";
const description = "Rociadores, alarmas centralizadas y señalamientos masivos para plazas comerciales y tiendas departamentales. NOM-002 y NOM-003. Diagnóstico gratuito CDMX.";

const breadcrumbs = [
  { label: "Inicio", href: "/" },
  { label: "Sectores", href: "/sectores/" },
  { label: "Centros Comerciales" },
];

const metricas = [
  { valor: "NOM-002", label: "STPS + NOM-003-SEGOB" },
  { valor: "Masivo", label: "Señalización por m²" },
  { valor: "NFPA 13", label: "Rociadores obligatorios" },
  { valor: "24h", label: "Entrega CDMX" },
];

const equipoObligatorio = [
  { nombre: "Rociadores Automáticos", desc: "Obligatorios en plazas de más de 1,000 m². Sistema NFPA 13 que actúa automáticamente sin intervención humana. La primera línea de defensa en alta afluencia.", href: "/sistemas/rociadores/", badge: "NFPA 13" },
  { nombre: "Alarma Centralizada", desc: "Panel de detección y alarma centralizado que cubre todos los locales y pasillos. Evacuación coordinada ante cualquier incidente en el inmueble.", href: "/sistemas/alarmas/", badge: "Obligatorio" },
  { nombre: "Extintores ABC (masivos)", desc: "Extintores en cada local y área común cada 300 m². En plazas grandes se requieren decenas de extintores distribuidos estratégicamente.", href: "/extintores/polvo-seco/", badge: "Por local" },
  { nombre: "Señalamientos NOM-003", desc: "Señalamientos fotoluminiscentes masivos: rutas de evacuación en todos los pasillos, señales de salida sobre cada acceso, punto de reunión exterior claramente marcado.", href: "/senalamientos/", badge: "NOM-003-SEGOB" },
  { nombre: "Detectores de Humo", desc: "Detectores en cada local, pasillo techado y estacionamiento interior. Conectados al panel centralizado para respuesta inmediata.", href: "/sistemas/detectores/", badge: "Por zona" },
  { nombre: "Extintores CO₂", desc: "Para el área de kioscos tecnológicos, cajeros automáticos, cuartos de servidores y subestaciones eléctricas del inmueble.", href: "/extintores/co2/", badge: "Áreas eléctricas" },
];

const pasos = [
  { titulo: "Evaluación del inmueble completo", desc: "Analizamos planta, locales, pasillos, estacionamiento, cuartos técnicos y accesos. La complejidad de un centro comercial requiere un plan por zona." },
  { titulo: "Diseño del sistema de detección", desc: "Planeamos la cobertura de detectores de humo y calor para garantizar que cualquier inicio de incendio sea detectado antes de propagarse." },
  { titulo: "Distribución de extintores por local", desc: "Cada local inquilino tiene su extintor. Los pasillos y áreas comunes tienen distribución según NOM. Todo debidamente señalizado." },
  { titulo: "Señalización masiva de evacuación", desc: "Señalamientos en todos los accesos, pasillos y escaleras. El punto de reunión exterior marcado en el estacionamiento o área abierta más cercana." },
  { titulo: "Coordinación con administración", desc: "Trabajamos con el administrador del inmueble y los inquilinos. Documentación de cumplimiento por área para el expediente de Protección Civil." },
];

const faqs = [
  { pregunta: "¿Los inquilinos de locales en una plaza necesitan sus propios extintores?", respuesta: "Sí. Cada local es un centro de trabajo independiente y el inquilino es responsable del cumplimiento de la NOM-002 dentro de su espacio. El administrador de la plaza es responsable de las áreas comunes, pasillos, estacionamiento y sistemas generales (rociadores, alarma central). No son excluyentes — ambos deben cumplir." },
  { pregunta: "¿Cuándo son obligatorios los rociadores automáticos en plazas?", respuesta: "En México, los rociadores automáticos se exigen en centros comerciales de más de <strong>1,000 m²</strong> de área construida con alta afluencia de público. Bajo las normas NFPA 13 que adopta Protección Civil en CDMX, también se exigen cuando hay más de un nivel de área comercial techada." },
  { pregunta: "¿Cómo funciona la señalización en emergencias masivas?", respuesta: "Los señalamientos fotoluminiscentes de la <strong>NOM-003-SEGOB</strong> deben ser visibles incluso en oscuridad total (se cargan con luz ambiental). En una evacuación masiva, las flechas de evacuación en pasillos y las señales de salida sobre accesos guían al público hacia el exterior sin necesidad de personal de seguridad en cada punto." },
  { pregunta: "¿Qué pasa con la plaza si Protección Civil detecta incumplimiento?", respuesta: "Para establecimientos con alta afluencia de público, Protección Civil en CDMX puede decretar clausura preventiva inmediata si detecta riesgo inminente para los visitantes. No espera multa — cierra primero. La reapertura requiere demostrar cumplimiento completo. Proyecto Red puede regularizar y documentar el cumplimiento para tramitar la reapertura." },
  { pregunta: "¿Los estacionamientos también necesitan equipo?", respuesta: "Sí. Los estacionamientos cubiertos requieren extintores CO₂ o ABC cada 300 m², detectores de CO y humo, y señalamientos de evacuación y punto de reunión. Es una de las áreas más olvidadas y de las primeras que revisa Protección Civil." },
];
---

<Base title={title} description={description} canonical="https://proyectored.com.mx/sectores/centros-comerciales/">

  <Breadcrumb items={breadcrumbs} />

  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-left">
          <span class="hero-badge"><span class="badge-dot"></span> NOM-002-STPS · NOM-003-SEGOB · NFPA 13</span>
          <h1>Protección Contra Incendios<br><span class="h1-accent">para Centros Comerciales</span></h1>
          <p class="hero-sub">Rociadores automáticos, alarma centralizada y señalización masiva NOM para plazas comerciales con alta afluencia de público. Diagnóstico gratuito.</p>
          <div class="hero-ctas">
            <a href={`${WA_URL}?text=Hola%2C%20necesito%20equipo%20contra%20incendios%20para%20centro%20comercial%20en%20CDMX`} class="btn-primary" target="_blank" rel="noopener noreferrer">Diagnóstico gratuito</a>
            <a href="/sectores/" class="btn-ghost">← Todos los sectores</a>
          </div>
        </div>
        <div class="hero-right">
          <p>Los centros comerciales tienen el mayor riesgo de consecuencias masivas en caso de incendio. La <strong>NOM-002-STPS</strong> y la <strong>NOM-003-SEGOB</strong> exigen sistemas de detección, rociadores automáticos y señalización exhaustiva en todo el inmueble. Para plazas de más de 1,000 m², los rociadores NFPA 13 son obligatorios.</p>
          <p>Proyecto Red asesora tanto a administradores de plazas como a inquilinos de locales. El cumplimiento es responsabilidad compartida — ambos necesitan su propio equipo certificado para evitar clausuras y sanciones.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBar />

  <section class="metricas-section">
    <div class="container">
      <div class="metricas-grid">
        {metricas.map(m => (
          <div class="metrica-item">
            <span class="metrica-valor">{m.valor}</span>
            <span class="metrica-label">{m.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--white">
    <div class="container">
      <div class="cat-header" style="margin-bottom:2.5rem">
        <div class="cat-header__info">
          <h2 class="cat-header__title">¿Qué sistemas requiere un centro comercial?</h2>
          <p class="cat-header__desc">La complejidad del inmueble requiere un enfoque por zona. Proyecto Red planea y suministra sistemas completos para plazas y tiendas departamentales:</p>
        </div>
        <div style="background:var(--c-primary-light);border-radius:8px;display:flex;align-items:center;justify-content:center;min-height:200px">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--c-primary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        </div>
      </div>
      <div class="productos-grid">
        {equipoObligatorio.map(p => (
          <a href={p.href} class="prod-card">
            <div class="prod-card__top">
              {p.badge && <span class="prod-badge">{p.badge}</span>}
            </div>
            <div class="prod-card__body">
              <h3>{p.nombre}</h3>
              <p>{p.desc}</p>
            </div>
            <div class="prod-card__footer">
              <span>Ver producto →</span>
            </div>
          </a>
        ))}
        <a href={`${WA_URL}?text=Hola%2C%20necesito%20cotizaci%C3%B3n%20para%20centro%20comercial%20o%20local%20en%20plaza`} class="prod-card prod-card--cta" target="_blank" rel="noopener noreferrer">
          <strong>¿Administrador de plaza o inquilino?</strong>
          <p>Asesoría diferenciada para cada caso</p>
          <span>Consultar ahora →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="cat-section cat-section--gray">
    <div class="container">
      <h2 style="font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;margin-bottom:0.5rem">Plan de cumplimiento para centros comerciales</h2>
      <p style="color:var(--c-muted);margin-bottom:0">Coordinación con administración e inquilinos para cumplimiento total.</p>
      <div class="cumplimiento-steps">
        {pasos.map((paso, i) => (
          <div class="cumplimiento-step">
            <span class="step-num">{i + 1}</span>
            <div class="step-content">
              <h4>{paso.titulo}</h4>
              <p>{paso.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FaqCotizacion
    titulo="Preguntas frecuentes — Centros Comerciales"
    subtitulo="Cumplimiento NOM para plazas, locales y tiendas departamentales"
    faqs={faqs}
    pageId="centros-comerciales"
    bgGray={false}
  />

  <section class="cta-final">
    <div class="container">
      <div class="cta-final-inner">
        <h2>Protege tu plaza y tus inquilinos.</h2>
        <p>Diagnóstico gratuito para administradores y locatarios. Cumplimiento total NOM.</p>
        <a href={`${WA_URL}?text=Hola%2C%20quiero%20asesor%C3%ADa%20para%20centro%20comercial%20en%20CDMX`} class="btn-primary btn-lg" target="_blank" rel="noopener noreferrer">Solicitar asesoría →</a>
      </div>
    </div>
  </section>

</Base>
