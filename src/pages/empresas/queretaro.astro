    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:0.875rem">
      <a href="/extintores/co2/" style="display:block;padding:1rem 1.25rem;border:1px solid var(--c-border);border-radius:8px;background:var(--c-white);text-decoration:none;color:var(--c-ink);font-weight:600;font-size:0.9375rem">❄️ Extintor CO2 para salas de control</a>
      <a href="/extintores/abc/" style="display:block;padding:1rem 1.25rem;border:1px solid var(--c-border);border-radius:8px;background:var(--c-white);text-decoration:none;color:var(--c-ink);font-weight:600;font-size:0.9375rem">🔥 Extintor polvo ABC industrial</a>
      <a href="/sistemas/alarmas/" style="display:block;padding:1rem 1.25rem;border:1px solid var(--c-border);border-radius:8px;background:var(--c-white);text-decoration:none;color:var(--c-ink);font-weight:600;font-size:0.9375rem">🔔 Alarmas contra incendio para naves</a>
