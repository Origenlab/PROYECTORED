      <a href="/senalamientos/" style="display:block;padding:1rem 1.25rem;border:1px solid var(--c-border);border-radius:8px;background:var(--c-white);text-decoration:none;color:var(--c-ink);font-weight:600;font-size:0.9375rem">⚠️ Señalamientos y rutas de evacuación</a>
    </div>
  </section>
</Categoria>