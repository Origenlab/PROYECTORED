---
/**
 * empresas/index.astro — Página de cobertura de Proyecto Red
 * ─────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO.
 * Mismo patrón que productos.astro y servicios.astro —
 * cada sección es un componente autónomo.
 */

import Base                from '../../layouts/Base.astro'
import Breadcrumb          from '../../components/ui/Breadcrumb.astro'
import CtaBar              from '../../components/CtaBar.astro'

// ── Secciones de Empresas / Cobertura ──────────────
import HeroEmpresas        from '../../components/sections/HeroEmpresas.astro'
import CatalogoEmpresas    from '../../components/sections/CatalogoEmpresas.astro'
import SeleccionIndex      from '../../components/sections/SeleccionIndex.astro'
import NormasIndex         from '../../components/sections/NormasIndex.astro'
import ProcesoIndex        from '../../components/sections/ProcesoIndex.astro'
import FaqEmpresas         from '../../components/sections/FaqEmpresas.astro'
import CTAFinalIndex       from '../../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ──────────────────────────────
import { SITE, CONTACT } from '../../config/site'

const siteUrl   = SITE.url
const pageUrl   = `${siteUrl}/empresas/`
const ogImage   = `${siteUrl}/imagenes/og/proyectored-og.jpg`

// ── Schema: BreadcrumbList ──────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Cobertura",
      "item": pageUrl
    }
  ]
}

// ── Schema: OfferCatalog (zonas de cobertura) ───────
const schemaOfferCatalog = {
  "@context": "https://schema.org",
  "@type": "OfferCatalog",
  "name": "Zonas de Cobertura — Equipos Contra Incendios | Proyecto Red",
  "description": "Entrega directa de equipos contra incendios certificados en Ciudad de México, Estado de México, Querétaro, Puebla, Aguascalientes y Baja California. Proveedor directo con logística propia y envíos nacionales.",
  "url": pageUrl,
  "numberOfItems": 6,
  "itemListElement": [
    { "@type": "OfferCatalog", "name": "Equipos Contra Incendios en Ciudad de México — Sede principal, entrega el mismo día", "url": `${siteUrl}/empresas/cdmx/` },
    { "@type": "OfferCatalog", "name": "Equipos Contra Incendios en Estado de México — Zona metropolitana, 24-48 hrs", "url": `${siteUrl}/empresas/edomex/` },
    { "@type": "OfferCatalog", "name": "Equipos Contra Incendios en Querétaro — Corredor industrial, 48-72 hrs", "url": `${siteUrl}/empresas/queretaro/` },
    { "@type": "OfferCatalog", "name": "Equipos Contra Incendios en Puebla — Industria automotriz, envío coordinado", "url": `${siteUrl}/empresas/puebla/` },
    { "@type": "OfferCatalog", "name": "Equipos Contra Incendios en Aguascalientes — Corredor automotriz", "url": `${siteUrl}/empresas/aguascalientes/` },
    { "@type": "OfferCatalog", "name": "Equipos Contra Incendios en Baja California — Maquiladoras y zona fronteriza", "url": `${siteUrl}/empresas/baja-california/` },
  ]
}

// ── Schema: FAQPage ─────────────────────────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Entregan equipos contra incendios el mismo día en CDMX?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Pedidos confirmados antes de las 2 PM se entregan el mismo día en toda la Ciudad de México (16 alcaldías). Para el Estado de México, la entrega es en 24-48 horas dependiendo del municipio. Todo con logística propia."
      }
    },
    {
      "@type": "Question",
      "name": "¿Tienen cobertura en todo el Estado de México?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cubrimos directamente los municipios más industrializados: Naucalpan, Tlalnepantla, Ecatepec, Cuautitlán Izcalli, Toluca, Lerma, Atizapán, Texcoco y Huixquilucan. Para municipios fuera de esta lista coordinamos la entrega en la cotización."
      }
    },
    {
      "@type": "Question",
      "name": "¿Hacen envíos a otros estados fuera de CDMX y EDOMEX?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Enviamos a Querétaro, Puebla, Aguascalientes, Baja California y al resto de la república para pedidos de volumen. Coordinamos logística con paqueterías certificadas e incluimos el costo de flete en la cotización."
      }
    },
    {
      "@type": "Question",
      "name": "¿El equipo llega con documentación NOM completa?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Siempre. Todo equipo se entrega con ficha técnica, certificado de conformidad NOM, etiqueta de inspección y cualquier documentación adicional que tu expediente de Protección Civil requiera."
      }
    },
    {
      "@type": "Question",
      "name": "¿Ofrecen instalación y capacitación fuera de CDMX?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Para CDMX y Estado de México incluimos instalación y capacitación presencial. Para otros estados lo evaluamos por proyecto: en pedidos de cierto volumen podemos desplazar un equipo técnico para instalación de sistemas CI, señalización y capacitación con constancias DC-3."
      }
    },
    {
      "@type": "Question",
      "name": "¿Pueden ser nuestro proveedor fijo para múltiples sucursales?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. Trabajamos con empresas que tienen sucursales en varios estados y necesitan un solo proveedor. Ofrecemos facturación consolidada, entregas programadas por sucursal, precios preferenciales por volumen y un contacto único para todas tus ubicaciones."
      }
    }
  ]
}
---

<Base
  title="Cobertura — Equipos Contra Incendios en CDMX, EDOMEX y República | Proyecto Red"
  description="Entrega directa de equipos contra incendios certificados en Ciudad de México, Estado de México, Querétaro, Puebla, Aguascalientes y Baja California. Proveedor directo con logística propia y envíos nacionales."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <!-- ── Barra de migas de pan ────────────────────────────── -->
  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Cobertura' }
  ]} />

  <!-- ── Secciones ──────────────────────────────────────── -->
  <HeroEmpresas />
  <CtaBar />
  <CatalogoEmpresas />
  <SeleccionIndex />
  <NormasIndex />
  <ProcesoIndex />
  <FaqEmpresas />
  <CTAFinalIndex />

  <!-- ── Datos estructurados JSON-LD ──────────────────────
       Inyectados al final del <body> para no bloquear render
  ─────────────────────────────────────────────────────── -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaOfferCatalog)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

</Base>
