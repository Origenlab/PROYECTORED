---
// src/pages/senalamientos/[producto].astro
// Páginas de Nivel 4 — productos de señalamientos de emergencia
// Genera: /senalamientos/evacuacion/, /senalamientos/prohibicion/,
//         /senalamientos/advertencia/, /senalamientos/obligacion/,
//         /senalamientos/fotoluminiscentes/, /senalamientos/personalizados/

import CategoryLayout from '../../layouts/CategoryLayout.astro'
import SectionHeader from '../../components/ui/SectionHeader.astro'
import { waUrl, SERVICES } from '../../config/site'
import { SENALAMIENTO_PAGES, SENALAMIENTO_PRODUCTS } from '../../data/senalamientos-productos'
import '../../styles/product-page.css'

// Servicios más relevantes para esta categoría
const RELATED_SERVICES = SERVICES.filter((s) =>
  ['senalizacion', 'asesoria-tecnica'].includes(s.id)
)

// ── Rutas estáticas ──────────────────────────────────────────
export function getStaticPaths() {
  return SENALAMIENTO_PRODUCTS.map((p) => ({
    params: { producto: p.slug },
    props: { slug: p.slug },
  }))
}

const { producto } = Astro.params
const data = SENALAMIENTO_PAGES[producto]

if (!data) {
  return Astro.redirect('/senalamientos/')
}

// Señalamientos relacionados (los demás, excluyendo el actual)
const related = SENALAMIENTO_PRODUCTS.filter((p) => p.slug !== producto)

const PAGE_WA = waUrl(data.waMessage)
---

<CategoryLayout
  title={data.metaTitle}
  description={data.metaDesc}
  badge={data.badge}
  heroTitle={data.heroTitle}
  heroAccent={data.heroAccent}
  heroSubtitle={data.heroSubtitle}
  heroDescRight={data.heroDescRight}
  cta1={{ text: 'Cotizar por WhatsApp', href: PAGE_WA }}
  cta2={{ text: 'Ver todos los señalamientos', href: '/senalamientos/' }}
  breadcrumb={[
    { label: 'Inicio',        href: '/'               },
    { label: 'Productos',     href: '/productos/'     },
    { label: 'Señalamientos', href: '/senalamientos/' },
    { label: data.heroAccent },
  ]}
  stats={data.stats}
  showForm={true}
  faqItems={data.faqItems}
  ctaTitle={data.ctaTitle}
  ctaBody={data.ctaBody}
  ctaCTA1Text="Cotizar por WhatsApp"
  ctaCTA1Href={PAGE_WA}
  ctaCTA2Text="Ver todos los señalamientos"
  ctaCTA2Href="/senalamientos/"
>

  <!-- ===========================================================
       BLOQUE 1 — Características técnicas
       =========================================================== -->
  <section class="prod-section section" id="caracteristicas">
    <div class="container">

      <SectionHeader
        eyebrow={data.caracteristicas.eyebrow}
        titleLine1={data.caracteristicas.titleLine1}
        titleLine2={data.caracteristicas.titleLine2}
        desc={data.caracteristicas.desc}
      />

      <div class="features-grid">
        {data.caracteristicas.items.map((item) => (
          <div class="feature-card">
            <div class="feature-card__icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </div>
            <div class="feature-card__body">
              <h3 class="feature-card__title">{item.title}</h3>
              <p class="feature-card__desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA inline -->
      <div class="inline-cta">
        <p class="inline-cta__text">¿Tienes dudas sobre qué señal aplica en tu instalación? Te asesoramos sin costo.</p>
        <a
          href={PAGE_WA}
          class="btn btn--red"
          target="_blank"
          rel="noopener noreferrer"
        >
          Preguntar por WhatsApp
        </a>
      </div>

    </div>
  </section>

  <!-- ===========================================================
       BLOQUE 2 — ¿Dónde instalar?
       =========================================================== -->
  <section class="prod-section prod-section--light section--sm" id="donde-instalar">
    <div class="container">

      <SectionHeader
        eyebrow={data.dondeInstalar.eyebrow}
        titleLine1={data.dondeInstalar.titleLine1}
        titleLine2={data.dondeInstalar.titleLine2}
        desc={data.dondeInstalar.desc}
      />

      <div class="usos-grid">
        {data.dondeInstalar.usos.map((uso) => (
          <div class="uso-item">
            <div class="uso-item__dot" aria-hidden="true"></div>
            <div class="uso-item__body">
              <h3 class="uso-item__label">{uso.label}</h3>
              <p class="uso-item__desc">{uso.desc}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ===========================================================
       BLOQUE 3 — Servicios relacionados
       =========================================================== -->
  <section class="prod-section section--sm" id="servicios-senalamiento">
    <div class="container">
      <div class="svc-header">
        <p class="svc-header__label">Servicios disponibles para señalización</p>
        <a href="/servicios/" class="svc-header__link">Ver todos los servicios →</a>
      </div>
      <div class="svc-grid">
        {RELATED_SERVICES.map((svc) => (
          <a href={`/servicios/#${svc.id}`} class="svc-card">
            <span class="svc-card__name">{svc.label}</span>
            <span class="svc-card__desc">{svc.desc}</span>
            <span class="svc-card__arrow" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===========================================================
       BLOQUE 4 — Otros señalamientos del catálogo
       =========================================================== -->
  <section class="prod-section section--sm">
    <div class="container">

      <div class="related-header">
        <p class="related-header__label">{data.relatedTitle}:</p>
        <a href="/senalamientos/" class="related-header__link">Ver todos los señalamientos →</a>
      </div>

      <div class="related-grid">
        {related.map((r) => (
          <a href={`/senalamientos/${r.slug}/`} class="related-card">
            <span class="related-card__label">{r.label}</span>
            <span class="related-card__badge">{r.badge}</span>
          </a>
        ))}
      </div>

    </div>
  </section>

</CategoryLayout>

<!-- Estilos compartidos en src/styles/product-page.css (importado en frontmatter) -->
