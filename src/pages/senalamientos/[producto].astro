---
// src/pages/senalamientos/[producto].astro
// Páginas de Nivel 4 — productos individuales de la categoría Señalamientos de Emergencia
// Genera: /senalamientos/evacuacion/, /senalamientos/prohibicion/,
//         /senalamientos/advertencia/, /senalamientos/obligacion/,
//         /senalamientos/fotoluminiscentes/, /senalamientos/personalizados/
//
// Patrón 100% homologado con equipo-bomberos/[producto].astro (patrón canónico L4).
// Secciones: Características → ¿Dónde instalar? → Servicios →
//            TrustIndex → NormasSenalamientos → Otros señalamientos

import CategoryLayout from '../../layouts/CategoryLayout.astro'
import SectionHeaderDuo from '../../components/ui/SectionHeaderDuo.astro'
import TrustIndex from '../../components/sections/TrustIndex.astro'
import NormasSenalamientos from '../../components/sections/NormasSenalamientos.astro'
import { waUrl, SERVICES } from '../../config/site'
import { SENALAMIENTO_PAGES, SENALAMIENTO_PRODUCTS } from '../../data/senalamientos-productos'
import '../../styles/product-page.css'
import '../../styles/pages.css'

// Servicios relevantes para señalamientos
const RELATED_SERVICES = SERVICES.filter((s) =>
  ['senalizacion', 'asesoria-tecnica'].includes(s.id)
)

// ── Rutas estáticas ──────────────────────────────────────────
export function getStaticPaths() {
  return SENALAMIENTO_PRODUCTS.map((p) => ({
    params: { producto: p.slug },
    props: { slug: p.slug },
  }))
}

const { producto } = Astro.params
const data = SENALAMIENTO_PAGES[producto]

if (!data) {
  return Astro.redirect('/senalamientos/')
}

// Señalamientos relacionados (los demás, excluyendo el actual)
const related = SENALAMIENTO_PRODUCTS.filter((p) => p.slug !== producto)

const PAGE_WA = waUrl(data.waMessage)

// ── ¿Tiene tipos/modelos disponibles? ───────────────────────
// Controla la alternancia de fondos: con tipos S0=white → S1=gray → S2=white → S3=gray
const hasTipos = Boolean(data.tipos && data.tipos.length > 0)

const getTiposDesc = (): string => {
  const n = data.tipos?.length ?? 0
  return `${n} tipos disponibles de ${data.heroAccent} con certificación NOM y suministro en CDMX y Estado de México.`
}
---

<CategoryLayout
  title={data.metaTitle}
  description={data.metaDesc}
  badge={data.badge}
  heroTitle={data.heroTitle}
  heroAccent={data.heroAccent}
  heroSubtitle={data.heroSubtitle}
  heroDescRight={data.heroDescRight}
  cta1={{ text: 'Cotizar por WhatsApp', href: PAGE_WA }}
  cta2={{ text: 'Ver todos los señalamientos', href: '/senalamientos/' }}
  breadcrumb={[
    { label: 'Inicio',        href: '/'               },
    { label: 'Productos',     href: '/productos/'     },
    { label: 'Señalamientos', href: '/senalamientos/' },
    { label: data.heroAccent },
  ]}
  showForm={true}
  faqItems={data.faqItems}
  ctaTitle={data.ctaTitle}
  ctaBody={data.ctaBody}
  ctaCTA1Text="Cotizar por WhatsApp"
  ctaCTA1Href={PAGE_WA}
  ctaCTA2Text="Ver todos los señalamientos"
  ctaCTA2Href="/senalamientos/"
>

  <!-- ===========================================================
       SECCIÓN 0 — Tipos disponibles (opcional)
       Solo se renderiza si el producto tiene `tipos` definidos.
       Alternancia con tipos:  S0=white → S1=gray → S2=white → S3=gray
       Alternancia sin tipos:  S1=white → S2=gray → S3=white
       =========================================================== -->
  {hasTipos && (
    <section class="cat-section cat-section--white" id="tipos">
      <div class="container">

        <SectionHeaderDuo
          eyebrow={data.tiposEyebrow ?? 'Tipos disponibles'}
          titleLine1={data.tiposTitleLine1 ?? 'Modelos disponibles'}
          titleLine2={data.tiposTitleLine2}
          desc={getTiposDesc()}
          bodyPara1={data.tiposBodyPara ?? 'Cotiza el tipo correcto para tu instalación. Todos los señalamientos se entregan con documentación NOM de origen y asesoría técnica incluida.'}
        />

        <div class="catidx-grid" role="list" aria-label={`Tipos de ${data.heroAccent}`}>
          {data.tipos?.map((tipo, i) => (
            <article class="ccard ccard--tipo" role="listitem" aria-label={tipo.nombre}>
              <div class="ccard__content">
                {tipo.badge && (
                  <span class="ccard__badge ccard__badge--top">{tipo.badge}</span>
                )}
                <h3 class="ccard__title">{tipo.nombre}</h3>
                <p class="ccard__desc">{tipo.desc}</p>
                {tipo.specs && <p class="ccard__specs">{tipo.specs}</p>}
                <a
                  href={waUrl(tipo.waText)}
                  class="ccard__cta"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Cotizar este señalamiento
                  <svg
                    width="13" height="13"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}

          <!-- CTA Card WhatsApp — siempre última tarjeta -->
          <article class="ccard ccard--cta-wa" aria-label="Asesoría para elegir el señalamiento correcto">
            <a
              href={PAGE_WA}
              class="ccard--cta-wa__inner"
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="ccard--cta-wa__icon" aria-hidden="true">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <p class="ccard--cta-wa__title">¿No encuentras lo que necesitas?</p>
              <p class="ccard--cta-wa__sub">
                Cuéntanos la señal que buscas y te cotizamos sin costo.
              </p>
              <span class="ccard--cta-wa__btn">Asesoría por WhatsApp →</span>
            </a>
          </article>
        </div>

      </div>
    </section>
  )}

  <!-- ===========================================================
       SECCIÓN 1 — Características técnicas
       Fondo: --gray si hay tipos (S0=white antes) / --white si no
       =========================================================== -->
  <section
    class={`cat-section ${hasTipos ? 'cat-section--gray' : 'cat-section--white'}`}
    id="caracteristicas"
  >
    <div class="container">

      <SectionHeaderDuo
        eyebrow={data.caracteristicas.eyebrow}
        titleLine1={data.caracteristicas.titleLine1}
        titleLine2={data.caracteristicas.titleLine2}
        desc={data.caracteristicas.desc}
        bodyPara1="Consulta con nuestro equipo técnico para verificar el tipo de señalamiento correcto para cada área, los materiales adecuados y la documentación que necesitas para tu expediente de Protección Civil y STPS."
      />

      <div class="l4-svc-grid" role="list" aria-label="Características técnicas">
        {data.caracteristicas.items.map((item, idx) => (
          <div class="srv-mini" role="listitem" aria-label={item.title}>
            <span class="srv-mini__num" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</span>
            <div class="srv-mini__body">
              <strong class="srv-mini__titulo">{item.title}</strong>
              <span class="srv-mini__sub">{item.desc}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA inline -->
      <div class="inline-cta">
        <p class="inline-cta__text">
          ¿Tienes dudas sobre qué señalamiento aplica en tu instalación? Te asesoramos sin costo.
        </p>
        <a
          href={PAGE_WA}
          class="btn btn--red"
          target="_blank"
          rel="noopener noreferrer"
        >
          Preguntar por WhatsApp
        </a>
      </div>

    </div>
  </section>

  <!-- ===========================================================
       SECCIÓN 2 — ¿Dónde se instalan?
       Fondo: --white si hay tipos (S0=white S1=gray S2=white) / --gray si no
       =========================================================== -->
  <section
    class={`cat-section ${hasTipos ? 'cat-section--white' : 'cat-section--gray'}`}
    id="donde-instalar"
  >
    <div class="container">

      <SectionHeaderDuo
        eyebrow={data.dondeInstalar.eyebrow}
        titleLine1={data.dondeInstalar.titleLine1}
        titleLine2={data.dondeInstalar.titleLine2}
        desc={data.dondeInstalar.desc}
        bodyPara1="¿Tu caso no está listado? Cuéntanos el tipo de instalación, la cantidad de trabajadores y el giro de la empresa — hacemos el levantamiento y te proponemos el plan de señalización sin costo."
      />

      <div class="l4-svc-grid" role="list" aria-label="Instalaciones y usos aplicables">
        {data.dondeInstalar.usos.map((uso, idx) => (
          <div class="srv-mini" role="listitem" aria-label={uso.label}>
            <span class="srv-mini__num" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</span>
            <div class="srv-mini__body">
              <strong class="srv-mini__titulo">{uso.label}</strong>
              <span class="srv-mini__sub">{uso.desc}</span>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA inline -->
      <div class="inline-cta">
        <p class="inline-cta__text">
          ¿Necesitas señalización completa para tu inmueble? Realizamos el levantamiento y entregamos el plano para Protección Civil.
        </p>
        <a
          href={PAGE_WA}
          class="btn btn--red"
          target="_blank"
          rel="noopener noreferrer"
        >
          Solicitar levantamiento
        </a>
      </div>

    </div>
  </section>

  <!-- ===========================================================
       SECCIÓN 3 — Servicios relacionados
       Fondo: --gray si hay tipos (S0=white S1=gray S2=white S3=gray) / --white si no
       =========================================================== -->
  <section
    class={`cat-section ${hasTipos ? 'cat-section--gray' : 'cat-section--white'}`}
    id="servicios-senalamientos"
  >
    <div class="container">

      <SectionHeaderDuo
        eyebrow="Servicios disponibles"
        titleLine1="Más que señalamientos:"
        titleLine2="instalación y cumplimiento normativo"
        desc="No solo suministramos la señal — te acompañamos con instalación, levantamiento y documentación para Protección Civil."
        bodyPara1="Plano de señalización útil para tu expediente de Protección Civil. Diagnóstico de tu instalación sin costo. Señalamientos NOM con materiales certificados, tintas UV y versión fotoluminiscente disponible."
      />

      {RELATED_SERVICES.length > 0 && (
        <div class="l4-svc-grid" role="list" aria-label="Servicios disponibles para señalización">
          {RELATED_SERVICES.map((svc, idx) => (
            <a
              href={`/servicios/#${svc.id}`}
              class="srv-mini"
              role="listitem"
              aria-label={svc.label}
            >
              <span class="srv-mini__num" aria-hidden="true">{String(idx + 1).padStart(2, '0')}</span>
              <div class="srv-mini__body">
                <strong class="srv-mini__titulo">{svc.label}</strong>
                <span class="srv-mini__sub">{svc.desc}</span>
              </div>
              <svg
                class="srv-mini__arrow"
                width="16" height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>
      )}

    </div>
  </section>

  <!-- ===========================================================
       SECCIÓN 4 — Por qué Proyecto Red (homologado con L1/L3/L4)
       TrustIndex tiene su propio fondo — no interrumpe la alternancia.
       =========================================================== -->
  <TrustIndex />

  <!-- ===========================================================
       SECCIÓN 5 — Normas que regulan la señalización de emergencia
       NormasSenalamientos tiene su propio fondo.
       =========================================================== -->
  <NormasSenalamientos />

  <!-- ===========================================================
       SECCIÓN 6 — Otros señalamientos del catálogo
       Siempre --white (después de las secciones con fondo propio).
       Cards sin imagen (.ccard--text) — patrón idéntico a bomberos S6.
       =========================================================== -->
  <section class="cat-section cat-section--white" id="otros-senalamientos">
    <div class="container">

      <SectionHeaderDuo
        eyebrow="Más opciones"
        titleLine1={data.relatedTitle}
        desc="La señalización de emergencia es un sistema completo: evacuación, prohibición, advertencia y obligación trabajan juntos para cumplir con NOM y Protección Civil."
        bodyPara1="Explora el resto del catálogo para cubrir todos los tipos de señalización que tu instalación requiere. Suministramos señalamientos certificados NOM con materiales de larga durabilidad y documentación para tu expediente."
      />

      <div class="catidx-grid catidx-grid--compact" role="list" aria-label="Otros tipos de señalamientos de emergencia">
        {related.map((r) => (
          <article class="ccard ccard--text" role="listitem" aria-label={r.label}>
            <div class="ccard__content">
              <span class="ccard__badge ccard__badge--top">{r.badge}</span>
              <h3 class="ccard__title">{r.label}</h3>
              <a
                href={`/senalamientos/${r.slug}/`}
                class="ccard__cta"
                aria-label={`Ver detalles de ${r.label}`}
              >
                Ver detalles
                <svg
                  width="13" height="13"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        ))}

        <!-- CTA Card WhatsApp — siempre última tarjeta -->
        <article class="ccard ccard--cta-wa" aria-label="Asesoría para elegir la señalización correcta">
          <a
            href={PAGE_WA}
            class="ccard--cta-wa__inner"
            target="_blank"
            rel="noopener noreferrer"
          >
            <div class="ccard--cta-wa__icon" aria-hidden="true">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <p class="ccard--cta-wa__title">¿No sabes qué señalamientos necesitas?</p>
            <p class="ccard--cta-wa__sub">
              Cuéntanos el tipo de instalación y hacemos el levantamiento sin costo.
            </p>
            <span class="ccard--cta-wa__btn">Asesoría por WhatsApp →</span>
          </a>
        </article>
      </div>

    </div>
  </section>

</CategoryLayout>

<!-- ─────────────────────────────────────────────────────────────
     Estilos compartidos (importados en el frontmatter):
     · product-page.css → .l4-svc-grid, .srv-mini, .inline-cta
     · pages.css        → .catidx-grid, .ccard, .ccard--cta-wa, .cat-section

     Estilos scoped solo para variantes específicas de esta página:
     · .ccard--text          → card sin imagen para la sección "Otros señalamientos"
     · .ccard__badge--top    → badge de norma encima del título en .ccard--text
     · .catidx-grid--compact → más columnas para cards sin imagen
     ───────────────────────────────────────────────────────────── -->

<style>
  /* ── Card de tipo/modelo — usada en S0 "Tipos disponibles" ── */
  /* Sin .ccard__header: solo contenido con badge, título, desc, specs y CTA */
  .ccard--tipo {
    background: var(--c-white);
    border: 1px solid var(--c-border, #E4E4E7);
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .ccard--tipo .ccard__content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
  }

  .ccard--tipo .ccard__title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--c-text);
    line-height: 1.3;
    margin: 0;
  }

  .ccard--tipo .ccard__desc {
    font-size: 0.875rem;
    color: var(--c-text-muted, #666);
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }

  .ccard--tipo .ccard__specs {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-text-muted, #666);
    margin: 0;
  }

  .ccard--tipo .ccard__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--c-primary, #C41E24);
    text-decoration: none;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--c-border, #E4E4E7);
  }

  /* ── Card sin imagen — usada en S6 "Otros señalamientos" ─── */
  .ccard--text {
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: var(--c-bg-alt, #F8F8F8);
    border: 1px solid var(--c-border, #E4E4E7);
    border-radius: 10px;
    overflow: hidden;
    min-height: 140px;
  }

  .ccard--text .ccard__content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  /* ── Badge superior pequeño (norma NOM) en .ccard--text ──── */
  .ccard__badge--top {
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--c-primary, #C41E24);
    background: rgba(196, 30, 36, 0.06);
    border: 1px solid rgba(196, 30, 36, 0.18);
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
    align-self: flex-start;
    line-height: 1.4;
  }

  /* ── Grid compacto: más columnas para cards sin imagen ─────── */
  .catidx-grid--compact {
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  }

  @media (max-width: 640px) {
    .catidx-grid--compact {
      grid-template-columns: 1fr;
    }
  }
</style>
