---
/**
 * senalamientos/index.astro — L3 Señalamientos de Emergencia
 * ─────────────────────────────────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas y define SEO + JSON-LD de nivel técnico.
 * Estructura 100% homologada con extintores/index.astro (L3 template autorizado).
 * Cada sección vive en src/components/sections/ con sus propios estilos.
 * SectionHeaderDuo es el complemento oficial de encabezado en todas las secciones.
 */

import Base              from '../../layouts/Base.astro'
import CtaBar            from '../../components/CtaBar.astro'
import Breadcrumb        from '../../components/ui/Breadcrumb.astro'

// ── Secciones específicas de señalamientos ─────────────────
import HeroSenalamientos      from '../../components/sections/HeroSenalamientos.astro'
import CatalogoSenalamientos  from '../../components/sections/CatalogoSenalamientos.astro'
import GuiaSenalamientos      from '../../components/sections/GuiaSenalamientos.astro'
import NormasSenalamientos    from '../../components/sections/NormasSenalamientos.astro'
import FaqSenalamientos       from '../../components/sections/FaqSenalamientos.astro'

// ── Secciones genéricas reutilizadas ───────────────────────
import TrustIndex        from '../../components/sections/TrustIndex.astro'
import CTAFinalIndex     from '../../components/sections/CTAFinalIndex.astro'

// ── Datos para JSON-LD ─────────────────────────────────────
import { SITE, CONTACT } from '../../config/site'

const siteUrl = SITE.url
const pageUrl = `${siteUrl}/senalamientos/`
const ogImage = `${siteUrl}/imagenes/og/senalamientos-og.jpg`

// ── Schema: ItemList — 6 categorías de señalamientos ───────
const schemaItemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Señalamientos de emergencia certificados NOM — Proyecto Red",
  "description": "Catálogo de señalamientos de emergencia certificados NOM-003-SEGOB y NOM-026-STPS: evacuación, prohibición, advertencia, obligación, fotoluminiscentes y personalizados. Levantamiento gratuito de inmueble.",
  "url": pageUrl,
  "numberOfItems": 6,
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Señales de Evacuación y Salvamento",
      "description": "Rutas de evacuación, salidas de emergencia, punto de reunión y ubicación de extintores. Certificadas NOM-003-SEGOB. Fotoluminiscentes 8+ horas sin electricidad. Obligatorias para dictamen de Protección Civil.",
      "url": `${siteUrl}/senalamientos/evacuacion/`
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Señales de Prohibición",
      "description": "Círculo rojo con diagonal. No fumar, no paso, prohibido fuego abierto. NOM-003-SEGOB. PVC, acrílico y vinilo UV-resistente.",
      "url": `${siteUrl}/senalamientos/prohibicion/`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Señales de Advertencia",
      "description": "Triángulo amarillo. Riesgo eléctrico, material inflamable, piso resbaloso. NOM-026-STPS. Verificadas en auditorías STPS.",
      "url": `${siteUrl}/senalamientos/advertencia/`
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "Señales de Obligación EPP",
      "description": "Círculo azul. Uso obligatorio de casco, lentes, guantes, calzado y protección auditiva. NOM-017-STPS. Por zona de riesgo.",
      "url": `${siteUrl}/senalamientos/obligacion/`
    },
    {
      "@type": "ListItem",
      "position": 5,
      "name": "Señalamientos Fotoluminiscentes",
      "description": "Brillan 8+ horas sin electricidad ni baterías. El estándar que exige NOM-003-SEGOB para rutas de evacuación y salidas de emergencia.",
      "url": `${siteUrl}/senalamientos/fotoluminiscentes/`
    },
    {
      "@type": "ListItem",
      "position": 6,
      "name": "Señalización Personalizada",
      "description": "Señales a medida con pictograma NOM, texto personalizado, medidas especiales y materiales de alto rendimiento. Diseño normativo incluido.",
      "url": `${siteUrl}/senalamientos/personalizados/`
    }
  ]
}

// ── Schema: FAQPage ────────────────────────────────────────
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Cuáles señalamientos son obligatorios para pasar la inspección de Protección Civil?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Para obtener el dictamen favorable necesitas como mínimo: rutas de evacuación en todos los pasillos, salida de emergencia en cada salida, punto de reunión exterior, ubicación de extintores en cada equipo y no fumar en áreas de riesgo. Si los señalamientos no son fotoluminiscentes, el inspector puede rechazarlos incluso si están en las posiciones correctas."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué diferencia hay entre señalamientos fotoluminiscentes y los estándar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los fotoluminiscentes absorben luz ambiental y emiten luz en oscuridad total durante 8 horas o más sin electricidad ni baterías. Son los que exige la NOM-003-SEGOB para rutas de evacuación y salidas de emergencia. Los señalamientos estándar solo son visibles con luz."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuántos señalamientos necesito para mi negocio u oficina?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depende de la superficie y la distribución. Una oficina de 200 m² necesita entre 15 y 25 señales. Un restaurante entre 20 y 35. Una nave industrial de 1,000 m² puede requerir 50 o más. Hacemos levantamiento gratuito con plano de ubicación."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuánto cuesta un señalamiento certificado NOM en CDMX?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los señalamientos en PVC estándar arrancan desde $35 MXN por pieza. Los fotoluminiscentes certificados NOM-003-SEGOB van desde $65 MXN. Para pedidos de 20+ piezas aplicamos precio por volumen."
      }
    },
    {
      "@type": "Question",
      "name": "¿Instalan los señalamientos o solo los venden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los dos. Vendemos señalamientos sueltos y también ofrecemos el servicio completo: levantamiento, plano, venta e instalación. La instalación incluye colocación a la altura correcta según NOM (entre 1.80 m y 2.20 m del piso)."
      }
    },
    {
      "@type": "Question",
      "name": "¿Qué pasa si Protección Civil rechaza mis señalamientos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Si compraste con nosotros y seguiste el plano de señalización que entregamos, eso no va a pasar. Si por alguna razón el inspector hace una observación, la resolvemos sin costo adicional."
      }
    }
  ]
}

// ── Schema: BreadcrumbList ─────────────────────────────────
const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
    { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
    { "@type": "ListItem", "position": 3, "name": "Señalamientos de Emergencia", "item": pageUrl }
  ]
}

// ── Schema: CollectionPage ─────────────────────────────────
const schemaWebPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Señalamientos de Emergencia NOM en CDMX — Fotoluminiscentes y Certificados | Proyecto Red",
  "description": "Venta de señalamientos fotoluminiscentes certificados NOM-003-SEGOB y NOM-026-STPS: evacuación, prohibición, obligación y advertencia. Levantamiento gratuito con plano. Desde $35 MXN. Entrega en CDMX.",
  "url": pageUrl,
  "image": ogImage,
  "inLanguage": "es-MX",
  "isPartOf": { "@type": "WebSite", "name": "Proyecto Red", "url": siteUrl },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Inicio", "item": `${siteUrl}/` },
      { "@type": "ListItem", "position": 2, "name": "Productos", "item": `${siteUrl}/productos/` },
      { "@type": "ListItem", "position": 3, "name": "Señalamientos", "item": pageUrl }
    ]
  },
  "mainEntity": {
    "@id": pageUrl + "#itemlist"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Proyecto Red",
    "url": siteUrl,
    "logo": `${siteUrl}/imagenes/logos/logo-proyectored-201x60.png`,
    "telephone": `+52${CONTACT.phoneRaw}`,
    "email": CONTACT.email
  }
}
---

<Base
  title="Señalamientos de Emergencia NOM en CDMX — Fotoluminiscentes y Certificados | Proyecto Red"
  description="Venta de señalamientos fotoluminiscentes certificados NOM-003-SEGOB y NOM-026-STPS: evacuación, prohibición, obligación y advertencia. Levantamiento gratuito con plano de señalización. Desde $35 MXN. Entrega directa en CDMX."
  canonical={pageUrl}
  ogImage={ogImage}
>

  <Breadcrumb items={[
    { label: 'Inicio', href: '/' },
    { label: 'Productos', href: '/productos/' },
    { label: 'Señalamientos de Emergencia' }
  ]} />

  <HeroSenalamientos />
  <CtaBar />
  <CatalogoSenalamientos />
  <GuiaSenalamientos />
  <TrustIndex />
  <NormasSenalamientos />
  <FaqSenalamientos />
  <CTAFinalIndex />

  <script type="application/ld+json" set:html={JSON.stringify(schemaItemList)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaBreadcrumb)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaWebPage)} />

</Base>
