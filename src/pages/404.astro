---
// 404.astro — Página de error personalizada
import BaseLayout from '../layouts/BaseLayout.astro'
import { waUrl, PRODUCT_CATEGORIES } from '../config/site'

const PAGE_WA = waUrl('Hola, no encuentro lo que busco en el sitio')
---

<BaseLayout
  title="Página no encontrada (404) | Proyecto Red"
  description="La página que buscas no existe. Encuentra extintores, señalamientos, sistemas CI y equipo contra incendios en nuestro catálogo."
  noindex={true}
>

  <section class="notfound">
    <div class="container notfound__inner">

      <div class="notfound__code" aria-hidden="true">404</div>

      <h1 class="notfound__title">Página no encontrada</h1>
      <p class="notfound__desc">
        La dirección que buscas no existe o fue movida. Pero si estás buscando extintores, señalamientos, sistemas contra incendio o cualquier equipo de seguridad — estás en el lugar correcto.
      </p>

      <div class="notfound__actions">
        <a href="/" class="notfound__btn notfound__btn--primary">
          Ir al inicio
        </a>
        <a href="/productos/" class="notfound__btn notfound__btn--outline">
          Ver catálogo
        </a>
        <a href={PAGE_WA} class="notfound__btn notfound__btn--wa" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Ayuda por WhatsApp
        </a>
      </div>

      <!-- Links rápidos a las categorías principales -->
      <div class="notfound__categories">
        <p class="notfound__categories-label">O ir directamente a:</p>
        <div class="notfound__categories-grid">
          {PRODUCT_CATEGORIES.slice(0, 6).map((cat) => (
            <a href={`/${cat.slug}/`} class="notfound__cat-link">
              {cat.label}
            </a>
          ))}
          <a href="/servicios/" class="notfound__cat-link">Servicios</a>
          <a href="/contacto/" class="notfound__cat-link">Contacto</a>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .notfound {
    min-height: calc(100vh - 200px);
    display: flex;
    align-items: center;
    padding: var(--sp-20) 0;
    background: var(--color-gray-50);
  }

  .notfound__inner {
    text-align: center;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-6);
  }

  .notfound__code {
    font-size: clamp(6rem, 20vw, 10rem);
    font-weight: var(--weight-black);
    color: var(--color-red);
    line-height: 1;
    opacity: 0.15;
    letter-spacing: -0.05em;
    pointer-events: none;
    user-select: none;
  }

  .notfound__title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-black);
    color: var(--color-gray-900);
    line-height: var(--leading-tight);
    margin-top: calc(var(--sp-16) * -1);
  }

  .notfound__desc {
    font-size: var(--text-lg);
    color: var(--color-gray-500);
    line-height: var(--leading-relaxed);
    max-width: 520px;
  }

  .notfound__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-3);
  }

  .notfound__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-6);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-lg);
    transition: background var(--transition), color var(--transition), border-color var(--transition);
  }

  .notfound__btn--primary {
    background: var(--color-red);
    color: var(--color-white);
  }
  .notfound__btn--primary:hover { background: var(--color-red-hover); }

  .notfound__btn--outline {
    background: transparent;
    color: var(--color-gray-700);
    border: 2px solid var(--border);
  }
  .notfound__btn--outline:hover {
    border-color: var(--color-red);
    color: var(--color-red);
    background: var(--color-red-faint);
  }

  .notfound__btn--wa {
    background: #25D366;
    color: var(--color-white);
  }
  .notfound__btn--wa:hover { background: #1EA855; }

  .notfound__categories {
    margin-top: var(--sp-4);
    width: 100%;
  }

  .notfound__categories-label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-gray-400);
    margin-bottom: var(--sp-4);
  }

  .notfound__categories-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-2);
  }

  .notfound__cat-link {
    padding: var(--sp-2) var(--sp-4);
    background: var(--color-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    color: var(--color-gray-600);
    font-weight: var(--weight-medium);
  }

  .notfound__cat-link:hover {
    border-color: var(--color-red);
    color: var(--color-red);
  }
</style>
