---
// /productos/ — Catálogo completo de equipos contra incendios
import CategoryLayout from '../../layouts/CategoryLayout.astro'
import { PRODUCT_CATEGORIES, waUrl } from '../../config/site'

const PAGE_WA = waUrl('Hola, quiero cotizar equipos del catálogo')

const stats = [
  { value: '8+',  label: 'Categorías de equipo' },
  { value: '50+', label: 'Productos en catálogo' },
  { value: 'NOM', label: 'Certificación incluida' },
  { value: '24h', label: 'Entrega en CDMX'       },
]

const faqItems = [
  {
    question: '¿Cuánto cuesta un extintor certificado NOM en CDMX?',
    answer: 'El precio varía según tipo y capacidad. Un extintor de polvo seco ABC de 4 kg (el más solicitado para oficinas) es el más accesible. Los extintores CO₂ para electrónica y Tipo K para cocinas industriales tienen precios distintos. Escríbenos para una cotización exacta.',
  },
  {
    question: '¿Qué equipo contra incendios exige Protección Civil para empresas en CDMX?',
    answer: 'La NOM-002-STPS establece un extintor por cada 300 m² de área de trabajo, mínimo uno por piso. La NOM-003-SEGOB exige señalamientos de evacuación, salidas de emergencia y ubicación de extintores en materiales fotoluminiscentes.',
  },
  {
    question: '¿Hacen entrega a domicilio en CDMX y Estado de México?',
    answer: 'Sí, entrega directa en toda la Ciudad de México y el Estado de México. Pedidos confirmados antes de las 2 PM se entregan el mismo día en la zona metropolitana.',
  },
  {
    question: '¿Los extintores incluyen certificado NOM y documentación para Protección Civil?',
    answer: 'Sí. Todos nuestros extintores cumplen con la NOM-154-SCFI y se entregan con ficha técnica, certificado de conformidad, garantía y etiqueta de inspección.',
  },
  {
    question: '¿También realizan mantenimiento preventivo y recarga de extintores?',
    answer: 'Sí. Ofrecemos mantenimiento preventivo, recarga y prueba hidrostática directamente en tus instalaciones. El servicio incluye revisión del agente, presión, manguera y collar de garantía.',
  },
  {
    question: '¿Manejan precios especiales para empresas y pedidos de volumen?',
    answer: 'Sí. Trabajamos con empresas que abastecen múltiples sucursales, plantas o proyectos. A partir de cierto volumen ofrecemos precios preferenciales, crédito a 30 días, facturación consolidada y entregas programadas.',
  },
]

// Contenido específico de cada categoría (descripción + subcategorías)
// Separado del config global para mantener site.ts limpio
const catalogContent: Record<string, { description: string; subcategories: string[] }> = {
  'extintores': {
    description: 'Extintores certificados NOM-154-SCFI para todo tipo de riesgo. Polvo seco ABC, CO₂, AFFF, Tipo K para cocinas, agente limpio y automáticos. Entrega con documentación completa lista para tu expediente de Protección Civil y STPS.',
    subcategories: ['Polvo seco PQS / ABC', 'CO₂ para equipos electrónicos', 'AFFF — espuma para líquidos', 'Tipo K para cocinas industriales', 'Agente limpio para archivos y datos', 'Automáticos y Cold Fire'],
  },
  'equipo-bomberos': {
    description: 'Equipo profesional certificado NFPA 1971 para bomberos y brigadas de emergencia industrial. Trajes estructurales, equipos de respiración autónoma (ERA), herramientas de rescate manual, hidráulico, neumático y eléctrico, y arneses para rescate en altura.',
    subcategories: ['Trajes estructurales NFPA 1971', 'ERA — Equipos de respiración autónoma', 'Herramientas de rescate hidráulico', 'Herramientas de rescate neumático', 'Arneses y equipos de rescate', 'Complementos y accesorios de uniforme'],
  },
  'senalamientos': {
    description: 'Señalamientos fotoluminiscentes y en PVC para evacuación, prohibición, advertencia y obligación. Cumplimiento con NOM-003-SEGOB y NOM-026-STPS. Incluimos levantamiento del inmueble, recomendación de cantidades, instalación y plano para tu expediente de Protección Civil.',
    subcategories: ['Evacuación y rutas de salida', 'Prohibición (no fumar, no acceso)', 'Advertencia de riesgo', 'Obligación (uso de EPP)', 'Fotoluminiscentes (sin electricidad)', 'Señalización personalizada NOM'],
  },
  'gabinetes': {
    description: 'Gabinetes para extintor, hidrante y bombero. Porta extintores de pedestal y pared para cualquier capacidad. Soluciones para resguardo, accesibilidad y presentación de equipos en edificios corporativos, naves industriales y espacios comerciales.',
    subcategories: ['Gabinetes para extintor', 'Porta extintores pared y pedestal', 'Gabinetes para hidrante y manguera', 'Gabinetes para bombero', 'Soportes y herrajes de fijación'],
  },
  'mangueras': {
    description: 'Mangueras para hidrante, chiflones, válvulas angulares, adaptadores, carretes portátiles, tomas siamesas y llaves de conexión. Distribuidor autorizado Elkhart Brass. Todo lo que necesitas para completar tu red hidráulica contra incendio conforme a NFPA 14.',
    subcategories: ['Mangueras para hidrante (1½" y 2½")', 'Chiflones y boquillas de ataque', 'Válvulas angulares y de compuerta', 'Adaptadores y acopladores', 'Tomas siamesas y llaves', 'Monitores contra incendio Elkhart Brass'],
  },
  'sistemas': {
    description: 'Sistemas completos de detección, alarma y supresión: detectores de humo y calor, sirenas, rociadores automáticos NFPA 13, tableros FACP y controladores de bomba NFPA 20. Instalación llave en mano para edificios, plantas industriales y complejos comerciales.',
    subcategories: ['Detectores de humo y calor', 'Alarmas, sirenas y luces de emergencia', 'Rociadores automáticos (sprinklers)', 'Tableros FACP — control y monitoreo', 'Controladores de bomba NFPA 20', 'Monitoreo remoto y supervisión 24/7'],
  },
  'primeros-auxilios': {
    description: 'Botiquines certificados STPS, camillas rígidas y de cuchara, collarines cervicales, material de curación y equipo básico de reanimación. Completa tu plan de primeros auxilios conforme a la NOM-005-STPS y tenlo listo para cualquier inspección laboral.',
    subcategories: ['Botiquines STPS tipo A y B', 'Camillas rígidas y de cuchara', 'Collarines cervicales', 'Material de curación y vendaje', 'Equipo de reanimación básico', 'Oxígeno de emergencia portátil'],
  },
  'equipo-seguridad': {
    description: 'EPP certificado para protección craneal, visual, auditiva, respiratoria, de manos, pies y para trabajo en alturas. Cumplimiento con NOM-017-STPS-2008 y estándares internacionales ANSI, EN y CSA. Catálogo completo para industria, construcción y manufactura.',
    subcategories: ['Protección craneal (cascos y gorras)', 'Protección visual (lentes y caretas)', 'Protección auditiva (tapones y orejeras)', 'Respiratoria (mascarillas y filtros)', 'Manos y pies (guantes y calzado)', 'Trabajo en alturas (arneses y líneas)'],
  },
}
---

<CategoryLayout
  title="Catálogo de Productos Contra Incendios CDMX | Proyecto Red"
  description="Más de 50 productos contra incendios certificados NOM y NFPA. Extintores, señalamientos, gabinetes, sistemas CI y equipo para bomberos. Entrega en CDMX."
  badge="Catálogo certificado NOM y NFPA"
  heroTitle="Catálogo de Equipos Contra"
  heroAccent="Incendios"
  heroSubtitle="Más de 50 productos en 8 categorías. Todo certificado NOM y NFPA. Entrega directa en CDMX y Estado de México con asesoría técnica incluida."
  heroDescRight={[
    'En Proyecto Red somos proveedores directos de equipo contra incendios certificado para empresas, plantas industriales, restaurantes, edificios y cuerpos de bomberos en la Ciudad de México y el Estado de México.',
    'Cada producto de nuestro catálogo cumple con las normas NOM y NFPA vigentes. Entregamos con documentación completa: fichas técnicas, certificados de conformidad y etiqueta de inspección lista para tu expediente de Protección Civil y STPS.',
  ]}
  cta1={{ text: 'Solicitar cotización', href: PAGE_WA }}
  cta2={{ text: 'Ver catálogo', href: '#catalogo' }}
  breadcrumb={[{ label: 'Inicio', href: '/' }, { label: 'Productos' }]}
  {stats}
  faqItems={faqItems}
  ctaTitle="¿Necesitas equipo contra incendios en CDMX?"
  ctaBody="Mándanos un WhatsApp con el producto y la cantidad que necesitas. Te respondemos con precio, disponibilidad y tiempo de entrega en menos de 24 horas."
  ctaCTA1Text="Cotizar por WhatsApp"
  ctaCTA1Href={PAGE_WA}
  ctaCTA2Text="Ver nuestros servicios"
  ctaCTA2Href="/servicios/"
>

  <!-- =====================================================
       CONTENIDO ÚNICO: Catálogo por categorías
       ===================================================== -->
  <div id="catalogo">

    <!-- Navegación de anclas (sticky) -->
    <nav class="cat-nav" aria-label="Ir a categoría">
      <div class="container cat-nav__inner">
        <span class="cat-nav__label">Ir a categoría:</span>
        {PRODUCT_CATEGORIES.map((cat) => (
          <a href={`#${cat.slug}`} class="cat-nav__link">{cat.label}</a>
        ))}
      </div>
    </nav>

    <!-- Bloques de categoría generados desde config + catalogContent -->
    <div class="catalog">
      {PRODUCT_CATEGORIES.map((cat) => {
        const content = catalogContent[cat.slug]
        return (
          <section class="catalog__section section" id={cat.slug} aria-labelledby={`cat-${cat.slug}`}>
            <div class="container catalog__inner">

              <div class="catalog__header">
                <div>
                  {cat.badge && <span class="catalog__badge">{cat.badge}</span>}
                  <h2 class="catalog__title" id={`cat-${cat.slug}`}>{cat.label}</h2>
                </div>
                <div class="catalog__ctas">
                  <a href={cat.href} class="btn btn--red">Ver categoría completa</a>
                  <a href={waUrl(`Hola, necesito cotizar ${cat.label}`)} class="btn btn--outline" target="_blank" rel="noopener noreferrer">Cotizar por WhatsApp</a>
                </div>
              </div>

              <div class="catalog__content">
                <div class="catalog__image-wrap">
                  <img
                    src={`/images/categorias/${cat.slug}.webp`}
                    alt={`${cat.label} — Proyecto Red`}
                    width="520"
                    height="340"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                {content && (
                  <div class="catalog__body">
                    <p class="catalog__desc">{content.description}</p>
                    <ul class="catalog__subcats">
                      {content.subcategories.map((sub) => (
                        <li class="catalog__subcat">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg>
                          {sub}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>

            </div>
          </section>
        )
      })}
    </div>
  </div>

</CategoryLayout>

<style>
  /* Navegación de anclas */
  .cat-nav {
    position: sticky;
    top: 72px;
    z-index: 50;
    background: var(--color-white);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow-xs);
    padding-block: var(--sp-3);
  }

  .cat-nav__inner {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .cat-nav__inner::-webkit-scrollbar { display: none; }

  .cat-nav__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-gray-500);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cat-nav__link {
    padding: var(--sp-2) var(--sp-3);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-gray-700);
    border-radius: var(--radius-full);
    white-space: nowrap;
    background: var(--color-gray-100);
    transition: background var(--transition), color var(--transition);
    flex-shrink: 0;
  }

  .cat-nav__link:hover {
    background: var(--color-red-faint);
    color: var(--color-red);
  }

  /* Catálogo */
  .catalog__section:nth-child(even) {
    background: var(--color-gray-50);
  }

  .catalog__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--sp-6);
    margin-bottom: var(--sp-8);
    flex-wrap: wrap;
  }

  .catalog__badge {
    display: inline-block;
    padding: 3px var(--sp-3);
    background: var(--color-red-faint);
    color: var(--color-red);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-full);
    margin-bottom: var(--sp-2);
  }

  .catalog__title {
    font-size: var(--text-2xl);
    font-weight: var(--weight-black);
    color: var(--color-gray-900);
    line-height: var(--leading-tight);
  }

  .catalog__ctas {
    display: flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  .catalog__content {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--sp-10);
    align-items: start;
  }

  .catalog__image-wrap img {
    width: 100%;
    height: 280px;
    object-fit: cover;
    border-radius: var(--radius-xl);
    background: var(--color-gray-200);
  }

  .catalog__body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .catalog__desc {
    font-size: var(--text-base);
    color: var(--color-gray-600);
    line-height: var(--leading-relaxed);
  }

  .catalog__subcats {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-2) var(--sp-4);
  }

  .catalog__subcat {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--text-sm);
    color: var(--color-gray-700);
    font-weight: var(--weight-medium);
  }

  .catalog__subcat svg {
    color: var(--color-red);
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .catalog__content { grid-template-columns: 1fr; }
    .catalog__header { flex-direction: column; }
    .catalog__subcats { grid-template-columns: 1fr; }
  }
</style>
