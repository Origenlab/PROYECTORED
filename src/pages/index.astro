---
/**
 * index.astro — Home de Proyecto Red
 * ──────────────────────────────────
 * Orquestador limpio: importa secciones dedicadas e inyecta datos estructurados
 * por página. LocalBusiness se emite en Base.astro (global); aquí solo añadimos
 * FAQPage, WebSite y BreadcrumbList específicos de home.
 */

import Base          from '../layouts/Base.astro'
import CtaBar        from '../components/CtaBar.astro'
import '../styles/pages.css'

// ── Secciones del Index ────────────────────────────────────
import HeroIndex           from '../components/sections/HeroIndex.astro'
import CategoriasIndex     from '../components/sections/CategoriasIndex.astro'
import SeleccionIndex      from '../components/sections/SeleccionIndex.astro'
import TrustIndex          from '../components/sections/TrustIndex.astro'
import ServiciosIndex      from '../components/sections/ServiciosIndex.astro'
import NormasIndex         from '../components/sections/NormasIndex.astro'
import ProcesoIndex        from '../components/sections/ProcesoIndex.astro'
import CoberturaIndex      from '../components/sections/CoberturaIndex.astro'
import BlogPreviewIndex    from '../components/sections/BlogPreviewIndex.astro'
import ReviewsIndex        from '../components/sections/ReviewsIndex.astro'
import FaqCotizacionIndex  from '../components/sections/FaqCotizacionIndex.astro'
import CTAFinalIndex       from '../components/sections/CTAFinalIndex.astro'

// ── SEO: datos centralizados (única fuente de verdad) ─────
import { SITE } from '../config/site'
import { faqPageLd, websiteLd, breadcrumbLd, FAQS_GLOBALES } from '../lib/seo'

const pageUrl = `${SITE.url}/`
const ogImage = `${SITE.url}/imagenes/og/proyectored-og.jpg`

// Schemas específicos de home
const schemaFAQ       = faqPageLd(FAQS_GLOBALES)
const schemaWebsite   = websiteLd
const schemaBreadcrumb = breadcrumbLd([{ label: 'Inicio' }])
---

<Base
  title="Venta de Equipos Contra Incendios en CDMX | Proyecto Red"
  description="Extintores, sistemas contra incendio, señalización NOM y equipo para bomberos. Entrega el mismo día en CDMX y Estado de México. Diagnóstico técnico sin costo."
  canonical={pageUrl}
  ogImage={ogImage}
>
  <!-- JSON-LD específico de home — emitido en <head> -->
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaFAQ)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaWebsite)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaBreadcrumb)} />
  </Fragment>

  <!-- ── Secciones ──────────────────────────────────────── -->
  <HeroIndex />
  <CtaBar />
  <CategoriasIndex />
  <SeleccionIndex />
  <TrustIndex />
  <ServiciosIndex />
  <NormasIndex />
  <ProcesoIndex />
  <CoberturaIndex />
  <BlogPreviewIndex />
  <ReviewsIndex />
  <FaqCotizacionIndex />
  <CTAFinalIndex />
</Base>
