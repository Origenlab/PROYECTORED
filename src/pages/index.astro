---
import Base from '../layouts/Base.astro';
import CtaBar from '../components/CtaBar.astro';

const categorias = [
  {
    titulo: 'Extintores',
    sub: 'Polvo seco · CO₂ · AFFF · Tipo K · Agente Limpio',
    href: '/extintores/',
    img: '/imagenes/extintores/extintores-contra-incendios.jpg',
    badge: '10 tipos',
  },
  {
    titulo: 'Equipo para Bomberos',
    sub: 'Trajes · ERA · Herramientas · Arneses',
    href: '/equipo-bomberos/',
    img: '/imagenes/equipo-bomberos/equipo-bomberos-hero.jpg',
    badge: 'NFPA',
  },
  {
    titulo: 'Señalamientos',
    sub: 'Prohibición · Obligación · Advertencia · Salvación',
    href: '/senalamientos/',
    img: '/imagenes/senalamientos/senalamientos-hero.jpg',
    badge: 'NOM-003',
  },
  {
    titulo: 'Gabinetes',
    sub: 'Para extintor · Para manguera · Para bombero',
    href: '/gabinetes/',
    img: '/imagenes/gabinetes/gabinetes-extintores.jpg',
    badge: null,
  },
  {
    titulo: 'Mangueras y Herrajes',
    sub: 'Hidrantes · Chiflones · Válvulas · Adaptadores',
    href: '/mangueras/',
    img: '/imagenes/mangueras/mangueras-hero.jpg',
    badge: null,
  },
  {
    titulo: 'Sistemas contra Incendio',
    sub: 'Alarmas · Detectores · Rociadores · Tableros',
    href: '/sistemas/',
    img: '/imagenes/sistemas/alarmas.jpg',
    badge: 'NFPA 13/72',
  },
  {
    titulo: 'Primeros Auxilios',
    sub: 'Botiquines · Camillas · Material de curación',
    href: '/primeros-auxilios/',
    img: '/imagenes/primeros-auxilios/botiquines-hero.jpg',
    badge: 'STPS',
  },
  {
    titulo: 'Equipo de Seguridad',
    sub: 'Cascos · Lentes · Guantes · Arneses · EPP',
    href: '/equipo-seguridad/',
    img: '/imagenes/equipo-seguridad/equipos-seguridad-hero.jpg',
    badge: null,
  },
];

const estados = [
  { nombre: 'Ciudad de México', href: '/empresas/cdmx/' },
  { nombre: 'Estado de México', href: '/empresas/edomex/' },
  { nombre: 'Querétaro',        href: '/empresas/queretaro/' },
  { nombre: 'Puebla',           href: '/empresas/puebla/' },
  { nombre: 'Aguascalientes',   href: '/empresas/aguascalientes/' },
  { nombre: 'Baja California',  href: '/empresas/baja-california/' },
];


const trust = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    titulo: 'Equipo certificado NOM y NFPA',
    desc: 'Todo lo que vendemos cumple con la normativa mexicana e internacional. Pasa tus inspecciones de Protección Civil y STPS sin contratiempos.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`,
    titulo: 'Entrega directa en CDMX y EDOMEX',
    desc: 'Somos proveedor directo. Sin intermediarios que encarecen el precio o alargan los tiempos. Entregamos en toda la zona metropolitana.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    titulo: 'Cotización en menos de 24 horas',
    desc: 'Mandanos un WhatsApp con lo que necesitas y te respondemos con precios reales, disponibilidad y tiempos de entrega ese mismo día.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
    titulo: 'Asesoría técnica incluida',
    desc: 'Nuestro equipo analiza tu tipo de instalación y te recomienda el equipo correcto. No vendemos por volumen — vendemos lo que tu negocio realmente necesita.',
  },
];
---

<Base
  title="Venta de Equipos Contra Incendios en CDMX | Proyecto Red"
  description="Proyecto Red vende equipos contra incendios certificados en la Ciudad de México y Estado de México. Extintores, señalamientos NOM, equipo para bomberos, sistemas de detección y más. Entrega directa y asesoría técnica."
>

  <!-- ═══════════════════════════════════════════════════════
       HERO — 2 columnas: H1+CTAs izq / texto SEO der
  ══════════════════════════════════════════════════════════ -->
  <section class="hero">
    <div class="container hero-grid">

      <div class="hero-left">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          CDMX y Estado de México
        </div>
        <h1>Venta de Equipos<br>Contra <span class="h1-accent">Incendios</span></h1>
        <p class="hero-sub">Extintores certificados, señalamientos NOM, equipo para bomberos y sistemas contra incendio. Entrega directa en CDMX y Estado de México con asesoría técnica incluida.</p>
        <div class="hero-ctas">
          <a
            href="https://wa.me/525537238544?text=Hola%2C%20necesito%20informaci%C3%B3n%20sobre%20equipos%20contra%20incendios"
            class="btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Solicitar cotización
          </a>
          <a href="/extintores/" class="btn-secondary">Ver catálogo completo</a>
        </div>

      </div>

      <div class="hero-right">
        <p>En Proyecto Red vendemos e instalamos equipos contra incendios directamente a empresas, plantas industriales, restaurantes y edificios en la Ciudad de México y el Estado de México. Sin intermediarios — lo que significa mejores precios, tiempos de entrega rápidos y alguien disponible para resolver tus dudas técnicas.</p>
        <p>Todo nuestro catálogo cumple con las normas NOM y estándares NFPA, lo que te permite pasar inspecciones de Protección Civil y STPS sin contratiempos. Un solo proveedor, catálogo completo, documentación en orden.</p>
      </div>

    </div>
  </section>

  <CtaBar />

  <!-- ═══════════════════════════════════════════════════════
       CATEGORÍAS — Grid asimétrico con imágenes
  ══════════════════════════════════════════════════════════ -->
  <section class="categorias-section">
    <div class="container">
      <div class="section-header">
        <p class="section-label">Catálogo completo</p>
        <h2>Todas las categorías de<br>equipo contra incendios</h2>
      </div>

      <div class="cat-grid">
        {categorias.map((cat, i) => (
          <a
            href={cat.href}
            class={`cat-card ${i === 0 ? 'cat-card--featured' : ''}`}
            aria-label={cat.titulo}
          >
            <div class="cat-img-wrap">
              <img
                src={cat.img}
                alt={cat.titulo}
                loading={i < 3 ? 'eager' : 'lazy'}
                width="600"
                height="400"
              />
              <div class="cat-overlay"></div>
            </div>
            <div class="cat-body">
              {cat.badge && <span class="cat-badge">{cat.badge}</span>}
              <h3>{cat.titulo}</h3>
              <p>{cat.sub}</p>
              <span class="cat-arrow">
                Ver productos
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       CATÁLOGO — Cards con subsecciones estilo GAMA
  ══════════════════════════════════════════════════════════ -->
  <section class="catalogo-section" id="catalogo">
    <div class="container">

      <div class="catalogo-header">
        <div class="catalogo-header__left">
          <p class="section-label">Catálogo completo</p>
          <h2>Equipos Contra Incendios:<br>Todo en un Solo Proveedor</h2>
          <p class="catalogo-sub">Equipo certificado NOM y NFPA. Selecciona una categoría para conocer productos y solicitar cotización directa.</p>
        </div>
        <div class="catalogo-header__right">
          <p>Extintores de todos los tipos, señalamientos fotoluminiscentes, equipo profesional para bomberos, gabinetes industriales, mangueras y herrajes, sistemas de detección y supresión, botiquines y equipo de protección personal. Todo lo que necesitas para cumplir con Protección Civil y STPS en la Ciudad de México y Estado de México.</p>
          <p>Cada producto incluye ficha técnica, certificados de conformidad y asesoría para elegir el equipo correcto según el tipo y tamaño de tu instalación. Sin intermediarios — somos el proveedor directo.</p>
        </div>
      </div>

      <div class="catalogo-grid">

        <article class="cat-card-v2">
          <div class="cat-card-v2__img">
            <img src="/imagenes/extintores/extintores-contra-incendios.jpg" alt="Extintores contra incendios" loading="lazy" width="640" height="360" />
          </div>
          <div class="cat-card-v2__body">
            <h3>Extintores</h3>
            <p>Primera línea de defensa para cualquier tipo de riesgo</p>
            <div class="cat-card-v2__pills">
              <a href="/extintores/polvo-seco/">Polvo Seco (PQS)</a>
              <a href="/extintores/co2/">CO₂</a>
              <a href="/extintores/afff/">AFFF / Espuma</a>
              <a href="/extintores/tipo-k/">Tipo K — Cocinas</a>
              <a href="/extintores/purpura-k/">Púrpura K</a>
              <a href="/extintores/agua-a-presion/">Agua a Presión</a>
              <a href="/extintores/cold-fire/">Cold Fire</a>
              <a href="/extintores/automaticos/">Automáticos</a>
              <a href="/extintores/abc/">ABC Multiuso</a>
              <a href="/extintores/agente-limpio/">Agente Limpio</a>
            </div>
            <a href="/extintores/" class="cat-card-v2__btn">Ver todos los extintores</a>
          </div>
        </article>

        <article class="cat-card-v2">
          <div class="cat-card-v2__img">
            <img src="/imagenes/equipo-bomberos/equipo-bomberos-hero.jpg" alt="Equipo para bomberos" loading="lazy" width="640" height="360" />
          </div>
          <div class="cat-card-v2__body">
            <h3>Equipo para Bomberos</h3>
            <p>Protección personal certificada NFPA para cuerpos de bomberos y brigadas</p>
            <div class="cat-card-v2__pills">
              <a href="/equipo-bomberos/trajes/">Trajes Estructurales</a>
              <a href="/equipo-bomberos/complementos/">Complementos</a>
              <a href="/equipo-bomberos/respiracion-autonoma/">Respiración Autónoma (ERA)</a>
              <a href="/equipo-bomberos/herramientas/">Herramientas de Rescate</a>
              <a href="/equipo-bomberos/arneses/">Arneses</a>
            </div>
            <a href="/equipo-bomberos/" class="cat-card-v2__btn">Ver equipo de bomberos</a>
          </div>
        </article>

        <article class="cat-card-v2">
          <div class="cat-card-v2__img">
            <img src="/imagenes/senalamientos/senalamientos-hero.jpg" alt="Señalamientos de emergencia" loading="lazy" width="640" height="360" />
          </div>
          <div class="cat-card-v2__body">
            <h3>Señalamientos de Emergencia</h3>
            <p>Señalética fotoluminiscente conforme a NOM-003-SEGOB y STPS</p>
            <div class="cat-card-v2__pills">
              <a href="/senalamientos/prohibicion/">Prohibición</a>
              <a href="/senalamientos/obligacion/">Obligación</a>
              <a href="/senalamientos/advertencia/">Advertencia</a>
              <a href="/senalamientos/salvacion/">Salvación / Evacuación</a>
            </div>
            <a href="/senalamientos/" class="cat-card-v2__btn">Ver señalamientos</a>
          </div>
        </article>

        <article class="cat-card-v2">
          <div class="cat-card-v2__img">
            <img src="/imagenes/gabinetes/gabinetes-extintores.jpg" alt="Gabinetes contra incendios" loading="lazy" width="640" height="360" />
          </div>
          <div class="cat-card-v2__body">
            <h3>Gabinetes y Porta Extintores</h3>
            <p>Resguardo y acceso inmediato para equipo contra incendios</p>
            <div class="cat-card-v2__pills">
              <a href="/gabinetes/para-extintor/">Para Extintor</a>
              <a href="/gabinetes/porta-extintor-cenicero/">Porta Extintor Cenicero</a>
              <a href="/gabinetes/para-bombero/">Para Bombero</a>
              <a href="/gabinetes/para-hidrante/">Para Hidrante</a>
            </div>
            <a href="/gabinetes/" class="cat-card-v2__btn">Ver gabinetes</a>
          </div>
        </article>

        <article class="cat-card-v2">
          <div class="cat-card-v2__img">
            <img src="/imagenes/mangueras/mangueras-hero.jpg" alt="Mangueras y herrajes contra incendios" loading="lazy" width="640" height="360" />
          </div>
          <div class="cat-card-v2__body">
            <h3>Mangueras y Herrajes</h3>
            <p>Conducción de agua a alta presión para respuesta inmediata</p>
            <div class="cat-card-v2__pills">
              <a href="/mangueras/para-hidrante/">Para Hidrante</a>
              <a href="/mangueras/chiflones/">Chiflones</a>
              <a href="/mangueras/valvulas/">Válvulas</a>
              <a href="/mangueras/adaptadores/">Adaptadores</a>
              <a href="/mangueras/carretes/">Carretes</a>
              <a href="/mangueras/toma-siamesa/">Toma Siamesa</a>
              <a href="/mangueras/llaves/">Llaves de Herramienta</a>
              <a href="/mangueras/monitores/">Monitores</a>
            </div>
            <a href="/mangueras/" class="cat-card-v2__btn">Ver mangueras y herrajes</a>
          </div>
        </article>

        <article class="cat-card-v2">
          <div class="cat-card-v2__img">
            <img src="/imagenes/sistemas/alarmas.jpg" alt="Sistemas contra incendio" loading="lazy" width="640" height="360" />
          </div>
          <div class="cat-card-v2__body">
            <h3>Sistemas Contra Incendio</h3>
            <p>Detección, supresión y control automático para protección total</p>
            <div class="cat-card-v2__pills">
              <a href="/sistemas/alarmas/">Alarmas</a>
              <a href="/sistemas/detectores/">Detectores de Humo</a>
              <a href="/sistemas/rociadores/">Rociadores Automáticos</a>
              <a href="/sistemas/tableros/">Tableros de Control</a>
              <a href="/sistemas/redes-hidraulicas/">Redes Hidráulicas</a>
            </div>
            <a href="/sistemas/" class="cat-card-v2__btn">Ver sistemas CI</a>
          </div>
        </article>

        <article class="cat-card-v2">
          <div class="cat-card-v2__img">
            <img src="/imagenes/primeros-auxilios/botiquines-hero.jpg" alt="Primeros auxilios" loading="lazy" width="640" height="360" />
          </div>
          <div class="cat-card-v2__body">
            <h3>Primeros Auxilios</h3>
            <p>Kits de respuesta inmediata conforme a normativa STPS</p>
            <div class="cat-card-v2__pills">
              <a href="/primeros-auxilios/">Botiquines STPS</a>
              <a href="/primeros-auxilios/">Camillas de Emergencia</a>
              <a href="/primeros-auxilios/">Collarines</a>
              <a href="/primeros-auxilios/">Material de Curación</a>
            </div>
            <a href="/primeros-auxilios/" class="cat-card-v2__btn">Ver primeros auxilios</a>
          </div>
        </article>

        <article class="cat-card-v2">
          <div class="cat-card-v2__img">
            <img src="/imagenes/equipo-seguridad/equipos-seguridad-hero.jpg" alt="Equipo de seguridad industrial" loading="lazy" width="640" height="360" />
          </div>
          <div class="cat-card-v2__body">
            <h3>Equipo de Seguridad Industrial</h3>
            <p>EPP certificado para entornos industriales y comerciales</p>
            <div class="cat-card-v2__pills">
              <a href="/equipo-seguridad/">Cascos de Seguridad</a>
              <a href="/equipo-seguridad/">Lentes de Protección</a>
              <a href="/equipo-seguridad/">Chalecos Reflectantes</a>
              <a href="/equipo-seguridad/">Tapones Auditivos</a>
              <a href="/equipo-seguridad/">Conos de Señalización</a>
            </div>
            <a href="/equipo-seguridad/" class="cat-card-v2__btn">Ver equipo de seguridad</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       TRUST — Por qué Proyecto Red
  ══════════════════════════════════════════════════════════ -->
  <section class="trust-section">
    <div class="container">
      <div class="trust-inner">
        <div class="trust-header">
          <p class="section-label">Por qué elegirnos</p>
          <h2>Proveedor directo.<br>Sin intermediarios.</h2>
          <p class="trust-desc">Llevamos años equipando empresas en la CDMX y el Estado de México. Catálogo amplio, equipo certificado y alguien que responde cuando lo necesitas.</p>
          <a href="https://wa.me/525537238544?text=Hola%2C%20necesito%20informaci%C3%B3n" class="btn-outline" target="_blank" rel="noopener noreferrer">
            Hablar con un especialista
          </a>
        </div>
        <div class="trust-grid">
          {trust.map(t => (
            <div class="trust-item">
              <div class="trust-icon" set:html={t.icon} />
              <h3>{t.titulo}</h3>
              <p>{t.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>



  <!-- ═══════════════════════════════════════════════════════
       RESEÑAS
  ══════════════════════════════════════════════════════════ -->
  <section class="reviews-section">
    <div class="container">
      <div class="reviews-header">
        <p class="section-label">Lo que dicen nuestros clientes</p>
        <h2>Empresas que confían<br>en Proyecto Red</h2>
      </div>
      <div class="reviews-grid">

        <article class="review-card review-card--featured">
          <div class="review-top">
            <div class="review-stars">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
            <span class="review-badge">Empresa verificada</span>
          </div>
          <blockquote>
            "Con más de 80 años en venta y mantenimiento de extintores en CDMX, sabemos reconocer un proveedor serio. Proyecto Red cumple: equipo certificado NOM-154-SCFI y NOM-002-STPS, entrega puntual y documentación lista para Protección Civil. Es el aliado que buscábamos para complementar nuestro inventario cuando los volúmenes lo exigen."
          </blockquote>
          <div class="review-author">
            <div class="review-avatar-logo">
              <img src="https://mantenimientodeextintores.mx/favicon.ico" alt="Mantenimiento de Extintores" width="32" height="32" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
              <span style="display:none" class="review-avatar">ME</span>
            </div>
            <div class="review-info">
              <strong>MantenimientoDeExtintores.mx</strong>
