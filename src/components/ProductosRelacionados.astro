---
interface Relacionado {
  nombre: string;
  href: string;
  desc?: string;
}

interface Props {
  items: Relacionado[];
}

const { items } = Astro.props;
---
<section class="relacionados-section">
  <h3 class="relacionados-title">Productos relacionados</h3>
  <div class="relacionados-grid">
    {items.map(item => (
      <a href={item.href} class="relacionado-card">
        <span class="relacionado-nombre">{item.nombre}</span>
        {item.desc && <span class="relacionado-desc">{item.desc}</span>}
        <span class="relacionado-link">Ver más →</span>
      </a>
    ))}
  </div>
</section>

<style>
  .relacionados-section {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--c-border);
  }

  .relacionados-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.01em;
    margin-bottom: 1.25rem;
  }

  .relacionados-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .relacionado-card {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--c-border);
    border-radius: 6px;
    text-decoration: none;
    background: var(--c-surface);
    transition: border-color 0.15s, background 0.15s;
  }

  .relacionado-card:hover {
    border-color: var(--c-primary);
    background: var(--c-white);
  }

  .relacionado-nombre {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--c-ink);
    line-height: 1.3;
  }

  .relacionado-card:hover .relacionado-nombre {
    color: var(--c-primary);
  }

  .relacionado-desc {
    font-size: 0.8125rem;
    color: var(--c-muted);
    line-height: 1.45;
  }

  .relacionado-link {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-primary);
    margin-top: 0.25rem;
  }
</style>
