---
/**
 * NormasGabinetes.astro — v1
 * Cards de normas para gabinetes contra incendio.
 * Patrón 100% homologado con NormasSenalamientos / NormasExtintores.
 * Usa SectionHeaderDuo + .norma-card global (pages.css).
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'

const normas = [
  {
    norma: 'NOM-002-STPS',
    tipo: 'Prevención',
    alcance: 'Condiciones de seguridad — prevención y protección contra incendios en centros de trabajo. Define el resguardo correcto de extintores: ubicación, accesibilidad y protección del equipo.',
    aplica: 'Todo centro de trabajo. La STPS verifica que los extintores estén en buen estado y accesibles. Un extintor deteriorado por falta de gabinete (polvo, golpes, humedad) puede generar observación o multa en auditoría.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>`,
  },
  {
    norma: 'NFPA 10',
    tipo: 'Internacional',
    alcance: 'Estándar para extintores portátiles — instalación, inspección y mantenimiento. Incluye requisitos de protección física del extintor según el tipo de riesgo y la ubicación.',
    aplica: 'Plantas industriales, almacenes y proyectos con estándares internacionales. NFPA 10 es referencia técnica para decidir cuándo se requiere gabinete y qué tipo de protección es adecuada según la clase de riesgo.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>`,
  },
  {
    norma: 'NFPA 14',
    tipo: 'Sistemas hidráulicos',
    alcance: 'Instalación de sistemas de tuberías verticales y mangueras — define la ubicación, el tipo de gabinete y los accesorios requeridos (válvula, manguera, llave) en cada punto del sistema hidráulico.',
    aplica: 'Edificios de más de 5 pisos y naves industriales con red hidráulica contra incendio. Cada toma de agua para bomberos requiere gabinete para hidrante con manguera pre-conectada y válvula angular 2½".',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22V12m0 0c0-4-4-8-4-8s4 1 4 8zm0 0c0-4 4-8 4-8s-4 1-4 8z"/><path d="M5 12H2M22 12h-3M12 2V0"/></svg>`,
  },
  {
    norma: 'NOM-003-SEGOB',
    tipo: 'Señalización',
    alcance: 'Señales y avisos para protección civil — cada gabinete debe incluir señalamiento de ubicación visible desde el acceso. Define color rojo + blanco para gabinetes de extintor y manguera.',
    aplica: 'Todo inmueble con gabinetes instalados. El señalamiento del gabinete es parte del dictamen de Protección Civil. Sin señal visible de ubicación, el inspector puede hacer observación aunque el gabinete esté correctamente instalado.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
]
---

<section class="normas-gab" id="normas-gabinetes" aria-labelledby="normas-gab-heading">
  <div class="container">

    <SectionHeaderDuo
      id="normas-gab-heading"
      eyebrow="Marco normativo"
      titleLine1="Normas que Aplican a"
      titleLine2="Gabinetes e Instalación"
      desc="NOM-002-STPS, NFPA 10 y NFPA 14 definen cuándo se necesita gabinete, qué tipo y cómo debe instalarse."
      bodyPara1="La decisión de usar gabinete en lugar de soporte de pared no es solo estética — tiene respaldo normativo. NOM-002-STPS exige que los extintores estén protegidos y operables en todo momento. NFPA 10 detalla los criterios según tipo de riesgo. Y NFPA 14 es obligatoria en edificios con sistema de hidrantes. Cumplir las cuatro normas garantiza que no haya observaciones en inspección."
    />

    <div class="normas-gab-grid" role="list" aria-label="Normas aplicables a gabinetes contra incendio">
      {normas.map(n => (
        <article class="norma-card" role="listitem">
          <div class="norma-card__head">
            <div class="norma-card__icon" aria-hidden="true" set:html={n.icon} />
            <div>
              <span class="norma-card__codigo">{n.norma}</span>
              <span class="norma-tipo">{n.tipo}</span>
            </div>
          </div>
          <p class="norma-card__alcance">{n.alcance}</p>
          <div class="norma-card__aplica">
            <span class="norma-card__aplica-label">Aplica en</span>
            <p>{n.aplica}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="normas-nota">
      <svg class="normas-nota__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
      <p class="normas-nota__text">
        <strong>¿Gabinete empotrado, sobrepuesto o pedestal?</strong> Cada tipo de instalación tiene implicaciones normativas y constructivas distintas. Asesoramos sin costo — cotiza por WhatsApp con foto del espacio y del extintor que vas a resguardar.
      </p>
    </div>

  </div>
</section>

<style>
  .normas-gab {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-white);
    border-top: 1px solid var(--c-border);
  }

  .normas-gab-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 900px) { .normas-gab-grid { grid-template-columns: 1fr; } }
</style>
