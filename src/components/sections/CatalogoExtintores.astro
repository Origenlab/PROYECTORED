---
/**
 * CatalogoExtintores.astro
 * Catálogo de los 10 tipos de extintores — patrón .ccard homologado con L1/L2.
 * Usa SectionHeaderDuo (complemento título oficial) + .ccard con subcats.
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import { waUrl } from '../../config/site'
import '../../styles/pages.css'

const waHref = waUrl('Hola, quiero cotizar extintores contra incendios')

const extintores = [
  {
    nombre: 'Polvo Seco ABC (PQS)',
    desc: 'El más utilizado en México. Combate fuegos clase A, B y C. Obligatorio en la mayoría de inmuebles según NOM-002-STPS.',
    href: '/extintores/polvo-seco/',
    img: '/imagenes/extintores/polvo-seco.jpg',
    badge: 'Más vendido',
    ctaLabel: 'Ver polvo seco ABC',
    subcats: [
      { label: 'PQS 4.5 kg', href: '/extintores/polvo-seco/' },
      { label: 'PQS 6 kg', href: '/extintores/polvo-seco/' },
      { label: 'PQS 9 kg', href: '/extintores/polvo-seco/' },
      { label: 'PQS 12 kg', href: '/extintores/polvo-seco/' },
      { label: 'PQS 50 kg (carretilla)', href: '/extintores/polvo-seco/' },
      { label: 'PQS 2.5 kg (vehículo)', href: '/extintores/polvo-seco/' },
    ],
  },
  {
    nombre: 'CO₂ — Dióxido de Carbono',
    desc: 'Descarga limpia sin residuos. Ideal para equipos eléctricos, servidores, laboratorios y salas de cómputo.',
    href: '/extintores/co2/',
    img: '/imagenes/extintores/co2.jpg',
    badge: 'Electrónica',
    ctaLabel: 'Ver CO₂',
    subcats: [
      { label: 'CO₂ 2.5 kg', href: '/extintores/co2/' },
      { label: 'CO₂ 5 kg', href: '/extintores/co2/' },
      { label: 'CO₂ 10 kg', href: '/extintores/co2/' },
      { label: 'CO₂ 20 kg (carretilla)', href: '/extintores/co2/' },
    ],
  },
  {
    nombre: 'AFFF — Espuma Mecánica',
    desc: 'Espuma formadora de película acuosa para líquidos inflamables: gasolina, aceites y solventes.',
    href: '/extintores/afff/',
    img: '/imagenes/extintores/afff.jpg',
    badge: null,
    ctaLabel: 'Ver AFFF',
    subcats: [
      { label: 'AFFF 9 litros', href: '/extintores/afff/' },
      { label: 'AFFF 20 litros', href: '/extintores/afff/' },
      { label: 'AFFF 50 litros (carretilla)', href: '/extintores/afff/' },
      { label: 'Espuma AR-AFFF', href: '/extintores/afff/' },
    ],
  },
  {
    nombre: 'Tipo K — Cocinas Industriales',
    desc: 'Especializado en aceites vegetales y grasas animales. Obligatorio en restaurantes y cocinas con freidoras.',
    href: '/extintores/tipo-k/',
    img: '/imagenes/extintores/tipo-k.jpg',
    badge: 'Restaurantes',
    ctaLabel: 'Ver Tipo K',
    subcats: [
      { label: 'Tipo K 1.7 galones', href: '/extintores/tipo-k/' },
      { label: 'Tipo K 3 galones', href: '/extintores/tipo-k/' },
      { label: 'Tipo K 6 litros', href: '/extintores/tipo-k/' },
      { label: 'Sistema fijo Tipo K', href: '/extintores/tipo-k/' },
    ],
  },
  {
    nombre: 'Púrpura K — Bicarbonato de Potasio',
    desc: 'Mayor poder de extinción que el PQS en fuegos clase B y C de alta intensidad. Industria petroquímica.',
    href: '/extintores/purpura-k/',
    img: '/imagenes/extintores/purpura-k.jpg',
    badge: null,
    ctaLabel: 'Ver Púrpura K',
    subcats: [
      { label: 'Púrpura K 4.5 kg', href: '/extintores/purpura-k/' },
      { label: 'Púrpura K 6 kg', href: '/extintores/purpura-k/' },
      { label: 'Púrpura K 9 kg', href: '/extintores/purpura-k/' },
    ],
  },
  {
    nombre: 'Agua a Presión',
    desc: 'Solución ecológica para materiales sólidos: madera, papel, tela y textiles. Sin agentes químicos.',
    href: '/extintores/agua-a-presion/',
    img: '/imagenes/extintores/agua-a-presion.jpg',
    badge: null,
    ctaLabel: 'Ver agua a presión',
    subcats: [
      { label: 'Agua 9 litros', href: '/extintores/agua-a-presion/' },
      { label: 'Agua 20 litros', href: '/extintores/agua-a-presion/' },
      { label: 'Agua desmineralizada', href: '/extintores/agua-a-presion/' },
    ],
  },
  {
    nombre: 'Cold Fire — Enfriamiento Avanzado',
    desc: 'Tecnología de enfriamiento rápido. Biodegradable, no tóxico y recargable con agua. Clase A, B, D y K.',
    href: '/extintores/cold-fire/',
    img: '/imagenes/extintores/extintores-contra-incendios.jpg',
    badge: 'Innovación',
    ctaLabel: 'Ver Cold Fire',
    subcats: [
      { label: 'Cold Fire 2.5 litros', href: '/extintores/cold-fire/' },
      { label: 'Cold Fire 9 litros', href: '/extintores/cold-fire/' },
      { label: 'Cold Fire 20 litros', href: '/extintores/cold-fire/' },
      { label: 'Concentrado Cold Fire', href: '/extintores/cold-fire/' },
    ],
  },
  {
    nombre: 'Automáticos — Sin Intervención',
    desc: 'Activación autónoma por temperatura a 68 °C o 93 °C. Ideales para áreas desatendidas.',
    href: '/extintores/automaticos/',
    img: '/imagenes/extintores/automaticos.jpg',
    badge: null,
    ctaLabel: 'Ver automáticos',
    subcats: [
      { label: 'Automático PQS 1 kg', href: '/extintores/automaticos/' },
      { label: 'Automático PQS 6 kg', href: '/extintores/automaticos/' },
      { label: 'Automático PQS 12 kg', href: '/extintores/automaticos/' },
      { label: 'Automático CO₂ 5 kg', href: '/extintores/automaticos/' },
    ],
  },
  {
    nombre: 'ABC Multipropósito',
    desc: 'El más versátil: sólidos, líquidos y eléctricos. Requerido por norma en la mayoría de inmuebles.',
    href: '/extintores/abc/',
    img: '/imagenes/extintores/abc.jpg',
    badge: 'Obligatorio',
    ctaLabel: 'Ver ABC multipropósito',
    subcats: [
      { label: 'ABC 4.5 kg', href: '/extintores/abc/' },
      { label: 'ABC 6 kg', href: '/extintores/abc/' },
      { label: 'ABC 9 kg', href: '/extintores/abc/' },
      { label: 'ABC 12 kg', href: '/extintores/abc/' },
    ],
  },
  {
    nombre: 'Agente Limpio',
    desc: 'Cero residuos, cero daño. Protege equipos electrónicos, archivos y materiales sensibles.',
    href: '/extintores/agente-limpio/',
    img: '/imagenes/extintores/agente-limpio.jpg',
    badge: 'Premium',
    ctaLabel: 'Ver agente limpio',
    subcats: [
      { label: 'FE-36 — 2.5 kg', href: '/extintores/agente-limpio/' },
      { label: 'FE-36 — 5 kg', href: '/extintores/agente-limpio/' },
      { label: 'FE-36 — 10 kg', href: '/extintores/agente-limpio/' },
      { label: 'Solkaflam / HFC-227ea', href: '/extintores/agente-limpio/' },
    ],
  },
]
---

<section class="catalogo-extintores cat-section cat-section--white" id="catalogo-extintores" aria-labelledby="catalogo-ext-heading">
  <div class="container">

    <SectionHeaderDuo
      eyebrow="10 tipos certificados NOM"
      titleLine1="Catálogo de Extintores:"
      titleLine2="El Tipo Correcto para Cada Riesgo"
      desc="Selecciona el extintor adecuado según el tipo de fuego de tu instalación. Todos incluyen certificado NOM-154-SCFI, ficha técnica y soporte de pared."
      bodyPara1="Un extintor no sirve de nada si el agente no es el correcto para el tipo de fuego que puede presentarse en tu instalación. La NOM-002-STPS exige que el extintor sea del tipo adecuado para el riesgo predominante de cada zona — no uno genérico para toda la planta. Te ayudamos a elegir exactamente lo que necesitas por zona, con la capacidad correcta y la documentación lista para tu expediente."
    />

    <!-- Grid de cards — patrón .ccard homologado con L1/L2 -->
    <div class="catidx-grid" role="list" aria-label="Tipos de extintores disponibles">
      {extintores.map((ext, i) => (
        <article class="ccard" role="listitem" aria-label={ext.nombre}>
          <div class="ccard__header">
            <img
              src={ext.img}
              alt={ext.nombre}
              loading={i < 4 ? 'eager' : 'lazy'}
              width="640"
              height="360"
              decoding="async"
            />
            <div class="ccard__header-overlay" aria-hidden="true"></div>
            {ext.badge && <span class="ccard__badge">{ext.badge}</span>}
          </div>
          <div class="ccard__content">
            <h3 class="ccard__title">{ext.nombre}</h3>
            <p class="ccard__desc">{ext.desc}</p>

            {ext.subcats && ext.subcats.length > 0 && (
              <ul class="ccard__list" aria-label={`Modelos de ${ext.nombre}`}>
                {ext.subcats.map(sub => (
                  <li>
                    <a href={sub.href} class="ccard__link-btn">
                      {sub.label}
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                    </a>
                  </li>
                ))}
              </ul>
            )}

            <a href={ext.href} class="ccard__cta">
              {ext.ctaLabel || 'Ver detalles'}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}

      <!-- Card CTA WhatsApp -->
      <article class="ccard ccard--cta-wa" aria-label="Asesoría para elegir extintor">
        <a
          href={waHref}
          class="ccard--cta-wa__inner"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="ccard--cta-wa__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <p class="ccard--cta-wa__title">¿No sabes qué extintor necesitas?</p>
          <p class="ccard--cta-wa__sub">Dinos tu tipo de instalación y los riesgos — te recomendamos el equipo correcto por zona, gratis.</p>
          <span class="ccard--cta-wa__btn">Asesoría por WhatsApp →</span>
        </a>
      </article>
    </div>

  </div>
</section>
