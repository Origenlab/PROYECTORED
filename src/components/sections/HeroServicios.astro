---
/**
 * HeroServicios.astro
 * Hero de la página de servicios — mismo patrón visual que HeroProductos.
 * Izq: badge + H1 + subtítulo + CTAs / Der: párrafos descriptivos.
 */
import { waUrl, WA_MESSAGES } from '../../config/site'

const waHref = waUrl(WA_MESSAGES.servicios)
---

<section class="hero-servicios" aria-label="Servicios profesionales contra incendios">
  <div class="container hero-servicios__grid">

    <!-- ── Columna izquierda ── -->
    <div class="hero-servicios__left">

      <div class="hero-badge" aria-hidden="true">
        <span class="badge-pulse"></span>
        Servicios profesionales certificados
      </div>

      <h1 class="hero-servicios__h1">
        Servicios de Protección<br>
        Contra <span class="h1-accent">Incendios</span>
      </h1>

      <p class="hero-servicios__sub">
        Venta, recarga, mantenimiento, instalación, capacitación y señalización.
        Todo lo que tu empresa necesita para cumplir con Protección Civil y STPS
        en CDMX y Estado de México.
      </p>

      <div class="hero-servicios__ctas">
        <a
          href={waHref}
          class="btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Solicitar cotización
        </a>
        <a href="#catalogo" class="btn-secondary">Ver todos los servicios</a>
      </div>

    </div>

    <!-- ── Columna derecha: dos párrafos ── -->
    <div class="hero-servicios__right">
      <p>
        En Proyecto Red no solo vendemos equipos — ofrecemos protección integral
        contra incendios. Desde la asesoría técnica inicial hasta la capacitación
        de tu personal, nos encargamos de que tu empresa tenga el equipo correcto,
        funcionando y documentado para cualquier inspección.
      </p>
      <p>
        Todos nuestros servicios cumplen con la normativa mexicana vigente:
        NOM-002-STPS, NOM-154-SCFI, NOM-003-SEGOB y estándares NFPA.
        Un solo proveedor para todo — sin buscar entre cinco empresas diferentes.
      </p>
    </div>

  </div>
</section>

<style>
  /* ── HERO SERVICIOS ────────────────────────────────── */
  .hero-servicios {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background:
      radial-gradient(ellipse 55% 65% at 75% 50%, rgba(196,30,36,.13) 0%, transparent 65%),
      linear-gradient(160deg, #0A0A0A 0%, #160A0A 50%, #0A0A0A 100%);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .hero-servicios::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .badge-pulse {
    width: 7px;
    height: 7px;
    background: var(--c-primary);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero-servicios__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── TIPOGRAFÍA H1 ─────────────────────────────────── */
  .hero-servicios__h1 {
    font-size: clamp(2.5rem, 4.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -.03em;
    margin-bottom: 1.25rem;
  }

  /* ── SUBTÍTULO ─────────────────────────────────────── */
  .hero-servicios__sub {
    font-size: 1.0625rem;
    color: rgba(255,255,255,.6);
    line-height: 1.65;
    max-width: 50ch;
    margin-bottom: 2rem;
  }

  /* ── CTAs ──────────────────────────────────────────── */
  .hero-servicios__ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  /* ── COLUMNA DERECHA ───────────────────────────────── */
  .hero-servicios__right p {
    color: rgba(255,255,255,.55);
    font-size: 0.9375rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  .hero-servicios__right p:last-child { margin-bottom: 0; }

  /* ── RESPONSIVE ────────────────────────────────────── */
  @media (max-width: 1024px) {
    .hero-servicios__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hero-servicios { padding-top: 3rem; }
  }

  @media (max-width: 768px) {
    .hero-servicios { padding-bottom: 3rem; }
  }
</style>
