---
/**
 * CategoriasIndex.astro
 * Grid 4 columnas — cards blancas con imagen, botones en 2 col y badge.
 * Mismo patrón visual que CatalogoIndex (complemento aprobado).
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import Img from '../ui/Img.astro'

const categorias = [
  {
    titulo: 'Extintores',
    desc: 'Agente adecuado para cada riesgo: PQS, CO₂, AFFF, Tipo K, agente limpio y más.',
    img: '/imagenes/extintores/extintores-contra-incendios.jpg',
    alt: 'Extintores contra incendios certificados NOM-154-SCFI',
    href: '/extintores/',
    ctaLabel: 'Ver todos los extintores',
    badge: 'NOM-154',
    subcats: [
      { label: 'Polvo Seco (PQS)', href: '/extintores/polvo-seco/' },
      { label: 'CO₂', href: '/extintores/co2/' },
      { label: 'AFFF / Espuma', href: '/extintores/afff/' },
      { label: 'Tipo K — Cocinas', href: '/extintores/tipo-k/' },
      { label: 'Púrpura K', href: '/extintores/purpura-k/' },
      { label: 'Agua a Presión', href: '/extintores/agua-a-presion/' },
      { label: 'Cold Fire', href: '/extintores/cold-fire/' },
      { label: 'Automáticos', href: '/extintores/automaticos/' },
      { label: 'ABC Multiuso', href: '/extintores/abc/' },
      { label: 'Agente Limpio', href: '/extintores/agente-limpio/' },
    ],
  },
  {
    titulo: 'Equipo para Bomberos',
    desc: 'Línea profesional para brigadas y cuerpos de emergencia: trajes, ERA y rescate.',
    img: '/imagenes/equipo-bomberos/equipo-bomberos-hero.jpg',
    alt: 'Equipo para bomberos certificado NFPA 1971',
    href: '/equipo-bomberos/',
    ctaLabel: 'Ver equipo de bomberos',
    badge: 'NFPA 1971',
    subcats: [
      { label: 'Trajes Estructurales', href: '/equipo-bomberos/trajes/' },
      { label: 'Complementos de Uniforme', href: '/equipo-bomberos/complementos/' },
      { label: 'Respiración Autónoma (ERA)', href: '/equipo-bomberos/respiracion-autonoma/' },
      { label: 'Herramientas de Rescate', href: '/equipo-bomberos/herramientas/' },
      { label: 'Arneses de Rescate', href: '/equipo-bomberos/arneses/' },
    ],
  },
  {
    titulo: 'Señalamientos de Emergencia',
    desc: 'Fotoluminiscentes conforme a NOM-003-SEGOB y NOM-026-STPS, con plano incluido.',
    img: '/imagenes/senalamientos/senalamientos-hero.jpg',
    alt: 'Señalamientos de emergencia fotoluminiscentes NOM',
    href: '/senalamientos/',
    ctaLabel: 'Ver señalamientos',
    badge: 'NOM-003',
    subcats: [
      { label: 'Prohibición', href: '/senalamientos/prohibicion/' },
      { label: 'Obligación', href: '/senalamientos/obligacion/' },
      { label: 'Advertencia', href: '/senalamientos/advertencia/' },
      { label: 'Salvación / Evacuación', href: '/senalamientos/salvacion/' },
    ],
  },
  {
    titulo: 'Gabinetes y Porta Extintores',
    desc: 'Resguardo profesional para extintor, hidrante y equipo de bombero — acceso inmediato.',
    img: '/imagenes/gabinetes/gabinetes-extintores.jpg',
    alt: 'Gabinetes y porta extintores para empresas',
    href: '/gabinetes/',
    ctaLabel: 'Ver gabinetes',
    badge: 'NFPA 14',
    subcats: [
      { label: 'Para Extintor', href: '/gabinetes/para-extintor/' },
      { label: 'Porta Extintor Cenicero', href: '/gabinetes/porta-extintor-cenicero/' },
      { label: 'Para Bombero', href: '/gabinetes/para-bombero/' },
      { label: 'Para Hidrante', href: '/gabinetes/para-hidrante/' },
    ],
  },
  {
    titulo: 'Mangueras y Herrajes',
    desc: 'Conducción a alta presión con herrajes bronce — mangueras, chiflones, válvulas y siamesas.',
    img: '/imagenes/mangueras/mangueras-hero.jpg',
    alt: 'Mangueras contra incendio y herrajes para hidrantes',
    href: '/mangueras/',
    ctaLabel: 'Ver mangueras y herrajes',
    badge: 'NFPA 1961',
    subcats: [
      { label: 'Para Hidrante', href: '/mangueras/para-hidrante/' },
      { label: 'Chiflones', href: '/mangueras/chiflones/' },
      { label: 'Válvulas', href: '/mangueras/valvulas/' },
      { label: 'Adaptadores', href: '/mangueras/adaptadores/' },
      { label: 'Carretes', href: '/mangueras/carretes/' },
      { label: 'Toma Siamesa', href: '/mangueras/toma-siamesa/' },
      { label: 'Llaves de Herramienta', href: '/mangueras/llaves/' },
      { label: 'Monitores CI', href: '/mangueras/monitores/' },
    ],
  },
  {
    titulo: 'Sistemas Contra Incendio',
    desc: 'Detección, supresión y control automático — alarmas NFPA 72 y rociadores NFPA 13.',
    img: '/imagenes/sistemas/alarmas.jpg',
    alt: 'Sistemas contra incendio NFPA 13 y NFPA 72',
    href: '/sistemas/',
    ctaLabel: 'Ver sistemas CI',
    badge: 'NFPA 13/72',
    subcats: [
      { label: 'Alarmas y Detectores', href: '/sistemas/alarmas/' },
      { label: 'Detectores de Humo', href: '/sistemas/detectores/' },
      { label: 'Rociadores Automáticos', href: '/sistemas/rociadores/' },
      { label: 'Tableros FACP / NFPA 72', href: '/sistemas/tableros/' },
      { label: 'Redes Hidráulicas', href: '/sistemas/redes-hidraulicas/' },
    ],
  },
  {
    titulo: 'Primeros Auxilios',
    desc: 'Botiquines STPS, camillas, DEA y material de curación — con resurtido periódico.',
    img: '/imagenes/primeros-auxilios/botiquines-hero.jpg',
    alt: 'Botiquines de primeros auxilios STPS para empresas',
    href: '/primeros-auxilios/',
    ctaLabel: 'Ver primeros auxilios',
    badge: 'STPS',
    subcats: [
      { label: 'Botiquines STPS', href: '/primeros-auxilios/' },
      { label: 'Camillas de Emergencia', href: '/primeros-auxilios/' },
      { label: 'Collarines Cervicales', href: '/primeros-auxilios/' },
      { label: 'Material de Curación', href: '/primeros-auxilios/' },
    ],
  },
  {
    titulo: 'Equipo de Seguridad Industrial',
    desc: 'EPP completo ANSI y NOM-017-STPS: casco, visual, auditivo, respiratorio y alturas.',
    img: '/imagenes/equipo-seguridad/equipos-seguridad-hero.jpg',
    alt: 'Equipo de protección personal EPP industrial NOM-017-STPS',
    href: '/equipo-seguridad/',
    ctaLabel: 'Ver equipo de seguridad',
    badge: 'NOM-017',
    subcats: [
      { label: 'Cascos de Seguridad', href: '/equipo-seguridad/' },
      { label: 'Lentes de Protección', href: '/equipo-seguridad/' },
      { label: 'Chalecos Reflectantes', href: '/equipo-seguridad/' },
      { label: 'Protección Auditiva', href: '/equipo-seguridad/' },
      { label: 'Conos de Señalización', href: '/equipo-seguridad/' },
    ],
  },
]
---

<section class="categorias-index" id="categorias" aria-labelledby="cat-heading">
  <div class="container">

    <SectionHeaderDuo
      id="cat-heading"
      eyebrow="Catálogo completo"
      titleLine1="Ocho categorías,"
      titleLine2="un solo proveedor"
      desc="Organizadas por tipo de riesgo — para que no tengas que comprar extintor con uno y señalética con otro."
      bodyPara1="Concentramos en Proyecto Red toda la infraestructura de protección contra incendios que una empresa necesita para operar y pasar inspecciones. Desde extintores NOM-154-SCFI y señalamientos NOM-003-SEGOB, hasta sistemas NFPA 72, equipo para bomberos NFPA 1971 y EPP NOM-017-STPS. Cada categoría tiene su subcatálogo, precio de referencia y ficha técnica lista."
      bodyPara2="Resolvemos riesgos específicos: cocinas industriales, líquidos inflamables, centros de datos, almacenes, hospitales y edificios de uso mixto. Con un solo contacto cotizas, recibes, instalas y tienes la documentación lista para Protección Civil y STPS — sin peloteos entre tres proveedores para un mismo expediente."
    />

    <!-- Grid 4 columnas -->
    <div class="catidx-grid">
      {categorias.map((cat, i) => (
        <article class="ccard" aria-label={cat.titulo}>
          <!-- Imagen header -->
          <div class="ccard__header">
            <Img
              src={cat.img}
              alt={cat.alt}
              loading={i < 4 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
              width={640}
              height={360}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 320px"
            />
            <div class="ccard__header-overlay" aria-hidden="true"></div>
            {cat.badge && <span class="ccard__badge">{cat.badge}</span>}
          </div>

          <!-- Contenido -->
          <div class="ccard__content">
            <h3 class="ccard__title">{cat.titulo}</h3>
            <p class="ccard__desc">{cat.desc}</p>

            <ul class="ccard__list" aria-label={`Subcategorías de ${cat.titulo}`}>
              {cat.subcats.map(sub => (
                <li>
                  <a href={sub.href} class="ccard__link-btn">
                    {sub.label}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                  </a>
                </li>
              ))}
            </ul>

            <a href={cat.href} class="ccard__cta">
              {cat.ctaLabel}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .categorias-index {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-white, #fff);
  }

  /* ── GRID 4 COLUMNAS ──────────────────────────────── */
  .catidx-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  /* ── CARD ──────────────────────────────────────────── */
  .ccard {
    background: var(--c-white, #fff);
    border: 1px solid var(--c-border, #E4E4E7);
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* ── HEADER / IMAGEN ──────────────────────────────── */
  .ccard__header {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--c-ink, #111);
  }

  .ccard__header img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
  }

  .ccard__header-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      transparent 40%,
      rgba(0, 0, 0, 0.35) 100%
    );
    pointer-events: none;
  }

  /* Badge */
  .ccard__badge {
    position: absolute;
    top: 0.625rem;
    left: 0.625rem;
    display: inline-block;
    background: var(--c-primary, #C41E24);
    color: #fff;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    line-height: 1.3;
  }

  /* ── CONTENIDO ────────────────────────────────────── */
  .ccard__content {
    padding: 1.125rem 1.125rem 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ccard__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-ink, #111);
    letter-spacing: -0.02em;
    line-height: 1.25;
    padding-left: 0.625rem;
    border-left: 3px solid var(--c-primary, #C41E24);
  }

  .ccard__desc {
    font-size: 0.8125rem;
    color: var(--c-muted, #71717A);
    line-height: 1.45;
  }

  /* ── LISTA DE BOTONES (2 columnas) ──────────────────── */
  .ccard__list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.25rem;
    margin-top: 0.25rem;
  }

  .ccard__link-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.5rem 0.625rem;
    background: var(--c-surface, #F4F4F5);
    border: 1px solid transparent;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--c-ink-2, #27272A);
    text-decoration: none;
    line-height: 1.3;
  }

  .ccard__link-btn svg {
    flex-shrink: 0;
    opacity: 0;
    color: var(--c-primary, #C41E24);
  }

  .ccard__link-btn:hover {
    background: var(--c-primary-light, #F9E8E8);
    border-color: var(--c-primary, #C41E24);
    color: var(--c-primary, #C41E24);
    padding-left: 0.75rem;
  }

  .ccard__link-btn:hover svg {
    opacity: 1;
    transform: translateX(2px);
  }

  /* ── CTA ──────────────────────────────────────────── */
  .ccard__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--c-border, #E4E4E7);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-primary, #C41E24);
    text-decoration: none;
  }

  .ccard__cta:hover {
    color: var(--c-primary-dark, #A01820);
    gap: 0.6rem;
  }

  /* ── RESPONSIVE ───────────────────────────────────── */
  @media (max-width: 1200px) {
    .catidx-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 860px) {
    .catidx-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .catidx-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .ccard__content {
      padding: 1rem;
    }
  }
</style>
