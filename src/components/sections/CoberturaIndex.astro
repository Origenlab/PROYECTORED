---
/**
 * CoberturaIndex.astro
 * Cobertura por estado — 2 columnas con links de empresa por estado.
 * Encabezado: sidebar-header (clases compartidas en components.css).
 */

const estados = [
  { nombre: 'Ciudad de México',  href: '/empresas/cdmx/',            principal: true },
  { nombre: 'Estado de México',  href: '/empresas/edomex/',          principal: true },
  { nombre: 'Querétaro',         href: '/empresas/queretaro/',       principal: false },
  { nombre: 'Puebla',            href: '/empresas/puebla/',          principal: false },
  { nombre: 'Aguascalientes',    href: '/empresas/aguascalientes/',  principal: false },
  { nombre: 'Baja California',   href: '/empresas/baja-california/', principal: false },
]
---

<section class="cobertura-index" aria-labelledby="cobertura-heading">
  <div class="container cobertura-index__inner">

    <!-- Izquierda: texto -->
    <div class="cobertura-index__left">
      <p class="sidebar-header__eyebrow">Cobertura</p>
      <h2 id="cobertura-heading" class="sidebar-header__title">
        Entrega directa en<br>
        <span>toda la República</span>
      </h2>
      <p class="sidebar-header__desc">
        Nuestro centro de operaciones está en la Ciudad de México. Entregamos el mismo día
        en la zona metropolitana y coordinamos envíos a todo el país para pedidos de volumen.
        Cobertura comercial activa en seis estados.
      </p>
      <div class="cob-badges">
        <span class="cob-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          Entrega el mismo día en CDMX
        </span>
        <span class="cob-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Envíos nacionales disponibles
        </span>
        <span class="cob-badge">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Factura electrónica CFDI
        </span>
      </div>
    </div>

    <!-- Derecha: cards de estados -->
    <div class="cobertura-index__right" role="list" aria-label="Estados con cobertura de Proyecto Red">
      {estados.map(e => (
        <a
          href={e.href}
          class={`estado-card ${e.principal ? 'estado-card--principal' : ''}`}
          role="listitem"
          aria-label={`Equipos contra incendios en ${e.nombre}`}
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          <span class="estado-card__nombre">{e.nombre}</span>
          {e.principal && <span class="estado-card__tag">Operaciones</span>}
          <svg class="estado-card__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .cobertura-index {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-surface, #F4F4F5);
    border-top: 1px solid var(--c-border);
  }

  .cobertura-index__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  /* ── IZQUIERDA ────────────────────────────────────────── */
  .cob-badges {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .cob-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--c-ink-2);
  }

  .cob-badge svg { color: var(--c-primary); flex-shrink: 0; }

  /* ── DERECHA — ESTADOS ────────────────────────────────── */
  .cobertura-index__right {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--c-border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--c-white);
  }

  .estado-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--c-border);
    text-decoration: none;
    color: var(--c-ink);
    transition: background 0.15s;
  }

  .estado-card:last-child { border-bottom: none; }

  .estado-card:hover {
    background: var(--c-primary-light, #F9E8E8);
  }

  .estado-card svg:first-child {
    color: var(--c-primary);
    flex-shrink: 0;
  }

  .estado-card--principal .estado-card svg:first-child {
    color: var(--c-primary);
  }

  .estado-card__nombre {
    flex: 1;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--c-ink);
    letter-spacing: -.01em;
  }

  .estado-card__tag {
    font-size: 0.6875rem;
    font-weight: 700;
    background: var(--c-primary);
    color: #fff;
    padding: .175rem .5rem;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: .04em;
  }

  .estado-card__arrow {
    color: var(--c-muted);
    transition: transform 0.15s, color 0.15s;
    flex-shrink: 0;
  }

  .estado-card:hover .estado-card__arrow {
    color: var(--c-primary);
    transform: translateX(3px);
  }

  /* ── RESPONSIVE ───────────────────────────────────────── */
  @media (max-width: 1024px) {
    .cobertura-index__inner { grid-template-columns: 1fr; gap: 2.5rem; }
  }
</style>
