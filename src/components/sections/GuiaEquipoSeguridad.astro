---
/**
 * GuiaEquipoSeguridad.astro — v1
 * Guía de selección por tipo de industria — 4 escenarios.
 * Patrón 100% homologado con GuiaPrimerosAuxilios / GuiaSistemas.
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import Img from '../ui/Img.astro'
import { waUrl } from '../../config/site'
import '../../styles/pages.css'

const waHref = waUrl('Hola, necesito asesoría para seleccionar el EPP correcto para los puestos de trabajo de mi empresa')

const escenarios = [
  {
    img: '/imagenes/equipo-seguridad/cascos.jpg',
    badge: 'Construcción / Obra civil',
    norma: 'NOM-017-STPS',
    titulo: 'EPP Completo para Obra',
    desc: 'En obra civil el riesgo es múltiple: impacto en cabeza, partículas en ojos, ruido de maquinaria, riesgo de caída en alturas y calzado inadecuado para superficies irregulares. El EPP mínimo para obra incluye casco clase G, lentes de seguridad, tapones auditivos, calzado con casquillo y arnés para trabajos superiores a 1.80 m.',
    specs: [
      'Casco clase G con suspensión 6 puntos',
      'Lentes de seguridad policarbonato ANSI Z87',
      'Tapones auditivos NRR 29 dB',
      'Calzado casquillo acero + antiperforación',
    ],
  },
  {
    img: '/imagenes/equipo-seguridad/equipos-seguridad-hero.jpg',
    badge: 'Planta industrial / Manufactura',
    norma: 'NOM-017-STPS · NOM-011-STPS',
    titulo: 'EPP por Puesto de Trabajo',
    desc: 'En plantas industriales cada puesto tiene riesgos distintos: el operador de prensa no necesita el mismo EPP que el técnico de mantenimiento eléctrico. La NOM-017-STPS exige análisis de riesgo por puesto para determinar el equipo específico. El programa de EPP documentado es lo que verifica la STPS en auditorías — no solo que el equipo exista.',
    specs: [
      'Diagnóstico de riesgo por puesto de trabajo',
      'EPP específico por tipo de riesgo identificado',
      'Programa de EPP con lista y asignación por puesto',
      'Documentación para expediente STPS',
    ],
  },
  {
    img: '/imagenes/equipo-seguridad/chalecos.jpg',
    badge: 'Obras viales / Trabajo exterior',
    norma: 'ANSI 107 · NOM-017-STPS',
    titulo: 'Alta Visibilidad y Protección Climática',
    desc: 'Para trabajo en vialidades, patios de logística, aeropuertos y cualquier área donde circula maquinaria o vehículos, la visibilidad del trabajador es crítica. Los chalecos y ropa de alta visibilidad clase 2 (fondo de día) y clase 3 (máxima visibilidad) siguen la norma ANSI 107. La diferencia entre clase 2 y 3 puede ser la diferencia entre ser visto y no serlo.',
    specs: [
      'Chaleco reflectivo clase 2 — operaciones generales',
      'Chaleco clase 3 — vialidades de alta velocidad',
      'Overall FR alta visibilidad — zonas de arco eléctrico',
      'Impermeable reflectivo para trabajo nocturno',
    ],
  },
  {
    img: '/imagenes/equipo-seguridad/tapones-auditivos.jpg',
    badge: 'Mantenimiento eléctrico / Alta tensión',
    norma: 'NOM-029-STPS · NFPA 70E',
    titulo: 'EPP para Riesgo Eléctrico',
    desc: 'El trabajo eléctrico requiere EPP específico que no puede sustituirse con equipo genérico. El guante dieléctrico tiene clase según el voltaje de trabajo. El casco debe ser clase E. El calzado debe ser EH (Electrical Hazard). Para arco eléctrico, la ropa debe ser FR (flame resistant) con la calificación ATPV en cal/cm² suficiente para el nivel de energía del sistema.',
    specs: [
      'Casco clase E — hasta 20,000V',
      'Guante dieléctrico clase 0–4 según voltaje',
      'Calzado EH sin partes metálicas conductoras',
      'Ropa FR con calificación ATPV para arco eléctrico',
    ],
  },
]
---

<section class="guia-es" id="guia-epp" aria-labelledby="guia-es-heading">
  <div class="container">

    <SectionHeaderDuo
      id="guia-es-heading"
      eyebrow="Guía por tipo de industria"
      titleLine1="El EPP Correcto para"
      titleLine2="Cada Tipo de Riesgo"
      desc="Construcción, planta industrial, obra vial o trabajo eléctrico — cada entorno exige equipo específico. Aquí está la selección técnica para cada caso."
      bodyPara1="El error más común en EPP es comprar equipo genérico para todos los puestos. La NOM-017-STPS no acepta eso: exige análisis de riesgo por puesto y EPP seleccionado específicamente para los riesgos identificados. Un trabajador de mantenimiento eléctrico con guantes de cuero genéricos no está protegido — aunque use guantes."
      bodyPara2="Hacemos la selección técnica por puesto de trabajo para tu empresa: identificamos los riesgos, determinamos el EPP correcto, especificamos la norma aplicable y entregamos el programa de EPP documentado para tus expedientes STPS."
    />

    <div class="guia-es-grid">
      {escenarios.map((e, i) => (
        <article class="guia-card">
          <div class="guia-card__img-wrap">
            <Img
              src={e.img}
              alt={`EPP para ${e.badge} — equipo seguridad industrial Proyecto Red`}
              width={560}
              height={320}
              loading={i < 2 ? 'eager' : 'lazy'}
            />
            <span class="guia-card__badge">{e.badge}</span>
            <span class="guia-card__norma">{e.norma}</span>
          </div>
          <div class="guia-card__body">
            <h3 class="guia-card__title">{e.titulo}</h3>
            <p class="guia-card__desc">{e.desc}</p>
            <ul class="guia-card__specs">
              {e.specs.map(s => <li>{s}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <div class="guia-cta-bar">
      <div class="guia-cta-bar__text">
        <strong>¿Necesitas EPP con diagnóstico de riesgo por puesto?</strong>
        <span>Analizamos los puestos de trabajo de tu empresa, determinamos el EPP correcto para cada riesgo y entregamos el programa documentado para STPS.</span>
      </div>
      <a href={waHref} class="btn-primary" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Diagnóstico EPP por puesto de trabajo
      </a>
    </div>

  </div>
</section>

<style>
  .guia-es {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-surface, #F4F4F5);
    border-top: 1px solid var(--c-border);
  }

  .guia-es-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  @media (max-width: 900px) { .guia-es-grid { grid-template-columns: 1fr; } }
</style>
