import FaqCotizacion from '../FaqCotizacion.astro'

const faqsCobertura = [
  {
    pregunta: '¿Entregan equipos contra incendios el mismo día en CDMX?',
    respuesta: 'Sí. Pedidos confirmados <strong>antes de las 2 PM</strong> se entregan el mismo día en toda la Ciudad de México (16 alcaldías). Para el Estado de México, la entrega es en <strong>24-48 horas</strong> dependiendo del municipio. Todo con logística propia — sin depender de paqueterías.',
  },
  {
    pregunta: '¿Tienen cobertura en todo el Estado de México?',
    respuesta: 'Cubrimos directamente los municipios más industrializados: <strong>Naucalpan, Tlalnepantla, Ecatepec, Cuautitlán Izcalli, Toluca, Lerma, Atizapán, Texcoco y Huixquilucan</strong>. Para municipios fuera de esta lista coordinamos la entrega en la cotización — normalmente 48-72 horas.',
