---
/**
 * CatalogoMangueras.astro — v1
 * Catálogo de 8 productos de mangueras y herrajes — patrón .ccard estándar.
 * Nav sticky + SectionHeaderDuo + .ccard grid (4 cols).
 * 100% homologado con CatalogoGabinetes / CatalogoExtintores.
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import Img from '../ui/Img.astro'
import { waUrl } from '../../config/site'
import '../../styles/pages.css'

const waHref = waUrl('Hola, quiero cotizar mangueras y herrajes contra incendio para mi sistema')

const productos = [
  {
    nombre: 'Mangueras para Hidrante',
    desc: 'Fibra sintética con forro de hule para sistemas de hidrantes en edificios, plantas y naves. Presión de trabajo hasta 300 PSI. Prueba hidrostática incluida antes de entrega.',
    img: '/imagenes/mangueras/mangueras-hero.jpg',
    badge: 'NFPA 1961',
    href: '/mangueras/para-hidrante/',
    ctaLabel: 'Ver mangueras para hidrante',
    subcats: [
      { label: 'Diámetro 1.5" — edificios residenciales', href: '/mangueras/para-hidrante/' },
      { label: 'Diámetro 2.5" — estándar industrial', href: '/mangueras/para-hidrante/' },
      { label: 'Diámetro 4" — bomberos y alto caudal', href: '/mangueras/para-hidrante/' },
      { label: 'Longitudes 15, 20 y 30 metros', href: '/mangueras/para-hidrante/' },
      { label: 'Jacket doble · 300 PSI', href: '/mangueras/para-hidrante/' },
    ],
  },
  {
    nombre: 'Chiflones y Boquillas',
    desc: 'Controlan el patrón de descarga: chorro directo para penetración, niebla para protección y combinado para versatilidad. Compatibles con diámetro de la manguera.',
    img: '/imagenes/mangueras/chiflon.jpg',
    badge: 'NFPA 1964',
    href: '/mangueras/chiflones/',
    ctaLabel: 'Ver chiflones y boquillas',
    subcats: [
      { label: 'Chorro directo — máxima penetración', href: '/mangueras/chiflones/' },
      { label: 'Niebla — protección personal', href: '/mangueras/chiflones/' },
      { label: 'Combinado — chorro + niebla', href: '/mangueras/chiflones/' },
      { label: 'Aluminio y bronce · 95-250 GPM', href: '/mangueras/chiflones/' },
      { label: 'Para 1.5" y 2.5"', href: '/mangueras/chiflones/' },
    ],
  },
  {
    nombre: 'Válvulas de Control',
    desc: 'Regulan y dirigen el flujo de agua en la red hidráulica. Angulares para gabinetes, de compuerta para redes principales, check para evitar retorno y de alivio para proteger tuberías.',
    img: '/imagenes/mangueras/valvulas.jpg',
    badge: null,
    href: '/mangueras/valvulas/',
    ctaLabel: 'Ver válvulas de control',
    subcats: [
      { label: 'Angular 2½" — para gabinetes de hidrante', href: '/mangueras/valvulas/' },
      { label: 'Compuerta — redes principales', href: '/mangueras/valvulas/' },
      { label: 'Check — evita retorno de agua', href: '/mangueras/valvulas/' },
      { label: 'Alivio — protege tubería de sobrepresión', href: '/mangueras/valvulas/' },
      { label: 'Bronce e hierro dúctil', href: '/mangueras/valvulas/' },
    ],
  },
  {
    nombre: 'Adaptadores y Conexiones',
    desc: 'Acoplan mangueras de diferente diámetro o rosca. Indispensables cuando el equipo de bomberos tiene un acople diferente al de tu sistema. NST y Storz son los estándares en México.',
    img: '/imagenes/mangueras/adaptadores.jpg',
    badge: null,
    href: '/mangueras/adaptadores/',
    ctaLabel: 'Ver adaptadores y conexiones',
    subcats: [
      { label: 'NST (rosca estándar México)', href: '/mangueras/adaptadores/' },
      { label: 'Storz (cuarto de giro, sin rosca)', href: '/mangueras/adaptadores/' },
      { label: 'NST a Storz — compatibilidad total', href: '/mangueras/adaptadores/' },
      { label: 'Reducciones de diámetro', href: '/mangueras/adaptadores/' },
      { label: 'Aluminio, bronce y fundición', href: '/mangueras/adaptadores/' },
    ],
  },
  {
    nombre: 'Carretes Porta Manguera',
    desc: 'Enrollan y protegen la manguera para acceso inmediato. Fijos de pared, pivotantes (giro 180°) o con gabinete integrado. Cada piso de un edificio con hidrantes necesita uno.',
    img: '/imagenes/mangueras/carrete-manguera.jpg',
    badge: null,
    href: '/mangueras/carretes/',
    ctaLabel: 'Ver carretes porta manguera',
    subcats: [
      { label: 'De pared — fijo, más económico', href: '/mangueras/carretes/' },
      { label: 'Pivotante — giro 180° para mejor acceso', href: '/mangueras/carretes/' },
      { label: 'Con gabinete integrado — ahorra espacio', href: '/mangueras/carretes/' },
      { label: 'Capacidad para 30 m de manguera', href: '/mangueras/carretes/' },
      { label: 'Para 1.5" y 2.5"', href: '/mangueras/carretes/' },
    ],
  },
  {
    nombre: 'Toma Siamesa',
    desc: 'Conexión exterior que permite a los bomberos alimentar tu sistema hidráulico desde su camión cisterna. Obligatoria en edificios con rociadores o red de hidrantes. Se instala en fachada.',
    img: '/imagenes/mangueras/toma-siamesa.jpg',
    badge: 'Obligatoria',
    href: '/mangueras/toma-siamesa/',
    ctaLabel: 'Ver toma siamesa',
    subcats: [
      { label: '2×2½" NST — estándar México', href: '/mangueras/toma-siamesa/' },
      { label: 'Hierro fundido con acabado rojo', href: '/mangueras/toma-siamesa/' },
      { label: 'Válvulas check integradas', href: '/mangueras/toma-siamesa/' },
      { label: 'Tapones con cadena incluidos', href: '/mangueras/toma-siamesa/' },
      { label: 'Instalación en fachada exterior', href: '/mangueras/toma-siamesa/' },
    ],
  },
  {
    nombre: 'Llaves Spanner',
    desc: 'Herramientas para conectar y desconectar acoples rápidamente bajo presión. Cada gabinete de manguera debe tener una — sin llave, el bombero pierde segundos críticos.',
    img: '/imagenes/mangueras/llaves.jpg',
    badge: null,
    href: '/mangueras/llaves/',
    ctaLabel: 'Ver llaves spanner',
    subcats: [
      { label: 'Universal para NST 1.5"', href: '/mangueras/llaves/' },
      { label: 'Universal para NST 2.5"', href: '/mangueras/llaves/' },
      { label: 'Aluminio forjado — ligera y resistente', href: '/mangueras/llaves/' },
      { label: 'Incluye cadena de retención', href: '/mangueras/llaves/' },
      { label: 'Se incluye en gabinetes para bombero', href: '/mangueras/llaves/' },
    ],
  },
  {
    nombre: 'Monitores Contra Incendio',
    desc: 'Cañones fijos o portátiles para descarga masiva de agua. Para patios de tanques, estacionamientos industriales y zonas de alto riesgo donde la manguera manual no tiene el alcance ni el caudal.',
    img: '/imagenes/mangueras/mangueras-hero.jpg',
    badge: 'Industrial',
    href: '/mangueras/monitores/',
    ctaLabel: 'Ver monitores contra incendio',
    subcats: [
      { label: '500 GPM — mediano caudal', href: '/mangueras/monitores/' },
      { label: '1000-2000 GPM — alto caudal industrial', href: '/mangueras/monitores/' },
      { label: 'Fijo en estructura o portátil', href: '/mangueras/monitores/' },
      { label: 'Bronce o acero inoxidable', href: '/mangueras/monitores/' },
      { label: 'Distribuidor Elkhart Brass', href: '/mangueras/monitores/' },
    ],
  },
]
---

<section class="catalogo-mangueras cat-section cat-section--white" id="catalogo-mangueras" aria-labelledby="catalogo-man-heading">
  <div class="container">

    <SectionHeaderDuo
      id="catalogo-man-heading"
      eyebrow="Sistema hidráulico NFPA"
      titleLine1="8 Productos para tu Sistema"
      titleLine2="de Mangueras Contra Incendio"
      desc="Mangueras, chiflones, válvulas, adaptadores, carretes, toma siamesa, llaves y monitores. Todo el sistema en un solo proveedor."
      bodyPara1="Un sistema hidráulico contra incendio no es solo la manguera — es la combinación correcta de manguera, chiflón, válvula, adaptadores y carrete, todos compatibles entre sí y con el equipo de los bomberos de tu municipio. Comprar componentes de distintos proveedores sin verificar compatibilidad resulta en sistemas que no funcionan en emergencia."
    />

    <!-- Grid de cards — patrón .ccard homologado con L1/L2/L3 -->
    <div class="catidx-grid" role="list" aria-label="Productos de mangueras y sistemas disponibles">
      {productos.map((p, i) => (
        <article class="ccard" role="listitem" aria-label={p.nombre}>
          <div class="ccard__header">
            <Img
              src={p.img}
              alt={p.nombre}
              loading={i < 4 ? 'eager' : 'lazy'}
              fetchpriority={i === 0 ? 'high' : undefined}
              width={640}
              height={360}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 320px"
            />
            <div class="ccard__header-overlay" aria-hidden="true"></div>
            {p.badge && <span class="ccard__badge">{p.badge}</span>}
          </div>
          <div class="ccard__content">
            <h3 class="ccard__title">{p.nombre}</h3>
            <p class="ccard__desc">{p.desc}</p>

            {p.subcats && p.subcats.length > 0 && (
              <ul class="ccard__list" aria-label={`Modelos de ${p.nombre}`}>
                {p.subcats.map(sub => (
                  <li>
                    <a href={sub.href} class="ccard__link-btn">
                      {sub.label}
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
                    </a>
                  </li>
                ))}
              </ul>
            )}

            <a href={p.href} class="ccard__cta">
              {p.ctaLabel || 'Ver detalles'}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}

      <!-- Card CTA WhatsApp -->
      <article class="ccard ccard--cta-wa" aria-label="Asesoría para sistema de mangueras">
        <a
          href={waHref}
          class="ccard--cta-wa__inner"
          target="_blank"
          rel="noopener noreferrer"
        >
          <div class="ccard--cta-wa__icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <p class="ccard--cta-wa__title">¿Sistema completo o componente de reemplazo?</p>
          <p class="ccard--cta-wa__sub">Cotizamos paquete completo piso por piso con compatibilidad garantizada, o vendemos piezas sueltas para reemplazar lo que ya tienes.</p>
          <span class="ccard--cta-wa__btn">Asesoría por WhatsApp →</span>
        </a>
      </article>
    </div>

  </div>
</section>

