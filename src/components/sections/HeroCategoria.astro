---
/**
 * HeroCategoria.astro
 * Hero premium L2: badge + H1 + subtítulo izq / 2 párrafos SEO der.
 * Gradiente oscuro, glow rojo, grid sutil de fondo.
 *
 * Sustituye a los 8 antiguos clones Hero{Extintores,Bomberos,...}.astro.
 * Contenido por categoría: src/data/heroes-categorias.ts
 * Uso:  <HeroCategoria {...HERO_CATEGORIAS['extintores']} />
 */
import type { HeroCategoriaConfig } from '../../data/heroes-categorias'

type Props = HeroCategoriaConfig

const { ariaLabel, badge, h1Html, subHtml, rightHtml } = Astro.props
---

<section class="hero-categoria" aria-label={ariaLabel}>

  <div class="hero-categoria__glow" aria-hidden="true"></div>
  <div class="hero-categoria__grid-bg" aria-hidden="true"></div>

  <div class="container hero-categoria__grid">

    <!-- ═══ Columna izquierda: badge + H1 + subtítulo ═══ -->
    <div class="hero-categoria__left">

      <div class="hero-categoria__badge" aria-hidden="true">
        <span class="badge-pulse"></span>
        <span class="badge-pulse-ring"></span>
        {badge}
      </div>

      <h1 class="hero-categoria__h1" set:html={h1Html}></h1>

      <p class="hero-categoria__sub" set:html={subHtml}></p>

    </div>

    <!-- ═══ Columna derecha: texto SEO ═══ -->
    <div class="hero-categoria__right">
      {rightHtml.map(p => <p set:html={p}></p>)}
    </div>

  </div>
</section>

<style>
  /* ═══════════════════════════════════════════════════════
     HERO CATEGORÍA — patrón L2 canónico (ex HeroExtintores)
     Nota: el contenido llega vía set:html, por eso los
     selectores de elementos inyectados usan :global().
     ═══════════════════════════════════════════════════════ */

  .hero-categoria {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background:
      linear-gradient(160deg, #080808 0%, #130A0A 40%, #1A0D0D 60%, #0A0A0A 100%);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .hero-categoria__glow {
    position: absolute;
    width: 700px;
    height: 700px;
    top: -20%;
    right: -10%;
    background: radial-gradient(circle, rgba(196,30,36,0.15) 0%, rgba(196,30,36,0.05) 40%, transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }

  .hero-categoria__grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 30%, transparent 70%);
    pointer-events: none;
  }

  .hero-categoria__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-categoria__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(196,30,36,0.4);
    background: rgba(196,30,36,0.08);
    color: rgba(255,255,255,0.85);
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.375rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    letter-spacing: .01em;
    position: relative;
    backdrop-filter: blur(8px);
  }

  .badge-pulse {
    width: 7px;
    height: 7px;
    background: var(--c-primary);
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
  }

  .badge-pulse-ring {
    position: absolute;
    left: 0.9375rem;
    top: 50%;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-primary);
    transform: translateY(-50%);
    pointer-events: none;
  }

  .hero-categoria__h1 {
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -.035em;
    margin-bottom: 1.25rem;
  }

  .hero-categoria__h1 :global(.h1-accent) { color: var(--c-primary); }

  .hero-categoria__sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    max-width: 52ch;
  }

  .hero-categoria__sub :global(strong) {
    color: rgba(255,255,255,0.9);
    font-weight: 700;
  }

  .hero-categoria__right :global(p) {
    color: rgba(255,255,255,0.55);
    font-size: 0.9375rem;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .hero-categoria__right :global(p:last-child) { margin-bottom: 0; }

  @media (max-width: 1024px) {
    .hero-categoria { padding-top: 3.5rem; padding-bottom: 3.5rem; }
    .hero-categoria__grid { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  @media (max-width: 768px) {
    .hero-categoria { padding-bottom: 3rem; }
  }
</style>
