---
/**
 * HeroIndex.astro
 * Hero principal — izq: H1 + CTAs / der: diferenciadores visuales + normas
 */
import { CONTACT, waUrl, WA_MESSAGES } from '../../config/site'

const waHref = waUrl(WA_MESSAGES.cotizacion)
---

<section class="hero-index" aria-label="Equipos contra incendios en CDMX">
  <div class="container hero-index__grid">

    <!-- ── Columna izquierda ── -->
    <div class="hero-index__left">

      <div class="hero-badge" aria-hidden="true">
        <span class="badge-pulse"></span>
        Proveedor directo · CDMX y Estado de México
      </div>

      <h1 class="hero-index__h1">
        Venta de Equipos<br>
        Contra <span class="h1-accent">Incendios</span><br>
        <span class="h1-sub">Certificados</span>
      </h1>

      <p class="hero-index__sub">
        Extintores, señalización NOM, sistemas de detección y supresión.
        Entrega directa en CDMX — sin intermediarios, con asesoría técnica incluida.
      </p>

      <div class="hero-index__ctas">
        <a
          href={waHref}
          class="hero-btn hero-btn--primary"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Solicitar cotización por WhatsApp"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Cotización gratis
        </a>
        <a href="/productos/" class="hero-btn hero-btn--ghost">
          Ver catálogo
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>

      <!-- Contacto directo -->
      <div class="hero-contact">
        <a href={`tel:${CONTACT.phoneRaw}`} class="hero-contact__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92v2z"/>
          </svg>
          {CONTACT.phone}
        </a>
        <span class="hero-contact__sep">·</span>
        <span class="hero-contact__item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
          </svg>
          Lun–Vie 8:00–18:00
        </span>
      </div>

    </div>

    <!-- ── Columna derecha: diferenciadores visuales ── -->
    <div class="hero-index__right">

      <!-- Card principal de diferenciadores -->
      <div class="hero-card">
        <p class="hero-card__label">¿Por qué Proyecto Red?</p>
        <ul class="hero-features">
          <li class="hero-feature">
            <span class="hero-feature__icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <div>
              <strong>Proveedor directo, sin intermediarios</strong>
              <span>Precios competitivos y entrega el mismo día en CDMX</span>
            </div>
          </li>
          <li class="hero-feature">
            <span class="hero-feature__icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <div>
              <strong>Catálogo completo en un solo lugar</strong>
              <span>Extintores, señalización, sistemas, mantenimiento y más</span>
            </div>
          </li>
          <li class="hero-feature">
            <span class="hero-feature__icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <div>
              <strong>Documentación para Protección Civil</strong>
              <span>Certificados, fichas técnicas y constancias DC-3 incluidas</span>
            </div>
          </li>
          <li class="hero-feature">
            <span class="hero-feature__icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            <div>
              <strong>Asesoría técnica gratuita</strong>
              <span>Diagnóstico sin costo, recomendaciones según tu industria</span>
            </div>
          </li>
        </ul>

        <!-- Badges de normas -->
        <div class="hero-normas">
          <span class="norma-badge">NOM-154-SCFI</span>
          <span class="norma-badge">NFPA 72</span>
          <span class="norma-badge">NFPA 20</span>
          <span class="norma-badge">NOM-026-STPS</span>
          <span class="norma-badge">NOM-003-SEGOB</span>
        </div>
      </div>

    </div>

  </div>
</section>

<!-- ── Barra de estadísticas ── -->
<div class="hero-index__stats" role="list" aria-label="Estadísticas de Proyecto Red">
  <div class="container hero-index__stats-inner">
    <div class="stat-item" role="listitem">
      <span class="stat-valor">+50</span>
      <span class="stat-label">Productos certificados</span>
    </div>
    <div class="stat-item" role="listitem">
      <span class="stat-valor">8</span>
      <span class="stat-label">Categorías de equipo</span>
    </div>
    <div class="stat-item" role="listitem">
      <span class="stat-valor">6</span>
      <span class="stat-label">Estados con cobertura</span>
    </div>
    <div class="stat-item" role="listitem">
      <span class="stat-valor">24 h</span>
      <span class="stat-label">Cotización garantizada</span>
    </div>
  </div>
</div>

<style>
  /* ── HERO ──────────────────────────────────────────────── */
  .hero-index {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background:
      radial-gradient(ellipse 55% 65% at 75% 50%, rgba(196,30,36,.13) 0%, transparent 65%),
      linear-gradient(160deg, #0A0A0A 0%, #160A0A 50%, #0A0A0A 100%);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  /* Líneas de fondo sutil */
  .hero-index::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .hero-index__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── BADGE ──────────────────────────────────────────────── */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(196,30,36,.45);
    background: rgba(196,30,36,.1);
    color: rgba(255,255,255,.85);
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.3125rem 0.875rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    letter-spacing: .01em;
  }

  .badge-pulse {
    width: 7px;
    height: 7px;
    background: var(--c-primary);
    border-radius: 50%;
    flex-shrink: 0;
    box-shadow: 0 0 0 2px rgba(196,30,36,.3);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 2px rgba(196,30,36,.3); }
    50%       { box-shadow: 0 0 0 5px rgba(196,30,36,.0); }
  }

  /* ── TIPOGRAFÍA H1 ──────────────────────────────────────── */
  .hero-index__h1 {
    font-size: clamp(2.5rem, 4.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -.03em;
    margin-bottom: 1.25rem;
  }

  .h1-accent {
    color: var(--c-primary);
  }

  .h1-sub {
    font-size: clamp(1.5rem, 2.5vw, 2.25rem);
    font-weight: 400;
    color: rgba(255,255,255,.45);
    letter-spacing: -.01em;
  }

  /* ── SUBTÍTULO ──────────────────────────────────────────── */
  .hero-index__sub {
    font-size: 1.0625rem;
    color: rgba(255,255,255,.6);
    line-height: 1.65;
    margin-bottom: 2.25rem;
    max-width: 50ch;
  }

  /* ── BOTONES ────────────────────────────────────────────── */
  .hero-index__ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8125rem 1.625rem;
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.18s;
  }

  .hero-btn--primary {
    background: var(--c-primary);
    color: #fff;
    border: 2px solid var(--c-primary);
  }
  .hero-btn--primary:hover {
    background: var(--c-primary-dark);
    border-color: var(--c-primary-dark);
    color: #fff;
  }

  .hero-btn--ghost {
    background: transparent;
    color: rgba(255,255,255,.85);
    border: 2px solid rgba(255,255,255,.25);
  }
  .hero-btn--ghost:hover {
    border-color: rgba(255,255,255,.6);
    color: #fff;
    background: rgba(255,255,255,.06);
  }

  /* ── CONTACTO DIRECTO ───────────────────────────────────── */
  .hero-contact {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .hero-contact__item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.8125rem;
    color: rgba(255,255,255,.45);
    text-decoration: none;
    transition: color .15s;
  }

  a.hero-contact__item:hover { color: rgba(255,255,255,.8); }

  .hero-contact__sep {
    color: rgba(255,255,255,.2);
    font-size: 1rem;
  }

  /* ── CARD DIFERENCIADORES ───────────────────────────────── */
  .hero-card {
    background: rgba(255,255,255,.04);
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 12px;
    padding: 1.75rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hero-card__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: rgba(255,255,255,.35);
    margin-bottom: 1.25rem;
  }

  /* ── LISTA DE CARACTERÍSTICAS ───────────────────────────── */
  .hero-features {
    list-style: none;
    margin: 0 0 1.5rem;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .hero-feature {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
  }

  .hero-feature__icon {
    width: 26px;
    height: 26px;
    background: rgba(196,30,36,.2);
    border: 1px solid rgba(196,30,36,.4);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FF6B6B;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .hero-feature div {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .hero-feature strong {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgba(255,255,255,.9);
    line-height: 1.3;
  }

  .hero-feature span {
    font-size: 0.8125rem;
    color: rgba(255,255,255,.45);
    line-height: 1.4;
  }

  /* ── BADGES DE NORMAS ───────────────────────────────────── */
  .hero-normas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(255,255,255,.08);
  }

  .norma-badge {
    display: inline-block;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    color: rgba(255,255,255,.55);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: .05em;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
  }

  /* ── BARRA DE ESTADÍSTICAS ──────────────────────────────── */
  .hero-index__stats {
    background: var(--c-primary);
    padding: 1.75rem 0;
  }

  .hero-index__stats-inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 0.75rem 1rem;
    border-right: 1px solid rgba(255,255,255,.2);
  }
  .stat-item:last-child { border-right: none; }

  .stat-valor {
    font-size: 1.875rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -.04em;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.8125rem;
    color: rgba(255,255,255,.75);
    font-weight: 500;
    line-height: 1.3;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .hero-index__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hero-index__stats-inner {
      grid-template-columns: repeat(2, 1fr);
    }
    .stat-item:nth-child(2) { border-right: none; }
    .stat-item:nth-child(3) { border-top: 1px solid rgba(255,255,255,.2); }
    .hero-index { padding-top: 3rem; }
  }

  @media (max-width: 768px) {
    .hero-index__ctas { flex-direction: column; align-items: flex-start; }
    .hero-index { padding-bottom: 3rem; }
  }

  @media (max-width: 480px) {
    .hero-index__stats-inner { grid-template-columns: repeat(2, 1fr); }
    .hero-card { padding: 1.25rem; }
  }
</style>
