---
/**
 * FaqCategoria.astro
 * FAQ de categoría + tarjeta de cotización sticky (patrón L2 homologado).
 *
 * Sustituye a los 8 antiguos clones Faq{Extintores,Bomberos,Gabinetes,
 * Mangueras,Senalamientos,Sistemas,PrimerosAuxilios,EquipoSeguridad}.astro.
 *
 * Contenido por categoría: src/data/faqs-categorias.ts
 * Uso:  <FaqCategoria {...FAQ_CATEGORIAS['gabinetes']} />
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import { CONTACT } from '../../config/site'
import type { FaqCategoriaConfig } from '../../data/faqs-categorias'

type Props = FaqCategoriaConfig

const {
  id,
  badge,
  header,
  faqs,
  form,
  wa,
  colTitle = 'Lo que preguntan nuestros clientes',
  colTextBefore = '¿Tienes una duda específica? Escríbenos al ',
  colTextAfter = ' — respondemos en menos de 24 horas.',
} = Astro.props

const {
  empresaLabel = 'Empresa o negocio',
  empresaPlaceholder = 'Nombre de tu empresa',
  detalleLabel = 'Cuéntanos más (opcional)',
} = form

// Configuración que consume el script del botón de WhatsApp (ver <script> abajo)
const waConfig = JSON.stringify({
  message: wa.message,
  tipoMsgLabel: wa.tipoMsgLabel,
  empresaMsgLabel: wa.empresaMsgLabel ?? '🏢 Empresa',
  whatsapp: CONTACT.whatsapp,
})
---

<section
  class="faq-categoria"
  id={`faq-${id}`}
  aria-labelledby={`faq-${id}-heading`}
  data-wa-config={waConfig}
>
  <div class="container">

    <SectionHeaderDuo
      id={`faq-${id}-heading`}
      eyebrow="Preguntas Frecuentes"
      titleLine1={header.titleLine1}
      titleLine2={header.titleLine2}
      desc={header.desc}
      bodyPara1={header.bodyPara1}
    />

    <div class="faq-categoria-grid">

      <!-- ── Columna FAQ ── -->
      <div class="faq-col" aria-labelledby="faq-col-heading">
        <div class="faq-col__top">
          <span class="faq-col__badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            {badge}
          </span>
          <h3 id="faq-col-heading">{colTitle}</h3>
          <p>{colTextBefore}<a href={`https://wa.me/${CONTACT.whatsapp}`} target="_blank" rel="noopener noreferrer">WhatsApp {CONTACT.phone}</a>{colTextAfter}</p>
        </div>

        <div class="faq-items">
          {faqs.map(f => (
            <details class="faq-item" itemscope itemtype="https://schema.org/Question">
              <summary>
                <span itemprop="name">{f.q}</span>
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div class="faq-answer" itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                <p itemprop="text" set:html={f.a}></p>
              </div>
            </details>
          ))}
        </div>
      </div>

      <!-- ── Columna Cotización ── -->
      <div class="cot-col">
        <div class="cot-card">
          <div class="cot-card__head">
            <span class="cot-badge">Cotización Gratuita</span>
            <h3>Solicita tu cotización</h3>
            <p>Respuesta en menos de 24 horas. Sin compromiso.</p>
          </div>

          <div class="cot-card__body">
            <div class="cot-field">
              <label for={`cot-${id}-nombre`}>Nombre completo *</label>
              <input type="text" id={`cot-${id}-nombre`} name="nombre" placeholder="Tu nombre completo" autocomplete="name" />
            </div>
            <div class="cot-field">
              <label for={`cot-${id}-tel`}>Teléfono *</label>
              <input type="tel" id={`cot-${id}-tel`} name="tel" placeholder="55 1234 5678" autocomplete="tel" />
            </div>
            <div class="cot-field">
              <label for={`cot-${id}-empresa`}>{empresaLabel}</label>
              <input type="text" id={`cot-${id}-empresa`} name="empresa" placeholder={empresaPlaceholder} autocomplete="organization" />
            </div>
            <div class="cot-field">
              <label for={`cot-${id}-tipo`}>{form.tipoLabel}</label>
              <select id={`cot-${id}-tipo`} name="tipo">
                <option value="" disabled selected>{form.tipoPlaceholder}</option>
                {form.tipoOptions.map(o => <option>{o}</option>)}
              </select>
            </div>
            <div class="cot-field">
              <label for={`cot-${id}-detalle`}>{detalleLabel}</label>
              <textarea id={`cot-${id}-detalle`} name="detalle" rows="3" placeholder={form.detallePlaceholder}></textarea>
            </div>
          </div>

          <div class="cot-card__footer">
            <a
              href={`https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent(wa.message)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="cot-btn"
              role="button"
              aria-label={wa.ariaLabel}
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              {wa.btnLabel}
            </a>
            <p class="cot-note">{wa.note}</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  // Arma el mensaje de WhatsApp con los datos capturados en la tarjeta.
  // La configuración por categoría viaja en data-wa-config (JSON).
  document.querySelectorAll<HTMLElement>('.faq-categoria').forEach((section) => {
    const cfg = JSON.parse(section.dataset.waConfig || '{}')
    const btn = section.querySelector<HTMLAnchorElement>('.cot-btn')

    btn?.addEventListener('click', (e) => {
      e.preventDefault()
      const val = (name: string) =>
        (section.querySelector(`[name="${name}"]`) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement | null)
          ?.value.trim() ?? ''

      const nombre  = val('nombre')
      const tel     = val('tel')
      const empresa = val('empresa')
      const tipo    = val('tipo')
      const detalle = val('detalle')

      let msg = `${cfg.message}.`
      if (nombre)  msg += `\n\n👤 Nombre: ${nombre}`
      if (tel)     msg += `\n📞 Teléfono: ${tel}`
      if (empresa) msg += `\n${cfg.empresaMsgLabel}: ${empresa}`
      if (tipo)    msg += `\n${cfg.tipoMsgLabel}: ${tipo}`
      if (detalle) msg += `\n📝 Detalle: ${detalle}`

      window.open(`https://wa.me/${cfg.whatsapp}?text=${encodeURIComponent(msg)}`, '_blank')
    })
  })
</script>

<style>
  .faq-categoria {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-surface, #F4F4F5);
    border-top: 1px solid var(--c-border);
  }

  .faq-categoria-grid {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: 4rem;
    align-items: start;
  }

  /* ── FAQ COLUMN ───────────────────────────────────────── */
  .faq-col__top {
    margin-bottom: 2rem;
  }

  .faq-col__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: var(--c-white);
    border: 1px solid var(--c-border);
    color: var(--c-ink-2);
    font-size: 0.75rem;
    font-weight: 600;
    padding: .3rem .75rem;
    border-radius: 100px;
    margin-bottom: 0.875rem;
  }

  .faq-col__top h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -.02em;
    margin-bottom: 0.5rem;
  }

  .faq-col__top p {
    font-size: 0.875rem;
    color: var(--c-muted);
  }

  .faq-col__top a {
    color: var(--c-primary);
    font-weight: 600;
  }

  /* ── FAQ ITEMS ────────────────────────────────────────── */
  .faq-items {
    display: flex;
    flex-direction: column;
  }

  .faq-item {
    border-top: 1px solid var(--c-border);
    background: var(--c-white);
  }

  .faq-item:first-child {
    border-radius: 8px 8px 0 0;
  }

  .faq-item:last-child {
    border-bottom: 1px solid var(--c-border);
    border-radius: 0 0 8px 8px;
  }

  .faq-item:hover:not([open]) {
    background: rgba(249,232,232,0.3);
  }

  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    cursor: pointer;
    list-style: none;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--c-ink);
    line-height: 1.4;
  }

  .faq-item:hover summary { padding-left: 1.75rem; }

  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary span { flex: 1; }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--c-muted);
  }

  .faq-item[open] > summary {
    background: var(--c-primary-light, #F9E8E8);
    border-left: 3px solid var(--c-primary);
    padding-left: calc(1.5rem - 3px);
  }

  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--c-primary);
  }

  .faq-answer {
    padding: 0 1.5rem 1.5rem;
  }

  .faq-answer p {
    font-size: 0.9rem;
    color: var(--c-muted);
    line-height: 1.7;
  }

  .faq-answer strong {
    color: var(--c-ink-2);
    font-weight: 600;
  }

  /* ── COTIZACIÓN COLUMN ────────────────────────────────── */
  .cot-card {
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: 12px;
    overflow: hidden;
    position: sticky;
    top: calc(var(--stack-height, 124px) + 1.5rem);
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  }

  .cot-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
  }

  .cot-card__head {
    background: linear-gradient(135deg, var(--c-ink) 0%, #1a1a1a 100%);
    color: #fff;
    padding: 1.75rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .cot-card__head::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -30%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(196,30,36,0.15) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .cot-badge {
    display: inline-block;
    background: var(--c-primary);
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: .05em;
    text-transform: uppercase;
    padding: .2rem .625rem;
    border-radius: 3px;
    margin-bottom: 0.625rem;
  }

  .cot-card__head h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -.02em;
    margin-bottom: 0.375rem;
  }

  .cot-card__head p {
    font-size: 0.875rem;
    color: rgba(255,255,255,.6);
  }

  .cot-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cot-field {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .cot-field label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-ink-2);
  }

  .cot-field input,
  .cot-field select,
  .cot-field textarea {
    padding: 0.75rem 1rem;
    border: 1px solid var(--c-border);
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    color: var(--c-ink);
    background: var(--c-surface, #F4F4F5);
    outline: none;
    width: 100%;
  }

  .cot-field input:focus,
  .cot-field select:focus,
  .cot-field textarea:focus {
    border-color: var(--c-primary);
    background: var(--c-white);
    box-shadow: 0 0 0 3px rgba(196,30,36,0.08);
  }

  .cot-field textarea { resize: vertical; min-height: 80px; }

  .cot-card__footer {
    padding: 1.25rem 1.5rem;
    border-top: 1px solid var(--c-border);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .cot-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    background: #25D366;
    color: #fff;
    padding: 0.875rem 1.5rem;
    border-radius: 4px;
    font-size: 0.9375rem;
    font-weight: 700;
    text-decoration: none;
    transition: background 0.2s;
  }

  .cot-btn:hover { background: #1EBA57; }

  .cot-note {
    font-size: 0.75rem;
    color: var(--c-muted);
    text-align: center;
    line-height: 1.5;
  }

  /* ── RESPONSIVE ───────────────────────────────────────── */
  @media (max-width: 1200px) {
    .faq-categoria-grid { grid-template-columns: 1fr 380px; gap: 3rem; }
  }

  @media (max-width: 1024px) {
    .faq-categoria-grid { grid-template-columns: 1fr; gap: 3rem; }
    .cot-card { position: static; }
  }
</style>
