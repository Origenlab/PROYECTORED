---
/**
 * GuiaExtintores.astro
 * Guía de selección por tipo de instalación — 4 escenarios críticos.
 * Usa SectionHeaderDuo (complemento título oficial). Copy de alto impacto marketing.
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import { waUrl } from '../../config/site'

const waHref = waUrl('Hola, necesito asesoría para elegir el extintor correcto para mi instalación')

const escenarios = [
  {
    tipo: 'Oficina, comercio o edificio corporativo',
    norma: 'NOM-002-STPS',
    necesitas: 'PQS ABC 4.5 kg como estándar + CO₂ 4.5 kg en cuarto de servidores o UPS + señalamiento fotoluminiscente en cada extintor',
    porque: 'La norma exige 1 extintor por cada 300 m² mínimo. El PQS ABC cubre todos los fuegos de oficina. El CO₂ protege equipos electrónicos sin dejar residuo de polvo — el polvo penetra en componentes y genera cortocircuitos. Sin señalamiento, el extintor no cuenta en la inspección de STPS.',
    href: '/extintores/polvo-seco/',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>`,
  },
  {
    tipo: 'Restaurante o cocina industrial con freidoras',
    norma: 'NFPA 10 · NOM-002',
    necesitas: 'Extintor Tipo K de 6 L bajo campana extractora + PQS ABC en área de comensales + señalamiento específico por zona de riesgo',
    porque: 'Los aceites vegetales a temperatura de fritura (180–200 °C) generan fuegos Clase K que el PQS puede agravar — el polvo levanta las grasas encendidas y extiende el incendio. Solo el acetato de potasio del Tipo K suprime este fuego de forma efectiva. Es el único extintor aceptado bajo campana en cocinas industriales.',
    href: '/extintores/tipo-k/',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg>`,
  },
  {
    tipo: 'Planta industrial o bodega de manufactura',
    norma: 'NOM-002-STPS',
    necesitas: 'PQS 9–12 kg en zonas de producción + AFFF en área de líquidos inflamables + automáticos en cuartos de máquinas desatendidos + extintor rodante 50 kg en patio',
    porque: 'Las naves industriales tienen cargas de fuego mixtas: sólidos, líquidos y eléctrico. Un solo tipo no cubre todos los riesgos. La norma exige que el extintor sea del tipo adecuado para el riesgo predominante de cada zona — no uno general para toda la planta. Ignorarlo es una observación garantizada en cualquier auditoría.',
    href: '/extintores/afff/',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 22V2h14v20"/><path d="M23 22V10l-8-4v16"/><path d="M5 6h4"/><path d="M5 10h4"/><path d="M5 14h4"/></svg>`,
  },
  {
    tipo: 'Centro de datos, archivos o laboratorio',
    norma: 'NFPA 10 · NFPA 75',
    necesitas: 'Agente limpio (FM-200 o Novec 1230) en rack de servidores + CO₂ de respaldo + extintor automático montado en techo sin intervención humana',
    porque: 'El PQS destruye el equipo que intenta proteger: el polvo penetra en los componentes y genera cortocircuitos inmediatos. El agente limpio suprime en menos de 10 segundos sin residuo, sin daño a equipos y sin riesgo para el personal presente. En centros de datos, es el único agente técnicamente aceptable.',
    href: '/extintores/agente-limpio/',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><path d="M6 6h.01M6 18h.01"/></svg>`,
  },
]
---

<section class="guia-extintores" id="guia-extintores" aria-labelledby="guia-ext-heading">
  <div class="container">

    <SectionHeaderDuo
      eyebrow="Selección por tipo de riesgo"
      titleLine1="El Extintor Incorrecto No Solo No Apaga —"
      titleLine2="Puede Agravar el Incendio"
      desc="Agua en fuego eléctrico = electrocución. PQS en freidora = reavivamiento del fuego. CO₂ en exterior = dispersión sin efectividad. Conoce la configuración correcta para tu instalación."
      bodyPara1="Elegir el tipo incorrecto de extintor no es solo un problema de cumplimiento normativo — es un riesgo operativo real. En una emergencia, el personal que intenta usar un extintor inadecuado puede agravar el incendio, sufrir un accidente o simplemente perder los segundos críticos que hacen la diferencia entre un conato controlado y una evacuación total. Asesoría técnica sin costo para que definas la configuración correcta por zona antes de comprar."
    />

    <!-- Grid de escenarios -->
    <div class="guia-grid" role="list" aria-label="Guía de selección de extintores por tipo de instalación">
      {escenarios.map(esc => (
        <article class="guia-card" role="listitem">
          <div class="guia-card__head">
            <div class="guia-icon" set:html={esc.icon} />
            <span class="guia-norma">{esc.norma}</span>
          </div>
          <h3 class="guia-card__tipo">{esc.tipo}</h3>
          <div class="guia-card__necesitas">
            <span class="guia-label">Qué necesitas:</span>
            <p>{esc.necesitas}</p>
          </div>
          <div class="guia-card__porque">
            <span class="guia-label">Por qué:</span>
            <p>{esc.porque}</p>
          </div>
          <a href={esc.href} class="guia-card__cta">
            Ver extintor recomendado
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </article>
      ))}
    </div>

    <!-- CTA asesoría -->
    <div class="guia-cta-bar">
      <div class="guia-cta-bar__text">
        <strong>¿Tu instalación tiene riesgos mixtos?</strong>
        <span>Te hacemos el levantamiento técnico sin costo y te entregamos la configuración correcta por zona.</span>
      </div>
      <a
        href={waHref}
        class="btn-primary guia-cta-bar__btn"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Asesoría técnica gratuita
      </a>
    </div>

  </div>
</section>

<style>
  .guia-extintores {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-surface, #F4F4F5);
    border-top: 1px solid var(--c-border);
  }

  /* ── GRID 2 COLUMNAS ─────────────────────────────────── */
  .guia-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }

  /* ── CARD ─────────────────────────────────────────────── */
  .guia-card {
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: 8px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.2s;
  }

  .guia-card:hover {
    box-shadow: var(--shadow-md, 0 4px 16px rgba(196,30,36,.12));
  }

  /* Head */
  .guia-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .guia-icon {
    width: 40px;
    height: 40px;
    background: var(--c-primary-light, #F9E8E8);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-primary);
    flex-shrink: 0;
  }

  .guia-norma {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: var(--c-primary);
    background: var(--c-primary-light, #F9E8E8);
    padding: .2rem .625rem;
    border-radius: 3px;
  }

  /* Tipo */
  .guia-card__tipo {
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -.02em;
    line-height: 1.25;
  }

  /* Necesitas / Porque */
  .guia-card__necesitas,
  .guia-card__porque {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .guia-label {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--c-muted);
  }

  .guia-card__necesitas p {
    font-size: 0.875rem;
    color: var(--c-ink-2);
    font-weight: 600;
    line-height: 1.5;
  }

  .guia-card__porque p {
    font-size: 0.875rem;
    color: var(--c-muted);
    line-height: 1.65;
  }

  /* CTA */
  .guia-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: auto;
    padding-top: 0.875rem;
    border-top: 1px solid var(--c-border);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-primary);
    text-decoration: none;
    transition: gap 0.2s;
  }

  .guia-card:hover .guia-card__cta { gap: 0.625rem; }

  /* ── CTA BAR ──────────────────────────────────────────── */
  .guia-cta-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-left: 4px solid var(--c-primary);
    border-radius: 8px;
    padding: 1.5rem 2rem;
  }

  .guia-cta-bar__text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .guia-cta-bar__text strong {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -.01em;
  }

  .guia-cta-bar__text span {
    font-size: 0.875rem;
    color: var(--c-muted);
    line-height: 1.5;
  }

  .guia-cta-bar__btn {
    flex-shrink: 0;
    white-space: nowrap;
  }

  /* ── RESPONSIVE ───────────────────────────────────────── */
  @media (max-width: 1024px) {
    .guia-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 768px) {
    .guia-cta-bar {
      flex-direction: column;
      text-align: center;
      padding: 1.5rem;
    }
    .guia-cta-bar__btn { width: 100%; justify-content: center; }
  }
</style>
