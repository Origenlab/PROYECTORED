// Devuelve la URL CDN lista para usar en el src de <img>
function getPostImageCdn(slug: string, frontmatterImage: string | undefined, category: string | undefined): string {
  const raw = frontmatterImage ?? slugImages[slug] ?? (category ? categoryImages[category] : undefined) ?? ''
  if (!raw) return ''
  if (raw.startsWith('/imagenes/')) {
    return `https://ewvydcs5uyw.exactdn.com${raw}?strip=all&lossy=1&w=480`
  }
  return raw
}
---

<section id="articulos" class="blog-catalogo cat-section cat-section--white" aria-labelledby="blog-catalogo-heading">
  <div class="container">

    <!-- ── Encabezado SectionHeaderDuo (homologado) ── -->
    <SectionHeaderDuo
      id="blog-catalogo-heading"
      eyebrow="Blog"
      titleLine1="Guías y recursos sobre"
      titleLine2="protección contra incendios"
      desc="Contenido escrito por especialistas en seguridad contra incendios."
      bodyPara1="Artículos técnicos sobre normativa mexicana, selección de equipo, mantenimiento preventivo y preparación para inspecciones de Protección Civil y STPS."
      bodyPara2="Publicamos guías prácticas para que tu empresa entienda qué equipo necesita, cómo mantenerlo y qué documentación presentar ante las autoridades competentes."
    />

    <!-- ── Layout 2 columnas: contenido + sidebar ── -->
    <div class="blog-layout">

      <!-- ═══ COLUMNA PRINCIPAL ═══════════════════════ -->
      <div class="blog-layout__main">

        <!-- Contador de resultados -->
        <div class="blog-results-bar">
          <span class="blog-results-bar__count">{posts.length} artículos disponibles</span>
        </div>

        <!-- Grid de artículos (todas las cards, JS controla paginación) -->
        <div class="blog-grid" id="blogGrid">
          {posts.map((post, i) => (
            <a
              href={`/blog/${post.id}/`}
              class="blogcard"
              data-index={i}
              style={i >= POSTS_PER_PAGE ? 'display:none' : ''}
            >
              <!-- Imagen principal (siempre presente) -->
              <div class="blogcard__visual" style={`background: ${getGradient(post.data.category)}`}>
                <img
                  src={getPostImageCdn(post.id, post.data.image, post.data.category)}
                  alt={post.data.title}
                  width="480"
                  height="260"
                  loading={i < POSTS_PER_PAGE ? 'eager' : 'lazy'}
                  decoding="async"
                  class="blogcard__img"
                />
                {post.data.category && (
                  <span class="blogcard__badge">{post.data.category}</span>
                )}
              </div>

              <!-- Contenido -->
              <div class="blogcard__content">
                <h3 class="blogcard__title">{post.data.title}</h3>
                <p class="blogcard__desc">{post.data.description}</p>
                <span class="blogcard__cta">
                  Leer artículo
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </div>
            </a>
          ))}
        </div>

        <!-- Paginación -->
        {totalPages > 1 && (
          <nav class="blog-pagination" id="blogPagination" aria-label="Paginación del blog">
            <button class="blog-pagination__btn blog-pagination__prev" id="blogPrev" disabled aria-label="Página anterior">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
              Anterior
            </button>

            <div class="blog-pagination__pages" id="blogPages">
              {Array.from({ length: totalPages }, (_, i) => (
                <button
                  class:list={['blog-pagination__page', { 'blog-pagination__page--active': i === 0 }]}
                  data-page={i}
                >
                  {i + 1}
                </button>
              ))}
            </div>

            <button class="blog-pagination__btn blog-pagination__next" id="blogNext" aria-label="Página siguiente">
              Siguiente
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            </button>
          </nav>
        )}

      </div>

      <!-- ═══ SIDEBAR ════════════════════════════════ -->
      <BlogSidebar />

    </div>

  </div>
</section>

<script define:vars={{ POSTS_PER_PAGE, totalPages }}>
  // Paginación client-side
  const grid = document.getElementById('blogGrid')
  const cards = grid ? Array.from(grid.querySelectorAll('.blogcard')) : []
  const prevBtn = document.getElementById('blogPrev')
  const nextBtn = document.getElementById('blogNext')
  const pagesBtns = document.querySelectorAll('.blog-pagination__page')

  let currentPage = 0

  function showPage(page) {
    currentPage = page
    const start = page * POSTS_PER_PAGE
    const end = start + POSTS_PER_PAGE

    cards.forEach((card, i) => {
      card.style.display = (i >= start && i < end) ? '' : 'none'
    })

    // Actualizar botones
    pagesBtns.forEach((btn) => {
      const p = parseInt(btn.dataset.page)
      btn.classList.toggle('blog-pagination__page--active', p === page)
    })

    if (prevBtn) prevBtn.disabled = page === 0
    if (nextBtn) nextBtn.disabled = page === totalPages - 1

    // Scroll suave al grid
    const section = document.getElementById('articulos')
    if (section) {
      section.scrollIntoView({ behavior: 'smooth', block: 'start' })
    }
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      if (currentPage > 0) showPage(currentPage - 1)
    })
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      if (currentPage < totalPages - 1) showPage(currentPage + 1)
    })
  }

  pagesBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      showPage(parseInt(btn.dataset.page))
    })
  })
</script>
