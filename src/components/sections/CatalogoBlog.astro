const defaultGradient = 'linear-gradient(135deg, #1a1a1a 0%, #2d1515 40%, #0f0f1a 100%)'

function getGradient(category: string | undefined): string {
  if (!category) return defaultGradient
  return categoryGradients[category] ?? defaultGradient
}

