---
/**
 * CatalogoBlog.astro
 * Sección principal del blog L2 — SectionHeaderDuo + layout 2 columnas
 * (grid artículos con paginación + sidebar interlinking).
 * Patrón homologado con CatalogoProductos.
 * CSS en: src/styles/pages.css (.blog-catalogo, .blog-layout)
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import BlogSidebar from './BlogSidebar.astro'
import { getCollection } from 'astro:content'

const POSTS_PER_PAGE = 9

// Obtener todos los artículos ordenados por fecha
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())

const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE)

