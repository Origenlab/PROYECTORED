---
// CotizacionForm.astro
// Formulario de cotización — un solo componente usado en Productos, Contacto y Home
// Envía via WhatsApp con mensaje pre-construido

import { CONTACT, waUrl } from '../../config/site'

const WA_NUMBER = CONTACT.whatsapp
---

<section class="cotizacion section" id="cotizacion">
  <div class="container cotizacion__inner">

    <!-- Trust indicators -->
    <div class="cotizacion__trust" aria-hidden="true">
      <span>✓ Equipo certificado NOM y NFPA</span>
      <span>✓ Respuesta en menos de 24 horas</span>
      <span>✓ Entrega en CDMX y Estado de México</span>
      <span>✓ Asesoría técnica gratuita</span>
      <span>✓ Cotización sin costo</span>
    </div>

    <div class="cotizacion__layout">
      <!-- Copy izquierdo -->
      <div class="cotizacion__copy">
        <p class="cotizacion__eyebrow">Cotización Gratuita</p>
        <h2 class="cotizacion__title">Solicita tu cotización ahora</h2>
        <p class="cotizacion__desc">
          Cuéntanos qué necesitas — te respondemos con precio real,
          disponibilidad y tiempo de entrega en menos de 24 horas.
        </p>
        <div class="cotizacion__contact">
          <p>¿Prefieres WhatsApp directo?</p>
          <a
            href={waUrl('Hola, necesito cotizar equipos contra incendios')}
            class="cotizacion__wa"
            target="_blank"
            rel="noopener noreferrer"
          >
            WhatsApp {CONTACT.phone} →
          </a>
        </div>
      </div>

      <!-- Formulario -->
      <form class="cotizacion__form" id="cotizacion-form" novalidate>
        <div class="form__row">
          <div class="form__field">
            <label for="nombre" class="form__label">
              Nombre completo <span class="form__required" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              class="form__input"
              placeholder="Tu nombre o razón social"
              required
              autocomplete="name"
            />
          </div>
          <div class="form__field">
            <label for="telefono" class="form__label">
              Teléfono / WhatsApp <span class="form__required" aria-hidden="true">*</span>
            </label>
            <input
              type="tel"
              id="telefono"
              name="telefono"
              class="form__input"
              placeholder="55 1234 5678"
              required
              autocomplete="tel"
            />
          </div>
        </div>

        <div class="form__field">
          <label for="empresa" class="form__label">
            Empresa o negocio <span class="form__optional">(opcional)</span>
          </label>
          <input
            type="text"
            id="empresa"
            name="empresa"
            class="form__input"
            placeholder="Nombre de tu empresa"
            autocomplete="organization"
          />
        </div>

        <div class="form__field">
          <label for="categoria" class="form__label">
            ¿Qué producto o servicio necesitas? <span class="form__required" aria-hidden="true">*</span>
          </label>
          <select id="categoria" name="categoria" class="form__select" required>
            <option value="">Selecciona una categoría</option>
            <optgroup label="Productos">
              <option value="Extintores">Extintores certificados NOM</option>
              <option value="Señalamientos">Señalamientos de Emergencia NOM-003</option>
              <option value="Equipo para Bomberos">Equipo para Bomberos (NFPA)</option>
              <option value="Gabinetes">Gabinetes y Porta Extintores</option>
              <option value="Mangueras y Herrajes">Mangueras, Chiflones y Herrajes</option>
              <option value="Sistemas CI">Sistemas Contra Incendio</option>
              <option value="Primeros Auxilios">Botiquines y Primeros Auxilios</option>
              <option value="EPP">Equipo de Protección Personal (EPP)</option>
            </optgroup>
            <optgroup label="Servicios">
              <option value="Recarga de Extintores">Recarga de Extintores</option>
              <option value="Mantenimiento Preventivo">Mantenimiento Preventivo</option>
              <option value="Instalación de Sistemas CI">Instalación de Sistemas CI</option>
              <option value="Prueba Hidrostática">Prueba Hidrostática</option>
              <option value="Capacitación contra Incendios">Capacitación y Brigadas</option>
              <option value="Señalización NOM">Señalización e Instalación NOM</option>
            </optgroup>
            <option value="Varios">Varios / No estoy seguro</option>
          </select>
        </div>

        <div class="form__field">
          <label for="detalle" class="form__label">
            Detalle de tu solicitud <span class="form__optional">(opcional)</span>
          </label>
          <textarea
            id="detalle"
            name="detalle"
            class="form__textarea"
            rows="3"
            placeholder="Ejemplo: 3 extintores polvo seco 6 kg para bodega de 400 m², necesito entrega antes del viernes..."
          ></textarea>
        </div>

        <div class="form__field">
          <p class="form__label">¿Qué tan urgente es?</p>
          <div class="form__radios">
            <label class="form__radio">
              <input type="radio" name="urgencia" value="Hoy mismo" />
              <span>🔴 Hoy mismo</span>
            </label>
            <label class="form__radio">
              <input type="radio" name="urgencia" value="Esta semana" checked />
              <span>🟡 Esta semana</span>
            </label>
            <label class="form__radio">
              <input type="radio" name="urgencia" value="Sin urgencia" />
              <span>🟢 Sin urgencia</span>
            </label>
          </div>
        </div>

        <button type="submit" class="form__submit">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Enviar cotización por WhatsApp
        </button>

        <p class="form__footer-note">
          Sin compromiso · Respuesta &lt;24h · Datos protegidos
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  .cotizacion { background: var(--color-white); }

  .cotizacion__trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin-bottom: var(--sp-10);
    padding-bottom: var(--sp-6);
    border-bottom: 1px solid var(--border);
    font-size: var(--text-sm);
    color: var(--color-gray-500);
  }

  .cotizacion__layout {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }

  .cotizacion__eyebrow {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-red);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--sp-3);
  }

  .cotizacion__title {
    font-size: var(--text-2xl);
    font-weight: var(--weight-black);
    line-height: var(--leading-tight);
    color: var(--color-gray-900);
    margin-bottom: var(--sp-4);
  }

  .cotizacion__desc {
    font-size: var(--text-base);
    color: var(--color-gray-500);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--sp-8);
  }

  .cotizacion__contact p {
    font-size: var(--text-sm);
    color: var(--color-gray-500);
    margin-bottom: var(--sp-2);
  }

  .cotizacion__wa {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-red);
  }
  .cotizacion__wa:hover { opacity: 0.75; }

  /* Formulario */
  .cotizacion__form {
    background: var(--color-gray-50);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: var(--sp-8);
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }

  .form__field { display: flex; flex-direction: column; gap: var(--sp-2); }

  .form__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-gray-700);
  }

  .form__required { color: var(--color-red); margin-left: 2px; }
  .form__optional { color: var(--color-gray-400); font-weight: var(--weight-normal); }

  .form__input,
  .form__select,
  .form__textarea {
    width: 100%;
    padding: var(--sp-3) var(--sp-4);
    font: var(--weight-normal) var(--text-sm) / var(--leading-normal) var(--font-sans);
    color: var(--color-gray-700);
    background: var(--color-white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    appearance: none;
    -webkit-appearance: none;
  }

  .form__input:focus,
  .form__select:focus,
  .form__textarea:focus {
    outline: none;
    border-color: var(--color-red);
    box-shadow: 0 0 0 3px rgba(196,30,58,0.12);
  }

  .form__textarea { resize: vertical; min-height: 80px; }

  .form__radios {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }

  .form__radio {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    cursor: pointer;
    font-size: var(--text-sm);
    color: var(--color-gray-700);
  }

  .form__submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    width: 100%;
    padding: var(--sp-4);
    background: var(--color-red);
    color: var(--color-white);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    border-radius: var(--radius-lg);
    transition: background var(--transition);
    margin-top: var(--sp-2);
  }

  .form__submit:hover { background: var(--color-red-hover); }

  .form__footer-note {
    text-align: center;
    font-size: var(--text-xs);
    color: var(--color-gray-400);
  }

  @media (max-width: 1024px) {
    .cotizacion__layout { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .form__row { grid-template-columns: 1fr; }
    .cotizacion__form { padding: var(--sp-5); }
  }
</style>

<script define:vars={{ WA_NUMBER }}>
  const form = document.getElementById('cotizacion-form')

  form?.addEventListener('submit', (e) => {
    e.preventDefault()

    const data = new FormData(form)
    const nombre   = data.get('nombre')?.toString().trim()
    const telefono = data.get('telefono')?.toString().trim()
    const empresa  = data.get('empresa')?.toString().trim()
    const categoria= data.get('categoria')?.toString().trim()
    const detalle  = data.get('detalle')?.toString().trim()
    const urgencia = data.get('urgencia')?.toString().trim()

    if (!nombre || !telefono || !categoria) {
      alert('Por favor completa los campos requeridos.')
      return
    }

    const msg = [
      `Hola, quiero solicitar una cotización.`,
      `Nombre: ${nombre}`,
      telefono ? `Teléfono: ${telefono}` : null,
      empresa  ? `Empresa: ${empresa}`   : null,
      `Categoría: ${categoria}`,
      detalle  ? `Detalle: ${detalle}`   : null,
      urgencia ? `Urgencia: ${urgencia}` : null,
    ].filter(Boolean).join('\n')

    window.open(`https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`, '_blank')
  })
</script>
