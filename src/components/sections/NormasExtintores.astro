---
/**
 * NormasExtintores.astro
 * Tabla de normas y certificaciones específicas para extintores.
 * Usa SectionHeader.astro (complemento aprobado). Patrón: NormasIndex.
 */
import SectionHeader from '../ui/SectionHeader.astro'

const normas = [
  {
    norma: 'NOM-154-SCFI',
    alcance: 'Extintores de polvo químico seco, CO₂, agentes limpios y espuma — requisitos de seguridad, pruebas e información comercial',
    aplica: 'Todo extintor portátil vendido en México. Sin este sello, el equipo no es válido ante Protección Civil ni STPS.',
  },
  {
    norma: 'NOM-002-STPS-2010',
    alcance: 'Condiciones de seguridad y prevención de incendio en centros de trabajo. Establece tipo, cantidad, ubicación y distancia máxima de los extintores',
    aplica: 'Toda empresa con trabajadores. Define la obligación de 1 extintor por cada 300 m² mínimo, del tipo adecuado para el riesgo de cada zona.',
  },
  {
    norma: 'NOM-100-STPS-1994',
    alcance: 'Seguridad — extintores contra incendio a base de polvo químico seco con presión contenida. Especificaciones y métodos de prueba',
    aplica: 'Fabricantes y distribuidores de extintores PQS. Define los parámetros de presión, agente y rendimiento que debe cumplir el cilindro.',
  },
  {
    norma: 'NOM-101-STPS-1994',
    alcance: 'Seguridad — extintores a base de CO₂. Especificaciones, pruebas y comportamiento en operación',
    aplica: 'Extintores de dióxido de carbono. Aplica en entornos con equipos electrónicos, laboratorios y áreas sensibles a residuos.',
  },
  {
    norma: 'NFPA 10',
    alcance: 'Estándar para extintores portátiles contra incendio. Clasifica tipos de fuego (A, B, C, D, K) y define criterios de selección, instalación y mantenimiento',
    aplica: 'Proyectos con clientes o aseguradoras que exigen estándar internacional, centros de datos y plantas con certificación OSHA/ISO.',
  },
  {
    norma: 'Prueba Hidrostática (NOM-154-SCFI)',
    alcance: 'Verificación estructural del cilindro cada 5 años. Prueba de presión interna para detectar corrosión, fisuras o deformaciones',
    aplica: 'Todos los cilindros de extintores portátiles con más de 5 años desde su fabricación o desde la última prueba. Obligatoria — sin ella, el cilindro no está en norma.',
  },
]
---

<section class="normas-extintores" aria-labelledby="normas-ext-heading">
  <div class="container">

    <SectionHeader
      eyebrow="Respaldo normativo"
      titleLine1="Normas que Regulan"
      titleLine2="la Venta y Uso de Extintores"
      align="left"
    />

    <div class="normas-extintores__intro">
      <p>
        En México, la validez de un extintor ante Protección Civil o la STPS no depende solo de que
        el cilindro funcione — depende de que cuente con la <strong>certificación de conformidad NOM vigente</strong>,
        la etiqueta de inspección actualizada y la prueba hidrostática al corriente. Durante una auditoría,
        la autoridad revisa los tres elementos. Si uno falta, el extintor no cuenta. Todos los equipos
        que distribuimos incluyen la documentación necesaria para tu expediente regulatorio.
      </p>
    </div>

    <div class="tabla-responsive">
      <table class="tabla-seo" role="table" aria-label="Normas y certificaciones que aplican a extintores contra incendios">
        <thead>
          <tr>
            <th scope="col">Norma / Estándar</th>
            <th scope="col">Alcance</th>
            <th scope="col">Por qué importa</th>
          </tr>
        </thead>
        <tbody>
          {normas.map(n => (
            <tr>
              <td><strong>{n.norma}</strong></td>
              <td>{n.alcance}</td>
              <td>{n.aplica}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="normas-nota">
      Cada extintor que vendemos sale con su ficha técnica, certificado de conformidad NOM, etiqueta de
      inspección y garantía del fabricante — los cuatro documentos que solicita la autoridad en una
      inspección. Asesoramos sin costo sobre qué documentación adicional puede requerir tu aseguradora o
      el área de Protección Civil de tu alcaldía o municipio.
    </p>

  </div>
</section>

<style>
  .normas-extintores {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-white);
    border-top: 1px solid var(--c-border);
  }

  .normas-extintores__intro {
    max-width: 80ch;
    margin-bottom: 2rem;
  }

  .normas-extintores__intro p {
    font-size: 0.9375rem;
    color: var(--c-muted);
    line-height: 1.7;
  }

  .normas-extintores__intro strong {
    color: var(--c-ink-2);
    font-weight: 600;
  }

  /* ── TABLA ────────────────────────────────────────────── */
  .tabla-responsive {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 6px;
    border: 1px solid var(--c-border);
    margin-bottom: 1.5rem;
  }

  .tabla-seo {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    min-width: 640px;
  }

  .tabla-seo thead {
    background: var(--c-ink, #111111);
    color: #fff;
  }

  .tabla-seo th {
    padding: 0.875rem 1.25rem;
    text-align: left;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: .04em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .tabla-seo td {
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--c-border);
    color: var(--c-ink-2);
    line-height: 1.55;
    vertical-align: top;
  }

  .tabla-seo td strong {
    color: var(--c-primary);
    font-weight: 700;
    white-space: nowrap;
  }

  .tabla-seo tbody tr:last-child td { border-bottom: none; }

  .tabla-seo tbody tr:nth-child(even) {
    background: var(--c-surface, #F4F4F5);
  }

  /* ── NOTA ─────────────────────────────────────────────── */
  .normas-nota {
    font-size: 0.875rem;
    color: var(--c-muted);
    line-height: 1.65;
    max-width: 80ch;
  }
</style>
