---
// CTAFinal.astro
// Sección de cierre con CTA — aparece al final de cada página de Nivel 2

interface Props {
  title: string
  body: string
  cta1Text: string
  cta1Href: string
  cta2Text?: string
  cta2Href?: string
}

const { title, body, cta1Text, cta1Href, cta2Text, cta2Href } = Astro.props
---

<section class="cta-final section--dark">
  <div class="container cta-final__inner">
    <h2 class="cta-final__title">{title}</h2>
    <p class="cta-final__body">{body}</p>
    <div class="cta-final__actions">
      <a
        href={cta1Href}
        class="btn btn--primary"
        target={cta1Href.startsWith('https') ? '_blank' : undefined}
        rel={cta1Href.startsWith('https') ? 'noopener noreferrer' : undefined}
      >
        {cta1Text}
      </a>
      {cta2Text && cta2Href && (
        <a href={cta2Href} class="btn btn--outline-white">{cta2Text}</a>
      )}
    </div>
  </div>
</section>

<style>
  .cta-final {
    padding-block: var(--sp-20);
    text-align: center;
  }

  .cta-final__inner {
    max-width: 680px;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-5);
  }

  .cta-final__title {
    font-size: var(--text-3xl);
    font-weight: var(--weight-black);
    color: var(--color-white);
    line-height: var(--leading-tight);
  }

  .cta-final__body {
    font-size: var(--text-base);
    color: rgba(255,255,255,0.75);
    line-height: var(--leading-relaxed);
    max-width: 55ch;
  }

  .cta-final__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    justify-content: center;
  }

</style>
