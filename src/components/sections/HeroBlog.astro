---
/**
 * HeroBlog.astro
 * Hero de la página de blog — mismo patrón visual que HeroProductos.
 * Izq: badge + H1 + subtítulo + CTAs / Der: párrafos descriptivos.
 */
import { getCollection } from 'astro:content'
import { waUrl, WA_MESSAGES } from '../../config/site'

const posts = await getCollection('blog')
const totalArticulos = posts.length

// Contar categorías únicas
const categorias = new Set(posts.map(p => p.data.category).filter(Boolean))
const totalCategorias = categorias.size

const PAGE_WA = waUrl(WA_MESSAGES.blog)
---

<section class="hero-blog" aria-label="Blog de seguridad contra incendios">
  <div class="container hero-blog__grid">

    <!-- ── Columna izquierda ── -->
    <div class="hero-blog__left">

      <div class="hero-badge" aria-hidden="true">
        <span class="badge-pulse"></span>
        Guías técnicas y normativas
      </div>

      <h1 class="hero-blog__h1">
        Blog de Seguridad<br>
        Contra <span class="h1-accent">Incendios</span>
      </h1>

      <p class="hero-blog__sub">
        {totalArticulos} artículos técnicos en {totalCategorias} categorías sobre normativa mexicana,
        selección de equipo, mantenimiento preventivo y cumplimiento ante Protección Civil y STPS.
      </p>

      <!-- CTAs -->
      <div class="hero-blog__ctas">
        <a href="#articulos" class="btn btn--white">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/></svg>
          Ver artículos
        </a>
        <a href={PAGE_WA} class="btn btn--ghost-light" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Consulta técnica gratis
        </a>
      </div>

    </div>

    <!-- ── Columna derecha: dos párrafos ── -->
    <div class="hero-blog__right">
      <p>
        En Proyecto Red creamos contenido técnico real — no relleno genérico. Cada artículo
        responde preguntas que nuestros clientes nos hacen todos los días: qué extintor necesitan,
        qué exige Protección Civil, cómo pasar una auditoría STPS o qué norma aplica a su giro.
      </p>
      <p>
        Si después de leer tienes dudas, escríbenos por WhatsApp. Nuestro equipo técnico te
        asesora sin costo sobre el equipo y los servicios que tu empresa necesita.
      </p>
    </div>

  </div>
</section>

<style>
  /* ── HERO BLOG ─────────────────────────────────── */
  .hero-blog {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background:
      radial-gradient(ellipse 55% 65% at 75% 50%, rgba(196,30,36,.13) 0%, transparent 65%),
      linear-gradient(160deg, #0A0A0A 0%, #160A0A 50%, #0A0A0A 100%);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .hero-blog::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .badge-pulse {
    width: 7px;
    height: 7px;
    background: var(--c-primary);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero-blog__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-blog__h1 {
    font-size: clamp(2.5rem, 4.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -.03em;
    margin-bottom: 1.25rem;
  }

  .hero-blog__sub {
    font-size: 1.0625rem;
    color: rgba(255,255,255,.6);
    line-height: 1.65;
    max-width: 50ch;
    margin-bottom: 2rem;
  }

  .hero-blog__ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .hero-blog__right p {
    color: rgba(255,255,255,.55);
    font-size: 0.9375rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  .hero-blog__right p:last-child { margin-bottom: 0; }

  /* ── RESPONSIVE ────────────────────────────────── */
  @media (max-width: 1024px) {
    .hero-blog__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hero-blog { padding-top: 3rem; }
    .hero-blog__right { display: none; }
  }

  @media (max-width: 768px) {
    .hero-blog { padding-bottom: 3rem; }
  }
</style>
