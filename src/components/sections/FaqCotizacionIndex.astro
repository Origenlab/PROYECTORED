---
/**
 * FaqCotizacionIndex.astro
 * FAQ + Formulario de cotización con JS dinámico para WhatsApp.
 * Encabezado: SectionHeaderDuo (complemento aprobado).
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import { CONTACT } from '../../config/site'
import { FAQS_GLOBALES } from '../../lib/seo'

// Fuente única: lib/seo.ts. El contenido visible coincide con el JSON-LD
// FAQPage que emite index.astro, evitando mismatch contenido/schema.
const faqs = FAQS_GLOBALES.map(({ pregunta, respuesta }) => ({ q: pregunta, a: respuesta }))
---

<section class="faq-cot-index" id="cotizacion" aria-labelledby="faq-heading">
  <div class="container">

    <SectionHeaderDuo
      id="faq-heading"
      eyebrow="FAQ y Cotización"
      titleLine1="Preguntas Frecuentes y"
      titleLine2="Cotización Gratuita"
      desc="Resolvemos tus dudas y te cotizamos en menos de 24 horas."
      bodyPara1="Las preguntas más comunes de nuestros clientes sobre precios, certificaciones, tiempos de entrega y servicios. Si no encuentras tu respuesta, mándanos un WhatsApp y te respondemos ese mismo día."
      bodyPara2="También puedes solicitar tu cotización directamente desde esta página. Solo dinos qué necesitas y nuestro equipo técnico te prepara una propuesta con precios, disponibilidad y tiempos de entrega."
    />

    <div class="faq-cot-index__grid">

      <!-- ── FAQ ── -->
      <div class="faq-col" aria-labelledby="faq-col-heading">
        <div class="faq-col__top">
          <span class="faq-col__badge">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Preguntas Frecuentes
          </span>
          <h3 id="faq-col-heading">Lo que nuestros clientes preguntan</h3>
          <p>¿No encuentras tu respuesta? Escríbenos al <a href={`https://wa.me/${CONTACT.whatsapp}`} target="_blank" rel="noopener noreferrer">WhatsApp {CONTACT.phone}</a>.</p>
        </div>

        <div class="faq-items">
          {faqs.map((f, i) => (
            <details class="faq-item" itemscope itemtype="https://schema.org/Question">
              <summary>
                <span itemprop="name">{f.q}</span>
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div class="faq-answer" itemprop="acceptedAnswer" itemscope itemtype="https://schema.org/Answer">
                <p itemprop="text" set:html={f.a}></p>
              </div>
            </details>
          ))}
        </div>
      </div>

      <!-- ── COTIZACIÓN ── -->
      <div class="cot-col">
        <div class="cot-card">
          <div class="cot-card__head">
            <span class="cot-badge">Cotización Gratuita</span>
            <h3>Solicita tu cotización</h3>
            <p>Respuesta en menos de 24 horas. Sin compromiso.</p>
          </div>

          <div class="cot-card__body">
            <div class="cot-field">
              <label for="cot-nombre">Nombre completo *</label>
              <input type="text" id="cot-nombre" name="nombre" placeholder="Tu nombre completo" autocomplete="name" />
            </div>
            <div class="cot-field">
              <label for="cot-tel">Teléfono *</label>
              <input type="tel" id="cot-tel" name="tel" placeholder="55 1234 5678" autocomplete="tel" />
            </div>
            <div class="cot-field">
              <label for="cot-empresa">Empresa o negocio</label>
              <input type="text" id="cot-empresa" name="empresa" placeholder="Nombre de tu empresa" autocomplete="organization" />
            </div>
            <div class="cot-field">
              <label for="cot-servicio">¿Qué necesitas? *</label>
              <select id="cot-servicio" name="servicio">
                <option value="" disabled selected>Selecciona una categoría</option>
                <option>Extintores</option>
                <option>Señalamientos de Emergencia</option>
                <option>Equipo para Bomberos</option>
                <option>Gabinetes y Porta Extintores</option>
                <option>Mangueras y Herrajes</option>
                <option>Sistemas Contra Incendio</option>
                <option>Primeros Auxilios</option>
                <option>Equipo de Seguridad Industrial</option>
                <option>Varios / No estoy seguro</option>
              </select>
            </div>
            <div class="cot-field">
              <label for="cot-detalle">Cuéntanos más (opcional)</label>
              <textarea id="cot-detalle" name="detalle" rows="3" placeholder="Tipo de instalación, cantidad aproximada, urgencia..."></textarea>
            </div>
          </div>

          <div class="cot-card__footer">
            <a
              id="cot-wa-btn"
              data-wa={CONTACT.whatsapp}
              href={`https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent('Hola, quiero una cotización de equipos contra incendios')}`}
              target="_blank"
              rel="noopener noreferrer"
              class="cot-btn"
              role="button"
              aria-label="Solicitar cotización por WhatsApp"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Solicitar Cotización por WhatsApp
            </a>
            <p class="cot-note">Cotización gratuita · Respuesta en menos de 24h · Equipo certificado NOM</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('cot-wa-btn')
  btn?.addEventListener('click', (e) => {
    e.preventDefault()
    const nombre   = (document.getElementById('cot-nombre') as HTMLInputElement)?.value.trim()
    const tel      = (document.getElementById('cot-tel') as HTMLInputElement)?.value.trim()
    const empresa  = (document.getElementById('cot-empresa') as HTMLInputElement)?.value.trim()
    const servicio = (document.getElementById('cot-servicio') as HTMLSelectElement)?.value
    const detalle  = (document.getElementById('cot-detalle') as HTMLTextAreaElement)?.value.trim()

    let msg = 'Hola, quiero una cotización de equipos contra incendios.'
    if (nombre)   msg += `\n\n👤 Nombre: ${nombre}`
    if (tel)      msg += `\n📞 Teléfono: ${tel}`
    if (empresa)  msg += `\n🏢 Empresa: ${empresa}`
    if (servicio) msg += `\n📦 Necesito: ${servicio}`
    if (detalle)  msg += `\n📝 Detalle: ${detalle}`

    const waNum = btn?.dataset.wa || '525627596245'
    window.open(`https://wa.me/${waNum}?text=${encodeURIComponent(msg)}`, '_blank')
  })
</script>

<style>
  /* Estilos principales en src/styles/faq-cotizacion-index.css (cargado vía global.css) */
</style>
