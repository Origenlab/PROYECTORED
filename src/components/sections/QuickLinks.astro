---
// QuickLinks.astro
// Barra de 4 accesos rápidos — IDÉNTICA en todas las páginas
// No acepta props: datos estáticos desde config/site.ts

import { QUICK_LINKS } from '../../config/site'
---

<section class="quicklinks" aria-label="Accesos rápidos">
  <div class="quicklinks__grid">
    {QUICK_LINKS.map((link) => (
      <a
        href={link.href}
        class:list={['quicklinks__item', { 'quicklinks__item--cta': 'cta' in link && link.cta }]}
        target={link.href.startsWith('https') ? '_blank' : undefined}
        rel={link.href.startsWith('https') ? 'noopener noreferrer' : undefined}
      >
        <div class="quicklinks__text">
          <span class="quicklinks__label">{link.label}</span>
          <span class="quicklinks__desc">{link.desc}</span>
        </div>
        <svg class="quicklinks__arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </a>
    ))}
  </div>
</section>

<style>
  .quicklinks {
    border-bottom: 1px solid var(--border);
  }

  .quicklinks__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .quicklinks__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding: var(--sp-5) var(--sp-6);
    background: var(--color-white);
    border-right: 1px solid var(--border);
  }

  .quicklinks__item:last-child {
    border-right: none;
  }

  .quicklinks__item:hover {
    background: var(--color-gray-50);
  }

  .quicklinks__item--cta {
    background: var(--color-red);
    color: var(--color-white);
    border-right: none;
  }

  .quicklinks__item--cta:hover {
    background: var(--color-red-hover);
  }

  .quicklinks__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .quicklinks__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
  }

  .quicklinks__desc {
    font-size: var(--text-xs);
    opacity: 0.7;
    line-height: var(--leading-snug);
  }

  .quicklinks__arrow {
    flex-shrink: 0;
    opacity: 0.5;
  }

  .quicklinks__item:hover .quicklinks__arrow {
    transform: translateX(3px);
    opacity: 1;
  }

  @media (max-width: 1024px) {
    .quicklinks__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .quicklinks__item:nth-child(2) { border-right: none; }
    .quicklinks__item:nth-child(3) { border-top: 1px solid var(--border); }
    .quicklinks__item:nth-child(4) { border-top: 1px solid var(--border); border-right: none; }
  }

  @media (max-width: 640px) {
    .quicklinks__grid {
      grid-template-columns: 1fr;
    }
    .quicklinks__item { border-right: none; border-bottom: 1px solid var(--border); }
    .quicklinks__item:last-child { border-bottom: none; }
  }
</style>
