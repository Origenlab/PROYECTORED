---
/**
 * StatsBarBomberos.astro
 * Barra de métricas clave — 4 stats en fondo rojo primario.
 * Patrón 100% homologado con StatsBarExtintores (L3 template aprobado).
 */
---

<section class="metricas-section" aria-label="Métricas clave de equipo para bomberos">
  <div class="container">
    <div class="metricas-grid">

      <div class="metrica-item">
        <span class="metrica-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </span>
        <span class="metrica-valor">5</span>
        <span class="metrica-label">Categorías de equipo<br>profesional NFPA</span>
      </div>

      <div class="metrica-item">
        <span class="metrica-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
        </span>
        <span class="metrica-valor">NFPA</span>
        <span class="metrica-label">1971 · 1851 · 1981<br>1983 · 1991 · NIOSH</span>
      </div>

      <div class="metrica-item">
        <span class="metrica-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </span>
        <span class="metrica-valor">24h</span>
        <span class="metrica-label">Respuesta a cotización<br>CDMX y Edo. Méx</span>
      </div>

      <div class="metrica-item metrica-item--last">
        <span class="metrica-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
        </span>
        <span class="metrica-valor">100%</span>
        <span class="metrica-label">Certificaciones<br>originales del fabricante</span>
      </div>

    </div>
  </div>
</section>

<!-- Estilos en pages.css (global) — sección EQUIPO PARA BOMBEROS -->
