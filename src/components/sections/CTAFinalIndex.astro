---
/**
 * CTAFinalIndex.astro
 * Barra de conversión final — fondo rojo con CTA primario + secundario.
 */
import { waUrl, WA_MESSAGES } from '../../config/site'

const waHref = waUrl(WA_MESSAGES.cotizacion)
---

<section class="cta-final-index" aria-label="Contactar a Proyecto Red">
  <div class="container cta-final-index__inner">

    <div class="cta-final-index__text">
      <h2>¿Necesitas equipo contra incendios en CDMX?</h2>
      <p>
        Mándanos un WhatsApp con lo que necesitas. Te respondemos con precios, disponibilidad
        y tiempos de entrega ese mismo día.
      </p>
    </div>

    <div class="cta-final-index__btns">
      <a
        href={waHref}
        class="btn-cta-wa"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Cotizar por WhatsApp"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Cotizar por WhatsApp
      </a>
      <a href="/productos/" class="btn-cta-ghost">Ver catálogo completo</a>
    </div>

  </div>
</section>

<style>
  .cta-final-index {
    background: var(--c-primary);
    padding: 4rem 0;
  }

  .cta-final-index__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }

  .cta-final-index__text h2 {
    font-size: clamp(1.375rem, 2.5vw, 1.875rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -.03em;
    line-height: 1.15;
    margin-bottom: 0.5rem;
  }

  .cta-final-index__text p {
    color: rgba(255,255,255,.75);
    font-size: 0.9375rem;
    max-width: 55ch;
    line-height: 1.6;
  }

  .cta-final-index__btns {
    display: flex;
    gap: 0.875rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .btn-cta-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #fff;
    color: var(--c-primary);
    padding: 0.875rem 1.75rem;
    border-radius: 4px;
    font-weight: 700;
    font-size: 0.9375rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .btn-cta-wa:hover {
    background: rgba(255,255,255,.9);
    color: var(--c-primary-dark);
  }

  .btn-cta-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 2px solid rgba(255,255,255,.5);
    color: #fff;
    padding: 0.8125rem 1.75rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .btn-cta-ghost:hover {
    border-color: #fff;
    background: rgba(255,255,255,.12);
    color: #fff;
  }

  @media (max-width: 768px) {
    .cta-final-index__inner { flex-direction: column; text-align: center; }
    .cta-final-index__btns { justify-content: center; }
    .cta-final-index__text p { max-width: 100%; }
  }
</style>
