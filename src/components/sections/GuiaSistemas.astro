---
/**
 * GuiaSistemas.astro — v1
 * Guía de selección por tipo de inmueble — 4 escenarios.
 * Patrón 100% homologado con GuiaMangueras / GuiaGabinetes.
 * Usa .guia-card y .guia-cta-bar (global pages.css) + scoped namespace .guia-sis.
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import Img from '../ui/Img.astro'
import { waUrl } from '../../config/site'
import '../../styles/pages.css'

const waHref = waUrl('Hola, necesito asesoría para el sistema contra incendio de mi inmueble. ¿Me pueden orientar sobre qué sistema necesito?')

const escenarios = [
  {
    img: '/imagenes/sistemas/rociadores.jpg',
    badge: 'Bodega / Nave industrial',
    norma: 'NFPA 13 · NFPA 20',
    titulo: 'Rociadores + Red Hidráulica',
    desc: 'Las bodegas son el riesgo más alto: carga de fuego elevada, poca supervisión y distancias largas. NFPA 13 exige rociadores automáticos cuando la carga de fuego supera ciertos umbrales o el área supera 300 m². La red hidráulica debe proveer la presión y el caudal para activar simultáneamente la zona más desfavorable.',
    specs: [
      'Rociadores colgantes o upright según altura de rack',
      'Bomba eléctrica + diésel conforme a NFPA 20',
      'Cálculo hidráulico para zona más desfavorable',
      'Toma siamesa en fachada para bomberos',
    ],
  },
  {
    img: '/imagenes/sistemas/alarmas.jpg',
    badge: 'Edificio de oficinas / Corporativo',
    norma: 'NFPA 72 · NFPA 13',
    titulo: 'Alarma Direccionable + Rociadores',
    desc: 'Un edificio corporativo necesita identificación exacta de zona y evacuación controlada por piso. El tablero FACP recibe la señal del detector, identifica exactamente dónde está el fuego, activa la alarma sonora en ese piso y en los pisos adyacentes, y envía alerta a monitoreo remoto — todo en segundos. Los rociadores en oficinas usan temperatura 57°C estándar.',
    specs: [
      'Tablero analógico-direccionable UL864',
      'Detectores fotoeléctricos por zona exacta',
      'Rociadores ocultos temperatura 57°C',
      'Monitoreo remoto 24/7 con notificación',
    ],
  },
  {
    img: '/imagenes/sistemas/detectores.jpg',
    badge: 'Restaurante / Cocina industrial',
    norma: 'NFPA 96 · NFPA 17A',
    titulo: 'Sistema Campana + Detección en Cocina',
    desc: 'Las cocinas industriales requieren un sistema específico: supresión química bajo la campana de extracción conforme a NFPA 96, más detección de humo en el comedor y zonas de servicio. Un extintor Tipo K no es suficiente — el sistema de campana actúa automáticamente al detectar calor excesivo y corta el gas simultáneamente, evitando reignición.',
    specs: [
      'Sistema supresión química bajo campana (NFPA 96)',
      'Interlock con válvula de gas automático',
      'Detectores de calor fijo en zona de cocina',
      'Detectores fotoeléctricos en comedor y servicio',
    ],
  },
  {
    img: '/imagenes/sistemas/tablero-control.jpg',
    badge: 'Centro de datos / Cuarto de servidores',
    norma: 'NFPA 75 · NFPA 2001',
    titulo: 'Agente Limpio + Detección Muy Temprana',
    desc: 'Los centros de datos no toleran agua. Un rociador activo destruye más equipo que el fuego mismo. La solución es agente limpio (FM-200, Novec 1230 o CO₂) con detección muy temprana VESDA — detecta partículas de humo antes de que haya llama. El sistema actúa en segundos, suprime el fuego sin residuo y sin daño a los equipos.',
    specs: [
      'Detección VESDA — muy temprana sin falsos positivos',
      'Agente limpio FM-200 o Novec 1230 (NFPA 2001)',
      'Pre-acción para protección doble contra activación accidental',
      'Tablero dedicado con monitoreo remoto e integración BMS',
    ],
  },
]
---

<section class="guia-sis" id="guia-sistemas" aria-labelledby="guia-sis-heading">
  <div class="container">

    <SectionHeaderDuo
      id="guia-sis-heading"
      eyebrow="Guía por tipo de inmueble"
      titleLine1="¿Qué Sistema Necesita"
      titleLine2="Tu Inmueble?"
      desc="Bodega, oficina, restaurante o centro de datos — cada riesgo tiene su sistema. Aquí está la solución correcta para cada caso."
      bodyPara1="No todos los inmuebles necesitan el mismo sistema. Una bodega con racks de almacenamiento tiene una carga de fuego completamente distinta a un corporativo de oficinas o a un cuarto de servidores. El sistema incorrecto puede activarse mal, no activarse, o causar más daño que el incendio mismo."
      bodyPara2="Hacemos diagnóstico gratuito del inmueble: evaluamos el riesgo, la normativa aplicable y el sistema más eficiente en costo-beneficio. Sin compromiso de compra."
    />

    <div class="guia-sis-grid">
      {escenarios.map((e, i) => (
        <article class="guia-card">
          <div class="guia-card__img-wrap">
            <Img
              src={e.img}
              alt={`Sistema contra incendio para ${e.badge} — Proyecto Red`}
              width={560}
              height={320}
              loading={i < 2 ? 'eager' : 'lazy'}
            />
            <span class="guia-card__badge">{e.badge}</span>
            <span class="guia-card__norma">{e.norma}</span>
          </div>
          <div class="guia-card__body">
            <h3 class="guia-card__title">{e.titulo}</h3>
            <p class="guia-card__desc">{e.desc}</p>
            <ul class="guia-card__specs">
              {e.specs.map(s => <li>{s}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <div class="guia-cta-bar">
      <div class="guia-cta-bar__text">
        <strong>¿No sabes qué sistema necesita tu inmueble?</strong>
        <span>Te hacemos un diagnóstico gratuito — evaluamos el riesgo, la normativa aplicable y el sistema correcto para tu caso.</span>
      </div>
      <a href={waHref} class="btn-primary" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Diagnóstico gratuito de mi inmueble
      </a>
    </div>

  </div>
</section>

<style>
  .guia-sis {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-surface, #F4F4F5);
    border-top: 1px solid var(--c-border);
  }

  .guia-sis-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  @media (max-width: 900px) { .guia-sis-grid { grid-template-columns: 1fr; } }
</style>
