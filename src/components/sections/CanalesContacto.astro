---
/**
 * CanalesContacto.astro
 * 4 canales de comunicación en grid profesional con SectionHeaderDuo.
 * WhatsApp destacado como canal principal.
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import { CONTACT, waUrl, WA_MESSAGES } from '../../config/site'

const waHref = waUrl(WA_MESSAGES.contacto)

const canales = [
  {
    titulo: 'WhatsApp',
    sub: 'La forma más rápida de contactarnos',
    dato: `+52 ${CONTACT.phone}`,
    href: waHref,
    external: true,
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
    badge: 'Respuesta inmediata',
    cta: 'Escribir ahora',
    accent: true,
  },
  {
    titulo: 'Teléfono',
    sub: 'Llamadas en horario de atención',
    dato: CONTACT.phone,
    href: `tel:+${CONTACT.whatsapp}`,
    external: false,
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>`,
    badge: null,
    cta: 'Llamar ahora',
    accent: false,
  },
  {
    titulo: 'Email',
    sub: 'Para cotizaciones formales y documentación',
    dato: CONTACT.email,
    href: `mailto:${CONTACT.email}`,
    external: false,
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
    badge: null,
    cta: 'Enviar correo',
    accent: false,
  },
  {
    titulo: 'Ubicación',
    sub: 'Centro de operaciones y almacén',
    dato: CONTACT.address,
    href: CONTACT.mapsUrl,
    external: true,
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
    badge: null,
    cta: 'Ver en mapa',
    accent: false,
  },
]
---

<section class="canales-contacto" aria-labelledby="canales-heading">
  <div class="container">

    <SectionHeaderDuo
      id="canales-heading"
      eyebrow="Cómo contactarnos"
      titleLine1="Elige el Canal que Prefieras —"
      titleLine2="Todos te Llevan al Mismo Equipo"
      desc="WhatsApp es el más rápido, pero respondemos en todos. Cotización gratuita y sin compromiso."
      bodyPara1="Cuando nos contactas — por cualquier canal — tu mensaje lo recibe directamente nuestro equipo técnico-comercial. No pasas por un call center ni por un sistema automatizado. Hablamos de precio real, disponibilidad inmediata y tiempos de entrega concretos."
      bodyPara2="Para cotizaciones formales o documentación de soporte (fichas técnicas, certificados NOM, propuestas para licitación), te recomendamos email. Para todo lo demás, WhatsApp es el canal más ágil."
    />

    <div class="canales-grid">
      {canales.map(c => (
        <a
          href={c.href}
          class:list={['canal-card', { 'canal-card--accent': c.accent }]}
          target={c.external ? '_blank' : undefined}
          rel={c.external ? 'noopener noreferrer' : undefined}
        >
          <div class="canal-card__header">
            <span class="canal-card__icon" set:html={c.icon} />
            {c.badge && <span class="canal-card__badge">{c.badge}</span>}
          </div>
          <div class="canal-card__body">
            <h3 class="canal-card__titulo">{c.titulo}</h3>
            <p class="canal-card__sub">{c.sub}</p>
            <p class="canal-card__dato">{c.dato}</p>
          </div>
          <div class="canal-card__footer">
            <span class="canal-card__cta">
              {c.cta}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .canales-contacto {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-white);
  }

  /* ── GRID ─────────────────────────────────────────── */
  .canales-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  /* ── CARD ──────────────────────────────────────────── */
  .canal-card {
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-decoration: none;
  }

  .canal-card:hover {
    border-color: var(--c-primary);
    box-shadow: 0 4px 20px rgba(196,30,36,.08);
  }

  /* ── ACCENT (WhatsApp) ─────────────────────────────── */
  .canal-card--accent {
    border-color: rgba(37, 211, 102, 0.25);
    background: linear-gradient(180deg, rgba(37, 211, 102, 0.03) 0%, var(--c-white) 100%);
  }

  .canal-card--accent:hover {
    border-color: #25D366;
    box-shadow: 0 4px 20px rgba(37, 211, 102, 0.12);
  }

  /* ── HEADER ────────────────────────────────────────── */
  .canal-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .canal-card__icon {
    width: 48px;
    height: 48px;
    background: var(--c-primary-light);
    color: var(--c-primary);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .canal-card--accent .canal-card__icon {
    background: #25D366;
    color: #fff;
  }

  .canal-card__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: #25D366;
    color: #fff;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: .03em;
    text-transform: uppercase;
    padding: .2rem .625rem;
    border-radius: 3px;
    white-space: nowrap;
  }

  /* ── BODY ──────────────────────────────────────────── */
  .canal-card__body {
    flex: 1;
  }

  .canal-card__titulo {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -.01em;
    margin-bottom: 0.25rem;
  }

  .canal-card__sub {
    font-size: 0.8125rem;
    color: var(--c-muted);
    line-height: 1.5;
    margin-bottom: 0.625rem;
  }

  .canal-card__dato {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--c-ink);
    line-height: 1.4;
  }

  /* ── FOOTER ────────────────────────────────────────── */
  .canal-card__footer {
    border-top: 1px solid var(--c-border);
    padding-top: 0.875rem;
  }

  .canal-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-primary);
  }

  .canal-card--accent .canal-card__cta {
    color: #25D366;
  }

  .canal-card:hover .canal-card__cta { gap: 0.625rem; }

  /* ── RESPONSIVE ────────────────────────────────────── */
  @media (max-width: 1200px) {
    .canales-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .canales-grid { grid-template-columns: 1fr; }
  }
</style>
