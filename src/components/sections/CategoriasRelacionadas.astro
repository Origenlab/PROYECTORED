---
/**
 * CategoriasRelacionadas.astro
 * ─────────────────────────────
 * Sección de cross-linking entre categorías L2 (hub-and-spoke SEO).
 * Se muestra al final de cada categoría /extintores/, /senalamientos/, etc.
 * para distribuir link equity, reducir dead-ends y mejorar navegación contextual.
 *
 * Uso:
 *   <CategoriasRelacionadas current="extintores" />
 *
 * El parámetro `current` excluye la categoría activa del listado mostrado.
 * Si no se pasa, muestra todas las categorías.
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import Img from '../ui/Img.astro'

interface Props {
  /** Slug de la categoría actual — se excluye del listado (ej. 'extintores') */
  current?: string
  /** Límite de categorías a mostrar (default 4) */
  limit?: number
  /** Título personalizado (default: "Categorías relacionadas") */
  titulo?: string
  /** Subtítulo personalizado */
  subtitulo?: string
}

const { current = '', limit = 4, titulo, subtitulo } = Astro.props

// Fuente única de categorías con copy afín para contextualizar el cross-link.
// Mantener sincronizado con PRODUCT_CATEGORIES de site.ts (forma simplificada
// con campos de presentación añadidos para esta sección).
const CATS = [
  {
    slug: 'extintores',
    label: 'Extintores',
    href: '/extintores/',
    desc: '10 tipos certificados NOM-154: PQS, CO₂, AFFF, Tipo K, agente limpio.',
    img: '/imagenes/extintores/extintores-contra-incendios.jpg',
    alt: 'Extintores certificados NOM-154-SCFI',
  },
  {
    slug: 'equipo-bomberos',
    label: 'Equipo para Bomberos',
    href: '/equipo-bomberos/',
    desc: 'Trajes NFPA 1971, ERA, complementos y herramientas de rescate.',
    img: '/imagenes/equipo-bomberos/equipo-bomberos-hero.jpg',
    alt: 'Equipo profesional para bomberos certificado NFPA',
  },
  {
    slug: 'senalamientos',
    label: 'Señalamientos de Emergencia',
    href: '/senalamientos/',
    desc: 'Fotoluminiscentes NOM-003-SEGOB con plano y levantamiento.',
    img: '/imagenes/senalamientos/senalamientos-hero.jpg',
    alt: 'Señalamientos fotoluminiscentes NOM-003-SEGOB',
  },
  {
    slug: 'gabinetes',
    label: 'Gabinetes y Porta Extintores',
    href: '/gabinetes/',
    desc: 'Resguardo para extintor, bombero e hidrante — lámina e instalación.',
    img: '/imagenes/gabinetes/gabinetes-extintores.jpg',
    alt: 'Gabinetes contra incendio para empresas',
  },
  {
    slug: 'mangueras',
    label: 'Mangueras y Herrajes',
    href: '/mangueras/',
    desc: 'Mangueras NFPA 1961, chiflones, válvulas y toma siamesa.',
    img: '/imagenes/mangueras/mangueras-hero.jpg',
    alt: 'Mangueras contra incendio NFPA 1961 y herrajes',
  },
  {
    slug: 'sistemas',
    label: 'Sistemas Contra Incendio',
    href: '/sistemas/',
    desc: 'Alarmas NFPA 72, rociadores NFPA 13, tableros FACP y redes hidráulicas.',
    img: '/imagenes/sistemas/alarmas.jpg',
    alt: 'Sistemas contra incendio NFPA 13 y NFPA 72',
  },
  {
    slug: 'primeros-auxilios',
    label: 'Primeros Auxilios',
    href: '/primeros-auxilios/',
    desc: 'Botiquines STPS tipo A/B/C, DEA, camillas y resurtido.',
    img: '/imagenes/primeros-auxilios/botiquines-hero.jpg',
    alt: 'Botiquines de primeros auxilios STPS',
  },
  {
    slug: 'equipo-seguridad',
    label: 'Equipo de Seguridad Industrial',
    href: '/equipo-seguridad/',
    desc: 'EPP NOM-017: casco, lentes, auditiva, respiratoria y alturas.',
    img: '/imagenes/equipo-seguridad/equipos-seguridad-hero.jpg',
    alt: 'EPP certificado NOM-017-STPS',
  },
]

// Excluye la categoría activa y aplica límite.
const visibles = CATS.filter((c) => c.slug !== current).slice(0, limit)

const h1 = titulo ?? 'Categorías relacionadas'
const sub = subtitulo ?? 'Proyecto Red integra todas las líneas de protección contra incendios bajo un solo proveedor.'
---

<section class="cats-rel" aria-labelledby="cats-rel-heading">
  <div class="container">

    <SectionHeaderDuo
      id="cats-rel-heading"
      eyebrow="Catálogo completo"
      titleLine1="Otras categorías"
      titleLine2="de protección"
      desc={sub}
      bodyPara1={`${h1} — cada línea está diseñada para resolver un riesgo específico, pero en conjunto forman un expediente completo de Protección Civil. Combinar extintores, señalización, gabinetes y sistemas con un solo proveedor simplifica el cumplimiento y la documentación.`}
      bodyPara2="Si tu empresa necesita cubrir varias categorías en el mismo proyecto, un solo contacto basta: cotización consolidada, una sola orden de compra, una sola facturación y entregas coordinadas en sitio. Escríbenos por WhatsApp y armamos el expediente completo."
    />

    <div class="cats-rel__grid" role="list" aria-label="Otras categorías de equipo contra incendios">
      {visibles.map((cat, i) => (
        <a href={cat.href} class="cats-rel__card" role="listitem" aria-label={cat.label}>
          <div class="cats-rel__media">
            <Img
              src={cat.img}
              alt={cat.alt}
              loading="lazy"
              width={480}
              height={270}
              sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 280px"
            />
          </div>
          <div class="cats-rel__body">
            <h3 class="cats-rel__title">{cat.label}</h3>
            <p class="cats-rel__desc">{cat.desc}</p>
            <span class="cats-rel__cta">
              Ver categoría
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .cats-rel {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-surface-alt, #FAFAFA);
  }

  .cats-rel__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .cats-rel__card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--c-border, #E4E4E7);
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
  }

  .cats-rel__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--c-ink, #111);
  }

  .cats-rel__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: .9;
  }

  .cats-rel__body {
    padding: 1.125rem 1.125rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .cats-rel__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-ink, #111);
    letter-spacing: -.02em;
    line-height: 1.25;
    padding-left: 0.625rem;
    border-left: 3px solid var(--c-primary, #C41E24);
  }

  .cats-rel__desc {
    font-size: 0.8125rem;
    color: var(--c-muted, #71717A);
    line-height: 1.5;
    flex: 1;
  }

  .cats-rel__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: auto;
    padding-top: 0.75rem;
    border-top: 1px solid var(--c-border, #E4E4E7);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-primary, #C41E24);
  }

  @media (max-width: 1200px) {
    .cats-rel__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 860px) {
    .cats-rel__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .cats-rel__grid { grid-template-columns: 1fr; gap: 1rem; }
  }
</style>
