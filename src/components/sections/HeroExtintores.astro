---
/**
 * HeroExtintores.astro — v3
 * Hero premium: H1 + subtítulo izq / 2 párrafos SEO der.
 * Patrón homologado con HeroIndex (L1). Gradientes multicapa, badge con pulso, glow animado.
 */
import { waUrl } from '../../config/site'
---

<section class="hero-ext" aria-label="Venta de extintores contra incendios en CDMX">

  <!-- Glow animado de fondo -->
  <div class="hero-ext__glow" aria-hidden="true"></div>
  <div class="hero-ext__grid-bg" aria-hidden="true"></div>

  <div class="container hero-ext__grid">

    <!-- ═══ Columna izquierda: badge + H1 + subtítulo ═══ -->
    <div class="hero-ext__left">

      <div class="hero-ext__badge" aria-hidden="true">
        <span class="badge-pulse"></span>
        <span class="badge-pulse-ring"></span>
        10 tipos · NOM-154-SCFI · CDMX y Edo. Méx
      </div>

      <h1 class="hero-ext__h1">
        Venta de <span class="h1-accent">Extintores</span><br>
        Contra Incendios
      </h1>

      <p class="hero-ext__sub">
        ¿Tienes extintores vencidos, del tipo incorrecto o sin señalamiento? El agente incorrecto
        puede agravar el fuego en lugar de apagarlo. Extintor certificado NOM desde
        <strong>$450 MXN</strong> — asesoría técnica incluida y entrega el mismo día en CDMX.
      </p>

    </div>

    <!-- ═══ Columna derecha: texto SEO ═══ -->
    <div class="hero-ext__right">
      <p>
        Los extintores son la primera línea de defensa frente a un conato de incendio. Tener el
        tipo correcto, en la capacidad adecuada y con el mantenimiento al día es la diferencia entre
        un siniestro controlado en 30 segundos y una evacuación total con pérdidas materiales.
      </p>
      <p>
        En Proyecto Red vendemos extintores certificados NOM-154-SCFI para todos los tipos de fuego:
        polvo seco ABC, CO₂, AFFF espuma, Tipo K para cocinas, agente limpio, Cold Fire y
        automáticos. Cada unidad incluye ficha técnica, certificado de conformidad y soporte de
        pared. Proveedor directo — sin intermediarios.
      </p>
    </div>

  </div>
</section>


<style>
  /* ══════════════════════════════════════════════════════════
     HERO EXTINTORES — v3 Premium (patrón L1)
     ══════════════════════════════════════════════════════════ */

  .hero-ext {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background:
      linear-gradient(160deg, #080808 0%, #130A0A 40%, #1A0D0D 60%, #0A0A0A 100%);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  /* ── Glow animado ── */
  .hero-ext__glow {
    position: absolute;
    width: 700px;
    height: 700px;
    top: -20%;
    right: -10%;
    background: radial-gradient(circle, rgba(196,30,36,0.15) 0%, rgba(196,30,36,0.05) 40%, transparent 70%);
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }

  /* ── Grid sutil de fondo ── */
  .hero-ext__grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 30%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 50%, black 30%, transparent 70%);
    pointer-events: none;
  }

  /* ── Layout ── */
  .hero-ext__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── Badge con pulso ── */
  .hero-ext__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(196,30,36,0.4);
    background: rgba(196,30,36,0.08);
    color: rgba(255,255,255,0.85);
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.375rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    letter-spacing: .01em;
    position: relative;
    backdrop-filter: blur(8px);
  }

  .badge-pulse {
    width: 7px;
    height: 7px;
    background: var(--c-primary);
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
  }

  .badge-pulse-ring {
    position: absolute;
    left: 0.9375rem;
    top: 50%;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--c-primary);
    transform: translateY(-50%);
    pointer-events: none;
  }

  /* ── H1 ── */
  .hero-ext__h1 {
    font-size: clamp(2.25rem, 4.5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -.035em;
    margin-bottom: 1.25rem;
  }

  .h1-accent { color: var(--c-primary); }

  /* ── Subtítulo ── */
  .hero-ext__sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.7;
    max-width: 52ch;
  }

  .hero-ext__sub strong {
    color: rgba(255,255,255,0.9);
    font-weight: 700;
  }

  /* ═══ Columna derecha: texto SEO ═══ */
  .hero-ext__right p {
    color: rgba(255,255,255,0.55);
    font-size: 0.9375rem;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  .hero-ext__right p:last-child {
    margin-bottom: 0;
  }

  /* ═══ RESPONSIVE ═══ */
  @media (max-width: 1024px) {
    .hero-ext { padding-top: 3.5rem; padding-bottom: 3.5rem; }
    .hero-ext__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .hero-ext { padding-bottom: 3rem; }
  }
</style>
