---
/**
 * HeroExtintores.astro
 * Hero de la categoría de extintores — 2 columnas: H1 + CTAs izq / texto SEO der
 * Barra de métricas roja. Patrón aprobado HeroIndex.
 */
import { waUrl } from '../../config/site'

const waHref = waUrl('Hola, necesito cotizar extintores contra incendios')
---

<section class="hero-extintores" aria-label="Venta de extintores contra incendios en CDMX">
  <div class="container hero-extintores__grid">

    <!-- Columna izquierda: H1 + badge + CTAs -->
    <div class="hero-extintores__left">

      <div class="hero-badge" aria-hidden="true">
        <span class="badge-dot"></span>
        10 tipos · NOM-154-SCFI · CDMX y Estado de México
      </div>

      <h1 class="hero-extintores__h1">
        Venta de <span class="h1-accent">Extintores</span><br>
        Contra Incendios
      </h1>

      <p class="hero-extintores__sub">
        ¿Tienes extintores vencidos, del tipo incorrecto o sin señalamiento? El agente incorrecto
        puede agravar el fuego en lugar de apagarlo. Extintor certificado NOM desde $450 MXN —
        asesoría técnica incluida y entrega el mismo día en CDMX.
      </p>

      <div class="hero-extintores__ctas">
        <a
          href={waHref}
          class="btn-primary"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Cotizar extintores por WhatsApp"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Cotizar extintores
        </a>
        <a href="#catalogo-extintores" class="btn-secondary">Ver todos los tipos</a>
      </div>

    </div>

    <!-- Columna derecha: texto SEO -->
    <div class="hero-extintores__right">
      <p>
        Los extintores son la primera línea de defensa frente a un conato de incendio. Tener el
        tipo correcto, en la capacidad adecuada y con el mantenimiento al día es la diferencia entre
        un siniestro controlado en 30 segundos y una evacuación total con pérdidas materiales.
      </p>
      <p>
        En Proyecto Red vendemos extintores certificados NOM-154-SCFI para todos los tipos de fuego:
        polvo seco ABC, CO₂, AFFF espuma, Tipo K para cocinas, agente limpio, Cold Fire y
        automáticos. Cada unidad incluye ficha técnica, certificado de conformidad y soporte de
        pared. Proveedor directo — sin intermediarios.
      </p>
    </div>

  </div>
</section>


<style>
  /* ── HERO ─────────────────────────────────────────────── */
  .hero-extintores {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background:
      radial-gradient(ellipse 55% 65% at 75% 50%, rgba(196,30,36,.13) 0%, transparent 65%),
      linear-gradient(160deg, #0A0A0A 0%, #160A0A 50%, #0A0A0A 100%);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .hero-extintores__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* Badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid rgba(196,30,36,.4);
    background: rgba(196,30,36,.1);
    color: rgba(255,255,255,.8);
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.3125rem 0.875rem;
    border-radius: 100px;
    margin-bottom: 1.25rem;
    letter-spacing: .01em;
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    background: var(--c-primary);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* H1 */
  .hero-extintores__h1 {
    font-size: clamp(2.25rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -.03em;
    margin-bottom: 1.125rem;
  }

  .h1-accent { color: var(--c-primary); }

  /* Subtítulo */
  .hero-extintores__sub {
    font-size: 1rem;
    color: rgba(255,255,255,.65);
    line-height: 1.65;
    margin-bottom: 2rem;
    max-width: 52ch;
  }

  /* CTAs */
  .hero-extintores__ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  /* Columna derecha texto */
  .hero-extintores__right p {
    color: rgba(255,255,255,.55);
    font-size: 0.9375rem;
    line-height: 1.75;
    margin-bottom: 1rem;
  }

  /* ── RESPONSIVE ───────────────────────────────────────── */
  @media (max-width: 1024px) {
    .hero-extintores { padding-top: 3rem; }
    .hero-extintores__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  @media (max-width: 768px) {
    .hero-extintores__ctas { flex-direction: column; }
    .hero-extintores { padding-bottom: 3rem; }
  }
</style>
