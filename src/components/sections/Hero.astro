---
// Hero.astro
// Hero section reutilizable — idéntico en todas las páginas de Nivel 2
// Fondo oscuro, 2 columnas, badge, título con acento, 2 CTAs

import Breadcrumb from '../ui/Breadcrumb.astro'
import type { BreadcrumbItem } from '../../layouts/CategoryLayout.astro'

interface HeroCTA {
  text: string
  href: string
  variant?: 'primary' | 'outline'
}

interface Props {
  badge: string
  title: string
  accent: string          // Última(s) palabras del título en rojo
  subtitle: string        // Párrafo izquierdo debajo del H1
  descRight: string[]     // Párrafos columna derecha
  cta1: HeroCTA
  cta2: HeroCTA
  breadcrumb: BreadcrumbItem[]
}

const { badge, title, accent, subtitle, descRight, cta1, cta2, breadcrumb } = Astro.props
---

<section class="hero section--dark">
  <div class="container hero__inner">

    <!-- Columna izquierda -->
    <div class="hero__left">
      <Breadcrumb items={breadcrumb} />

      <span class="hero__badge">
        <span class="hero__badge-dot" aria-hidden="true"></span>
        {badge}
      </span>

      <h1 class="hero__title">
        {title}
        <span class="text-accent">{accent}</span>
      </h1>

      <p class="hero__subtitle">{subtitle}</p>

      <div class="hero__ctas">
        <a
          href={cta1.href}
          class="btn btn--primary"
          target={cta1.href.startsWith('https') ? '_blank' : undefined}
          rel={cta1.href.startsWith('https') ? 'noopener noreferrer' : undefined}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {cta1.text}
        </a>

        <a
          href={cta2.href}
          class="btn btn--outline-white"
        >
          {cta2.text}
        </a>
      </div>
    </div>

    <!-- Columna derecha -->
    <div class="hero__right" aria-hidden="false">
      {descRight.map((p) => <p class="hero__desc">{p}</p>)}
    </div>

  </div>
</section>

<style>
  .hero {
    padding-block: clamp(3rem, 6vw, 5rem);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }

  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-4);
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: rgba(255,255,255,0.9);
    margin-bottom: var(--sp-5);
  }

  .hero__badge-dot {
    width: 6px;
    height: 6px;
    background: var(--color-red-light);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero__title {
    font-size: var(--text-4xl);
    font-weight: var(--weight-black);
    line-height: var(--leading-tight);
    color: var(--color-white);
    margin-bottom: var(--sp-5);
    letter-spacing: -0.02em;
  }

  .hero__subtitle {
    font-size: var(--text-base);
    color: rgba(255,255,255,0.75);
    line-height: var(--leading-relaxed);
    max-width: 50ch;
    margin-bottom: var(--sp-8);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }

  .hero__right {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .hero__desc {
    font-size: var(--text-base);
    color: rgba(255,255,255,0.75);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
    .hero__right { display: none; }
  }
</style>
