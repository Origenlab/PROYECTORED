---
/**
 * GuiaCategoria.astro
 * Guía de selección por escenario — 4 cards con imagen + CTA bar final.
 * Estilos de cards/cta-bar: .guia-* global (pages.css).
 *
 * Sustituye a los 8 antiguos clones Guia{Extintores,Bomberos,...}.astro.
 * Soporta dos modos por escenario:
 *   - necesitas: string   → párrafo (extintores, bomberos, gabinetes, mangueras, senalamientos)
 *   - necesitas: string[] → subtítulo + lista (sistemas, primeros-auxilios, equipo-seguridad)
 *
 * Contenido por categoría: src/data/guias-categorias.ts
 * Uso:  <GuiaCategoria {...GUIA_CATEGORIAS['gabinetes']} />
 */
import SectionHeaderDuo from '../ui/SectionHeaderDuo.astro'
import Img from '../ui/Img.astro'
import { waUrl } from '../../config/site'
import type { GuiaCategoriaConfig } from '../../data/guias-categorias'

type Props = GuiaCategoriaConfig

const { id, header, gridAria, cardCta, escenarios, ctaBar } = Astro.props
const waHref = waUrl(ctaBar.waMessage)
---

<section class="guia-categoria" id={`guia-${id}`} aria-labelledby={`guia-${id}-heading`}>
  <div class="container">

    <SectionHeaderDuo
      id={`guia-${id}-heading`}
      eyebrow={header.eyebrow}
      titleLine1={header.titleLine1}
      titleLine2={header.titleLine2}
      desc={header.desc}
      bodyPara1={header.bodyPara1}
      bodyPara2={header.bodyPara2}
    />

    <div class="guia-grid" role="list" aria-label={gridAria}>
      {escenarios.map((esc, i) => (
        <article class="guia-card" role="listitem">
          <div class="guia-card__header">
            <Img
              src={esc.img}
              alt={esc.imgAlt}
              width={640}
              height={360}
              loading={i < 2 ? 'eager' : 'lazy'}
              class="guia-card__img"
            />
            <span class="guia-card__badge">{esc.norma}</span>
            <span class="guia-card__num">{esc.num}</span>
          </div>
          <div class="guia-card__body">
            <h3 class="guia-card__tipo">{esc.tipo}</h3>

            <div class="guia-card__block">
              <span class="guia-label">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
                Qué necesitas
              </span>
              {Array.isArray(esc.necesitas) ? (
                <>
                  {esc.subtitulo && <strong class="guia-card__sub">{esc.subtitulo}</strong>}
                  <ul class="guia-card__list">
                    {esc.necesitas.map(item => <li>{item}</li>)}
                  </ul>
                </>
              ) : (
                <p>{esc.necesitas}</p>
              )}
            </div>

            <div class="guia-card__block guia-card__block--muted">
              <span class="guia-label">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                Por qué
              </span>
              <p>{esc.porque}</p>
            </div>

            <a href={esc.href} class="guia-card__cta" target="_blank" rel="noopener noreferrer">
              {cardCta}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <div class="guia-cta-bar">
      <div class="guia-cta-bar__left">
        <div class="guia-cta-bar__icon" aria-hidden="true" set:html={ctaBar.iconSvg} />
        <div class="guia-cta-bar__text">
          <strong set:html={ctaBar.strongHtml}></strong>
          <span set:html={ctaBar.spanHtml}></span>
        </div>
      </div>
      <a href={waHref} class="btn-primary guia-cta-bar__btn" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        {ctaBar.btnLabel}
      </a>
    </div>

  </div>
</section>

<style>
  .guia-categoria {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-surface, #F4F4F5);
    border-top: 1px solid var(--c-border);
  }

  /* Pulido de hover del patrón v3 (ex GuiaExtintores), ahora para todas
     las categorías. El resto de estilos .guia-* vive en pages.css. */
  .guia-categoria :global(.guia-card:hover) {
    box-shadow: 0 12px 32px rgba(196,30,36,0.10), 0 4px 12px rgba(0,0,0,0.08);
    border-color: rgba(196,30,36,0.25);
  }

  .guia-categoria :global(.guia-cta-bar:hover) {
    box-shadow: 0 4px 20px rgba(196,30,36,0.06);
  }
</style>
