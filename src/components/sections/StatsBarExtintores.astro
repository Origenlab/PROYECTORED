---
/**
 * StatsBarExtintores.astro
 * Barra de métricas clave — 4 stats en fondo rojo primario.
 * Patrón homologado con .metricas-* de L1 (pages.css).
 * Micro-animación: contadores se animan al entrar en viewport.
 */
---

<section class="metricas-section" aria-label="Métricas clave de extintores">
  <div class="container">
    <div class="metricas-grid">

      <div class="metrica-item">
        <span class="metrica-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 6v6l4 2"/></svg>
        </span>
        <span class="metrica-valor" data-target="10">10</span>
        <span class="metrica-label">Tipos de extintor<br>certificados NOM</span>
      </div>

      <div class="metrica-item">
        <span class="metrica-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        </span>
        <span class="metrica-valor">$450</span>
        <span class="metrica-label">MXN precio base<br>extintor PQS 4.5 kg</span>
      </div>

      <div class="metrica-item">
        <span class="metrica-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </span>
        <span class="metrica-valor">24h</span>
        <span class="metrica-label">Entrega en CDMX<br>y Estado de México</span>
      </div>

      <div class="metrica-item metrica-item--last">
        <span class="metrica-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><path d="M22 4L12 14.01l-3-3"/></svg>
        </span>
        <span class="metrica-valor">NOM</span>
        <span class="metrica-label">Certificación<br>NOM-154-SCFI</span>
      </div>

    </div>
  </div>
</section>

<style>
  .metricas-section {
    background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark, #A01820) 100%);
    padding: 0;
    position: relative;
    overflow: hidden;
  }

  .metricas-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 50%, rgba(255,255,255,0.06) 0%, transparent 50%),
      radial-gradient(circle at 80% 50%, rgba(0,0,0,0.1) 0%, transparent 50%);
    pointer-events: none;
  }

  .metricas-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
    z-index: 1;
  }

  .metrica-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1rem;
    border-right: 1px solid rgba(255,255,255,0.15);
    position: relative;
  }

  .metrica-item--last,
  .metrica-item:last-child {
    border-right: none;
  }

  .metrica-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(255,255,255,0.12);
    color: #fff;
    margin-bottom: 0.75rem;
    backdrop-filter: blur(4px);
  }

  .metrica-valor {
    font-size: 2rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.375rem;
  }

  .metrica-label {
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.72);
    font-weight: 500;
    line-height: 1.35;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .metricas-grid { grid-template-columns: repeat(2, 1fr); }
    .metrica-item:nth-child(2) { border-right: none; }
    .metrica-item:nth-child(3),
    .metrica-item:nth-child(4) { border-top: 1px solid rgba(255,255,255,0.15); }
  }

  @media (max-width: 480px) {
    .metrica-item { padding: 1.5rem 0.75rem; }
    .metrica-valor { font-size: 1.625rem; }
  }
</style>
