---
/**
 * TrustIndex.astro
 * Sección "Por qué Proyecto Red" — 2 columnas: header izq + 4 cards razones.
 * Usa SectionHeader.astro (complemento aprobado).
 */
import { waUrl, WA_MESSAGES } from '../../config/site'

const waHref = waUrl(WA_MESSAGES.default)

const razones = [
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    titulo: 'Certificación NOM e internacional',
    desc: 'Todo lo que vendemos cumple con la normativa mexicana e internacional. Pasa tus inspecciones de las autoridades competentes sin contratiempos.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>`,
    titulo: 'Entrega directa en CDMX y EDOMEX',
    desc: 'Somos proveedor directo. Sin intermediarios que encarecen el precio o alargan los tiempos. Entregamos en toda la zona metropolitana.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    titulo: 'Cotización en menos de 24 horas',
    desc: 'Mándanos un WhatsApp con lo que necesitas y te respondemos con precios reales, disponibilidad y tiempos de entrega ese mismo día.',
  },
  {
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
    titulo: 'Asesoría técnica incluida',
    desc: 'Nuestro equipo analiza tu tipo de riesgo y te recomienda el equipo correcto. No vendemos por volumen — vendemos lo que tu negocio realmente necesita.',
  },
]
---

<section class="trust-index" aria-labelledby="trust-heading">
  <div class="container trust-index__inner">

    <!-- Columna izquierda: header + CTAs -->
    <div class="trust-index__header">
      <p class="trust-eyebrow" aria-hidden="true">Por qué elegirnos</p>
      <h2 id="trust-heading" class="trust-title">
        Equipo Certificado.<br>
        <span>Entrega Directa.</span>
      </h2>
      <p class="trust-desc">
        Llevamos años equipando empresas en la CDMX y el Estado de México. Catálogo amplio,
        equipo certificado y alguien que responde cuando lo necesitas.
      </p>
      <div class="trust-ctas">
        <a href="/servicios/" class="btn-outline">Ver todos los servicios</a>
        <a
          href={waHref}
          class="btn-ghost"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Hablar con un especialista por WhatsApp"
        >
          Hablar con un especialista
        </a>
      </div>
    </div>

    <!-- Columna derecha: 4 razones en grid -->
    <div class="trust-index__grid" role="list" aria-label="Razones para elegir Proyecto Red">
      {razones.map(r => (
        <article class="trust-item" role="listitem">
          <div class="trust-icon" set:html={r.icon} />
          <h3 class="trust-item__titulo">{r.titulo}</h3>
          <p class="trust-item__desc">{r.desc}</p>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .trust-index {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-white);
    border-top: 1px solid var(--c-border);
  }

  .trust-index__inner {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: 5rem;
    align-items: start;
  }

  /* ── HEADER ───────────────────────────────────────────── */
  .trust-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-primary);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 0.75rem;
  }

  .trust-title {
    font-size: clamp(1.75rem, 2.5vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -.03em;
    line-height: 1.1;
    color: var(--c-ink);
    margin-bottom: 1rem;
  }

  .trust-title span { color: var(--c-primary); }

  .trust-desc {
    font-size: 0.9375rem;
    color: var(--c-muted);
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .trust-ctas {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 2px solid rgba(196,30,36,.2);
    color: var(--c-muted);
    padding: 0.8125rem 1.75rem;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.9375rem;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--c-primary);
    color: var(--c-primary);
  }

  /* ── GRID RAZONES ─────────────────────────────────────── */
  .trust-index__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .trust-item {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .trust-icon {
    width: 48px;
    height: 48px;
    background: var(--c-primary-light, #F9E8E8);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-primary);
    flex-shrink: 0;
    margin-bottom: 0.25rem;
  }

  .trust-item__titulo {
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -.01em;
    line-height: 1.3;
  }

  .trust-item__desc {
    font-size: 0.875rem;
    color: var(--c-muted);
    line-height: 1.65;
  }

  /* ── RESPONSIVE ───────────────────────────────────────── */
  @media (max-width: 1200px) {
    .trust-index__inner { grid-template-columns: 320px 1fr; gap: 3.5rem; }
  }

  @media (max-width: 1024px) {
    .trust-index__inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .trust-index__grid { grid-template-columns: repeat(2, 1fr); }
    .trust-ctas { flex-direction: row; flex-wrap: wrap; }
  }

  @media (max-width: 600px) {
    .trust-index__grid { grid-template-columns: 1fr; }
    .trust-ctas { flex-direction: column; }
  }
</style>
