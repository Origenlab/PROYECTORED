---
/**
 * ReviewsIndex.astro
 * Reseñas verificadas de empresas clientes — grid con schema Review.
 * Usa SectionHeader.astro (complemento aprobado).
 */

const reviews = [
  {
    avatar: 'https://mantenimientodeextintores.mx/favicon.ico',
    initials: 'ME',
    empresa: 'MantenimientoDeExtintores.mx',
    giro: 'Empresa líder en extintores · CDMX y Estado de México',
    url: 'https://mantenimientodeextintores.mx/',
    texto: 'Con más de 80 años en venta y mantenimiento de extintores en CDMX, sabemos reconocer un proveedor serio. Proyecto Red cumple: producto certificado que cumple la normativa vigente, entrega puntual y documentación lista para Protección Civil. Es el aliado que buscábamos para complementar nuestro inventario cuando los volúmenes lo exigen.',
    rating: 5,
  },
  {
    avatar: 'https://lgacontraincendios.com/favicon.ico',
    initials: 'LGA',
    empresa: 'LGA Contra Incendios',
    giro: 'Venta de equipos contra incendios · Querétaro',
    url: 'https://lgacontraincendios.com/',
    texto: 'Desde Querétaro necesitábamos un proveedor confiable en CDMX para equipo certificado y suministros especializados que no encontramos localmente. Proyecto Red resolvió en 48 horas: entrega puntual, documentación NOM completa y sin un solo error en el pedido. Hoy son nuestro proveedor fijo para la zona metropolitana.',
    rating: 5,
  },
  {
    avatar: 'https://decalentadoressolares.com/favicon.ico',
    initials: 'CS',
    empresa: 'DeCalentadoresSolares.com',
    giro: 'Instalación solar residencial, comercial e industrial · CDMX',
    url: 'https://decalentadoressolares.com/',
    texto: 'En instalaciones solares para edificios y hoteles en CDMX, cada proyecto requiere equipamiento y señalización antes de la entrega final. Proyecto Red nos surte todo con documentación NOM lista para el expediente de Protección Civil. Rápidos, organizados y sin errores en la facturación — exactamente lo que necesitamos cuando manejamos varios proyectos al mismo tiempo.',
    rating: 5,
  },
  {
    avatar: 'https://maquinasdeconstruccion.com/favicon.ico',
    initials: 'MC',
    empresa: 'MaquinasDeContruccion.com',
    giro: 'Renta y venta de maquinaria de construcción · México',
    url: 'https://maquinasdeconstruccion.com/',
    texto: 'En obra, cada máquina tiene que tener su equipo portátil y cada área su señalización antes de que llegue la supervisión. Proyecto Red nos surte cilindros de polvo seco y señalización para todos nuestros frentes de trabajo en CDMX y Edomex. Respuesta el mismo día, precios directos y facturas en orden. Eso vale mucho cuando tienes cinco obras corriendo al mismo tiempo.',
    rating: 5,
  },
  {
    avatar: 'https://equipo-de-seguridad-industrial.com/favicon.ico',
    initials: 'SI',
    empresa: 'SEIND — Equipo de Seguridad Industrial',
    giro: 'EPP, señalización y equipos CI · República Mexicana',
    url: 'https://equipo-de-seguridad-industrial.com/',
    texto: 'En SEIND manejamos EPP, señalización y equipos contra incendios para clientes industriales en toda la república. Cuando necesitamos reforzar inventario de cilindros y compartimentos de resguardo en CDMX, Proyecto Red es nuestra primera llamada. Stock real, documentación NOM sin trámites extras y entrega el mismo día en la zona metropolitana.',
    rating: 5,
  },
  {
    avatar: 'https://sanyo-elevadoresyescaleras.com/favicon.ico',
    initials: 'SE',
    empresa: 'Sanyo Elevadores y Escaleras',
    giro: 'Venta, instalación y mantenimiento de elevadores · México',
    url: 'https://sanyo-elevadoresyescaleras.com/',
    texto: 'Cada edificio donde instalamos o modernizamos un elevador necesita señalización de evacuación y equipo portátil actualizado antes de la entrega final — es parte del expediente NOM-207. Proyecto Red nos tiene todo listo en tiempo: señalización fotoluminiscente, equipo certificado y la documentación que piden las autoridades. Sin ellos, nuestros proyectos se atrasan.',
    rating: 5,
  },
]

const STAR_PATH = 'M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z'
---

<section class="reviews-index" aria-labelledby="reviews-heading">
  <div class="container">

    <div class="reviews-index__top">
      <p class="rev-eyebrow">Lo que dicen nuestros clientes</p>
      <h2 id="reviews-heading" class="rev-titulo">
        Empresas que confían<br>
        <span>en Proyecto Red</span>
      </h2>
    </div>

    <div class="reviews-grid" role="list" aria-label="Reseñas de clientes de Proyecto Red">
      {reviews.map(r => (
        <article
          class="review-card"
          role="listitem"
          itemscope
          itemtype="https://schema.org/Review"
        >
          <!-- Rating -->
          <div class="review-card__top">
            <div class="review-stars" aria-label={`${r.rating} de 5 estrellas`} role="img">
              {Array.from({ length: r.rating }).map(() => (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={STAR_PATH}/>
                </svg>
              ))}
            </div>
            <span class="review-verified">Empresa verificada</span>
          </div>

          <!-- Texto -->
          <blockquote class="review-texto" itemprop="reviewBody">
            "{r.texto}"
          </blockquote>

          <!-- Autor -->
          <div class="review-author" itemprop="author" itemscope itemtype="https://schema.org/Organization">
            <div class="review-logo">
              <img
                src={r.avatar}
                alt={r.empresa}
                width="32"
                height="32"
                loading="lazy"
                onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
              />
              <span class="review-initials" style="display:none" aria-hidden="true">{r.initials}</span>
            </div>
            <div class="review-info">
              <strong itemprop="name">{r.empresa}</strong>
              <span>{r.giro}</span>
              <a
                href={r.url}
                target="_blank"
                rel="noopener noreferrer"
                class="review-link"
                aria-label={`Visitar ${r.empresa}`}
              >
                {r.url.replace('https://', '').replace(/\/$/, '')}
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .reviews-index {
    padding: var(--section-py, 5rem) 0;
    background: var(--c-surface, #F4F4F5);
  }

  /* ── TOP ──────────────────────────────────────────────── */
  .reviews-index__top {
    text-align: center;
    margin-bottom: 3rem;
  }

  .rev-eyebrow {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-primary);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin-bottom: 0.75rem;
  }

  .rev-titulo {
    font-size: clamp(1.75rem, 2.5vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -.03em;
    line-height: 1.1;
    color: var(--c-ink);
  }

  .rev-titulo span { color: var(--c-primary); }

  /* ── GRID ─────────────────────────────────────────────── */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  /* ── CARD ─────────────────────────────────────────────── */
  .review-card {
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: 8px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Top: stars + badge */
  .review-card__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .review-stars {
    display: flex;
    gap: 0.125rem;
    color: #F59E0B;
  }

  .review-verified {
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: #16A34A;
    background: #DCFCE7;
    padding: .2rem .5rem;
    border-radius: 3px;
  }

  /* Texto */
  .review-texto {
    font-size: 0.875rem;
    color: var(--c-ink-2);
    line-height: 1.7;
    flex: 1;
    font-style: italic;
  }

  /* Autor */
  .review-author {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding-top: 1rem;
    border-top: 1px solid var(--c-border);
  }

  .review-logo {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    border: 1px solid var(--c-border);
    overflow: hidden;
    flex-shrink: 0;
    background: var(--c-surface);
  }

  .review-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 4px;
  }

  .review-initials {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6875rem;
    font-weight: 700;
    color: var(--c-primary);
    background: var(--c-primary-light);
  }

  .review-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .review-info strong {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -.01em;
    line-height: 1.2;
  }

  .review-info span {
    font-size: 0.75rem;
    color: var(--c-muted);
    line-height: 1.3;
  }

  .review-link {
    font-size: 0.75rem;
    color: var(--c-primary);
    font-weight: 500;
    text-decoration: none;
  }

  .review-link:hover { text-decoration: underline; }

  /* ── RESPONSIVE ───────────────────────────────────────── */
  @media (max-width: 1200px) {
    .reviews-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .reviews-grid { grid-template-columns: 1fr; }
  }
</style>
