---
/**
 * HeroContacto.astro
 * Hero de la página de contacto — mismo patrón visual que HeroProductos.
 * Izq: badge + H1 + sub + CTAs / Der: párrafos descriptivos.
 */
import { waUrl, WA_MESSAGES, CONTACT } from '../../config/site'

const waHref = waUrl(WA_MESSAGES.contacto)
---

<section class="hero-contacto" aria-label="Contacto y cotización de equipos contra incendios">
  <div class="container hero-contacto__grid">

    <!-- ── Columna izquierda ── -->
    <div class="hero-contacto__left">

      <div class="hero-badge" aria-hidden="true">
        <span class="badge-pulse"></span>
        Respuesta en menos de 24 horas
      </div>

      <h1 class="hero-contacto__h1">
        Contacto y<br>
        <span class="h1-accent">Cotización Directa</span>
      </h1>

      <p class="hero-contacto__sub">
        Escríbenos por WhatsApp, llámanos o envía el formulario. Te respondemos con precio real,
        disponibilidad y tiempo de entrega — sin compromiso y sin intermediarios.
      </p>

      <div class="hero-contacto__ctas">
        <a
          href={waHref}
          class="btn-primary"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp directo
        </a>
        <a href="#cotizacion-contacto" class="btn-secondary">Formulario de cotización</a>
      </div>

      <div class="hero-contacto__trust">
        <span class="hero-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Cotización sin compromiso
        </span>
        <span class="hero-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Asesoría técnica gratuita
        </span>
        <span class="hero-trust-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Factura electrónica CFDI
        </span>
      </div>

    </div>

    <!-- ── Columna derecha: dos párrafos ── -->
    <div class="hero-contacto__right">
      <p>
        En Proyecto Red no usamos formularios genéricos que nadie contesta. Cuando nos escribes,
        te responde alguien que conoce el equipo, entiende la normativa y te puede dar un precio
        real con tiempo de entrega concreto.
      </p>
      <p>
        Nuestro canal principal es WhatsApp — ahí es donde respondemos más rápido. Pero también
        puedes llamarnos al <strong>{CONTACT.phone}</strong>, mandarnos un correo a
        <strong>{CONTACT.email}</strong> o llenar el formulario de cotización en esta misma página.
      </p>
    </div>

  </div>
</section>

<style>
  /* ── HERO CONTACTO ────────────────────────────────── */
  .hero-contacto {
    padding-top: 5rem;
    padding-bottom: 5rem;
    background:
      radial-gradient(ellipse 55% 65% at 75% 50%, rgba(196,30,36,.13) 0%, transparent 65%),
      linear-gradient(160deg, #0A0A0A 0%, #160A0A 50%, #0A0A0A 100%);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .hero-contacto::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .badge-pulse {
    width: 7px;
    height: 7px;
    background: var(--c-primary);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero-contacto__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  /* ── TIPOGRAFÍA H1 ─────────────────────────────────── */
  .hero-contacto__h1 {
    font-size: clamp(2.5rem, 4.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -.03em;
    margin-bottom: 1.25rem;
  }

  /* ── SUBTÍTULO ─────────────────────────────────────── */
  .hero-contacto__sub {
    font-size: 1.0625rem;
    color: rgba(255,255,255,.6);
    line-height: 1.65;
    max-width: 50ch;
    margin-bottom: 1.75rem;
  }

  /* ── CTAs ───────────────────────────────────────────── */
  .hero-contacto__ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  /* ── TRUST SIGNALS ─────────────────────────────────── */
  .hero-contacto__trust {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .hero-trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.8125rem;
    color: rgba(255,255,255,.5);
    font-weight: 500;
  }

  .hero-trust-item svg {
    color: #25D366;
    flex-shrink: 0;
  }

  /* ── COLUMNA DERECHA ───────────────────────────────── */
  .hero-contacto__right p {
    color: rgba(255,255,255,.55);
    font-size: 0.9375rem;
    line-height: 1.75;
    margin-bottom: 1.25rem;
  }
  .hero-contacto__right p:last-child { margin-bottom: 0; }

  .hero-contacto__right strong {
    color: rgba(255,255,255,.8);
    font-weight: 600;
  }

  /* ── RESPONSIVE ────────────────────────────────────── */
  @media (max-width: 1024px) {
    .hero-contacto__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hero-contacto { padding-top: 3rem; }
  }

  @media (max-width: 768px) {
    .hero-contacto { padding-bottom: 3rem; }
    .hero-contacto__trust { flex-direction: column; gap: 0.625rem; }
  }
</style>
