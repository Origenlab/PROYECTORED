---
const promo   = "Venta de equipos contra incendios en CDMX y Estado de México — NOM · NFPA";
const phone   = "55 3723 8544";
const wa      = "525537238544";
const waMsg   = "Hola%2C%20necesito%20informaci%C3%B3n%20sobre%20equipos%20contra%20incendios";
const horario = "Lun–Vie 8:00–18:00";
---

<div class="topbar" role="complementary" aria-label="Información de contacto">
  <div class="container tb-inner">

    <!-- Izquierda: keyword SEO -->
    <p class="tb-promo">{promo}</p>

    <!-- Centro: horario -->
    <div class="tb-center">
      <span class="tb-item">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        {horario}
      </span>
    </div>

    <!-- Derecha: teléfono + WhatsApp -->
    <div class="tb-right">
      <a href={`tel:${phone.replace(/\s/g,'')}`} class="tb-item tb-phone">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 8.63 19.79 19.79 0 01.12 4a2 2 0 012-2.18h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.91 9.91a16 16 0 006.29 6.29l1.28-1.36a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
        {phone}
      </a>
      <a
        href={`https://wa.me/${wa}?text=${waMsg}`}
        class="tb-wa"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Contactar por WhatsApp"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
    </div>

  </div>
</div>

<style>
  .topbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1001;
    background: var(--c-primary);
    border-bottom: none;
    height: 36px;
  }

  .tb-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: 1rem;
  }

  /* Promo — texto SEO izquierda */
  .tb-promo {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.85);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  /* Centro */
  .tb-center {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-shrink: 0;
  }

  /* Derecha */
  .tb-right {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    flex-shrink: 0;
  }

  /* Items genéricos */
  .tb-item {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.85);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .tb-item svg { opacity: 0.8; flex-shrink: 0; }

  /* Teléfono */
  .tb-phone:hover { color: #fff; }
  .tb-phone:hover svg { opacity: 1; }

  /* WhatsApp pill */
  .tb-wa {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--c-primary);
    background: #fff;
    padding: 0.2rem 0.625rem;
    border-radius: 100px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.2s;
  }
  .tb-wa:hover { background: rgba(255,255,255,0.9); color: var(--c-primary); }

  /* Separador visual */
  .tb-right::before {
    content: '';
    width: 1px;
    height: 14px;
    background: rgba(255,255,255,0.25);
    margin-right: 0.125rem;
  }

  /* ── Responsive ─────────────────────────────────── */
  @media (max-width: 1024px) {
    .tb-center { display: none; }
    .tb-promo {
      font-size: 0.7rem;
    }
  }

  @media (max-width: 640px) {
    .topbar { height: 32px; }
    /* Ocultar promo en móvil — mostrar solo teléfono + WA */
    .tb-promo { display: none; }
    .tb-right::before { display: none; }
    .tb-right { margin-left: auto; }
  }
</style>
