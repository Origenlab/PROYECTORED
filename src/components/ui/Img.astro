---
/**
 * Img.astro — Componente de imagen con AVIF + CDN + srcset responsive
 *
 * Dev:  rutas directas, sin AVIF source ni srcset CDN (los archivos AVIF y los
 *       redimensionados solo existen vía ExactDN en producción).
 *
 * Prod: <picture> con source AVIF via ExactDN + srcset de 4 anchos (?w=) para
 *       que móvil descargue la resolución que necesita, no la de desktop.
 *       El atributo `sizes` ya existía; sin srcset era inerte.
 */
import { cdnUrl } from '../../config/site'

interface Props {
  src: string
  alt: string
  width?: number
  height?: number
  loading?: 'eager' | 'lazy'
  decoding?: 'async' | 'sync' | 'auto'
  fetchpriority?: 'high' | 'low' | 'auto'
  sizes?: string
  class?: string
  [key: string]: any
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  sizes = '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw',
  class: className,
  ...rest
} = Astro.props

const isDev = import.meta.env.DEV

// Rutas base (sin CDN)
// Muchas imágenes solo existen como .avif (sin .jpg ni .png).
// El fallback del <img> usa la misma ruta AVIF — los navegadores modernos
// lo soportan y ExactDN puede convertir al formato óptimo.
const isAvif = src.endsWith('.avif')
const avifPath = isAvif ? src : src.replace(/\.(png|jpg|jpeg)$/, '.avif')
const fallbackPath = isAvif ? src : src   // fallback = ruta original (jpg/png/avif)

// En producción usamos CDN para ambas URLs (ExactDN convierte automáticamente)
// En desarrollo usamos rutas directas para que lea archivos locales
const finalAvif = isDev ? avifPath : cdnUrl(avifPath)
const finalFallback = isDev ? fallbackPath : cdnUrl(fallbackPath)

// srcset responsive vía ExactDN (?w=) — SOLO para JPG/PNG.
// Verificado contra el CDN: ?w= reduce JPG/PNG ~8× (90 KB → 11 KB @320),
// pero sobre AVIF re-codifica PEOR (52 KB → 93 KB) y no redimensiona,
// así que los .avif conservan su URL única original.
const WIDTHS = [320, 480, 640, 960, 1280]
const candidateWidths = width ? WIDTHS.filter((w) => w <= width * 2) : WIDTHS
const srcsetWidths = candidateWidths.length > 0 ? candidateWidths : WIDTHS.slice(0, 2)
const buildSrcset = (path: string) =>
  srcsetWidths.map((w) => `${cdnUrl(path, { w, lossy: 1, strip: 'all' })} ${w}w`).join(', ')
const fallbackSrcset = isDev || isAvif ? undefined : buildSrcset(fallbackPath)

// Usar <picture> con <source type="image/avif"> SOLO cuando el archivo original
// ya es .avif (sabemos que existe). Si el src es .jpg/.png, usar <img> directo
// porque no hay garantía de que exista una versión .avif en el origen
// y ExactDN devolvería 404 que rompe el <picture> completo.
const usePicture = isAvif
---

{usePicture ? (
  <picture class={className}>
    <source srcset={finalAvif} type="image/avif" />
    <img
      src={finalFallback}
      srcset={fallbackSrcset}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      sizes={sizes}
      style="display: block; width: 100%; height: 100%; object-fit: cover;"
      {...rest}
    />
  </picture>
) : (
  <img
    src={finalFallback}
    srcset={fallbackSrcset}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    sizes={sizes}
    style="display: block; width: 100%; height: 100%; object-fit: cover;"
    {...rest}
  />
)}

<style>
  picture {
    display: block;
    width: 100%;
    height: 100%;
  }
  img {
    background-color: #f3f4f6;
  }
</style>
