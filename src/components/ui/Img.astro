---
/**
 * Img.astro — Componente de imagen con AVIF + CDN
 *
 * Dev:  rutas directas, sin AVIF source (los archivos AVIF solo existen en producción
 *       o cuando se generaron explícitamente). Evita 404s de <source> en local.
 *
 * Prod: <picture> con source AVIF via ExactDN CDN (conversión automática) + fallback JPG.
 */
import { cdnUrl } from '../../config/site'

interface Props {
  src: string
  alt: string
  width?: number
  height?: number
  loading?: 'eager' | 'lazy'
  decoding?: 'async' | 'sync' | 'auto'
  fetchpriority?: 'high' | 'low' | 'auto'
  sizes?: string
  class?: string
  [key: string]: any
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  sizes = '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw',
  class: className,
  ...rest
} = Astro.props

const isDev = import.meta.env.DEV

// Rutas base (sin CDN)
// Muchas imágenes solo existen como .avif (sin .jpg ni .png).
// El fallback del <img> usa la misma ruta AVIF — los navegadores modernos
// lo soportan y ExactDN puede convertir al formato óptimo.
const isAvif = src.endsWith('.avif')
const avifPath = isAvif ? src : src.replace(/\.(png|jpg|jpeg)$/, '.avif')
const fallbackPath = isAvif ? src : src   // fallback = ruta original (jpg/png/avif)

// En producción usamos CDN para ambas URLs (ExactDN convierte automáticamente)
// En desarrollo usamos rutas directas para que lea archivos locales
const finalAvif = isDev ? avifPath : cdnUrl(avifPath)
const finalFallback = isDev ? fallbackPath : cdnUrl(fallbackPath)

// En dev, si el src original ya era .avif, asumimos que el archivo existe y usamos picture.
// Si el src era .jpg/.png, saltamos el <source> AVIF para evitar 404s en local.
const usePicture = !isDev || isAvif
---

{usePicture ? (
  <picture class={className}>
    <source srcset={finalAvif} type="image/avif" />
    <img
      src={finalFallback}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding={decoding}
      fetchpriority={fetchpriority}
      sizes={sizes}
      style="display: block; width: 100%; height: 100%; object-fit: cover;"
      {...rest}
    />
  </picture>
) : (
  <img
    src={finalFallback}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding={decoding}
    fetchpriority={fetchpriority}
    sizes={sizes}
    style="display: block; width: 100%; height: 100%; object-fit: cover;"
    {...rest}
  />
)}

<style>
  picture {
    display: block;
    width: 100%;
    height: 100%;
  }
  img {
    background-color: #f3f4f6;
  }
</style>
