---
// SectionHeader.astro
// Encabezado de sección — columna única, centrado o izquierda.
// CSS en: src/styles/components.css (.section-header)

interface Props {
  eyebrow?: string
  titleLine1: string
  titleLine2?: string
  desc?: string
  align?: 'center' | 'left'
}

const { eyebrow, titleLine1, titleLine2, desc, align = 'center' } = Astro.props
---

<header class:list={['section-header', { 'section-header--left': align === 'left' }]}>
  {eyebrow && <p class="section-header__eyebrow">{eyebrow}</p>}
  <h2 class="section-header__title">
    {titleLine1}
    {titleLine2 && (
      <>
        <br />
        <span>{titleLine2}</span>
      </>
    )}
  </h2>
  {desc && <p class="section-header__desc">{desc}</p>}
</header>
