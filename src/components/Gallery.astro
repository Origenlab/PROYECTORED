---
interface Props {
  folder: string; // e.g., 'abc', 'co2'
  count: number;  // number of images to show
  label?: string; // Descriptive label for alt text (e.g., "Extintor Tipo K para cocinas")
}

const { folder, count, label } = Astro.props;
const images = Array.from({ length: count }, (_, i) => `/imagenes/extintores/${folder}/galeria-${i + 1}.png`);
---

<div class="gallery-container">
  <div class="gallery-header">
    <span class="gallery-label">Galería de Productos</span>
    <h3>Inspección Visual del Equipo</h3>
    <p>Conoce a detalle la calidad y especificaciones de nuestros extintores certificados.</p>
  </div>

  <div class="gallery-grid">
    {images.map((src, index) => (
      <div class={`gallery-item item-${index + 1}`}>
        <img 
          src={src} 
          alt={label ? `${label} — imagen ${index + 1}` : `Extintor ${folder} certificado NOM — imagen ${index + 1}`}
          loading="lazy"
          onerror="this.parentElement.style.display='none'"
        />
        <div class="gallery-overlay">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .gallery-container {
    margin-top: 4rem;
    margin-bottom: 4rem;
  }

  .gallery-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .gallery-label {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--c-primary-light);
    color: var(--c-primary);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 99px;
    margin-bottom: 1rem;
  }

  .gallery-header h3 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--c-ink);
    margin-bottom: 0.5rem;
  }

  .gallery-header p {
    color: var(--c-muted);
    max-width: 600px;
    margin: 0 auto;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .gallery-item {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: var(--c-surface);
    box-shadow: var(--shadow-sm);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.4s;
    cursor: pointer;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: rgba(var(--c-primary-rgb), 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    color: white;
  }

  .gallery-item:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .gallery-item:hover img {
    transform: scale(1.1);
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  /* Responsive */
  @media (max-width: 992px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
    
    .gallery-header h3 {
      font-size: 1.5rem;
    }
  }
</style>
