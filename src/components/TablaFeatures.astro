---
interface Feature {
  caracteristica: string;
  queHace: string;
  beneficio: string;
}

interface Props {
  features: Feature[];
}

const { features } = Astro.props;
---
<div class="tabla-wrapper">
  <table class="tabla-features">
    <thead>
      <tr>
        <th>Caracteristica</th>
        <th>Que hace</th>
        <th>Beneficio</th>
      </tr>
    </thead>
    <tbody>
      {features.map((f) => (
        <tr>
          <td>{f.caracteristica}</td>
          <td>{f.queHace}</td>
          <td>{f.beneficio}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .tabla-wrapper {
    overflow-x: auto;
    margin: 2rem 0;
  }

  .tabla-features {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.95rem;
  }

  .tabla-features th {
    background-color: var(--color-black);
    color: #fff;
    padding: 0.875rem 1rem;
    text-align: left;
    font-weight: 600;
  }

  .tabla-features td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-gray-light);
  }

  .tabla-features tbody tr:hover {
    background-color: #fafafa;
  }
</style>
