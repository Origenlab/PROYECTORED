---
// Header.astro — Navegación principal con mega menú
// Usa --c-primary (sistema viejo) para consistencia con todas las secciones del sitio

import { PRODUCT_CATEGORIES, SERVICES, COVERAGE_STATES, waUrl, WA_MESSAGES } from '../../config/site'

const currentPath = Astro.url.pathname

const MEGA_SUBCATEGORIES: Record<string, { label: string; slug: string }[]> = {
  extintores: [
    { label: 'Polvo Seco ABC',        slug: 'polvo-seco'               },
    { label: 'CO₂',                   slug: 'co2'                      },
    { label: 'AFFF / Espuma',         slug: 'afff'                     },
    { label: 'Tipo K (Cocinas)',      slug: 'tipo-k'                   },
    { label: 'Agente Limpio',         slug: 'agente-limpio'            },
  ],
  'equipo-bomberos': [
    { label: 'Trajes Estructurales',  slug: 'trajes-estructurales'     },
    { label: 'ERA / Respiración',     slug: 'era'                      },
    { label: 'Rescate Hidráulico',    slug: 'rescate-hidraulico'       },
    { label: 'Arneses de Rescate',    slug: 'arneses-rescate-altura'   },
  ],
  senalamientos: [
    { label: 'Evacuación',            slug: 'evacuacion'               },
    { label: 'Prohibición',           slug: 'prohibicion'              },
    { label: 'Advertencia',           slug: 'advertencia'              },
    { label: 'Fotoluminiscentes',     slug: 'fotoluminiscentes'        },
  ],
  gabinetes: [
    { label: 'Gabinete para Extintor', slug: 'gabinete-extintor'       },
    { label: 'Porta Extintor',         slug: 'porta-extintor'          },
    { label: 'Gabinete para Bombero',  slug: 'gabinete-bombero'        },
    { label: 'Gabinete para Hidrante', slug: 'gabinete-hidrante'       },
  ],
  mangueras: [
    { label: 'Manguera Hidrante',     slug: 'manguera-hidrante'        },
    { label: 'Chiflones y Pitones',   slug: 'chiflones'                },
    { label: 'Toma Siamesa',          slug: 'toma-siamesa'             },
    { label: 'Monitor CI Elkhart',    slug: 'monitor-incendio'         },
  ],
  sistemas: [
    { label: 'Detección y Alarma',    slug: 'deteccion-alarma'         },
    { label: 'Rociadores Automáticos', slug: 'rociadores'              },
    { label: 'Red Hidráulica CI',     slug: 'red-hidraulica'           },
    { label: 'Agente Limpio',         slug: 'supresion-agente'         },
  ],
  'primeros-auxilios': [
    { label: 'Botiquín STPS',         slug: 'botiquin-stps'            },
    { label: 'Desfibrilador DEA',     slug: 'desfibrilador'            },
    { label: 'Camilla de Emergencia', slug: 'camilla-emergencia'       },
  ],
  'equipo-seguridad': [
    { label: 'Cascos de Seguridad',       slug: 'proteccion-craneal'       },
    { label: 'Trabajo en Alturas',        slug: 'trabajo-alturas'          },
    { label: 'Protección Respiratoria',   slug: 'proteccion-respiratoria'  },
  ],
}
---

<header class="site-header" role="banner">
  <div class="hdr-inner container">

    <!-- Logo -->
    <a href="/" class="hdr-logo" aria-label="Proyecto Red — Inicio">
      <img
        src="/imagenes/logos/logo-proyectored-201x60.png"
        alt="Proyecto Red — Equipos contra incendios"
        width="134"
        height="40"
        class="hdr-logo-img"
        loading="eager"
      />
    </a>

    <!-- Navegación desktop -->
    <nav class="hdr-nav" aria-label="Navegación principal">
      <ul class="hdr-nav__list" role="list">

        <!-- Productos (mega menú) -->
        <li class="hdr-nav__item hdr-nav__item--mega">
          <a
            href="/productos/"
            class:list={['hdr-nav__link', {
              'hdr-nav__link--active':
                currentPath.startsWith('/productos') ||
                currentPath.startsWith('/extintores') ||
                currentPath.startsWith('/equipo-bomberos') ||
                currentPath.startsWith('/senalamientos') ||
                currentPath.startsWith('/gabinetes') ||
                currentPath.startsWith('/mangueras') ||
                currentPath.startsWith('/sistemas') ||
                currentPath.startsWith('/primeros-auxilios') ||
                currentPath.startsWith('/equipo-seguridad')
            }]}
          >
            Productos
            <svg class="hdr-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </a>

          <div class="mega-dropdown" role="region" aria-label="Categorías de productos">
            <div class="container mega-dropdown__inner">
              <a href="/productos/" class="mega-dropdown__all">Ver catálogo completo →</a>
              <ul class="mega-grid" role="list">
                {PRODUCT_CATEGORIES.map((cat) => {
                  const subs = MEGA_SUBCATEGORIES[cat.slug] ?? []
                  return (
                    <li class="mega-col">
                      <a href={cat.href} class="mega-col__title">
                        {cat.label}
                        {cat.badge && <span class="mega-col__badge">{cat.badge}</span>}
                      </a>
                      {subs.length > 0 && (
                        <ul class="mega-sub" role="list">
                          {subs.map((sub) => (
                            <li>
                              <a href={`/${cat.slug}/${sub.slug}/`} class="mega-sub__link">
                                {sub.label}
                              </a>
                            </li>
                          ))}
                          <li>
                            <a href={cat.href} class="mega-sub__link mega-sub__link--ver-todos">
                              Ver todos →
                            </a>
                          </li>
                        </ul>
                      )}
                    </li>
                  )
                })}
              </ul>
            </div>
          </div>
        </li>

        <!-- Servicios -->
        <li class="hdr-nav__item hdr-nav__item--dropdown">
          <a
            href="/servicios/"
            class:list={['hdr-nav__link', { 'hdr-nav__link--active': currentPath.startsWith('/servicios') }]}
          >
            Servicios
            <svg class="hdr-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </a>
          <ul class="hdr-dropdown" role="list" aria-label="Servicios">
            <li class="hdr-dropdown__header">
              <a href="/servicios/">Ver todos los servicios →</a>
            </li>
            {SERVICES.map((svc) => (
              <li>
                <a href={`/servicios/#${svc.id}`} class="hdr-dropdown__link">{svc.label}</a>
              </li>
            ))}
          </ul>
        </li>

        <!-- Cobertura -->
        <li class="hdr-nav__item hdr-nav__item--dropdown">
          <a
            href="/empresas/"
            class:list={['hdr-nav__link', { 'hdr-nav__link--active': currentPath.startsWith('/empresas') }]}
          >
            Cobertura
            <svg class="hdr-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </a>
          <ul class="hdr-dropdown" role="list" aria-label="Cobertura">
            <li class="hdr-dropdown__header">
              <a href="/empresas/">Ver toda la cobertura →</a>
            </li>
            {COVERAGE_STATES.map((state) => (
              <li>
                <a href={`/empresas/${state.slug}/`} class="hdr-dropdown__link">{state.label}</a>
              </li>
            ))}
          </ul>
        </li>

        <!-- Blog -->
        <li class="hdr-nav__item">
          <a
            href="/blog/"
            class:list={['hdr-nav__link', { 'hdr-nav__link--active': currentPath.startsWith('/blog') }]}
          >Blog</a>
        </li>

        <!-- Contacto -->
        <li class="hdr-nav__item">
          <a
            href="/contacto/"
            class:list={['hdr-nav__link', { 'hdr-nav__link--active': currentPath === '/contacto/' }]}
          >Contacto</a>
        </li>

      </ul>
    </nav>

    <!-- CTA Cotizar -->
    <a
      href={waUrl(WA_MESSAGES.cotizacion)}
      class="hdr-cta"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Solicitar cotización por WhatsApp"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Cotizar
    </a>

    <!-- Hamburger mobile -->
    <button
      class="hdr-burger"
      id="hdr-burger-btn"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="hdr-mobile-nav"
    >
      <span></span><span></span><span></span>
    </button>

  </div>
</header>

<!-- Mobile nav overlay -->
<div class="hdr-mobile-nav" id="hdr-mobile-nav" aria-hidden="true">
  <nav aria-label="Navegación móvil">
    <a href="/productos/"   class="hdr-mobile-nav__link">Productos</a>
    <a href="/servicios/"   class="hdr-mobile-nav__link">Servicios</a>
    <a href="/empresas/"    class="hdr-mobile-nav__link">Cobertura</a>
    <a href="/blog/"        class="hdr-mobile-nav__link">Blog</a>
    <a href="/contacto/"    class="hdr-mobile-nav__link">Contacto</a>
    <a
      href={waUrl(WA_MESSAGES.cotizacion)}
      class="hdr-mobile-nav__cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      Cotizar por WhatsApp
    </a>
  </nav>
</div>

<style>
  /* ═══════════════════════════════════════════════════════
     HEADER PRINCIPAL
  ═══════════════════════════════════════════════════════ */
  .site-header {
    position: sticky;
    top: var(--topbar-height, 36px);
    z-index: 100;
    background: var(--c-white);
    border-bottom: 1px solid var(--c-border);
    box-shadow: var(--shadow-sm);
  }

  .hdr-inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: var(--header-height, 88px);
  }

  /* ─── Logo ─── */
  .hdr-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
  }

  .hdr-logo-img {
    height: 52px;
    width: auto;
    display: block;
  }

  /* ═══════════════════════════════════════════════════════
     NAVEGACIÓN DESKTOP
  ═══════════════════════════════════════════════════════ */
  .hdr-nav { margin-left: auto; }

  .hdr-nav__list {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hdr-nav__item { position: relative; }

  .hdr-nav__link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--c-ink-2);
    border-radius: 4px;
    transition: color 0.18s, background 0.18s;
    white-space: nowrap;
    text-decoration: none;
  }

  .hdr-nav__link:hover,
  .hdr-nav__link--active {
    color: var(--c-primary);
    background: var(--c-primary-light);
  }

  .hdr-chevron {
    transition: transform 0.18s;
    flex-shrink: 0;
    opacity: 0.6;
  }

  /* ─── Dropdown simple ─── */
  .hdr-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: 6px;
    box-shadow: var(--shadow-lg);
    padding: 0.5rem 0.375rem 0.375rem;
    z-index: 200;
    list-style: none;
    margin: 0;
    /* puente invisible: cubre el gap entre el link y el menú */
    padding-top: 0.5rem;
  }

  /* Extensión invisible sobre el dropdown para no perder hover al bajar el cursor */
  .hdr-dropdown::before {
    content: '';
    position: absolute;
    top: -10px;
    left: 0;
    right: 0;
    height: 10px;
  }

  .hdr-nav__item--dropdown:hover .hdr-dropdown,
  .hdr-nav__item--dropdown:focus-within .hdr-dropdown { display: block; }

  .hdr-nav__item--dropdown:hover .hdr-chevron { transform: rotate(180deg); }

  .hdr-dropdown__header {
    padding: 0.5rem 0.75rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--c-primary);
    border-bottom: 1px solid var(--c-border);
    margin-bottom: 0.25rem;
  }

  .hdr-dropdown__header a {
    color: var(--c-primary);
    text-decoration: none;
  }

  .hdr-dropdown__link {
    display: block;
    padding: 0.4375rem 0.75rem;
    font-size: 0.875rem;
    color: var(--c-ink-2);
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
  }

  .hdr-dropdown__link:hover {
    background: var(--c-primary-light);
    color: var(--c-primary);
  }

  /* ═══════════════════════════════════════════════════════
     MEGA MENÚ
  ═══════════════════════════════════════════════════════ */
  .mega-dropdown {
    display: none;
    position: fixed;
    left: 0;
    right: 0;
    top: var(--stack-height, 124px);
    background: var(--c-white);
    border-top: 2px solid var(--c-primary);
    border-bottom: 1px solid var(--c-border);
    box-shadow: var(--shadow-lg);
    z-index: 200;
    padding-block: 1.75rem;
  }

  .hdr-nav__item--mega:hover .mega-dropdown,
  .hdr-nav__item--mega:focus-within .mega-dropdown { display: block; }

  .hdr-nav__item--mega:hover .hdr-chevron { transform: rotate(180deg); }

  .mega-dropdown__all {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-primary);
    text-decoration: none;
  }

  .mega-dropdown__all:hover { color: var(--c-primary-dark); }

  .mega-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem 1.5rem;
    align-items: start;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mega-col {
    display: flex;
    flex-direction: column;
  }

  .mega-col__title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.4375rem 0.625rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--c-ink);
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
  }

  .mega-col__title:hover {
    background: var(--c-primary-light);
    color: var(--c-primary);
  }

  .mega-col__badge {
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--c-primary);
    background: var(--c-primary-light);
    border: 1px solid rgba(var(--c-primary-rgb), 0.2);
    padding: 0.1rem 0.4rem;
    border-radius: 100px;
    flex-shrink: 0;
  }

  /* Subcategorías L4 */
  .mega-sub {
    display: flex;
    flex-direction: column;
    margin-top: 0.25rem;
    padding-top: 0.25rem;
    border-top: 1px solid var(--c-border);
    list-style: none;
    padding-left: 0;
  }

  .mega-sub__link {
    display: block;
    padding: 0.25rem 0.625rem;
    font-size: 0.8125rem;
    color: var(--c-muted);
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
    line-height: 1.4;
  }

  .mega-sub__link:hover {
    background: var(--c-primary-light);
    color: var(--c-primary);
  }

  .mega-sub__link--ver-todos {
    font-weight: 600;
    color: var(--c-primary);
    margin-top: 0.125rem;
  }

  .mega-sub__link--ver-todos:hover { color: var(--c-primary-dark); }

  /* ═══════════════════════════════════════════════════════
     CTA BOTÓN
  ═══════════════════════════════════════════════════════ */
  .hdr-cta {
    display: flex;
    align-items: center;
    gap: 0.4375rem;
    padding: 0.5625rem 1.25rem;
    background: var(--c-primary);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 4px;
    white-space: nowrap;
    transition: background 0.18s;
    flex-shrink: 0;
    text-decoration: none;
  }

  .hdr-cta:hover { background: var(--c-primary-dark); color: #fff; }

  /* ═══════════════════════════════════════════════════════
     HAMBURGER MOBILE
  ═══════════════════════════════════════════════════════ */
  .hdr-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    margin-left: auto;
    cursor: pointer;
    border: none;
    background: none;
  }

  .hdr-burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--c-ink-2);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }

  /* ═══════════════════════════════════════════════════════
     MOBILE NAV OVERLAY
  ═══════════════════════════════════════════════════════ */
  .hdr-mobile-nav {
    display: none;
    position: fixed;
    inset: 0;
    top: var(--stack-height, 124px);
    background: var(--c-white);
    z-index: 99;
    padding: 1.5rem;
    overflow-y: auto;
    border-top: 2px solid var(--c-primary);
  }

  .hdr-mobile-nav[aria-hidden="false"] { display: block; }

  .hdr-mobile-nav__link {
    display: block;
    padding: 1rem 0;
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--c-ink);
    border-bottom: 1px solid var(--c-border);
    text-decoration: none;
  }

  .hdr-mobile-nav__link:hover { color: var(--c-primary); }

  .hdr-mobile-nav__cta {
    display: block;
    margin-top: 1.5rem;
    padding: 1rem;
    background: var(--c-primary);
    color: #fff;
    font-size: 1.0625rem;
    font-weight: 700;
    text-align: center;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.18s;
  }

  .hdr-mobile-nav__cta:hover { background: var(--c-primary-dark); color: #fff; }

  /* ═══════════════════════════════════════════════════════
     RESPONSIVE
  ═══════════════════════════════════════════════════════ */
  @media (max-width: 1024px) {
    .hdr-nav { display: none; }
    .hdr-cta { display: none; }
    .hdr-burger { display: flex; }
  }
</style>

<script>
  const burgerBtn   = document.getElementById('hdr-burger-btn')
  const mobileNav   = document.getElementById('hdr-mobile-nav')

  burgerBtn?.addEventListener('click', () => {
    const isOpen = mobileNav?.getAttribute('aria-hidden') === 'false'
    mobileNav?.setAttribute('aria-hidden', isOpen ? 'true' : 'false')
    burgerBtn.setAttribute('aria-expanded', isOpen ? 'false' : 'true')
  })
</script>
