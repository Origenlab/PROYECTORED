---
// TopBar.astro — Barra de información superior (roja)
// Usa --c-primary (sistema viejo) para consistencia con el sitio

import { SITE, CONTACT, waUrl, WA_MESSAGES } from '../../config/site'
---

<aside class="topbar" aria-label="Información de contacto">
  <div class="tb-inner container">

    <!-- Promo / tagline izquierda -->
    <span class="tb-promo">{SITE.tagline}</span>

    <!-- Centro: horario -->
    <div class="tb-center">
      <span class="tb-item tb-schedule">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
        </svg>
        {CONTACT.schedule.display}
      </span>
    </div>

    <!-- Derecha: teléfono + WhatsApp -->
    <div class="tb-right">
      <a
        href={`tel:${CONTACT.phoneRaw}`}
        class="tb-item tb-phone"
        aria-label={`Llamar al ${CONTACT.phone}`}
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92v2z"/>
        </svg>
        {CONTACT.phone}
      </a>

      <a
        href={waUrl(WA_MESSAGES.default)}
        class="tb-item tb-wa"
        aria-label="Contactar por WhatsApp"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp
      </a>
    </div>

  </div>
</aside>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 101;
    background: var(--c-primary);
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 500;
    height: var(--topbar-height, 36px);
    display: flex;
    align-items: center;
  }

  .tb-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
  }

  .tb-promo {
    opacity: 0.88;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    min-width: 0;
  }

  .tb-center {
    flex-shrink: 0;
  }

  .tb-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-shrink: 0;
  }

  .tb-item {
    display: flex;
    align-items: center;
    gap: 0.3125rem;
    color: #fff;
    text-decoration: none;
    white-space: nowrap;
  }

  .tb-item:hover { opacity: 0.8; color: #fff; }

  .tb-wa {
    background: rgba(255, 255, 255, 0.15);
    padding: 0.1875rem 0.625rem;
    border-radius: 100px;
    font-weight: 600;
  }

  .tb-wa:hover { background: rgba(255, 255, 255, 0.25); opacity: 1; }

  /* Responsive */
  @media (max-width: 900px) {
    .tb-promo  { display: none; }
    .tb-center { display: none; }
  }

  @media (max-width: 480px) {
    .tb-schedule { display: none; }
    .tb-phone    { display: none; }
  }
</style>
