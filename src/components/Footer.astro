---
const productos = [
  { label: 'Catálogo completo',    href: '/productos/' },
  { label: 'Extintores',          href: '/extintores/' },
  { label: 'Equipo Bomberos',     href: '/equipo-bomberos/' },
  { label: 'Señalamientos',       href: '/senalamientos/' },
  { label: 'Gabinetes',           href: '/gabinetes/' },
  { label: 'Mangueras y Herrajes',href: '/mangueras/' },
  { label: 'Sistemas CI',         href: '/sistemas/' },
  { label: 'Primeros Auxilios',   href: '/primeros-auxilios/' },
  { label: 'Equipo de Seguridad', href: '/equipo-seguridad/' },
];

const servicios = [
  { label: 'Venta de Equipos',        href: '/servicios/#venta-equipos' },
  { label: 'Recarga de Extintores',   href: '/servicios/#recarga-extintores' },
  { label: 'Mantenimiento Preventivo',href: '/servicios/#mantenimiento-preventivo' },
  { label: 'Instalación Sistemas CI', href: '/servicios/#instalacion-sistemas' },
  { label: 'Prueba Hidrostática',     href: '/servicios/#prueba-hidrostatica' },
  { label: 'Asesoría Técnica',        href: '/servicios/#asesoria-tecnica' },
  { label: 'Capacitación y Brigadas', href: '/servicios/#capacitacion' },
  { label: 'Señalización NOM',        href: '/servicios/#senalizacion' },
];

const cobertura = [
  { label: 'CDMX',            href: '/empresas/cdmx/' },
  { label: 'Estado de México', href: '/empresas/edomex/' },
  { label: 'Querétaro',       href: '/empresas/queretaro/' },
  { label: 'Puebla',          href: '/empresas/puebla/' },
  { label: 'Aguascalientes',  href: '/empresas/aguascalientes/' },
  { label: 'Baja California', href: '/empresas/baja-california/' },
];

const empresa = [
  { label: 'Nosotros',            href: '/nosotros/' },
  { label: 'Todos los servicios', href: '/servicios/' },
  { label: 'Productos',           href: '/productos/' },
  { label: 'Blog',               href: '/blog/' },
  { label: 'Contacto',           href: '/contacto/' },
];
---

<footer class="site-footer">
  <div class="container ftr-inner">

    <!-- Brand col -->
    <div class="ftr-brand">
      <a href="/" class="ftr-logo" aria-label="Proyecto Red inicio">
        <img src="/imagenes/logos/logo-proyectored-201x60.png" alt="Proyecto Red" width="134" height="40" loading="lazy" class="ftr-logo-img" />
      </a>
      <p>Venta de equipos contra incendios en CDMX y Estado de México. Equipo certificado NOM y NFPA con entrega directa.</p>
      <div class="ftr-contact">
        <a href="https://wa.me/525537238544" class="ftr-ci" target="_blank" rel="noopener noreferrer">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          55 3723 8544
        </a>
        <a href="mailto:info@proyectored.com.mx" class="ftr-ci">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          info@proyectored.com.mx
        </a>
        <div class="ftr-ci">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Paseo de la Reforma 26, Col. Juárez, Cuauhtémoc, CDMX 06600</span>
        </div>
        <div class="ftr-ci">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          Lun–Dom 6:00–18:00
        </div>
      </div>
    </div>

    <!-- Productos -->
    <div class="ftr-col">
      <h4>Productos</h4>
      <ul>
        {productos.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>

    <!-- Servicios -->
    <div class="ftr-col">
      <h4>Servicios</h4>
      <ul>
        {servicios.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>

    <!-- Cobertura + Empresa -->
    <div class="ftr-col">
      <h4>Cobertura</h4>
      <ul>
        {cobertura.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
      <h4 class="ftr-col__sub">Empresa</h4>
      <ul>
        {empresa.map(l => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </div>

  </div>

  <div class="ftr-bottom">
    <div class="container ftr-bottom-inner">
      <p>© {new Date().getFullYear()} Proyecto Red. Todos los derechos reservados.</p>
      <p>Venta de equipos contra incendios en CDMX · NOM · NFPA · Protección Civil</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--c-ink);
    color: rgba(255,255,255,0.55);
  }

  .ftr-inner {
    display: grid;
    grid-template-columns: 280px repeat(3, 1fr);
    gap: 3rem;
    padding-top: 4rem;
    padding-bottom: 3.5rem;
  }

  /* Brand */
  .ftr-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .ftr-logo-img {
    height: 54px;
    width: auto;
    display: block;
    background: rgba(255,255,255,0.9);
    border-radius: 4px;
    padding: 5px 10px;
  }

  .ftr-brand p {
    font-size: 0.875rem;
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .ftr-contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
  }
  .ftr-ci {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    color: rgba(255,255,255,0.5);
    font-size: 0.8125rem;
    text-decoration: none;
    line-height: 1.4;
  }
  .ftr-ci svg { flex-shrink: 0; margin-top: 1px; opacity: 0.6; }
  a.ftr-ci:hover { color: rgba(255,255,255,0.85); }
  a.ftr-ci:hover svg { opacity: 1; }

  /* Cols */
  .ftr-col h4 {
    font-size: 0.8125rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .ftr-col__sub {
    margin-top: 1.5rem;
  }
  .ftr-col ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .ftr-col a {
    color: rgba(255,255,255,0.5);
    font-size: 0.875rem;
    text-decoration: none;
  }
  .ftr-col a:hover { color: #fff; }

  /* Bottom bar */
  .ftr-bottom {
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .ftr-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;
    font-size: 0.8125rem;
  }

  @media (max-width: 1024px) {
    .ftr-inner {
      grid-template-columns: 1fr 1fr;
    }
    .ftr-brand {
      grid-column: span 2;
    }
  }

  @media (max-width: 640px) {
    .ftr-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .ftr-brand { grid-column: span 1; }
    .ftr-bottom-inner { flex-direction: column; text-align: center; }
  }
</style>
