---
interface Props {
  titulo: string;
  descripcion: string;
  href: string;
  icono?: string;
}

const { titulo, descripcion, href, icono } = Astro.props;
---
<a href={href} class="tarjeta-categoria">
  {icono && <span class="tarjeta-icono">{icono}</span>}
  <h3>{titulo}</h3>
  <p>{descripcion}</p>
  <span class="tarjeta-link">Ver mas &rarr;</span>
</a>

<style>
  .tarjeta-categoria {
    display: block;
    background: #fff;
    border: 1px solid var(--color-gray-light);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: var(--color-black);
    transition: box-shadow 0.2s, border-color 0.2s;
  }

  .tarjeta-categoria:hover {
    border-color: var(--color-primary);
    box-shadow: 0 4px 16px rgba(215, 40, 40, 0.1);
  }

  .tarjeta-icono {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  p {
    font-size: 0.9rem;
    color: var(--color-gray);
    line-height: 1.5;
    margin-bottom: 1rem;
  }

  .tarjeta-link {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>
