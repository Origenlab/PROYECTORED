<script>
  const burger = document.getElementById('burger-btn');
  const menu   = document.getElementById('mobile-menu');
  const header = document.getElementById('site-header');

  burger?.addEventListener('click', () => {
    const open = menu?.getAttribute('aria-hidden') === 'false';
    menu?.setAttribute('aria-hidden', open ? 'true' : 'false');
    burger.setAttribute('aria-expanded', open ? 'false' : 'true');
    burger.classList.toggle('is-open', !open);
    document.body.style.overflow = open ? '' : 'hidden';
  });

  // Cerrar al hacer click en link
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.setAttribute('aria-hidden', 'true');
      burger?.setAttribute('aria-expanded', 'false');
      burger?.classList.remove('is-open');
      document.body.style.overflow = '';
    });
  });

  // Mobile accordion toggles
  menu?.querySelectorAll('[data-mob-toggle]').forEach(btn => {
    btn.addEventListener('click', () => {
      const sub = btn.nextElementSibling as HTMLElement;
      const isOpen = sub?.getAttribute('aria-hidden') === 'false';
      // Close all
      menu.querySelectorAll('.mob-sub').forEach(s => s.setAttribute('aria-hidden', 'true'));
      menu.querySelectorAll('[data-mob-toggle]').forEach(b => b.classList.remove('is-open'));
      // Toggle current
      if (!isOpen) {
        sub?.setAttribute('aria-hidden', 'false');
        btn.classList.add('is-open');
      }
    });
  });

  // Header scroll shadow
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });
</script>

<style>
  /* ── BASE HEADER ─────────────────────────────────── */
  .site-header {
    position: fixed;
    top: var(--topbar-height, 36px); left: 0; right: 0;
    z-index: 1000;
    background: #fff;
    border-bottom: 1px solid var(--c-border);
    height: var(--header-height);
    transition: box-shadow 0.2s;
  }
  .site-header.scrolled {
    box-shadow: 0 2px 16px rgba(0,0,0,0.08);
  }

  .hdr-inner {
    height: 100%;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  /* Logo */
  .hdr-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }
  .hdr-logo-img {
    height: 52px;
    width: auto;
    display: block;
  }

  /* ── NAV DESKTOP ─────────────────────────────────── */
  .hdr-nav {
    display: flex;
    align-items: center;
    gap: 0;
    margin-left: auto;
  }

  .nav-item { position: relative; }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--c-ink-2);
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0 0.875rem;
    height: var(--header-height);
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .nav-link:hover { color: var(--c-primary); }
  .nav-link svg { opacity: 0.45; }

  /* ── DROPDOWN NORMAL (Servicios, Cobertura) ──────── */
  .nav-dropdown {
    position: absolute;
    top: calc(var(--header-height) - 4px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 240px;
    background: #fff;
    border: 1px solid var(--c-border);
    border-radius: 6px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.1);
    opacity: 0;
    pointer-events: none;
    z-index: 100;
    overflow: hidden;
  }
  .nav-item:hover .nav-dropdown,
  .nav-item:focus-within .nav-dropdown {
    opacity: 1;
    pointer-events: auto;
  }

  .dropdown-header {
    display: block;
    padding: 0.75rem 1rem 0.5rem;
    color: var(--c-primary);
    font-size: 0.8125rem;
    font-weight: 600;
    border-bottom: 1px solid var(--c-border);
    text-decoration: none;
    transition: color 0.2s;
  }
  .dropdown-header:hover { color: var(--c-primary-dark); }

  .nav-dropdown ul {
    list-style: none;
    padding: 0.5rem 0;
  }
  .nav-dropdown li a {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--c-ink-2);
    font-size: 0.875rem;
    text-decoration: none;
    transition: color 0.2s, background-color 0.2s;
  }
  .nav-dropdown li a:hover {
    color: var(--c-primary);
    background: var(--c-primary-light);
  }

  /* ── MEGA DROPDOWN (Productos) ───────────────────── */
  .mega-dropdown {
    position: absolute;
    top: calc(var(--header-height) - 4px);
    left: 50%;
    transform: translateX(-50%);
    width: min(1200px, 92vw);
    background: #fff;
    border: 1px solid var(--c-border);
    border-radius: 6px;
    box-shadow: 0 12px 48px rgba(0,0,0,0.12);
    opacity: 0;
    pointer-events: none;
    z-index: 100;
    overflow: hidden;
  }
  .nav-item--mega:hover .mega-dropdown,
  .nav-item--mega:focus-within .mega-dropdown {
    opacity: 1;
    pointer-events: auto;
  }

  .mega-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0;
    padding: 1.25rem 0 0.75rem;
  }

  .mega-col {
    padding: 0 1.25rem;
    border-right: 1px solid var(--c-border);
  }
  .mega-col:last-child { border-right: none; }

  .mega-col__title {
    display: block;
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin-bottom: 0.625rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--c-primary);
    text-decoration: none;
  }
  .mega-col__title:hover { color: var(--c-primary); }

  .mega-col ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .mega-col ul li a {
    display: block;
    padding: 0.3125rem 0;
    color: var(--c-ink-2);
    font-size: 0.8125rem;
    text-decoration: none;
    transition: color 0.2s;
    line-height: 1.4;
  }
  .mega-col ul li a:hover { color: var(--c-primary); }

  /* Footer del mega-menú */
  .mega-footer {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--c-border);
    background: var(--c-surface);
  }
  .mega-footer a {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--c-primary);
    text-decoration: none;
  }
  .mega-footer a:hover { color: var(--c-primary-dark); }
  .mega-footer a:last-child { margin-left: auto; }
  .mega-sep {
    color: var(--c-border);
    font-size: 0.75rem;
  }

  /* ── CTA HEADER ──────────────────────────────────── */
  .hdr-cta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--c-primary);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.5625rem 1.125rem;
    border-radius: 4px;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background-color 0.2s;
  }
  .hdr-cta:hover { background: var(--c-primary-dark); color: #fff; }

  /* ── BURGER ──────────────────────────────────────── */
  .hdr-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    margin-left: auto;
    flex-shrink: 0;
  }
  .hdr-burger span {
    display: block;
    width: 22px; height: 2px;
    background: var(--c-ink);
    border-radius: 2px;
    transition: transform 0.2s, opacity 0.2s;
  }
  .hdr-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hdr-burger.is-open span:nth-child(2) { opacity: 0; }
  .hdr-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── MOBILE MENU ─────────────────────────────────── */
  .mobile-menu {
    position: fixed;
    top: var(--stack-height, 108px);
    left: 0; right: 0; bottom: 0;
    background: #111;
    z-index: 999;
